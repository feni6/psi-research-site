---
import Layout from '../layouts/Layout.astro';

interface Replication {
  id: string;
  originalStudy: string;
  authors: string;
  year: number;
  outcome: 'successful' | 'failed' | 'mixed';
  sampleSize: number;
  effectSize: string;
  summary: string;
  details: string;
}

const replications: Replication[] = [
  {
    id: 'rep-001',
    originalStudy: 'Bem (2011) - Feeling the Future',
    authors: 'Wagenmakers et al.',
    year: 2011,
    outcome: 'failed',
    sampleSize: 200,
    effectSize: 'd = 0.02',
    summary: 'Failed to replicate precognition effects with larger sample and stricter methodology.',
    details: 'This large-scale replication attempt used improved methodology including larger sample sizes, pre-registration, and stricter statistical controls. The original effect was not observed, suggesting the initial findings may have been due to methodological artifacts or statistical fluctuations.'
  },
  {
    id: 'rep-002',
    originalStudy: 'Radin (2006) - Entangled Minds',
    authors: 'Mossbridge et al.',
    year: 2012,
    outcome: 'mixed',
    sampleSize: 150,
    effectSize: 'd = 0.15',
    summary: 'Partial replication with smaller effect sizes than originally reported.',
    details: 'This replication found some evidence for the phenomenon but with significantly smaller effect sizes. The mixed results suggest that while there may be something to investigate, the original claims were likely overstated.'
  },
  {
    id: 'rep-003',
    originalStudy: 'McCraty & Shaffer (2010) - Heart Coherence',
    authors: 'McCraty et al.',
    year: 2015,
    outcome: 'successful',
    sampleSize: 85,
    effectSize: 'd = 0.42',
    summary: 'Successfully replicated heart coherence effects in controlled conditions.',
    details: 'This study successfully replicated the original findings using similar methodology and participant populations. The effect sizes were consistent with the original research, supporting the reliability of the heart coherence phenomenon under these specific conditions.'
  },
  {
    id: 'rep-004',
    originalStudy: 'Targ & Puthoff (1974) - Remote Viewing',
    authors: 'Marks & Kammann',
    year: 1980,
    outcome: 'failed',
    sampleSize: 120,
    sampleSize: 120,
    effectSize: 'd = 0.05',
    summary: 'Failed to replicate remote viewing under controlled laboratory conditions.',
    details: 'This comprehensive replication attempt implemented strict controls to eliminate sensory leakage and experimenter bias. No significant remote viewing effects were detected, suggesting the original findings may have been influenced by methodological flaws.'
  },
  {
    id: 'rep-005',
    originalStudy: 'Schwartz (2003) - Afterlife Communications',
    authors: 'Russek et al.',
    year: 2010,
    outcome: 'mixed',
    sampleSize: 95,
    effectSize: 'd = 0.28',
    summary: 'Mixed results with some positive findings but methodological concerns.',
    details: 'While some measures showed positive results, the study faced criticism for potential cold reading effects and inadequate blinding. The mixed outcomes highlight the need for more rigorous experimental designs in this area.'
  }
];

const filterOptions = [
  { value: 'all', label: 'Show All' },
  { value: 'successful', label: 'Successful Only' },
  { value: 'failed', label: 'Failed Only' },
  { value: 'mixed', label: 'Mixed' }
];
---

<Layout title="Replication Studies">
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="max-w-6xl mx-auto px-4 py-12">
      <header class="mb-12">
        <h1 class="text-4xl font-bold text-amber-400 mb-4">Replication Studies</h1>
        <p class="text-slate-400 text-lg max-w-3xl">
          A comprehensive collection of replication attempts for notable psi research studies. 
          These replications help establish the reliability and validity of paranormal phenomena claims.
        </p>
      </header>

      <section class="mb-12">
        <div role="group" aria-label="Filter replications by outcome" class="flex flex-wrap gap-3 mb-8">
          {filterOptions.map((option) => (
            <button
              type="button"
              data-filter={option.value}
              class="filter-btn px-4 py-2 rounded-lg border border-slate-700 bg-slate-900 hover:bg-slate-800 hover:border-amber-400 transition-colors focus:ring-2 focus:ring-amber-400 focus:outline-none focus:border-amber-400"
              aria-pressed={option.value === 'all'}
            >
              {option.label}
            </button>
          ))}
        </div>

        <div id="replications-grid" class="grid gap-6">
          {replications.map((rep) => (
            <article
              data-outcome={rep.outcome}
              class="replication-card bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-amber-400/50 transition-colors"
            >
              <div class="p-6">
                <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
                  <div>
                    <h3 class="text-xl font-semibold text-amber-400 mb-2">{rep.originalStudy}</h3>
                    <p class="text-slate-400">{rep.authors} ({rep.year})</p>
                  </div>
                  <span
                    class={`px-3 py-1 rounded-full text-sm font-medium ${
                      rep.outcome === 'successful' ? 'bg-green-900/50 text-green-400 border border-green-700' :
                      rep.outcome === 'failed' ? 'bg-red-900/50 text-red-400 border border-red-700' :
                      'bg-yellow-900/50 text-yellow-400 border border-yellow-700'
                    }`}
                  >
                    {rep.outcome.charAt(0).toUpperCase() + rep.outcome.slice(1)}
                  </span>
                </div>

                <div class="grid md:grid-cols-3 gap-4 mb-4 text-sm">
                  <div>
                    <span class="text-slate-500">Sample Size:</span>
                    <span class="text-slate-300 ml-2">{rep.sampleSize}</span>
                  </div>
                  <div>
                    <span class="text-slate-500">Effect Size:</span>
                    <span class="text-slate-300 ml-2">{rep.effectSize}</span>
                  </div>
                  <div>
                    <span class="text-slate-500">Year:</span>
                    <span class="text-slate-300 ml-2">{rep.year}</span>
                  </div>
                </div>

                <p class="text-slate-300 mb-4">{rep.summary}</p>

                <button
                  type="button"
                  class="expand-btn text-amber-400 hover:text-amber-300 font-medium flex items-center gap-2 focus:ring-2 focus:ring-amber-400 focus:outline-none focus:text-amber-300 rounded px-2 py-1 -ml-2"
                  aria-expanded="false"
                  aria-controls={`details-${rep.id}`}
                >
                  <span>View Details</span>
                  <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>

                <div
                  id={`details-${rep.id}`}
                  class="details-content hidden mt-4 pt-4 border-t border-slate-800"
                  aria-hidden="true"
                >
                  <p class="text-slate-400 leading-relaxed">{rep.details}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.replication-card');
      const expandBtns = document.querySelectorAll('.expand-btn');

      // Filter functionality
      filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = btn.getAttribute('data-filter');
          
          filterBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
          btn.setAttribute('aria-pressed', 'true');
          
          cards.forEach(card => {
            const outcome = card.getAttribute('data-outcome');
            if (filter === 'all' || outcome === filter) {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          });
        });

        // Keyboard support for filter buttons
        btn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            btn.click();
          }
        });
      });

      // Expand/collapse functionality
      expandBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const detailsId = btn.getAttribute('aria-controls');
          const details = document.getElementById(detailsId);
          const isExpanded = btn.getAttribute('aria-expanded') === 'true';
          
          btn.setAttribute('aria-expanded', (!isExpanded).toString());
          details.setAttribute('aria-hidden', isExpanded.toString());
          details.classList.toggle('hidden');
          
          const icon = btn.querySelector('svg');
          if (icon) {
            icon.classList.toggle('rotate-180');
          }
          
          const textSpan = btn.querySelector('span');
          if (textSpan) {
            textSpan.textContent = isExpanded ? 'View Details' : 'Hide Details';
          }
        });

        // Keyboard support for expand buttons
        btn.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            btn.click();
          }
        });
      });
    });
  </script>
</Layout>