---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

// Helper to create URL-safe IDs
const slugify = (text: string) => {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
};

// Helper to get border color based on category
const getBorderColor = (category: string) => {
  switch (category) {
    case 'Statistics': return 'border-blue-500';
    case 'Protocols': return 'border-purple-500';
    case 'Phenomena': return 'border-amber-500';
    default: return 'border-slate-700';
  }
};

const terms = [
  { 
    term: "Ganzfeld", 
    category: "Protocols",
    definition: "A sensory deprivation protocol used in telepathy experiments. The receiver relaxes in a mild sensory isolation environment (often using halved ping-pong balls over eyes and white noise) while a sender attempts to transmit an image or video clip.",
    related: ["DMILS", "Remote Viewing"],
    link: { href: "/controversies/01_ganzfeld_telepathy", text: "Ganzfeld Meta-Analysis" }
  },
  { 
    term: "Effect Size", 
    category: "Statistics",
    definition: "A quantitative measure of the magnitude of an experimental effect. Common metrics include Cohen's d, Hedges' g, and correlation coefficient r. In psi research, effect sizes are typically small (r < 0.1) but statistically significant across large datasets.",
    related: ["Meta-analysis", "Bayes Factor", "p-value"],
    link: { href: "/stats", text: "Understanding Effect Sizes" }
  },
  { 
    term: "Pre-registration", 
    category: "Methodology",
    definition: "The practice of publicly registering hypotheses, methods, and analysis plans before data collection begins. Prevents post-hoc hypothesis revision (HARKing) and p-hacking, increasing the credibility of positive findings.",
    related: ["Replication", "Double-Blind"],
    link: { href: "/method", text: "Open Science Practices" }
  },
  { 
    term: "Meta-analysis", 
    category: "Statistics",
    definition: "A statistical technique that combines results from multiple independent studies to estimate an overall effect size. Addresses the 'file drawer problem' by aggregating evidence across experiments to find patterns invisible in single studies.",
    related: ["Effect Size", "File Drawer Problem"],
    link: { href: "/controversies/10_meta_debate", text: "The Meta-Analysis Debate" }
  },
  { 
    term: "Bayes Factor", 
    category: "Statistics",
    definition: "A ratio expressing how much more likely the observed data is under one hypothesis (e.g., psi exists) versus another (e.g., chance). BF > 3 is considered moderate evidence; BF > 10 is strong evidence.",
    related: ["p-value", "Effect Size"],
    link: { href: "/stats", text: "Bayesian Statistics" }
  },
  { 
    term: "RNG (Random Number Generator)", 
    category: "Equipment",
    definition: "A hardware or software device that produces random sequences, used in psychokinesis (PK) experiments. Participants attempt to mentally influence the output distribution toward a target value (e.g., more 1s than 0s).",
    related: [],
    link: { href: "/domain/psychokinesis", text: "PK Experiments" }
  },
  { 
    term: "Presentiment", 
    category: "Phenomena",
    definition: "The hypothesized ability of the body to anticipate future emotional events before they occur, measured via physiological responses like skin conductance, heart rate, or pupil dilation seconds before a stimulus is shown.",
    related: [],
    link: { href: "/controversies/03_presentiment", text: "Presentiment Research" }
  },
  { 
    term: "DMILS", 
    category: "Protocols",
    definition: "Direct Mental Interaction with Living Systems. Experiments testing whether one person's intention can influence another person's physiology (e.g., skin conductance) at a distance without sensory cues.",
    related: ["Ganzfeld"],
    link: { href: "/domain/telepathy", text: "DMILS Studies" }
  },
  { 
    term: "Remote Viewing", 
    category: "Protocols",
    definition: "A protocol where a 'viewer' attempts to describe a distant or hidden target location using only mental impressions. Originally studied under the US government's STAR GATE program using coordinate-based targeting.",
    related: ["Ganzfeld"],
    link: { href: "/domain/remote_viewing", text: "Remote Viewing Archives" }
  },
  { 
    term: "Psi", 
    category: "General",
    definition: "An umbrella term for anomalous mental phenomena including telepathy, clairvoyance, precognition, and psychokinesis. From the Greek letter ψ (psi), chosen by J.B. Rhine to represent the unknown factor.",
    related: [],
    link: { href: "/about", text: "About Psi Research" }
  },
  { 
    term: "File Drawer Problem", 
    category: "Methodology",
    definition: "The bias introduced when studies with null results go unpublished ('filed away'), making the published literature appear more supportive of an effect than the full evidence warrants. Meta-analyses attempt to correct for this.",
    related: ["Meta-analysis"],
    link: { href: "/method", text: "Bias in Science" }
  },
  { 
    term: "Double-Blind", 
    category: "Methodology",
    definition: "An experimental design where neither the participant nor the experimenter knows the condition assignment during data collection. Prevents unconscious bias (experimenter effect) from influencing results.",
    related: ["Pre-registration", "Replication"],
    link: { href: "/stats", text: "Experimental Design" }
  },
  { 
    term: "Replication", 
    category: "Methodology",
    definition: "An attempt to reproduce the findings of an earlier study using the same or similar methods. Successful replications strengthen confidence; failures weaken it. The 'replication crisis' affects all sciences, including psi.",
    related: ["Pre-registration", "Double-Blind"],
    link: { href: "/replications", text: "Replication Projects" }
  },
  { 
    term: "NDE (Near-Death Experience)", 
    category: "Phenomena",
    definition: "Profound experiences reported by people who have been close to death, often including out-of-body perceptions, tunnel vision, life reviews, and encounters with deceased persons or beings of light.",
    related: ["OBE"],
    link: { href: "/domain/nde", text: "NDE Research" }
  },
  { 
    term: "OBE (Out-of-Body Experience)", 
    category: "Phenomena",
    definition: "The sensation of perceiving the world from a vantage point outside one's physical body. Sometimes reported during NDEs, sleep paralysis, or induced through specific meditation practices and sensory deprivation.",
    related: ["NDE"],
    link: { href: "/domain/nde", text: "OBE Studies" }
  },
  { 
    term: "p-value", 
    category: "Statistics",
    definition: "The probability of obtaining test results at least as extreme as the results actually observed, under the assumption that the null hypothesis is correct. In psi, p < 0.05 is the standard threshold for significance.",
    related: ["Bayes Factor", "Effect Size"],
    link: { href: "/stats", text: "Significance Testing" }
  },
];

// Sort terms alphabetically
const sortedTerms = terms.sort((a, b) => a.term.localeCompare(b.term));

// Generate unique first letters and counts
const letterData = sortedTerms.reduce((acc, term) => {
  const letter = term.term.charAt(0).toUpperCase();
  if (!acc[letter]) {
    acc[letter] = { count: 0, terms: [] };
  }
  acc[letter].count++;
  acc[letter].terms.push(term);
  return acc;
}, {} as Record<string, { count: number, terms: typeof sortedTerms }>);

const availableLetters = Object.keys(letterData).sort();
---

<Layout title="Glossary" description="Key terms and definitions in parapsychology and psi research, from Bayes factors to remote viewing.">
  <div class="max-w-7xl mx-auto px-4 py-8 min-h-screen flex flex-col">
    
    <!-- Header Section -->
    <div class="mb-8 text-center">
      <Breadcrumb 
        items={[
          { label: "Home", href: "/" },
          { label: "Glossary", href: "/glossary" }
        ]} 
      />
      
      <h1 class="text-4xl md:text-5xl font-bold text-amber-400 mb-4 tracking-tight">Research Glossary</h1>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto mb-8">
        A comprehensive reference of key terms, protocols, and statistical concepts used throughout the Psi Research Library.
      </p>
      
      <!-- Search & Controls -->
      <div class="flex flex-col md:flex-row items-center justify-center gap-6 mb-8">
        <div class="relative w-full max-w-lg group">
          <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="w-5 h-5 text-slate-500 group-focus-within:text-amber-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </div>
          <input 
            type="text" 
            id="search-input"
            aria-label="Search glossary terms"
            placeholder="Search terms, definitions, or categories..." 
            class="w-full bg-slate-900/50 border border-slate-700 text-slate-200 rounded-xl py-4 pl-12 pr-4 focus:outline-none focus:ring-2 focus:ring-amber-400/50 focus:border-amber-400 transition-all shadow-lg backdrop-blur-sm"
            autocomplete="off"
          />
        </div>
        
        <div class="flex items-center gap-3 bg-slate-900 border border-slate-800 rounded-lg px-4 py-2 shadow-sm">
          <span class="text-2xl font-bold text-amber-400 font-mono" id="term-count">{terms.length}</span>
          <span class="text-slate-500 text-sm font-medium uppercase tracking-wider" id="term-label">Terms Defined</span>
        </div>
      </div>

      <!-- Sticky Alphabetical Jump Bar -->
      <div class="sticky top-20 z-40 mb-12">
        <div class="flex flex-wrap justify-center gap-1 sm:gap-2 p-3 bg-slate-950/90 border border-slate-800 rounded-2xl shadow-2xl backdrop-blur-md max-w-5xl mx-auto">
          {availableLetters.map((letter) => {
            const data = letterData[letter];
            return (
              <a 
                href={`#letter-${letter}`}
                class="jump-link relative group flex flex-col items-center justify-center w-8 h-10 sm:w-10 sm:h-12 rounded-lg font-mono text-xs sm:text-sm font-bold text-slate-400 hover:text-amber-400 hover:bg-slate-800 cursor-pointer transition-all duration-200"
                data-letter="${letter}"
              >
                <span class="z-10">{letter}</span>
                <span class="text-[9px] text-slate-600 group-hover:text-amber-500/70 transition-colors">{data.count}</span>
                <!-- Active Indicator Dot -->
                <span class="absolute -bottom-1 w-1 h-1 rounded-full bg-amber-400 opacity-0 transition-opacity duration-300 active-dot"></span>
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Glossary Content -->
    <div class="space-y-16 flex-grow" id="glossary-list">
      {availableLetters.map((letter) => (
        <div class="scroll-mt-48" id={`letter-${letter}`}>
          <!-- Section Header -->
          <div class="flex items-center gap-4 mb-8 border-b border-slate-800 pb-2">
            <span class="text-6xl font-serif text-slate-800 italic font-bold select-none">{letter}</span>
            <div class="h-px bg-slate-800 flex-grow"></div>
            <span class="text-slate-600 font-mono text-sm">{letterData[letter].count} {letterData[letter].count === 1 ? 'term' : 'terms'}</span>
          </div>
          
          <!-- Cards Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {letterData[letter].terms.map((item) => {
              const id = slugify(item.term);
              const borderColor = getBorderColor(item.category);
              
              return (
                <div 
                  class={`glossary-item group relative bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:shadow-2xl hover:shadow-black/50 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full ${borderColor} border-l-4`}
                  data-search={`${item.term} ${item.definition} ${item.category} ${item.related?.join(' ')}`.toLowerCase()}
                >
                  <!-- Anchor Target for direct linking -->
                  <div id={id} class="absolute -top-32"></div>
                  
                  <!-- Card Header -->
                  <div class="p-6 pb-2">
                    <div class="flex justify-between items-start gap-3 mb-2">
                      <h3 class="text-xl font-bold text-slate-200 group-hover:text-amber-400 transition-colors leading-tight">
                        {item.term}
                      </h3>
                      <a 
                        href={`#${id}`} 
                        class="opacity-0 group-hover:opacity-100 text-slate-600 hover:text-amber-400 transition-all text-lg font-mono"
                        title="Copy link to this term"
                      >
                        #
                      </a>
                    </div>
                    
                    <!-- Category Badge -->
                    <span class={`
                      inline-block text-[10px] uppercase tracking-wider font-bold px-2 py-0.5 rounded mb-4 w-fit border
                      ${item.category === 'Statistics' ? 'text-blue-400 bg-blue-950/30 border-blue-900/50' : ''}
                      ${item.category === 'Protocols' ? 'text-purple-400 bg-purple-950/30 border-purple-900/50' : ''}
                      ${item.category === 'Phenomena' ? 'text-amber-400 bg-amber-950/30 border-amber-900/50' : ''}
                      ${!['Statistics', 'Protocols', 'Phenomena'].includes(item.category) ? 'text-slate-400 bg-slate-950 border-slate-800' : ''}
                    `}>
                      {item.category}
                    </span>
                  </div>
                  
                  <!-- Expandable Definition -->
                  <details class="group/details px-6 pb-4 cursor-pointer">
                    <summary class="list-none flex items-center justify-between text-slate-400 text-sm font-medium hover:text-amber-400 transition-colors select-none">
                      <span>Read Definition</span>
                      <svg class="w-4 h-4 transform group-open/details:rotate-180 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </summary>
                    <div class="mt-3 text-slate-300 text-sm leading-relaxed animate-fadeIn">
                      {item.definition}
                    </div>
                  </details>
                  
                  <!-- Footer / Related Terms -->
                  <div class="mt-auto pt-4 px-6 pb-6 bg-slate-950/30 border-t border-slate-800/50">
                    {item.related && item.related.length > 0 && (
                      <div class="mb-3">
                        <span class="text-[10px] uppercase tracking-wider font-bold text-slate-500 block mb-2">Related Terms</span>
                        <div class="flex flex-wrap gap-2">
                          {item.related.map(rel => {
                            const relSlug = slugify(rel);
                            return (
                              <a 
                                href={`#${relSlug}`}
                                class="text-xs text-slate-400 hover:text-amber-400 hover:bg-slate-800 px-2 py-1 rounded transition-colors border border-transparent hover:border-slate-700"
                              >
                                {rel}
                              </a>
                            );
                          })}
                        </div>
                      </div>
                    )}
                    
                    {item.link && (
                      <a 
                        href={item.link.href} 
                        class="inline-flex items-center gap-2 text-xs font-medium text-slate-400 hover:text-amber-400 transition-colors group/link"
                      >
                        <span>Learn more:</span>
                        <span class="underline decoration-slate-700 group-hover/link:decoration-amber-400/50 underline-offset-4">
                          {item.link.text}
                        </span>
                        <svg class="w-3 h-3 opacity-0 group-hover/link:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <!-- No Results State -->
    <div id="no-results" class="hidden flex-col items-center justify-center py-24 text-center">
      <div class="w-20 h-20 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center mb-6 shadow-inner">
        <svg class="w-10 h-10 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-slate-300 mb-2">No terms found</h3>
      <p class="text-slate-500 max-w-md mb-6">
        We couldn't find any definitions matching "<span id="search-query-display" class="text-amber-400 font-mono"></span>". Try adjusting your search terms.
      </p>
      <button 
        onclick="document.getElementById('search-input').value = ''; document.getElementById('search-input').dispatchEvent(new Event('input'));"
        class="px-6 py-2 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg text-sm font-medium transition-colors border border-slate-700"
      >
        Clear Search
      </button>
    </div>

    <!-- Footer Action -->
    <div class="mt-24 pt-12 border-t border-slate-800 text-center">
      <p class="text-slate-500 mb-4">Missing a key concept?</p>
      <a 
        href="/wishlist" 
        class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-medium transition-colors border-b border-amber-400/30 hover:border-amber-400 pb-0.5"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
        </svg>
        Suggest a term for the glossary
      </a>
    </div>

  </div>

  <script>
    // --- Search Functionality ---
    document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const glossaryItems = document.querySelectorAll('.glossary-item');
    const letterSections = document.querySelectorAll('#glossary-list > div');
    const noResults = document.getElementById('no-results');
    const countDisplay = document.getElementById('term-count');
    const searchQueryDisplay = document.getElementById('search-query-display');

    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase().trim();
      let visibleCount = 0;
      let hasAnyResults = false;

      searchQueryDisplay.textContent = query;

      // 1. Filter individual cards
      glossaryItems.forEach(item => {
        const content = item.getAttribute('data-search');
        const matches = content.includes(query);
        
        if (matches) {
          item.classList.remove('hidden');
          visibleCount++;
          hasAnyResults = true;
        } else {
          item.classList.add('hidden');
        }
      });

      countDisplay.textContent = visibleCount;
      
      // Update pluralization
      const termLabel = document.getElementById('term-label');
      if (termLabel) {
        termLabel.textContent = visibleCount === 1 ? 'Term Defined' : 'Terms Defined';
      }

      // 2. Hide/Show Letter Sections & Headers
      letterSections.forEach(section => {
        const visibleItemsInSection = section.querySelectorAll('.glossary-item:not(.hidden)');
        const header = section.querySelector('div'); 
        
        if (visibleItemsInSection.length === 0) {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
          if(header) header.classList.remove('hidden');
        }
      });

      // 3. Toggle no results message
      if (hasAnyResults) {
        noResults.classList.add('hidden');
        noResults.classList.remove('flex');
        document.getElementById('glossary-list').classList.remove('hidden');
      } else {
        noResults.classList.remove('hidden');
        noResults.classList.add('flex');
        document.getElementById('glossary-list').classList.add('hidden');
      }
    });

    // --- Scroll Spy for Jump Bar ---
    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -60% 0px', // Trigger when section is near top
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const letter = entry.target.id.replace('letter-', '');
          
          // Remove active class from all links
          document.querySelectorAll('.jump-link').forEach(link => {
            link.classList.remove('text-amber-400', 'bg-slate-800', 'scale-110');
            link.classList.add('text-slate-400');
            link.querySelector('.active-dot')?.classList.remove('opacity-100');
          });

          // Add active class to current letter
          const activeLink = document.querySelector(`.jump-link[data-letter="${letter}"]`);
          if (activeLink) {
            activeLink.classList.remove('text-slate-400');
            activeLink.classList.add('text-amber-400', 'bg-slate-800', 'scale-110');
            activeLink.querySelector('.active-dot')?.classList.add('opacity-100');
          }
        }
      });
    }, observerOptions);

    letterSections.forEach(section => {
      observer.observe(section);
    });
    });
  </script>
</Layout>