---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import catalog from '../data/catalog.json';

// --- Data Processing ---

const decades = ['pre-1970', '1970s', '1980s', '1990s', '2000s', '2010s', '2020s'];

// Helper to determine decade bucket
function getDecade(year: number): string {
  if (year < 1970) return 'pre-1970';
  if (year < 1980) return '1970s';
  if (year < 1990) return '1980s';
  if (year < 2000) return '1990s';
  if (year < 2010) return '2000s';
  if (year < 2020) return '2010s';
  return '2020s';
}

// Domain Color Map (Tailwind classes)
const domainColors: Record<string, string> = {
  'Parapsychology': 'bg-blue-500',
  'Physics': 'bg-emerald-500',
  'Psychology': 'bg-violet-500',
  'Consciousness Studies': 'bg-amber-500',
  'Anomalistics': 'bg-rose-500',
  'History': 'bg-slate-500',
  'default': 'bg-slate-600'
};

function getDomainColor(domain: string): string {
  return domainColors[domain] || domainColors['default'];
}

function getDomainTextColor(domain: string): string {
  // Map bg colors to text colors for labels
  const map: Record<string, string> = {
    'bg-blue-500': 'text-blue-400',
    'bg-emerald-500': 'text-emerald-400',
    'bg-violet-500': 'text-violet-400',
    'bg-amber-500': 'text-amber-400',
    'bg-rose-500': 'text-rose-400',
    'bg-slate-500': 'text-slate-400',
    'bg-slate-600': 'text-slate-400'
  };
  return map[getDomainColor(domain)] || 'text-slate-400';
}

function formatDomainName(domain: string): string {
  if (!domain) return 'Unknown';
  return domain
    .replace(/_/g, ' ')
    .split(' ')
    .filter(word => word.length > 0)
    .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
    .join(' ');
}

// Initialize data structures
const decadeCounts: Record<string, number> = {};
const domainDecadeCounts: Record<string, Record<string, number>> = {};
const domainTotals: Record<string, number> = {};
const allDomains = new Set<string>();
const papersByYear: Record<number, any[]> = {};

decades.forEach(d => {
  decadeCounts[d] = 0;
  domainDecadeCounts[d] = {};
});

// Process Catalog
let minYear = 9999;
let maxYear = 0;
let earliestPaper: any = null;
let latestPaper: any = null;

catalog.papers.forEach(paper => {
  const year = paper.year || 0;
  const decade = getDecade(year);
  const domain = paper.psi_domain || 'Uncategorized';
  
  // Track Min/Max Years
  if (year > 0) {
    if (year < minYear) {
      minYear = year;
      earliestPaper = paper;
    }
    if (year > maxYear) {
      maxYear = year;
      latestPaper = paper;
    }
  }

  // Increment totals
  decadeCounts[decade]++;
  allDomains.add(domain);
  
  if (!domainTotals[domain]) domainTotals[domain] = 0;
  domainTotals[domain]++;

  if (!domainDecadeCounts[decade][domain]) domainDecadeCounts[decade][domain] = 0;
  domainDecadeCounts[decade][domain]++;
});

// Find max count for chart scaling
const maxCount = Math.max(...Object.values(decadeCounts));
const totalPapers = catalog.papers.length;

// Calculate Dominant Domain per Decade
const decadeDominance: Record<string, { domain: string, count: number }> = {};
decades.forEach(decade => {
  const counts = domainDecadeCounts[decade];
  let topDomain = 'Unknown';
  let topCount = 0;
  
  Object.entries(counts).forEach(([domain, count]) => {
    if (count > topCount) {
      topCount = count;
      topDomain = domain;
    }
  });
  decadeDominance[decade] = { domain: topDomain, count: topCount };
});

// Sort domains alphabetically for the table
const sortedDomains = Array.from(allDomains).sort();

// Generate Narrative Text
const peakDecade = Object.entries(decadeCounts).reduce((a, b) => a[1] > b[1] ? a : b)[0];
const peakCount = decadeCounts[peakDecade];
const peakPercentage = ((peakCount / totalPapers) * 100).toFixed(1);

const domain90s = decadeDominance['1990s']?.domain || 'various fields';
const domain00s = decadeDominance['2000s']?.domain || 'various fields';
const formattedDomain90s = formatDomainName(domain90s);
const formattedDomain00s = formatDomainName(domain00s);

let growthStory;
if (formattedDomain90s === formattedDomain00s) {
  growthStory = `Research activity saw a significant surge in the ${peakDecade.replace('s', '')}s, producing ${peakCount} papers—representing ${peakPercentage}% of the entire library's collection. During this period, ${formattedDomain90s} remained the dominant focus, reflecting sustained academic inquiry in this area.`;
} else {
  growthStory = `Research activity saw a significant surge in the ${peakDecade.replace('s', '')}s, producing ${peakCount} papers—representing ${peakPercentage}% of the entire library's collection. During this period, the dominant focus shifted from ${formattedDomain90s} in the preceding decade to ${formattedDomain00s}, reflecting broader changes in academic inquiry.`;
}

---

<Layout title="Research Trends">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">
    
    <!-- Header & Hero Stats -->
    <div class="space-y-8">
      <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Trends', href: '/trends' }]} />
      
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-800 pb-8">
        <div class="space-y-2">
          <h1 class="text-4xl font-bold text-amber-400 tracking-tight">Research Timeline</h1>
          <p class="text-slate-400 text-lg max-w-2xl">
            A quantitative analysis of {totalPapers} papers spanning {maxYear - minYear} years of inquiry.
          </p>
        </div>
        
        <div class="flex gap-8">
          <div class="text-right">
            <div class="text-sm text-slate-500 uppercase tracking-wider font-semibold">Time Span</div>
            <div class="text-2xl font-bold text-white">{minYear} — {maxYear}</div>
          </div>
          <div class="text-right">
            <div class="text-sm text-slate-500 uppercase tracking-wider font-semibold">Total Papers</div>
            <div class="text-2xl font-bold text-amber-400">{totalPapers}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Horizontal Bar Chart (Decades) -->
    <section class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 sm:p-8 shadow-xl">
      <h2 class="text-xl font-semibold text-slate-200 mb-6 flex items-center gap-2">
        <span class="w-2 h-6 bg-amber-500 rounded-sm"></span>
        Publication Volume by Decade
      </h2>
      
      <div class="space-y-4">
        {decades.map((decade) => {
          const count = decadeCounts[decade];
          const percentage = totalPapers > 0 ? ((count / totalPapers) * 100).toFixed(1) : '0';
          const widthPercent = maxCount > 0 ? (count / maxCount) * 100 : 0;
          const dominant = decadeDominance[decade];
          const barColor = getDomainColor(dominant.domain);
          const textColor = getDomainTextColor(dominant.domain);
          
          return (
            <div class="group relative">
              <div class="flex items-center gap-4 mb-1">
                <div class="w-24 text-sm font-medium text-slate-400">{decade.replace('pre-', 'Pre-')}</div>
                <div class="flex-1 h-8 bg-slate-950 rounded-md overflow-hidden relative">
                  <div 
                    class={`h-full ${barColor} opacity-80 group-hover:opacity-100 transition-all duration-500 ease-out flex items-center px-3`}
                    style={`width: ${widthPercent}%`}
                  >
                    <span class="text-xs font-bold text-white drop-shadow-md whitespace-nowrap">
                      {count} papers ({percentage}%)
                    </span>
                  </div>
                </div>
                <div class="w-32 text-right">
                   <span class={`text-xs font-bold uppercase ${textColor}`}>{formatDomainName(dominant.domain)}</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-4 text-xs text-slate-500 text-center italic">
        Bar color indicates the dominant research domain for that decade.
      </div>
    </section>

    <!-- Narrative & Milestones Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Growth Story -->
      <div class="lg:col-span-2 bg-gradient-to-br from-slate-900 to-slate-900/50 border border-slate-800 rounded-xl p-8 shadow-xl">
        <h2 class="text-2xl font-bold text-slate-200 mb-4">The Growth Story</h2>
        <p class="text-slate-300 text-lg leading-relaxed mb-6">
          {growthStory}
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8">
           <div class="bg-slate-950/50 p-4 rounded-lg border border-slate-800">
              <div class="text-slate-500 text-xs uppercase font-bold mb-1">Dominant 1990s</div>
              <div class={`text-xl font-bold ${getDomainTextColor(domain90s)}`}>{formatDomainName(domain90s)}</div>
           </div>
           <div class="bg-slate-950/50 p-4 rounded-lg border border-slate-800">
              <div class="text-slate-500 text-xs uppercase font-bold mb-1">Dominant 2000s</div>
              <div class={`text-xl font-bold ${getDomainTextColor(domain00s)}`}>{formatDomainName(domain00s)}</div>
           </div>
        </div>
      </div>

      <!-- Key Milestones -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-slate-200">Key Milestones</h2>
        
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-6">
          {/* Earliest */}
          <div class="relative pl-6 border-l-2 border-slate-700">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-slate-950 border-2 border-slate-500"></div>
            <div class="text-xs text-slate-500 font-bold uppercase">Earliest Record</div>
            <div class="text-white font-semibold">{earliestPaper?.year}</div>
            <div class="text-sm text-slate-400 truncate">{earliestPaper?.title}</div>
          </div>

          {/* Peak */}
          <div class="relative pl-6 border-l-2 border-amber-500">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-slate-950 border-2 border-amber-500"></div>
            <div class="text-xs text-amber-500 font-bold uppercase">Peak Activity</div>
            <div class="text-white font-semibold">{peakDecade}</div>
            <div class="text-sm text-slate-400">{peakCount} papers published</div>
          </div>

          {/* Latest */}
          <div class="relative pl-6 border-l-2 border-slate-700">
            <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-slate-950 border-2 border-slate-500"></div>
            <div class="text-xs text-slate-500 font-bold uppercase">Most Recent</div>
            <div class="text-white font-semibold">{latestPaper?.year}</div>
            <div class="text-sm text-slate-400 truncate">{latestPaper?.title}</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Domain Evolution Section -->
    <section class="space-y-6">
      <h2 class="text-2xl font-bold text-slate-200">Domain Evolution</h2>
      <p class="text-slate-400">How the share of research focus has shifted across major domains over time.</p>
      
      <div class="overflow-x-auto border border-slate-800 rounded-lg shadow-lg bg-slate-900/50">
        <table class="w-full text-left text-sm text-slate-400">
          <thead class="bg-slate-950 text-xs uppercase font-bold text-slate-500">
            <tr>
              <th class="px-6 py-4 sticky left-0 bg-slate-950 z-10">Domain</th>
              {decades.map(decade => (
                <th class="px-4 py-4 text-center min-w-[80px]">{decade.replace('pre-', 'Pre-')}</th>
              ))}
              <th class="px-6 py-4 text-right font-bold text-amber-500">Total Share</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            {sortedDomains.map((domain) => {
              const total = domainTotals[domain];
              const totalShare = ((total / totalPapers) * 100).toFixed(1);
              
              return (
                <tr class="hover:bg-slate-800/50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-200 sticky left-0 bg-slate-900/50 backdrop-blur-sm">
                    <div class="flex items-center gap-3">
                      <span class={`w-3 h-3 rounded-full ${getDomainColor(domain)}`}></span>
                      {formatDomainName(domain)}
                    </div>
                  </td>
                  {decades.map(decade => {
                    const count = domainDecadeCounts[decade][domain] || 0;
                    const decadeTotal = decadeCounts[decade];
                    const share = decadeTotal > 0 ? ((count / decadeTotal) * 100).toFixed(0) : '0';
                    const hasData = count > 0;
                    
                    return (
                      <td class="px-4 py-4 text-center">
                        {hasData ? (
                          <div class="flex flex-col items-center">
                            <span class="text-slate-200 font-medium">{share}%</span>
                            <div class="w-full bg-slate-800 h-1 mt-1 rounded-full overflow-hidden">
                              <div class={`h-full ${getDomainColor(domain)}`} style={`width: ${share}%`}></div>
                            </div>
                          </div>
                        ) : (
                          <span class="text-slate-700">-</span>
                        )}
                      </td>
                    );
                  })}
                  <td class="px-6 py-4 text-right font-bold text-amber-400">
                    {totalShare}%
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

  </div>
</Layout>