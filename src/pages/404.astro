---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <main id="main-content" class="max-w-3xl mx-auto px-4 py-24 text-center">
    
    <!-- Glowing background -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-amber-500/5 blur-[120px] rounded-full -z-10 pointer-events-none"></div>

    <!-- 404 Number -->
    <div class="text-8xl md:text-9xl font-bold text-transparent bg-clip-text bg-gradient-to-b from-slate-600 to-slate-800 mb-6 select-none">
      404
    </div>

    <!-- Message -->
    <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Page Not Found
    </h1>
    <p class="text-lg text-slate-400 mb-10 max-w-lg mx-auto leading-relaxed">
      The page you're looking for doesn't exist, may have moved, or perhaps was never observed in the first place.
    </p>

    <!-- Navigation Options -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 font-semibold rounded-lg transition-all hover:-translate-y-0.5 shadow-lg shadow-amber-900/20">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
        Go Home
      </a>
      <a href="/search" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg transition-all hover:-translate-y-0.5 border border-slate-700">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        Search Papers
      </a>
      <a href="/catalog" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white font-semibold rounded-lg transition-all hover:-translate-y-0.5 border border-slate-700">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        Browse Catalog
      </a>
    </div>

    <!-- Subtle hint -->
    <p class="mt-16 text-sm text-slate-600">
      Like a psi signal, this page remains elusive under controlled observation. 🔮
    </p>

  </main>
</Layout>
