---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/data/controversies');
  const files = fs.readdirSync(dir).filter(f => f.match(/^\d{2}_/) && f.endsWith('.md'));
  return files.map(f => {
    const id = f.replace('.md', '');
    const content = fs.readFileSync(path.join(dir, f), 'utf-8');
    return { params: { id }, props: { content, filename: f } };
  });
}

const { id } = Astro.params;
const { content } = Astro.props;
// Auto-link catalog IDs: [catalog ID: xxx] → linked to /paper/xxx
const linkedContent = content.replace(
  /\[catalog ID: ([^\]]+)\]/g,
  (_, id) => `[📄 ${id}](/paper/${id.trim()})`
);
const html = marked(linkedContent);
const title = content.split('\n')[0].replace(/^#\s*\d+\.\s*/, '').trim();
---

<Layout title={title}>
  <nav class="text-sm text-slate-500 mb-6">
    <a href="/controversies" class="hover:text-amber-400">← All Controversies</a>
  </nav>
  <article class="prose prose-invert prose-amber max-w-4xl" set:html={html} />
</Layout>
