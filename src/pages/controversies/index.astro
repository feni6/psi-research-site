---
import Layout from '../../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const KEY_QUESTIONS: Record<string, string> = {
  '01': "Can telepathy be demonstrated under controlled conditions?",
  '02': "Did Bem really prove precognition?",
  '03': "Does the body anticipate unpredictable future events?",
  '04': "Can consciousness affect quantum-level physical systems?",
  '05': "Can prayer or distant intention promote healing?",
  '06': "Can mediums genuinely access information from deceased persons?",
  '07': "Do NDEs provide evidence for consciousness beyond the brain?",
  '08': "Does collective human attention influence random systems worldwide?",
  '09': "Can facilitator-assisted communication reveal hidden cognitive abilities?",
  '10': "Do meta-analyses actually support the existence of psi?",
  '11': "Can people detect when they're being stared at?",
  '12': "Do pets genuinely anticipate their owner's return?",
  '13': "Can people sense who's calling before answering?",
  '14': "Do twins share a psychic connection?"
};

const GROUP_DEFINITIONS = [
  {
    id: 'telepathy',
    name: 'Telepathy & Remote Perception',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>',
    ids: ['01', '11', '12', '13', '14']
  },
  {
    id: 'precognition',
    name: 'Precognition & Presentiment',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    ids: ['02', '03']
  },
  {
    id: 'mind-matter',
    name: 'Mind-Matter Interaction',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>',
    ids: ['04', '08']
  },
  {
    id: 'healing',
    name: 'Healing & Survival',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>',
    ids: ['05', '06', '07']
  },
  {
    id: 'methodology',
    name: 'Methodology & Analysis',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>',
    ids: ['09', '10']
  }
];

function countProCon(content: string) {
  let pro = 0, con = 0;
  
  // Find Pro section and count bullet points (handles both **Pro:** and **Pro (description):**)
  const proMatch = content.match(/\*\*Pro[^*]*:\*\*([\s\S]*?)(?=\*\*Con[^*]*:\*\*|\*\*Critical evidence:|\*\*Current status:|$)/i);
  if (proMatch) {
    const proContent = proMatch[1];
    const proLines = proContent.split('\n').filter(line => line.trim().startsWith('- '));
    pro = proLines.length;
  }

  // Find Con section and count bullet points (handles both **Con:** and **Con (description):**)
  const conMatch = content.match(/\*\*Con[^*]*:\*\*([\s\S]*?)(?=\*\*Critical evidence:|\*\*Current status:|$)/i);
  if (conMatch) {
    const conContent = conMatch[1];
    const conLines = conContent.split('\n').filter(line => line.trim().startsWith('- '));
    con = conLines.length;
  }
  
  // Also check for alternative headers (only if primary headers not found)
  if (pro === 0) {
    const supportMatch = content.match(/\*\*Supporting evidence:\*\*([\s\S]*?)(?=\*\*Con:|\*\*Critical evidence:|\*\*Current status:|$)/i);
    if (supportMatch) {
      const supportContent = supportMatch[1];
      const supportLines = supportContent.split('\n').filter(line => line.trim().startsWith('- '));
      pro = supportLines.length;
    }
  }
  
  if (con === 0) {
    const criticalMatch = content.match(/\*\*Critical evidence:\*\*([\s\S]*?)(?=\*\*Current status:|$)/i);
    if (criticalMatch) {
      const criticalContent = criticalMatch[1];
      const criticalLines = criticalContent.split('\n').filter(line => line.trim().startsWith('- '));
      con = criticalLines.length;
    }
  }
  
  const total = pro + con;
  return { 
    pro, 
    con, 
    total,
    proPercent: total > 0 ? Math.round((pro / total) * 100) : 0,
    conPercent: total > 0 ? Math.round((con / total) * 100) : 0
  };
}

const dir = path.join(process.cwd(), 'src/data/controversies');
const files = fs.readdirSync(dir).filter(f => f.match(/^\d{2}_/) && f.endsWith('.md'));

const allControversies = files.map(f => {
  const content = fs.readFileSync(path.join(dir, f), 'utf-8');
  const id = f.replace('.md', '');
  const num = f.slice(0, 2);
  const title = content.split('\n')[0].replace(/^#\s*\d+\.\s*/, '').trim();
  
  // Extract current status
  const statusMatch = content.match(/\*\*Current status:\*\*\s*(.*?)(?:\n\n|$)/s);
  const status = statusMatch ? statusMatch[1].slice(0, 200) + '...' : '';
  
  // Calculate balance using keyword scanning
  const counts = countProCon(content);
  
  // Determine Heat Level (Visual only)
  let heatLevel = 1;
  let heatIcon = '🔥';
  if (counts.total > 20) { heatLevel = 3; heatIcon = '🔥🔥🔥'; }
  else if (counts.total >= 10) { heatLevel = 2; heatIcon = '🔥🔥'; }

  // Determine Domains
  const domains = GROUP_DEFINITIONS
    .filter(g => g.ids.includes(num))
    .map(g => g.id);
  
  // Determine Evidence Weight Indicator
  let evidenceIcon = '🟡';
  let evidenceColor = 'text-amber-400';
  let evidenceLabel = 'Mixed Evidence';
  
  if (counts.total > 0) {
    if (counts.proPercent >= 60) {
      evidenceIcon = '🟢';
      evidenceColor = 'text-green-400';
      evidenceLabel = 'Support Outweighs Criticism';
    } else if (counts.proPercent <= 40) {
      evidenceIcon = '🔴';
      evidenceColor = 'text-red-400';
      evidenceLabel = 'Criticism Outweighs Support';
    }
  } else {
    evidenceIcon = '⚪';
    evidenceColor = 'text-slate-500';
    evidenceLabel = 'Insufficient Data';
  }
  
  return { 
    id, 
    num,
    title, 
    keyQuestion: KEY_QUESTIONS[num] || '',
    status, 
    proCount: counts.pro, 
    conCount: counts.con,
    total: counts.total,
    proPercent: counts.proPercent,
    conPercent: counts.conPercent,
    heatLevel,
    heatIcon,
    domains,
    evidenceIcon,
    evidenceColor,
    evidenceLabel
  };
});

// 1. Sort by total paper count (most papers = most prominent)
allControversies.sort((a, b) => b.total - a.total);

// Identify Top 3 for badges
const top3Ids = new Set(allControversies.slice(0, 3).map(c => c.id));

// Identify "Start Here" recommendation (Meta-analysis #10)
const startHereItem = allControversies.find(c => c.num === '10');

// Organize into groups (items within groups will retain sort order if we map carefully)
const groupedControversies = GROUP_DEFINITIONS.map(group => {
  return {
    ...group,
    items: allControversies.filter(c => group.ids.includes(c.num))
  };
});

const totalControversies = allControversies.length;
---

<Layout title="Controversies" description="Explore the most debated topics in psi research, with evidence maps showing supporting and critical papers.">
  <!-- Hero Section -->
  <div class="relative mb-12 overflow-hidden rounded-xl bg-gradient-to-br from-slate-900 to-slate-950 border border-slate-800 p-8 sm:p-12 text-center shadow-2xl">
    <div class="absolute top-0 left-0 w-full h-full bg-[url('/grid.svg')] opacity-5 pointer-events-none"></div>
    <div class="relative z-10">
      <h1 class="text-xl sm:text-4xl md:text-5xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-600 tracking-tight leading-tight whitespace-normal">
        The Active Debates
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-8 font-light">
        Where does the evidence point? Explore both sides of <span class="text-amber-400 font-semibold">{totalControversies} contested questions</span> in psi research.
      </p>
      
      <div class="bg-slate-950/50 backdrop-blur-sm border border-slate-800 rounded-lg p-6 max-w-3xl mx-auto text-left shadow-inner">
        <p class="text-slate-300 leading-relaxed text-sm sm:text-base">
          <span class="text-amber-500 font-bold mr-2">⚠️ Note:</span>
          Each controversy map shows research <span class="text-green-400 font-medium">supporting</span> AND <span class="text-red-400 font-medium">challenging</span> the claim. 
          We present both sides so you can evaluate the evidence yourself. The "Heat" indicator reflects the volume of active discourse.
        </p>
      </div>
    </div>
  </div>

  <!-- "Start Here" Recommendation -->
  {startHereItem && (
    <div class="mb-12 relative group">
      <div class="absolute -inset-0.5 bg-gradient-to-r from-amber-500 to-amber-700 rounded-xl blur opacity-30 group-hover:opacity-60 transition duration-500"></div>
      <div class="relative bg-slate-900 border border-amber-500/30 rounded-xl p-6 sm:p-8 flex flex-col md:flex-row gap-6 items-center">
        <div class="shrink-0 bg-amber-500/10 p-4 rounded-full border border-amber-500/20">
          <svg class="w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div class="flex-1 text-center md:text-left">
          <div class="flex items-center justify-center md:justify-start gap-2 mb-2">
            <span class="bg-amber-500 text-slate-950 text-xs font-bold px-2 py-0.5 rounded uppercase tracking-wider">Recommended Start</span>
            <span class="text-slate-500 text-xs font-mono">Controversy #{startHereItem.num}</span>
          </div>
          <h3 class="text-xl font-bold text-slate-100 mb-2">{startHereItem.title}</h3>
          <p class="text-slate-400 text-sm mb-4 max-w-2xl">
            New to psi research? Start here. This debate covers the statistical foundation of the entire field, analyzing hundreds of studies to determine if the effect is real or an artifact.
          </p>
          <a href={`/controversies/${startHereItem.id}`} class="inline-flex items-center text-amber-400 font-semibold hover:text-amber-300 transition-colors text-sm group/link">
            Read the Meta-Analysis Debate 
            <svg class="w-4 h-4 ml-1 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
        </div>
      </div>
    </div>
  )}
  
  <!-- Controls: Filters & Search -->
  <div class="sticky top-20 z-40 bg-slate-950/95 backdrop-blur border-b border-slate-800 pb-4 mb-8 transition-all">
    <div class="flex flex-col lg:flex-row gap-4 items-start lg:items-center justify-between">
      
      <!-- Domain Filters -->
      <div class="flex flex-wrap gap-2" id="domain-filters">
        <button 
          class="filter-btn active px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider transition-all border bg-amber-500/10 border-amber-500/50 text-amber-400 hover:bg-amber-500/20"
          data-filter="all"
        >
          All Debates
        </button>
        {GROUP_DEFINITIONS.map(group => (
          <button 
            class="filter-btn px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider transition-all border border-slate-800 text-slate-500 hover:text-slate-300 hover:border-slate-600 hover:bg-slate-900"
            data-filter={group.id}
          >
            {group.name}
          </button>
        ))}
      </div>

      <!-- Search & Count -->
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center w-full lg:w-auto">
        <div class="relative w-full sm:w-64">
          <input 
            type="text" 
            id="search-input"
            aria-label="Search controversies"
            placeholder="Search debates..." 
            class="w-full bg-slate-900 border border-slate-700 rounded-md py-2 px-4 text-slate-200 placeholder-slate-500 focus:outline-none focus:border-amber-500/50 focus:ring-1 focus:ring-amber-500/50 transition font-mono text-sm"
          />
        </div>
        <div class="text-xs text-slate-500 whitespace-nowrap font-mono hidden sm:block">
          <span id="result-count" class="text-amber-400 font-bold">{totalControversies}</span> active debates
        </div>
      </div>
    </div>
  </div>
  
  <!-- Controversy List -->
  <div class="space-y-12" id="controversy-list">
    {groupedControversies.map((group) => (
      <div class="controversy-group transition-opacity duration-300" data-group-id={group.id}>
        <h2 class="text-lg font-bold text-slate-200 mb-6 flex items-center gap-3 border-l-4 border-amber-500 bg-slate-900/30 py-3 px-5 rounded-r-md">
          <span class="text-amber-500 opacity-90" set:html={group.icon}></span>
          {group.name}
        </h2>
        
        <div class="grid grid-cols-1 gap-4">
          {group.items.map((c) => {
            const isTop3 = top3Ids.has(c.id);
            return (
              <a 
                href={`/controversies/${c.id}`} 
                class="block bg-slate-900 border border-slate-800 rounded-lg p-5 hover:border-amber-500/50 hover:bg-slate-800/60 hover:shadow-[0_0_20px_rgba(245,158,11,0.1)] hover:-translate-y-1 transition-all duration-300 group controversy-item relative overflow-hidden"
                data-title={c.title.toLowerCase()}
                data-question={c.keyQuestion.toLowerCase()}
                data-group={group.id}
                data-domains={c.domains.join(',')}
              >
                <!-- Most Debated Badge -->
                {isTop3 && (
                  <div class="absolute top-0 right-0 bg-amber-500 text-slate-950 text-[10px] font-black px-3 py-1 rounded-bl-lg uppercase tracking-widest z-10 shadow-lg">
                    Most Debated
                  </div>
                )}

                <div class="flex flex-col sm:flex-row gap-4">
                  
                  <!-- Left: ID, Heat & Evidence Weight -->
                  <div class="flex sm:flex-col items-center sm:items-start gap-3 sm:gap-2 shrink-0 min-w-[80px]">
                    <span class="text-amber-500/80 font-mono text-sm font-bold bg-amber-950/30 border border-amber-900/30 px-2 py-1 rounded group-hover:bg-amber-900/40 group-hover:text-amber-400 transition">
                      #{c.num}
                    </span>
                    <span class="text-xs font-bold text-slate-500 bg-slate-950 px-2 py-1 rounded border border-slate-800" title="Debate Intensity">
                      {c.heatIcon}
                    </span>
                    <!-- New Evidence Weight Indicator -->
                    <div class="flex flex-col items-center sm:items-start gap-1 group/weight cursor-help">
                      <span class={`text-xl leading-none ${c.evidenceColor} drop-shadow-md transition-colors`} title={c.evidenceLabel}>
                        {c.evidenceIcon}
                      </span>
                      <span class="text-[9px] uppercase tracking-wider text-slate-600 font-bold group-hover/weight:text-slate-400 transition-colors">Weight</span>
                    </div>
                  </div>

                  <!-- Center: Content -->
                  <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-slate-100 mb-1 group-hover:text-amber-400 transition text-lg search-target-title" data-original={c.title}>
                      {c.title}
                    </h3>
                    <p class="text-slate-400 italic text-sm mb-3 search-target-question" data-original={c.keyQuestion}>
                      "{c.keyQuestion}"
                    </p>
                    
                    <!-- Domain Badges -->
                    <div class="flex flex-wrap gap-2 mb-3">
                      {c.domains.map(domainId => {
                        const domainDef = GROUP_DEFINITIONS.find(g => g.id === domainId);
                        return domainDef ? (
                          <span class="text-[10px] uppercase tracking-wider font-semibold text-slate-400 bg-slate-950 border border-slate-800 px-2 py-0.5 rounded group-hover:border-amber-500/30 group-hover:text-amber-400 transition-colors">
                            {domainDef.name}
                          </span>
                        ) : null;
                      })}
                    </div>

                    <!-- Balance Bar with Tooltip -->
                    {c.total > 0 && (
                      <div class="mt-2 relative group/bar cursor-help">
                        <div class="flex h-3 rounded-full overflow-hidden bg-slate-950 border border-slate-800 shadow-inner">
                          <div class="bg-gradient-to-r from-green-600 to-green-400 transition-all duration-500 relative" style={`width: ${c.proPercent}%`}>
                            <div class="absolute inset-0 bg-white/10 opacity-0 group-hover/bar:opacity-100 transition-opacity"></div>
                          </div>
                          <div class="bg-gradient-to-r from-red-600 to-red-400 transition-all duration-500 relative" style={`width: ${c.conPercent}%`}>
                             <div class="absolute inset-0 bg-white/10 opacity-0 group-hover/bar:opacity-100 transition-opacity"></div>
                          </div>
                        </div>
                        
                        <!-- Tooltip -->
                        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 hidden group-hover/bar:block z-20 w-max">
                          <div class="bg-slate-800 text-slate-200 text-xs font-mono py-1.5 px-3 rounded border border-slate-700 shadow-xl flex gap-3">
                            <span class="text-green-400 font-bold">{c.proCount} Pro</span>
                            <span class="text-slate-600">|</span>
                            <span class="text-red-400 font-bold">{c.conCount} Con</span>
                          </div>
                          <div class="w-2 h-2 bg-slate-800 border-r border-b border-slate-700 rotate-45 absolute left-1/2 -translate-x-1/2 -bottom-1"></div>
                        </div>

                        <div class="flex justify-between text-[10px] text-slate-500 mt-1.5 font-mono uppercase tracking-wide">
                          <span class="text-green-500/80 group-hover/bar:text-green-400 transition-colors">{c.proCount} Supporting</span>
                          <span class="text-red-500/80 group-hover/bar:text-red-400 transition-colors">{c.conCount} Critical</span>
                        </div>
                      </div>
                    )}
                  </div>

                  <!-- Right: Status Preview (Desktop Only) -->
                  {c.status && (
                    <div class="hidden lg:block w-48 shrink-0 border-l border-slate-800 pl-4">
                      <p class="text-slate-500 text-xs line-clamp-3 leading-relaxed group-hover:text-slate-400 transition-colors">{c.status}</p>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const resultCount = document.getElementById('result-count') as HTMLSpanElement;
    const items = document.querySelectorAll('.controversy-item') as NodeListOf<HTMLElement>;
    const groups = document.querySelectorAll('.controversy-group') as NodeListOf<HTMLElement>;
    const filterBtns = document.querySelectorAll('.filter-btn') as NodeListOf<HTMLButtonElement>;

    let activeFilter = 'all';

    // Helper to escape HTML to prevent XSS when injecting highlights
    const escapeHtml = (unsafe: string) => {
      return unsafe
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    };

    // Helper to highlight text
    const highlightText = (element: Element, query: string) => {
      const original = element.getAttribute('data-original');
      if (!original) return;

      if (!query) {
        element.textContent = original;
        return;
      }

      const regex = new RegExp(`(${query})`, 'gi');
      const highlighted = escapeHtml(original).replace(regex, '<mark class="bg-amber-500/30 text-amber-200 rounded px-0.5">$1</mark>');
      element.innerHTML = highlighted;
    };

    // Filter Logic
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update UI
        filterBtns.forEach(b => {
          b.classList.remove('active', 'bg-amber-500/10', 'border-amber-500/50', 'text-amber-400');
          b.classList.add('border-slate-800', 'text-slate-500');
        });
        btn.classList.add('active', 'bg-amber-500/10', 'border-amber-500/50', 'text-amber-400');
        btn.classList.remove('border-slate-800', 'text-slate-500');

        activeFilter = btn.dataset.filter || 'all';
        runFilters();
      });
    });

    const runFilters = () => {
      const query = searchInput.value.toLowerCase().trim();
      let visibleCount = 0;

      groups.forEach(group => {
        const groupId = group.dataset.groupId;
        let groupHasVisibleItems = false;

        const itemsInGroup = group.querySelectorAll('.controversy-item');
        itemsInGroup.forEach(item => {
          const itemDomains = (item.dataset.domains || '').split(',');
          const title = item.dataset.title || '';
          const question = item.dataset.question || '';
          
          // Check Filter Match
          const matchesFilter = activeFilter === 'all' || itemDomains.includes(activeFilter);
          
          // Check Search Match
          const matchesSearch = !query || title.includes(query) || question.includes(query);

          if (matchesFilter && matchesSearch) {
            item.style.display = 'block';
            groupHasVisibleItems = true;
            visibleCount++;
            
            // Highlight
            const titleEl = item.querySelector('.search-target-title');
            const questionEl = item.querySelector('.search-target-question');
            if (titleEl) highlightText(titleEl, query);
            if (questionEl) highlightText(questionEl, query);
          } else {
            item.style.display = 'none';
            // Clear Highlight
            const titleEl = item.querySelector('.search-target-title');
            const questionEl = item.querySelector('.search-target-question');
            if (titleEl) highlightText(titleEl, '');
            if (questionEl) highlightText(questionEl, '');
          }
        });

        // Toggle Group Visibility
        group.style.display = groupHasVisibleItems ? 'block' : 'none';
        
        // Dim effect for partial matches
        if (query && groupHasVisibleItems) {
           const totalInGroup = itemsInGroup.length;
           const visibleInGroup = Array.from(itemsInGroup).filter(i => i.style.display !== 'none').length;
           if (visibleInGroup < totalInGroup) {
             group.classList.add('opacity-50');
           } else {
             group.classList.remove('opacity-50');
           }
        } else {
          group.classList.remove('opacity-50');
        }
      });

      resultCount.textContent = visibleCount.toString();
    };

    searchInput.addEventListener('input', runFilters);
  </script>
</Layout>