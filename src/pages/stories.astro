---
import Layout from '../layouts/Layout.astro';
import { linkGlossaryTerms } from '../utils/glossary-linker';

interface Story {
  id: string;
  title: string;
  subtitle: string;
  domain: string;
  domainIcon: string;
  domainColor: string;
  paperIds: string[];
  body: string; // HTML content — two paragraphs
  image?: {
    src: string;
    alt: string;
    credit: string;  // attribution line
  };
  externalLinks?: {
    label: string;
    url: string;
  }[];
}

const stories: Story[] = [
  {
    id: 'jaytee',
    title: "The Dog Who Knew",
    subtitle: "In over 100 videotaped experiments, a terrier named Jaytee went to the window when his owner decided to come home — from seven kilometers away, at randomly chosen times, with nobody in the house who knew she was coming.",
    domain: 'Telepathy',
    domainIcon: '🧠',
    domainColor: 'purple',
    paperIds: ['sheldrake_2000_that', 'sheldrake_smart_1998_dog_preliminary', 'wiseman_1998_jaytee_dog', 'sheldrake_smart_2000_testing_kane'],
    image: {
      src: '/images/stories/terrier.jpg',
      alt: 'A scruffy mixed-breed terrier similar to Jaytee, the dog at the center of Sheldrake\'s telepathy experiments',
      credit: 'Photo: Chris Barber, CC BY 2.0, via Wikimedia Commons. Not the actual Jaytee — a similar terrier.',
    },
    externalLinks: [
      { label: 'Full paper on sheldrake.org', url: 'https://www.sheldrake.org/research/animal-powers/a-dog-that-seems-to-know-when-his-owner-is-coming-home-videotaped-experiments-and-observations' },
      { label: 'Video: The ORF experiment', url: 'https://www.sheldrake.org/videos/jaytee-a-dog-who-knew-when-his-owner-was-coming-home-the-orf-experiment' },
      { label: 'Dogs That Know When Their Owners Are Coming Home', url: 'https://www.sheldrake.org/books-by-rupert-sheldrake/dogs-that-know-when-their-owners-are-coming-home' },
    ],
    body: '<p>When Pam Smart went out, her terrier Jaytee ignored the front window — cameras recorded him there just 4% of the time across hundreds of hours of tape. But something happened the moment Pam decided to come home. From over seven kilometers away, at randomly chosen times nobody in the house could have known, Jaytee walked to the window and waited. He was there 55% of the time during her return journeys (p < 0.0001), across more than 100 videotaped experiments. In one trial filmed for Austrian television, he reached the window within 11 seconds of Pam being told — at a randomly selected instant — to head home. He did this when he was home alone. He did this when Pam returned at non-routine times of her own choosing. His anticipation typically began before she even started her journey — at the moment of her decision to leave. Over 200 hours of time-coded footage, <a href="/glossary#double-blind">scored blind</a>, documented the same impossible thing: this dog knew.</p><p>Skeptic Richard Wiseman tested the same dog with the same cameras and the same random-return protocol. He published a paper declaring the results negative. But his own videotapes showed Jaytee at the window 4% of the time during absences and 78% during returns — an even larger effect than Sheldrake had found. Wiseman reached his conclusion by applying a binary pass/fail threshold that did not capture the behavioral shift the tapes clearly showed; the dog behaved the same in both teams\' experiments. A separate replication with <a href="/paper/sheldrake_smart_2000_testing_kane">a Rhodesian ridgeback named Kane</a> found the same pattern: 1% during absences, 26% during returns (p = 0.0002). Two dogs, two owners, hundreds of hours of footage, and a skeptic whose own data confirmed what he set out to disprove. If these tapes mean what they appear to mean — that a dog can detect the moment its owner decides to come home, across miles, through walls, with no sensory cue — then something is passing between them that no branch of science can currently explain.</p>'
  },
  {
    id: 'what-the-dead-saw',
    title: "What the Dead Saw",
    subtitle: "Patients in cardiac arrest — with no measurable brain function — describe specific details about their resuscitations, identify objects they couldn't have seen, and encounter the recently dead before anyone knows they've died. When researchers check, the accounts keep turning out to be right.",
    domain: 'Near-Death Experiences',
    domainIcon: '✨',
    domainColor: 'cyan',
    paperIds: ['parnia_2014_aware', 'ring_1997_near_death_blind', 'greyson_2010_peak_in_darien', 'greyson_2011_western_approaches_nde', 'lommel_2001_neardeath'],
    image: {
      src: '/images/stories/tunnel-light.jpg',
      alt: 'A lone figure silhouetted against bright white light at the end of a dark tunnel — the image most commonly described by near-death experience survivors',
      credit: 'Illustration: Jesse Krauss, public domain, via Wikimedia Commons',
    },
    body: '<p>When Sam Parnia\'s <a href="/paper/parnia_2014_aware">AWARE study</a> tracked over 2,000 cardiac arrests across 15 hospitals, one patient stood out: during a three-minute period of clinical death with no measurable brain function, this person described the resuscitation team\'s actions in specific detail — and the medical staff confirmed every point. But this wasn\'t the first verified case, or the strangest. In <a href="/paper/ring_1997_near_death_blind">Kenneth Ring\'s study of blind NDE survivors</a>, a totally blind man identified the color and pattern of a necktie in his hospital room — something he could never have seen. A woman who had recently lost her sight described a hospital corridor in visual detail that an independent witness confirmed. When researcher Janice Holden reviewed all published cases of people reporting verifiable perceptions during NDEs, 92% proved completely accurate.</p><p>The cases that are hardest to explain may be what Bruce Greyson calls <a href="/paper/greyson_2010_peak_in_darien">&ldquo;Peak in Darien&rdquo; experiences</a>: NDE survivors who encounter someone they believed to be alive, only for everyone to discover afterward that person had just died — and nobody present knew it yet. Some met deceased people they had never seen in life. Out of 665 NDEs in the University of Virginia\'s collection, 21% included encounters with the deceased but just 4% with the living — the opposite of what expectation-driven hallucination would produce. Two major prospective studies — <a href="/paper/lommel_2001_neardeath">van Lommel\'s in <em>The Lancet</em></a> and Parnia\'s AWARE — were designed to test these reports under controlled conditions. Both found verified cases. The brain flatlines within seconds of cardiac arrest, and CPR provides a fraction of normal blood flow. Whatever is producing these perceptions — specific, accurate, and confirmed by independent witnesses — it is not coming through the ordinary channels of a functioning brain.</p>'
  },
  {
    id: 'nkisi',
    title: "What the Parrot Said",
    subtitle: "An African Grey parrot was filmed alone while his owner looked at random photographs in a sealed room on a different floor. Three blind judges transcribed what the parrot said. His words matched the pictures at odds of 4,000 to 1.",
    domain: 'Telepathy',
    domainIcon: '🧠',
    domainColor: 'purple',
    paperIds: ['sheldrake_2003_parrot_telepathy'],
    image: {
      src: '/images/stories/african-grey.jpg',
      alt: 'An African Grey parrot perched on a branch — the same species as N\'kisi, the language-using parrot tested for telepathy',
      credit: 'Photo: Pexels (free license). Not the actual N\'kisi — a similar African Grey.',
    },
    body: '<p>N\'kisi was an African Grey parrot and, his owner Aim\u00e9e Morgana believed, a mind reader. Rupert Sheldrake designed an experiment to test this under conditions that left no room for cues. Aim\u00e9e sat in a sealed room on a different floor from N\'kisi, opened a randomly selected photograph from a sealed envelope, and looked at it in silence for two minutes. Downstairs, N\'kisi talked — and was filmed. Three independent transcribers, who had no idea which photograph was being viewed, wrote down what the parrot said. Across 147 trials, N\'kisi\'s words matched the photograph 23 times. Chance predicted 12. The odds against a fluke were roughly 4,000 to 1 (p = 0.0002). The photographs had been randomized by a third party. The statistics were checked by an independent analyst at the Free University of Amsterdam. N\'kisi also repeated his key words more often when they were hits than misses — as if he was more certain when he was right. A parrot, alone in a room, was describing photographs he could not see, viewed by a person he could not hear, in a room he could not access.</p><p>NASA astrophysicist Jeffrey Scargle, one of three peer reviewers, raised a real concern: could biases in how N\'kisi\'s known vocabulary was matched to the photograph categories have inflated the results? Statistician Mikel Aickin applied an entirely different analytical method to the same data and reached the same conclusion — the effect held. The study made TIME magazine but has never been independently replicated, and that is its one genuine weakness. The controls, however, were unusually stringent for an animal study: sealed envelopes, synchronized time-coded video of both parrot and owner, blind transcription by three independent judges, and third-party randomization. If an African Grey parrot can reliably say what a person is looking at in a sealed room on another floor — through no sensory channel anyone can identify — then the bond between N\'kisi and Aim\u00e9e involved something that the word &ldquo;communication&rdquo; does not begin to cover.</p>'
  },
];

// Load catalog to resolve paper links
import catalog from '../data/catalog.json';
const papers = catalog.papers;

function getPaper(id: string) {
  return papers.find((p: any) => p.id === id);
}
---

<Layout title="Remarkable Experiments" description="The most striking cases from psi research — specific experiments and individuals that produced results difficult to explain by any conventional means.">
  <section class="py-16" role="region" aria-label="Remarkable Experiments">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-block mb-4 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs font-semibold tracking-wide uppercase">
          The Standout Cases
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-slate-100 mb-6">
          Remarkable Experiments
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Not every psi experiment is ambiguous. Some produced results so specific, so well-documented,
          and so resistant to conventional explanation that they deserve to be examined on their own terms.
          These are their stories.
        </p>
      </div>

      <!-- Story Cards -->
      <div class="space-y-12">
        {stories.map((story) => (
          <article class="group bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden hover:border-amber-500/30 transition-all duration-300" id={story.id}>
            <!-- Card Image -->
            {story.image && (
              <div class="relative">
                <img src={story.image.src} alt={story.image.alt} class="w-full h-64 sm:h-80 object-cover object-top" loading="lazy" />
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-950/90 to-transparent px-4 py-2">
                  <p class="text-xs text-slate-500 italic">{story.image.credit}</p>
                </div>
              </div>
            )}
            <!-- Card Header -->
            <div class="px-6 sm:px-8 pt-6 sm:pt-8">
              <div class="flex items-center gap-2 mb-3">
                <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-${story.domainColor}-500/10 text-${story.domainColor}-400 border border-${story.domainColor}-500/20`}>
                  <span>{story.domainIcon}</span>
                  {story.domain}
                </span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 mb-3">
                {story.title}
              </h2>
              <p class="text-base sm:text-lg text-amber-400/80 italic leading-relaxed mb-6">
                {story.subtitle}
              </p>
            </div>

            <!-- Card Body -->
            <div class="px-6 sm:px-8 pb-6 sm:pb-8">
              {story.body ? (
                <div class="prose-custom space-y-4 text-base leading-relaxed text-slate-300" set:html={linkGlossaryTerms(story.body)} />
              ) : (
                <div class="bg-slate-800/50 border border-dashed border-slate-700 rounded-xl p-8 text-center">
                  <p class="text-slate-500 italic">Story coming soon.</p>
                </div>
              )}

              <!-- Source Papers -->
              {story.paperIds.length > 0 && (
                <div class="mt-6 pt-6 border-t border-slate-800">
                  <span class="text-xs uppercase tracking-wider text-slate-500 font-medium">Source papers</span>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {story.paperIds.map((pid) => {
                      const paper = getPaper(pid);
                      return paper ? (
                        <a href={`/paper/${pid}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-amber-400 hover:border-amber-500/30 transition-all">
                          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                          {(paper as any).authors?.[0]?.split(',')[0]} {(paper as any).year}
                        </a>
                      ) : (
                        <span class="text-xs text-slate-600">{pid}</span>
                      );
                    })}
                  </div>
                </div>
              )}

              <!-- External Links -->
              {story.externalLinks && story.externalLinks.length > 0 && (
                <div class="mt-4 pt-4 border-t border-slate-800">
                  <span class="text-xs uppercase tracking-wider text-slate-500 font-medium">Learn more</span>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {story.externalLinks.map((link) => (
                      <a href={link.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-amber-400 hover:border-amber-500/30 transition-all">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style>
    .prose-custom p {
      margin-bottom: 1rem;
    }
    .prose-custom p:last-child {
      margin-bottom: 0;
    }
    [data-theme="light"] .prose-custom p {
      color: #334155 !important;
    }
  </style>
</Layout>
