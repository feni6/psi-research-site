---
import Layout from '../layouts/Layout.astro';
import { linkGlossaryTerms } from '../utils/glossary-linker';

interface Story {
  id: string;
  title: string;
  subtitle: string;
  domain: string;
  domainIcon: string;
  domainColor: string;
  domainUrl: string;
  paperIds: string[];
  body: string; // HTML content — two paragraphs
  image?: {
    src: string;
    alt: string;
    credit: string;  // attribution line
    position?: string; // CSS object-position override, e.g. 'center 70%'
  };
  externalLinks?: {
    label: string;
    url: string;
  }[];
}

const stories: Story[] = [
  {
    id: 'jaytee',
    title: "The Dog Who Knew",
    subtitle: "In over 100 videotaped experiments, a terrier named Jaytee went to the window when his owner decided to come home — from seven kilometers away, at randomly chosen times, with nobody in the house who knew she was coming.",
    domain: 'Telepathy',
    domainIcon: '🧠',
    domainColor: 'purple',
    domainUrl: '/domain/telepathy',
    paperIds: ['sheldrake_2000_that', 'sheldrake_smart_1998_dog_preliminary', 'wiseman_1998_jaytee_dog', 'sheldrake_smart_2000_testing_kane'],
    image: {
      src: '/images/stories/terrier.jpg',
      alt: 'A scruffy mixed-breed terrier similar to Jaytee, the dog at the center of Sheldrake\'s telepathy experiments',
      credit: 'Photo: Pexels (free license). Not the actual Jaytee — a similar terrier.',
    },
    externalLinks: [
      { label: 'Full paper on sheldrake.org', url: 'https://www.sheldrake.org/research/animal-powers/a-dog-that-seems-to-know-when-his-owner-is-coming-home-videotaped-experiments-and-observations' },
      { label: 'Video: The ORF experiment', url: 'https://www.sheldrake.org/videos/jaytee-a-dog-who-knew-when-his-owner-was-coming-home-the-orf-experiment' },
      { label: 'Dogs That Know When Their Owners Are Coming Home', url: 'https://www.sheldrake.org/books-by-rupert-sheldrake/dogs-that-know-when-their-owners-are-coming-home' },
    ],
    body: '<p>When Pam Smart went out, her terrier Jaytee ignored the front window — cameras recorded him there just 4% of the time across hundreds of hours of tape. But something happened the moment Pam decided to come home. From over seven kilometers away, at randomly chosen times nobody in the house could have known, Jaytee walked to the window and waited. He was there 55% of the time during her return journeys (p < 0.0001), across more than 100 videotaped experiments. In one trial filmed for Austrian television, he reached the window within 11 seconds of Pam being told — at a randomly selected instant — to head home. He did this when he was home alone. He did this when Pam returned at non-routine times of her own choosing. His anticipation typically began before she even started her journey — at the moment of her decision to leave. Over 200 hours of time-coded footage, <a href="/glossary#double-blind">scored blind</a>, documented the same impossible thing: this dog knew.</p><p>Skeptic Richard Wiseman tested the same dog with the same cameras and the same random-return protocol. He published a paper declaring the results negative. But his own videotapes showed Jaytee at the window 4% of the time during absences and 78% during returns — an even larger effect than Sheldrake had found. Wiseman reached his conclusion by applying a binary pass/fail threshold that did not capture the behavioral shift the tapes clearly showed; the dog behaved the same in both teams\' experiments. A separate replication with <a href="/paper/sheldrake_smart_2000_testing_kane">a Rhodesian ridgeback named Kane</a> found the same pattern: 1% during absences, 26% during returns (p = 0.0002). Two dogs, two owners, hundreds of hours of footage, and a skeptic whose own data confirmed what he set out to disprove. If these tapes mean what they appear to mean — that a dog can detect the moment its owner decides to come home, across miles, through walls, with no sensory cue — then something is passing between them that no branch of science can currently explain.</p>'
  },
  {
    id: 'telephone-telepathy',
    title: "Who's Calling?",
    subtitle: "In 571 randomized trials, participants guessed which of four people was calling before picking up the phone — correctly 40% of the time versus 25% chance. Callers from overseas were identified at an even higher rate of 65%, as if emotional closeness, not distance, carried the signal.",
    domain: 'Telepathy',
    domainIcon: '🧠',
    domainColor: 'purple',
    domainUrl: '/domain/telepathy',
    paperIds: ['sheldrake_smart_2003_experimental_tests_telephone', 'sheldrake_2003_videotaped', 'sheldrake_2004_nolan_telephone', 'schmidt_2009_who_is_calling', 'sheldrake_2025_telecommunication_telepathy_meta'],
    image: {
      src: '/images/stories/telephone.jpg',
      alt: 'A vintage rotary telephone dramatically lit against darkness — evoking the moment before you pick up and somehow already know who is calling',
      credit: 'Photo: Luis La, Pexels (free license)',
    },
    externalLinks: [
      { label: 'Full paper on sheldrake.org', url: 'https://www.sheldrake.org/research/telepathy/experimental-tests-for-telephone-telepathy' },
      { label: 'Nolan Sisters paper (PDF)', url: 'https://www.sheldrake.org/files/pdfs/papers/Nolan_Sisters.pdf' },
    ],
    body: '<p>In Rupert Sheldrake\'s <a href="/paper/sheldrake_smart_2003_experimental_tests_telephone">telephone telepathy experiments</a>, participants guessed which of four people was calling before picking up the phone. Across 571 trials with 63 participants, they were right 40% of the time \u2014 well above the 25% chance rate (p = 4 \u00d7 10\u207b\xb9\u2076). Callers from overseas, physically distant but emotionally close, were identified at 65% (p = 3 \u00d7 10\u207b\u2078), while callers in the UK scored 35%. In a companion study, Sheldrake <a href="/paper/sheldrake_2003_videotaped">videotaped 271 trials</a> with independent cameramen filming both locations; hit rates held steady at 45% (p = 10\u207b\xb9\xb2). Familiar callers were identified 61% of the time; strangers fell to chance. Participants who rated themselves confident in their guess were right 82% of the time. The paradigm was later extended to email, SMS, and automated online tests <a href="/replications#8-telephone-telepathy">over two decades of replications</a> (see also the <a href="/controversies/13_telephone_email_telepathy">full controversy</a>). In a <a href="/paper/sheldrake_2004_nolan_telephone">replication filmed for Channel Five television</a>, Colleen Nolan \u2014 the youngest of the Nolan Sisters, a 1980s British pop group \u2014 sat alone in a room at the Strand Palace Hotel while her four sisters waited in a bar on Poland Street, Soho. Casino dice chose who called. She named the right sister half the time. Her favorite sister Linda: identified every call. Her skeptical sister Anne: never.</p><p>The most rigorous independent replication came from <a href="/paper/schmidt_2009_who_is_calling">Stefan Schmidt\'s team</a> at the University of Freiburg: pre-deposited protocols, casino-grade dice, 557 videotaped trials, 29 participants. The group result was 26.7% \u2014 indistinguishable from chance. If the story ended there, it would be a clean failure to replicate. But one participant scored 42.5% across 80 trials (p = 0.00015, odds of roughly one in 6,600), and Schmidt\'s team concluded that \u201cthere are a few participants who are able to score reliably and repeatedly above chance.\u201d A 2025 <a href="/paper/sheldrake_2025_telecommunication_telepathy_meta">meta-analysis</a> pooling all 26 experiments from 15 papers found performance 8.7% above chance overall (p = 10\u207b\u2077), with stronger effects for emotionally bonded pairs and pre-selected participants. When the paradigm was tested under precognition conditions \u2014 the caller selected after the guess \u2014 results fell to chance, suggesting the effect requires a live mind at the other end. Twenty years of experiments, from landlines to email to text messages, tell the same story: distance does not diminish it, emotional closeness amplifies it, tighter controls do not make it disappear, and no one has identified a conventional mechanism that explains it.</p>'
  },
  {
    id: 'nkisi',
    title: "What the Parrot Said",
    subtitle: "An African Grey parrot was filmed alone while his owner looked at random photographs in a sealed room on a different floor. Three blind judges transcribed what the parrot said. His words matched the pictures at odds of 4,000 to 1.",
    domain: 'Telepathy',
    domainIcon: '🧠',
    domainColor: 'purple',
    domainUrl: '/domain/telepathy',
    paperIds: ['sheldrake_2003_parrot_telepathy'],
    image: {
      src: '/images/stories/african-grey.jpg',
      alt: 'An African Grey parrot perched on a branch — the same species as N\'kisi, the language-using parrot tested for telepathy',
      credit: 'Photo: Pexels (free license). Not the actual N\'kisi — a similar African Grey.',
    },
    body: '<p>N\'kisi was an African Grey parrot and, his owner Aim\u00e9e Morgana believed, a mind reader. Rupert Sheldrake designed an experiment to test this under conditions that left no room for cues. Aim\u00e9e sat in a sealed room on a different floor from N\'kisi, opened a randomly selected photograph from a sealed envelope, and looked at it in silence for two minutes. Downstairs, N\'kisi talked — and was filmed. Three independent transcribers, who had no idea which photograph was being viewed, wrote down what the parrot said. Across 147 trials, N\'kisi\'s words matched the photograph 23 times. Chance predicted 12. The odds against a fluke were roughly 4,000 to 1 (p = 0.0002). The photographs had been randomized by a third party. The statistics were checked by an independent analyst at the Free University of Amsterdam. N\'kisi also repeated his key words more often when they were hits than misses — as if he was more certain when he was right. A parrot, alone in a room, was describing photographs he could not see, viewed by a person he could not hear, in a room he could not access.</p><p>NASA astrophysicist Jeffrey Scargle, one of three peer reviewers, raised a real concern: could biases in how N\'kisi\'s known vocabulary was matched to the photograph categories have inflated the results? Statistician Mikel Aickin applied an entirely different analytical method to the same data and reached the same conclusion — the effect held. The study made TIME magazine but has never been independently replicated, and that is its one genuine weakness. The controls, however, were unusually stringent for an animal study: sealed envelopes, synchronized time-coded video of both parrot and owner, blind transcription by three independent judges, and third-party randomization. If an African Grey parrot can reliably say what a person is looking at in a sealed room on another floor — through no sensory channel anyone can identify — then the bond between N\'kisi and Aim\u00e9e involved something that the word &ldquo;communication&rdquo; does not begin to cover.</p>'
  },
  {
    id: 'when-the-ball-drops',
    title: "When the Ball Drops",
    subtitle: "For 27 consecutive years, random number generators around the world deviated from chance at the stroke of midnight on New Year\u2019s Eve. The effect appeared where billions celebrated. Where few did, it vanished.",
    domain: 'Mind & Matter',
    domainIcon: '\uD83C\uDF10',
    domainColor: 'teal',
    domainUrl: '/domain/psychokinesis',
    paperIds: ['radin_2025_years', 'nelson_2011_effects', 'nelson_2014_gcp_invited', 'bancel_2017_searching', 'scargle_2002_gcp_sept11'],
    image: {
      src: '/images/stories/disco-ball.jpg',
      alt: 'A disco ball casting scattered light against a dark background, evoking the celebratory energy of New Year\u2019s Eve',
      credit: 'Photo: NEOSiAM 2024+ on Pexels (free license)',
    },
    body: '<p>In time zones where billions of people ring in the New Year, random number generators become measurably less random at the stroke of midnight. In time zones where few people celebrate, they don\'t. That is the central finding of Dean Radin\'s <a href="/paper/radin_2025_years">analysis of 27 years of data</a> from the Global Consciousness Project \u2014 a worldwide network of quantum-noise devices that produce streams of truly random ones and zeros, running continuously in dozens of countries since 1998. Radin applied seven independent statistical methods to 33 billion samples (6.6 trillion bits), comparing every New Year\'s Eve midnight to every other midnight of the year. The principal components analysis flagged the deviation at z = \u22124.9 \u2014 less than one chance in two million. The mean-shift analysis found a 6-sigma anomaly in the four and a half minutes centered on midnight. No other night produced anything comparable. When Radin partitioned the data by population, time zones with 6.8 billion people counting down showed significant deviations; zones with only 629 million did not. More minds focused on the same joyful instant, bigger signal \u2014 the same dose-response relationship that, in any other field, would be treated as evidence that something real is happening.</p><p>The Global Consciousness Project has faced serious critique. NASA astrophysicist <a href="/paper/scargle_2002_gcp_sept11">Jeffrey Scargle argued</a> that the project\'s flagship cumulative-sum analyses can generate impressive-looking structure from pure noise. GCP insider <a href="/paper/bancel_2017_searching">Peter Bancel went further</a>: his reanalysis of the project\'s 7-sigma cumulative result argued the anomaly tracks the intentions of the handful of researchers running the experiment, not humanity\'s collective mood. The New Year\'s Eve study addresses both objections. Unlike post-hoc event selections such as September 11, New Year\'s Eve is as predictable as it gets \u2014 no cherry-picking, no ambiguity about when the window opens. And the population partition tests Bancel\'s reinterpretation directly: if the effect came from the experimenters\' minds rather than the celebrants\', it should appear equally in all time zones. Instead, it scaled with the crowd. The study is not pre-registered, and the choice of seven analytical methods introduces some flexibility \u2014 but those methods converge on the same answer across 27 independent replications of the same event. If random numbers respond to New Year\'s Eve because billions of minds are focused on the same moment \u2014 and fall silent where few minds are present \u2014 then something is coupling human consciousness to the behavior of machines specifically designed to be immune to outside influence.</p>'
  },
  {
    id: 'dreamer-skeptic',
    title: "The Dreamer and the Skeptic",
    subtitle: "In a pre-registered experiment, a lucid dreamer described women playing a game on a football pitch in a stadium. A prominent skeptic then randomly selected the target: Iranian women playing rugby. Out of 2,707 targets, the match was 80,000 to one.",
    domain: 'Precognition',
    domainIcon: '🌙',
    domainColor: 'blue',
    domainUrl: '/domain/precognition',
    paperIds: ['mossbridge_2025_future_dreams'],
    image: {
      src: '/images/stories/womens-rugby.jpg',
      alt: 'Women competing in a rugby lineout at the 2025 Rugby World Cup — the kind of scene a lucid dreamer described before a skeptic randomly selected it as a target',
      credit: 'Photo: JHock93, CC0, via Wikimedia Commons. 2025 Women\'s Rugby World Cup, Canada vs Australia.',
      position: 'center 75%',
    },
    body: '<p>Dave Green can enter a lucid dream almost at will. In a pre-registered experiment in 2023, he fell asleep, recognized he was dreaming, and walked to a computer in his dream house. He asked to see a photograph he had not yet been shown. What appeared: women seated around a table playing backgammon — but the table had markings like a football pitch, and they sat in the center of a large stadium with an audience watching. He woke, recorded the scene, and emailed it to Chris French — professor at Goldsmiths, University of London, and one of Britain\'s most prominent skeptics. French would then select a target using random.org, picking from a database of hundreds of news stories. The target he selected: Iranian women in hijabs playing rugby at a tournament in Italy. Women. A sport on a rectangular pitch. An audience. When AI text-embedding models compared Green\'s dream against all 2,707 items in the target database, the match scored Z = 4.99 — odds of roughly 80,000 to one after correcting for every comparison. The dream was recorded, timestamped, and in the skeptic\'s inbox before the target was chosen.</p><p>This was one of ten trials in a study by Green, French, and Mossbridge, published in the peer-reviewed International Journal of Dream Research. Across all ten, five of Green\'s lucid dreams matched their randomly selected targets by AI scoring (p = .033). Green recruited French himself, wanting a skeptic to close every loophole. In one miss, Green dreamed of a townhouse with a &ldquo;For Sale&rdquo; sign. French said nothing until the experiment ended, then revealed the sketch matched his own house, which at that moment had a real estate sign out front. He called it &ldquo;remarkably coincidental.&rdquo; The study has real limitations: ten trials from one dreamer, exploratory AI scoring, and flawed human judging. The skeptics on the team said the case for precognition remains unestablished. But one result sits in the published record: a dream of women on a football pitch in a stadium, sent to a skeptic whose random number generator then selected — from thousands of possibilities — Iranian women playing rugby. Whatever produced that dream, it described a target that did not yet exist, chosen by a man recruited because he did not believe such things were possible.</p>'
  },
  {
    id: 'water-crystals',
    title: "What the Water Showed",
    subtitle: "Two thousand people in Tokyo focused kind intentions on water locked in a shielded room in California, five thousand miles away. Blind judges rated the ice crystals it formed as significantly more beautiful. A triple-blind replication confirmed it.",
    domain: 'Mind & Matter',
    domainIcon: '💧',
    domainColor: 'teal',
    domainUrl: '/domain/psychokinesis',
    paperIds: ['radin_2006_doubleblind', 'radin_2008_effects', 'schwartz_2019_water', 'yu_2024_effects'],
    image: {
      src: '/images/stories/ice-crystal.jpg',
      alt: 'A snow crystal photographed by Wilson Bentley in the early 1900s — the kind of intricate ice formation that Emoto claimed could be influenced by human intention',
      credit: 'Photo: Wilson Bentley, c. 1900, CC0, via Metropolitan Museum of Art / Wikimedia Commons',
    },
    body: '<p>Masaru Emoto\'s photographs of ice crystals became a global phenomenon — water exposed to prayer formed intricate, beautiful crystals; water cursed or ignored formed ugly ones. His books sold millions. Scientists dismissed the claim as uncontrolled pseudoscience. Then Dean Radin designed a proper test. In 2006, approximately 2,000 people in Tokyo focused kind intentions toward water locked inside an electromagnetically shielded room in California, 5,000 miles away. A technician blind to which samples were treated photographed 40 ice crystals. One hundred independent judges, equally blind, rated their beauty. The treated crystals scored significantly higher (p &lt; .001), with a large <a href="/glossary#effect-size">effect size</a> (d &asymp; 1.04). In a <a href="/replications#7-water-crystal-formation">2008 triple-blind replication</a>, 1,900 people in Austria and Germany focused gratitude toward water in the same shielded room, and 2,579 online judges rated the resulting crystals. Again, treated water formed more beautiful crystals (p = 0.03). Combined across both studies: p = 0.0004.</p><p>The crystal studies have real limitations. The 2006 test drew its 40 crystals from only four bottles, making the effective sample size tiny despite the large effect. The 2008 replication produced marginal p-values, and distant control water scored slightly higher than treated water in some comparisons — an anomaly the researchers flagged but could not explain. Neither study was pre-registered, and Emoto was a co-author on both. But four independent teams have since found converging results using entirely different measures:</p><ul class="list-disc pl-6 space-y-1 text-base text-slate-300 my-4"><li><strong>Crystal formation:</strong> Radin\'s triple-blind replication with 2,579 judges confirmed the original aesthetic effect (p = 0.03).</li><li><strong>Infrared spectra:</strong> <a href="/paper/schwartz_2015_infrared">Schwartz found</a> that healers\' hands altered water\'s molecular absorption patterns (p = 0.0004).</li><li><strong>Taste:</strong> Meditators\' <a href="/paper/schwartz_2019_water">intention made wine preferred</a> in 11 of 12 blind tastings (p = 0.0005).</li><li><strong>Cell migration:</strong> In 2024, aggressive brain cancer cells cultured in <a href="/paper/yu_2024_effects">double-blind intention-treated water</a> migrated 25% less (p = 0.005).</li></ul><p>Four measures, four teams, one direction. If focused intention can change the physical properties of water through electromagnetic shielding from 5,000 miles away, and those changes show up on instruments and in judges\' ratings when nobody involved knows which water was treated — then something is reaching the water that the shielding was designed to stop.</p>'
  },
];

// Load catalog to resolve paper links
import catalog from '../data/catalog.json';
const papers = catalog.papers;

function getPaper(id: string) {
  return papers.find((p: any) => p.id === id);
}
---

<Layout title="Remarkable Experiments" description="The most striking cases from psi research — specific experiments and individuals that produced results difficult to explain by any conventional means.">
  <section class="py-16" role="region" aria-label="Remarkable Experiments">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Header -->
      <div class="text-center mb-16">
        <div class="inline-block mb-4 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs font-semibold tracking-wide uppercase">
          The Standout Cases
        </div>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-slate-100 mb-6">
          Remarkable Experiments
        </h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
          Not every psi experiment is ambiguous. Some produced results so specific, so well-documented,
          and so resistant to conventional explanation that they deserve to be examined on their own terms.
          These are their stories.
        </p>
      </div>

      <!-- Story Cards -->
      <div class="space-y-12">
        {stories.map((story) => (
          <article class="group bg-slate-900/50 border border-slate-800 rounded-2xl overflow-hidden hover:border-amber-500/30 transition-all duration-300" id={story.id}>
            <!-- Card Image -->
            {story.image && (
              <div class="relative">
                <img src={story.image.src} alt={story.image.alt} class="w-full h-64 sm:h-80 object-cover" style={`object-position: ${story.image.position || 'top'}`} loading="lazy" />
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-slate-950/90 to-transparent px-4 py-2">
                  <p class="text-xs text-slate-500 italic">{story.image.credit}</p>
                </div>
              </div>
            )}
            <!-- Card Header -->
            <div class="px-6 sm:px-8 pt-6 sm:pt-8">
              <div class="flex items-center gap-2 mb-3">
                <a href={story.domainUrl} class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-${story.domainColor}-500/10 text-${story.domainColor}-400 border border-${story.domainColor}-500/20 hover:bg-${story.domainColor}-500/20 transition-colors`}>
                  <span>{story.domainIcon}</span>
                  {story.domain}
                </a>
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold text-slate-100 mb-3">
                {story.title}
              </h2>
              <p class="text-base sm:text-lg text-amber-400/80 italic leading-relaxed mb-6">
                {story.subtitle}
              </p>
            </div>

            <!-- Card Body -->
            <div class="px-6 sm:px-8 pb-6 sm:pb-8">
              {story.body ? (
                <div class="prose-custom space-y-4 text-base leading-relaxed text-slate-300" set:html={linkGlossaryTerms(story.body)} />
              ) : (
                <div class="bg-slate-800/50 border border-dashed border-slate-700 rounded-xl p-8 text-center">
                  <p class="text-slate-500 italic">Story coming soon.</p>
                </div>
              )}

              <!-- Source Papers -->
              {story.paperIds.length > 0 && (
                <div class="mt-6 pt-6 border-t border-slate-800">
                  <span class="text-xs uppercase tracking-wider text-slate-500 font-medium">Source papers</span>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {story.paperIds.map((pid) => {
                      const paper = getPaper(pid);
                      return paper ? (
                        <a href={`/paper/${pid}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-amber-400 hover:border-amber-500/30 transition-all">
                          <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                          {(paper as any).authors?.[0]?.split(',')[0]} {(paper as any).year}
                        </a>
                      ) : (
                        <span class="text-xs text-slate-600">{pid}</span>
                      );
                    })}
                  </div>
                </div>
              )}

              <!-- External Links -->
              {story.externalLinks && story.externalLinks.length > 0 && (
                <div class="mt-4 pt-4 border-t border-slate-800">
                  <span class="text-xs uppercase tracking-wider text-slate-500 font-medium">Learn more</span>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {story.externalLinks.map((link) => (
                      <a href={link.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800 border border-slate-700 rounded-lg text-sm text-slate-300 hover:text-amber-400 hover:border-amber-500/30 transition-all">
                        <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                        {link.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <style is:global>
    .prose-custom p {
      margin-bottom: 1rem;
    }
    .prose-custom p:last-child {
      margin-bottom: 0;
    }
    [data-theme="light"] .prose-custom p {
      color: #334155 !important;
    }
    .prose-custom a:not([class]) {
      color: rgb(251 191 36);
      text-decoration: underline;
      text-decoration-color: rgb(251 191 36 / 0.4);
      text-underline-offset: 2px;
    }
    .prose-custom a:not([class]):hover {
      color: rgb(252 211 77);
      text-decoration-color: rgb(252 211 77 / 0.6);
    }
    [data-theme="light"] .prose-custom a:not([class]) {
      color: rgb(180 83 9);
      text-decoration-color: rgb(180 83 9 / 0.4);
    }
    [data-theme="light"] .prose-custom a:not([class]):hover {
      color: rgb(146 64 14);
      text-decoration-color: rgb(146 64 14 / 0.6);
    }
  </style>
</Layout>
