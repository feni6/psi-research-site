import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// --- Helper Functions ---

const safeNumber = (val) => {
  if (typeof val === 'number') return val;
  if (typeof val === 'string') {
    const parsed = parseFloat(val);
    return isNaN(parsed) ? null : parsed;
  }
  return null;
};

const getMedian = (arr) => {
  if (!arr || arr.length === 0) return null;
  const sorted = [...arr].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
};

const formatPercent = (count, total) => {
  if (total === 0) return '0%';
  return ((count / total) * 100).toFixed(1) + '%';
};

// --- Data Processing ---

const papers = catalog.papers;
const totalPapers = papers.length;

// 1. Overview Stats
const years = papers.map(p => p.year).filter(y => typeof y === 'number');
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const uniqueDomains = new Set(papers.map(p => p.psi_domain).filter(Boolean)).size;
const uniqueJournals = new Set(papers.map(p => p.journal).filter(Boolean)).size;

// 2. Domain Breakdown
const domainCounts = {};
papers.forEach(p => {
  const domain = p.psi_domain || 'Unknown';
  domainCounts[domain] = (domainCounts[domain] || 0) + 1;
});
const domainStats = Object.entries(domainCounts)
  .map(([domain, count]) => ({ domain, count, percent: formatPercent(count, totalPapers) }))
  .sort((a, b) => b.count - a.count);

// 3. Methodology Quality
let preRegTrue = 0, preRegFalse = 0, preRegNull = 0;
let blindDouble = 0, blindSingle = 0, blindNone = 0, blindOther = 0;
const effectSizes = [];

papers.forEach(p => {
  const m = p.methodology || {};
  
  // Pre-registration
  if (m.pre_registration === true) preRegTrue++;
  else if (m.pre_registration === false) preRegFalse++;
  else preRegNull++;

  // Blinding
  const blindVal = String(m.blinding || '').toLowerCase();
  if (blindVal.includes('double')) blindDouble++;
  else if (blindVal.includes('single')) blindSingle++;
  else if (blindVal.includes('none') || blindVal === 'no' || blindVal === 'n/a') blindNone++;
  else blindOther++;

  // Effect Size
  const es = safeNumber(m.effect_size);
  if (es !== null) effectSizes.push(es);
});

const effectSizeStats = effectSizes.length > 0 ? {
  count: effectSizes.length,
  min: Math.min(...effectSizes).toFixed(2),
  median: getMedian(effectSizes).toFixed(2),
  max: Math.max(...effectSizes).toFixed(2)
} : null;

// 4. Sample Size Ranges
const sampleSizes = papers
  .map(p => safeNumber(p.methodology?.sample_size))
  .filter(n => n !== null);

const overallSampleStats = sampleSizes.length > 0 ? {
  count: sampleSizes.length,
  min: Math.min(...sampleSizes).toLocaleString(),
  median: Math.round(getMedian(sampleSizes)).toLocaleString(),
  max: Math.max(...sampleSizes).toLocaleString()
} : null;

// Sample Size per Domain
const domainSampleStats = {};
papers.forEach(p => {
  const domain = p.psi_domain || 'Unknown';
  const size = safeNumber(p.methodology?.sample_size);
  if (size !== null) {
    if (!domainSampleStats[domain]) domainSampleStats[domain] = [];
    domainSampleStats[domain].push(size);
  }
});

const domainSampleTable = Object.entries(domainSampleStats).map(([domain, sizes]) => ({
  domain,
  count: sizes.length,
  median: Math.round(getMedian(sizes)).toLocaleString()
})).sort((a, b) => b.count - a.count);

// 5. Year Distribution (Decades)
const decadeCounts = {};
papers.forEach(p => {
  if (typeof p.year === 'number') {
    const decade = Math.floor(p.year / 10) * 10;
    decadeCounts[decade] = (decadeCounts[decade] || 0) + 1;
  }
});
const sortedDecades = Object.keys(decadeCounts).map(Number).sort((a, b) => a - b);
const maxDecadeCount = Math.max(...Object.values(decadeCounts));
const histogramData = sortedDecades.map(decade => ({
  decade: `${decade}s`,
  count: decadeCounts[decade],
  bar: '█'.repeat(Math.round((decadeCounts[decade] / maxDecadeCount) * 20))
}));

// 6. Skeptical Representation
const skepticalCount = papers.filter(p => p.folder === '10_Skeptical_and_Critical').length;
const skepticalPercent = formatPercent(skepticalCount, totalPapers);

---

<Layout title="Library Statistics">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-400 mb-6">
      <ol class="list-none p-0 inline-flex">
        <li class="flex items-center">
          <a href="/" class="hover:text-amber-400 transition-colors">Home</a>
          <svg class="fill-current w-3 h-3 mx-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 512"><path d="M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z"/></svg>
          <span class="text-amber-400 font-medium">Statistics</span>
        </li>
      </ol>
    </nav>

    <header class="mb-8">
      <h1 class="text-3xl font-bold text-slate-100 mb-2">Library Statistics</h1>
      <p class="text-slate-400">Aggregate analysis of {totalPapers.toLocaleString()} papers in the Psi Research Library.</p>
    </header>

    <!-- 1. Overview Stats -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <dt class="text-sm font-medium text-slate-400 uppercase tracking-wider">Total Papers</dt>
        <dd class="mt-2 text-3xl font-semibold text-amber-400">{totalPapers.toLocaleString()}</dd>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <dt class="text-sm font-medium text-slate-400 uppercase tracking-wider">Date Range</dt>
        <dd class="mt-2 text-3xl font-semibold text-slate-100">{minYear} – {maxYear}</dd>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <dt class="text-sm font-medium text-slate-400 uppercase tracking-wider">Psi Domains</dt>
        <dd class="mt-2 text-3xl font-semibold text-slate-100">{uniqueDomains}</dd>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <dt class="text-sm font-medium text-slate-400 uppercase tracking-wider">Journals</dt>
        <dd class="mt-2 text-3xl font-semibold text-slate-100">{uniqueJournals}</dd>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      
      <!-- 2. Domain Breakdown -->
      <div class="bg-slate-900 border border-slate-800 rounded-lg overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-800 bg-slate-900/50">
          <h2 class="text-lg font-medium text-slate-100">Domain Breakdown</h2>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full text-sm text-left">
            <thead class="text-xs text-slate-400 uppercase bg-slate-950/50">
              <tr>
                <th class="px-6 py-3">Domain</th>
                <th class="px-6 py-3 text-right">Count</th>
                <th class="px-6 py-3 text-right">%</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-800">
              {domainStats.map(stat => (
                <tr class="hover:bg-slate-800/50 transition-colors">
                  <td class="px-6 py-4 font-medium text-slate-200">{stat.domain}</td>
                  <td class="px-6 py-4 text-right text-slate-400">{stat.count}</td>
                  <td class="px-6 py-4 text-right text-amber-400/80">{stat.percent}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <!-- 3. Methodology Quality -->
      <div class="space-y-6">
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
          <h2 class="text-lg font-medium text-slate-100 mb-4">Methodology Rigor</h2>
          
          <div class="space-y-4">
            <!-- Pre-registration -->
            <div>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-slate-400">Pre-Registration</span>
                <span class="text-slate-200">{preRegTrue} True / {preRegFalse} False</span>
              </div>
              <div class="w-full bg-slate-800 rounded-full h-2.5">
                <div class="bg-amber-500 h-2.5 rounded-full" style={`width: ${formatPercent(preRegTrue, totalPapers)}`}></div>
              </div>
              <div class="text-xs text-slate-500 mt-1 text-right">{formatPercent(preRegTrue, totalPapers)} reported pre-registered</div>
            </div>

            <!-- Blinding -->
            <div class="pt-4 border-t border-slate-800">
              <h3 class="text-sm font-medium text-slate-300 mb-2">Blinding Procedures</h3>
              <div class="grid grid-cols-2 gap-4 text-sm">
                <div class="flex justify-between">
                  <span class="text-slate-400">Double Blind</span>
                  <span class="text-slate-200">{blindDouble}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Single Blind</span>
                  <span class="text-slate-200">{blindSingle}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">None / N/A</span>
                  <span class="text-slate-200">{blindNone}</span>
                </div>
                <div class="flex justify-between">
                  <span class="text-slate-400">Other / Unknown</span>
                  <span class="text-slate-200">{blindOther}</span>
                </div>
              </div>
            </div>

            <!-- Effect Size -->
            {effectSizeStats && (
              <div class="pt-4 border-t border-slate-800">
                <h3 class="text-sm font-medium text-slate-300 mb-2">Reported Effect Sizes (n={effectSizeStats.count})</h3>
                <div class="grid grid-cols-3 gap-2 text-center">
                  <div class="bg-slate-950 rounded p-2">
                    <div class="text-xs text-slate-500">Min</div>
                    <div class="text-amber-400 font-mono">{effectSizeStats.min}</div>
                  </div>
                  <div class="bg-slate-950 rounded p-2">
                    <div class="text-xs text-slate-500">Median</div>
                    <div class="text-amber-400 font-mono">{effectSizeStats.median}</div>
                  </div>
                  <div class="bg-slate-950 rounded p-2">
                    <div class="text-xs text-slate-500">Max</div>
                    <div class="text-amber-400 font-mono">{effectSizeStats.max}</div>
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>

        <!-- 6. Skeptical Representation -->
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 flex items-center justify-between">
          <div>
            <h3 class="text-lg font-medium text-slate-100">Skeptical & Critical Papers</h3>
            <p class="text-sm text-slate-400 mt-1">Papers in folder <code class="bg-slate-950 px-1 py-0.5 rounded text-slate-300">10_Skeptical_and_Critical</code></p>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-amber-400">{skepticalCount}</div>
            <div class="text-sm text-slate-500">{skepticalPercent} of total</div>
          </div>
        </div>
      </div>
    </div>

    <!-- 4. Sample Size Ranges -->
    <div class="bg-slate-900 border border-slate-800 rounded-lg overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-800 bg-slate-900/50 flex justify-between items-center">
        <h2 class="text-lg font-medium text-slate-100">Sample Size Analysis</h2>
        {overallSampleStats && (
          <span class="text-xs text-slate-400 bg-slate-950 px-2 py-1 rounded border border-slate-800">
            Overall Median: <span class="text-amber-400">{overallSampleStats.median}</span> (n={overallSampleStats.count})
          </span>
        )}
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm text-left">
          <thead class="text-xs text-slate-400 uppercase bg-slate-950/50">
            <tr>
              <th class="px-6 py-3">Domain</th>
              <th class="px-6 py-3 text-right">Papers with N</th>
              <th class="px-6 py-3 text-right">Median N</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            {domainSampleTable.map(stat => (
              <tr class="hover:bg-slate-800/50 transition-colors">
                <td class="px-6 py-4 font-medium text-slate-200">{stat.domain}</td>
                <td class="px-6 py-4 text-right text-slate-400">{stat.count}</td>
                <td class="px-6 py-4 text-right text-amber-400/80 font-mono">{stat.median}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- 5. Year Distribution -->
    <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
      <h2 class="text-lg font-medium text-slate-100 mb-6">Publication Distribution by Decade</h2>
      <div class="space-y-2 font-mono text-sm">
        {histogramData.map(item => (
          <div class="flex items-center gap-4">
            <span class="w-12 text-right text-slate-500">{item.decade}</span>
            <span class="w-8 text-right text-slate-300">{item.count}</span>
            <span class="text-amber-500/80">{item.bar}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</Layout>