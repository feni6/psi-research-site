---
import Layout from '../../layouts/Layout.astro';
import catalog from '../../data/catalog.json';
import paperImagesRaw from '../../data/paper-images.json';
const paperImages: Record<string, { image: string | null; publisherUrl: string | null }> = paperImagesRaw as any;

export function getStaticPaths() {
  return catalog.papers.map((paper: any) => ({
    params: { id: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;

// --- Context Badges Logic ---
// Load controversy and reading path files to check for references to this paper ID
const controversyFiles = import.meta.glob('../../data/controversies/*.md', { eager: true, query: '?raw', import: 'default' });
const pathFiles = import.meta.glob('../../data/reading_paths/path_*.md', { eager: true, query: '?raw', import: 'default' });

const foundControversies = [];
const foundPaths = [];

// Scan controversies
for (const [path, content] of Object.entries(controversyFiles)) {
  // Skip index files
  if (path.includes('_INDEX')) continue;
  
  if (content.includes(paper.id)) {
    // Extract name from filename: 01_ganzfeld_telepathy.md -> Ganzfeld Telepathy
    const filename = path.split('/').pop()?.replace('.md', '') || '';
    const name = filename
      .replace(/^\d+_/, '') // Remove leading number and underscore
      .replace(/_/g, ' ')   // Replace underscores with spaces
      .replace(/\b\w/g, c => c.toUpperCase()); // Title case
    foundControversies.push({ id: filename, name, path: `/controversies/${filename}` });
  }
}

// Scan reading paths
for (const [path, content] of Object.entries(pathFiles)) {
  if (content.includes(paper.id)) {
    // Extract name from filename: path_1_steelman_psi.md -> Steelman Psi
    const filename = path.split('/').pop()?.replace('.md', '') || '';
    // Remove 'path_' prefix and number
    const namePart = filename.replace(/^path_\d+_/, '');
    const name = namePart
      .replace(/_/g, ' ')
      .replace(/\b\w/g, c => c.toUpperCase());
    foundPaths.push({ id: filename, name, path: `/paths/${filename}` });
  }
}
// ----------------------------

const relatedPapersRaw = paper.related_papers || {};
const relatedEntries: { type: string; paper: any }[] = [];
if (typeof relatedPapersRaw === 'object' && !Array.isArray(relatedPapersRaw)) {
  for (const [relType, ids] of Object.entries(relatedPapersRaw)) {
    if (Array.isArray(ids)) {
      for (const id of ids as string[]) {
        const found = catalog.papers.find((p: any) => p.id === id);
        if (found) relatedEntries.push({ type: relType, paper: found });
      }
    }
  }
}
const relatedPapers = relatedEntries;
const relatedPaperIds = new Set(relatedPapers.map(rp => rp.paper.id));

const folderLabels: Record<string, string> = {
  '01_Meta-Analyses': 'Meta-Analyses',
  '02_Telepathy': 'Telepathy',
  '03_Precognition': 'Precognition',
  '04_Remote_Viewing': 'Remote Viewing',
  '05_Psychokinesis': 'Psychokinesis',
  '06_Healing_and_Intention': 'Healing & Intention',
  '07_Mediumship_and_Survival': 'Mediumship & Survival',
  '08_NDE_and_OBE': 'NDE & OBE',
  '09_Methodology_and_Theory': 'Methodology & Theory',
  '10_Skeptical_and_Critical': 'Skeptical & Critical',
  '11_Autism_and_Nonverbal': 'Autism & Nonverbal',
  '12_Books_and_Overviews': 'Books & Overviews',
  '13_Podcast_References': 'Podcast References',
};

// Find prev/next in same domain
const sameDomain = catalog.papers
  .filter((p: any) => p.psi_domain === paper.psi_domain)
  .sort((a: any, b: any) => (a.year || 0) - (b.year || 0));
const currentIndex = sameDomain.findIndex((p: any) => p.id === paper.id);
const prevPaper = currentIndex > 0 ? sameDomain[currentIndex - 1] : null;
const nextPaper = currentIndex < sameDomain.length - 1 ? sameDomain[currentIndex + 1] : null;

// Compute same domain papers (excluding related ones)
const sameDomainOthers = catalog.papers
  .filter((p: any) => p.psi_domain === paper.psi_domain && p.id !== paper.id)
  .filter((p: any) => !relatedPaperIds.has(p.id))
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0))
  .slice(0, 5);

// Compute shared author papers (excluding related and same-domain ones already shown)
const currentAuthors = new Set(paper.authors || []);
const sharedAuthorPapers = catalog.papers
  .filter((p: any) => p.id !== paper.id)
  .filter((p: any) => !relatedPaperIds.has(p.id))
  .filter((p: any) => !sameDomainOthers.some(sp => sp.id === p.id)) // Avoid dupes with domain section
  .filter((p: any) => {
    const paperAuthors = new Set(p.authors || []);
    // Check intersection
    for (const author of currentAuthors) {
      if (paperAuthors.has(author)) return true;
    }
    return false;
  })
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0))
  .slice(0, 3);

// Format domain name for display
const formatDomainName = (domain: string) => {
  return domain
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (l) => l.toUpperCase());
};

// Group related papers by type
const groupedRelated: Record<string, any[]> = {};
relatedPapers.forEach((entry) => {
  if (!groupedRelated[entry.type]) {
    groupedRelated[entry.type] = [];
  }
  groupedRelated[entry.type].push(entry.paper);
});

// Relationship type colors
const relationColors: Record<string, string> = {
  critiques: 'text-red-400 border-red-400/30 bg-red-400/10',
  critiqued_by: 'text-red-400 border-red-400/30 bg-red-400/10',
  extends: 'text-blue-400 border-blue-400/30 bg-blue-400/10',
  extended_by: 'text-blue-400 border-blue-400/30 bg-blue-400/10',
  replicated_by: 'text-green-400 border-green-400/30 bg-green-400/10',
  replication_of: 'text-green-400 border-green-400/30 bg-green-400/10',
  precursor: 'text-purple-400 border-purple-400/30 bg-purple-400/10',
};

const getRelationColor = (type: string) => {
  return relationColors[type] || 'text-slate-400 border-slate-400/30 bg-slate-400/10';
};

const formatRelationLabel = (type: string) => {
  return type.replace(/_/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
};

// Effect size color
const getEffectSizeColor = (es: number) => {
  if (es > 0.3) return 'bg-green-500';
  if (es >= 0.1) return 'bg-amber-500';
  return 'bg-red-500';
};

// Blinding badge
const getBlindingBadge = (blinding: string) => {
  if (!blinding) return null;
  const lower = blinding.toLowerCase();
  if (lower.includes('double')) {
    return { text: 'Double-Blind', color: 'bg-green-500/20 text-green-400 border-green-500/30' };
  }
  if (lower.includes('single')) {
    return { text: 'Single-Blind', color: 'bg-amber-500/20 text-amber-400 border-amber-500/30' };
  }
  return { text: 'Not Blinded', color: 'bg-red-500/20 text-red-400 border-red-500/30' };
};

// Era Badge Logic
const getEraBadge = (year: number) => {
  if (!year) return null;
  if (year < 1930) return { text: 'Pre-Modern', color: 'bg-purple-400/20 text-purple-400 border-purple-400/30' };
  if (year >= 1930 && year <= 1965) return { text: 'Rhine Era', color: 'bg-blue-400/20 text-blue-400 border-blue-400/30' };
  if (year > 1965 && year <= 1985) return { text: 'Ganzfeld Era', color: 'bg-cyan-400/20 text-cyan-400 border-cyan-400/30' };
  if (year > 1972 && year <= 1995) return { text: 'STAR GATE Era', color: 'bg-green-400/20 text-green-400 border-green-400/30' };
  if (year > 1995 && year <= 2015) return { text: 'Modern Era', color: 'bg-amber-400/20 text-amber-400 border-amber-400/30' };
  if (year > 2015) return { text: 'Current Era', color: 'bg-red-400/20 text-red-400 border-red-400/30' };
  return null;
};

const eraBadge = paper.year ? getEraBadge(paper.year) : null;

// Domain thumbnail config
const domainGradients: Record<string, string> = {
  telepathy: 'from-purple-600 to-purple-900', psychokinesis: 'from-red-600 to-red-900',
  nde: 'from-cyan-600 to-cyan-900', healing: 'from-green-600 to-green-900',
  precognition: 'from-violet-600 to-violet-900', skeptical: 'from-orange-600 to-orange-900',
  methodology: 'from-blue-600 to-blue-900', overview: 'from-amber-600 to-amber-900',
  remote_viewing: 'from-teal-600 to-teal-900', mediumship: 'from-indigo-600 to-indigo-900',
  nonverbal: 'from-pink-600 to-pink-900', meta_analysis: 'from-yellow-600 to-yellow-900',
};
const domainIconMap: Record<string, string> = {
  telepathy: '🧠', psychokinesis: '🎲', nde: '✨', healing: '💚', precognition: '🔮',
  skeptical: '🔍', methodology: '🔬', overview: '📖', remote_viewing: '👁️',
  mediumship: '🕯️', nonverbal: '🤝', meta_analysis: '📊',
};
const thumbGradient = domainGradients[paper.psi_domain] || 'from-slate-600 to-slate-900';
const thumbIcon = domainIconMap[paper.psi_domain] || '📄';
const ogImageUrl = paperImages[paper.id]?.image || null;
const publisherUrl = paperImages[paper.id]?.publisherUrl || (paper.doi ? `https://doi.org/${paper.doi}` : null);

// Epistemic Status Logic
const isSkepticalFolder = paper.folder === '10_Skeptical_and_Critical';
const hasCritiques = relatedPapers.some(r => r.type === 'critiques');
const isCritiqued = relatedPapers.some(r => r.type === 'critiqued_by');
const hasReplications = relatedPapers.some(r => r.type === 'replicated_by');
const isReplicationOf = relatedPapers.some(r => r.type === 'replication_of');

let epistemicStatus = {
  label: 'Original study',
  icon: '📄',
  color: 'bg-slate-700/50 text-slate-400 border-slate-600/30'
};

if (hasCritiques || isCritiqued) {
  epistemicStatus = {
    label: 'Contested',
    icon: '⚡',
    color: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30'
  };
} else if (hasReplications) {
  epistemicStatus = {
    label: 'Has replications',
    icon: '✅',
    color: 'bg-green-500/20 text-green-400 border-green-500/30'
  };
} else if (isReplicationOf && isSkepticalFolder) {
  epistemicStatus = {
    label: 'Critical replication',
    icon: '🛡️',
    color: 'bg-red-500/20 text-red-400 border-red-500/30'
  };
} else if (isSkepticalFolder) {
  epistemicStatus = {
    label: 'Skeptical/Critical',
    icon: '🧐',
    color: 'bg-red-500/20 text-red-400 border-red-500/30'
  };
}

// Generate JSON-LD structured data
const jsonLdData = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  "name": paper.title,
  "author": (paper.authors || []).map((name: string) => ({
    "@type": "Person",
    "name": name
  })),
  "datePublished": String(paper.year || ""),
  "description": paper.abstract || "",
  ...(paper.journal ? { "isPartOf": { "@type": "Periodical", "name": paper.journal } } : {}),
  ...(paper.doi ? { "sameAs": `https://doi.org/${paper.doi}` } : {}),
  ...(paper.source_url ? { "url": paper.source_url } : {})
};
const jsonLd = JSON.stringify(jsonLdData);

// Citation Generation
const authorList = (paper.authors || []).join(', ');
const apaYear = paper.year ? `(${paper.year})` : '(n.d.)';
const apaDoi = paper.doi ? ` https://doi.org/${paper.doi}` : '';
const apaCitation = `${authorList} ${apaYear}. ${paper.title}. ${paper.journal || ''}.${apaDoi}`;

const bibtexAuthors = (paper.authors || []).join(' and ');
const bibtexCitation = `@article{${paper.id},
  title = {${paper.title}},
  author = {${bibtexAuthors}},
  year = {${paper.year || ''}},
  journal = {${paper.journal || ''}},${paper.doi ? `\n  doi = {${paper.doi}},` : ''}
}`;
---

<Layout title={paper.title} description={paper.abstract?.substring(0, 160) || 'Psi Research Paper'} jsonLd={jsonLd} ogImage={ogImageUrl}>
  <article class="max-w-4xl mx-auto px-4 py-8" data-paper-id={paper.id}>
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400 rounded">Home</a>
      <span class="mx-1">/</span>
      <a href="/catalog" class="hover:text-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-400 rounded">Catalog</a>
      <span class="mx-1">/</span>
      <span class="text-slate-300">{paper.title}</span>
    </nav>

    <!-- Paper Header -->
    <header class="mb-8">
      <div class="flex flex-col sm:flex-row sm:items-start gap-4 mb-2">
        {ogImageUrl ? (
          <div class="hidden sm:block flex-shrink-0 w-24 h-32 rounded-lg overflow-hidden shadow-lg border border-white/10 transform -rotate-2 hover:rotate-0 transition-transform">
            <img src={ogImageUrl} alt={`Cover image for ${paper.title}`} class="w-full h-full object-cover" loading="lazy" />
          </div>
        ) : (
          <div class={`hidden sm:flex flex-shrink-0 w-24 h-32 rounded-lg bg-gradient-to-br ${thumbGradient} items-center justify-center shadow-lg border border-white/10 transform -rotate-2 hover:rotate-0 transition-transform`}>
            <div class="text-center">
              <div class="text-3xl mb-1">{thumbIcon}</div>
              <div class="text-[9px] text-white/70 px-2 truncate max-w-[5rem]">{paper.journal || ''}</div>
              <div class="text-sm font-bold text-white/90 mt-1">{paper.year}</div>
            </div>
          </div>
        )}
        <h1 class="text-3xl font-bold text-slate-100">{paper.title}</h1>
        {paper.source_url ? (
          <a 
            href={paper.source_url}
            target="_blank"
            rel="noopener noreferrer"
            title="View original source"
            class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium border whitespace-nowrap self-start sm:self-center hover:opacity-80 transition-opacity cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-400 ${epistemicStatus.color}`}
          >
            <span>{epistemicStatus.icon}</span>
            <span>{epistemicStatus.label}</span>
            <span class="text-[10px] opacity-60">↗</span>
          </a>
        ) : (
          <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium border whitespace-nowrap self-start sm:self-center ${epistemicStatus.color}`}>
            <span>{epistemicStatus.icon}</span>
            <span>{epistemicStatus.label}</span>
          </span>
        )}
      </div>
      
      <!-- Copy Link Button -->
      <div class="flex gap-2 mb-4">
        <button id="copy-url" class="text-xs bg-slate-800 text-slate-400 px-3 py-1.5 rounded hover:bg-slate-700 hover:text-amber-400 transition focus:outline-none focus:ring-2 focus:ring-amber-400" aria-label="Copy page link">
          Copy Link
        </button>
      </div>

      <div class="flex flex-wrap items-center gap-3 text-slate-400">
        <span class="text-amber-400">{paper.authors?.join(', ')}</span>
        {paper.year && (
          <>
            <span>•</span>
            <span>{paper.year}</span>
            {eraBadge && (
              <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${eraBadge.color}`}>
                {eraBadge.text}
              </span>
            )}
          </>
        )}
        {paper.psi_domain && (
          <>
            <span>•</span>
            <span class="px-2 py-0.5 rounded-full text-xs bg-amber-400/20 text-amber-400 border border-amber-400/30">
              {paper.psi_domain}
            </span>
          </>
        )}
      </div>

      <!-- Social Sharing -->
      <div class="flex items-center gap-4 mt-5 pt-4 border-t border-slate-800/50">
        <span class="text-xs text-slate-500 font-medium uppercase tracking-wider">Share</span>
        <div class="flex gap-4">
          <!-- Share on X -->
          <button 
            id="share-twitter" 
            class="flex items-center gap-1.5 text-xs text-slate-500 hover:text-amber-400 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400 rounded"
            aria-label="Share on X"
            data-title={paper.title}
            data-year={paper.year || ''}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
            <span>Share on X</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Context Badges (Controversies & Reading Paths) -->
    {(foundControversies.length > 0 || foundPaths.length > 0) && (
      <section class="mb-8">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">📌 Appears in:</h2>
        <div class="flex flex-wrap gap-2">
          {foundControversies.map(c => (
            <a 
              href={c.path} 
              class="px-2.5 py-1 rounded-full text-xs font-medium bg-amber-500/20 text-amber-400 border border-amber-500/30 hover:bg-amber-500/30 transition flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              <span>⚡</span> {c.name}
            </a>
          ))}
          {foundPaths.map(p => (
            <a 
              href={p.path} 
              class="px-2.5 py-1 rounded-full text-xs font-medium bg-blue-500/20 text-blue-400 border border-blue-500/30 hover:bg-blue-500/30 transition flex items-center gap-1 focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              <span>📖</span> {p.name}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Methodology Indicators -->
    {(paper.pre_registered !== undefined || paper.effect_size !== undefined || paper.blinding) && (
      <>
        <section class="mb-8 p-4 rounded-lg bg-slate-900 border border-slate-800">
          <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">Methodology</h2>
          <div class="flex flex-wrap gap-4">
            <!-- Pre-registration -->
            {paper.pre_registered !== undefined && (
              <div class="flex items-center gap-2">
                {paper.pre_registered ? (
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                ) : (
                  <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                <span class="text-slate-300 text-sm">
                  Pre-registered: <span class={paper.pre_registered ? 'text-green-400' : 'text-slate-500'}>
                    {paper.pre_registered ? 'Yes' : 'No'}
                  </span>
                </span>
              </div>
            )}

            <!-- Effect Size -->
            {typeof paper.effect_size === 'number' && (
              <div class="flex items-center gap-2">
                <span class="text-slate-300 text-sm">Effect Size:</span>
                <div class="flex items-center gap-2">
                  <div class="w-16 h-2 rounded-full bg-slate-700 overflow-hidden">
                    <div 
                      class={`h-full ${getEffectSizeColor(paper.effect_size)}`} 
                      style={`width: ${Math.min(Math.abs(paper.effect_size) * 100, 100)}%`}
                    ></div>
                  </div>
                  <span class="text-slate-300 text-sm font-mono">{paper.effect_size.toFixed(2)}</span>
                </div>
              </div>
            )}

            <!-- Blinding -->
            {paper.blinding && (() => {
              const badge = getBlindingBadge(paper.blinding);
              if (!badge) return null;
              return (
                <span class={`px-2 py-0.5 rounded text-xs border ${badge.color}`}>
                  {badge.text}
                </span>
              );
            })()}
          </div>
        </section>

        <div class="bg-amber-500/5 border border-amber-500/20 rounded-lg p-3 mb-6 text-sm">
          <p class="text-slate-400">
            <span class="text-amber-400 font-medium">⚠️ Data note:</span> 
            Methodology fields were AI-extracted and may contain errors. 
            <a href="/method" class="text-amber-400 hover:underline focus:outline-none focus:ring-2 focus:ring-amber-400 rounded">Read about our extraction process</a> 
            and verify against the source paper.
          </p>
        </div>
      </>
    )}

    <!-- Curator's Notes -->
    {paper.notes && (
      <section class="mb-8">
        <h2 class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">Research Notes</h2>
        <div class="border-l-4 border-blue-500/30 pl-5 bg-slate-900/30 rounded-r-lg py-4">
          <p class="text-base leading-relaxed text-slate-300">{paper.notes}</p>
        </div>
      </section>
    )}

    <!-- Abstract -->
    {paper.abstract && (
      <section class="mb-8">
        <h2 class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">Abstract</h2>
        <div class="border-l-4 border-amber-500/30 pl-5 bg-slate-900/30 rounded-r-lg py-4">
          <p class="text-base leading-relaxed text-slate-300">{paper.abstract}</p>
        </div>
      </section>
    )}

    <!-- Links -->
    {(paper.doi || paper.url || paper.pdf_url) && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Links</h2>
        <div class="flex flex-wrap gap-3">
          {paper.doi && (
            <a 
              href={`https://doi.org/${paper.doi}`} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-amber-400/20 text-amber-400 border border-amber-400/30 hover:bg-amber-400/30 transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              DOI: {paper.doi}
            </a>
          )}
          {paper.url && (
            <a 
              href={paper.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:bg-slate-700 transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              Publisher Page
            </a>
          )}
          {paper.pdf_url && (
            <a 
              href={paper.pdf_url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:bg-slate-700 transition-colors text-sm focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              PDF
            </a>
          )}
        </div>
      </section>
    )}

    <!-- Related Papers (Explicit) -->
    {Object.keys(groupedRelated).length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">Related Papers</h2>
        <div class="space-y-6">
          {Object.entries(groupedRelated).map(([relType, papers]) => (
            <div key={relType} class={`p-4 rounded-lg border ${getRelationColor(relType)}`}>
              <h3 class="text-sm font-semibold mb-3 uppercase tracking-wide">
                {formatRelationLabel(relType)}
              </h3>
              <ul class="space-y-2">
                {papers.map((relatedPaper: any) => (
                  <li key={relatedPaper.id}>
                    <a 
                      href={`/paper/${relatedPaper.id}`}
                      class="block text-amber-400 hover:text-amber-300 hover:underline transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400 rounded"
                    >
                      <span class="font-medium">{relatedPaper.title}</span>
                      <span class="text-slate-500 text-sm"> — {relatedPaper.authors?.[0] || 'Unknown'} ({relatedPaper.year || 'n.d.'})</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Papers by Same Authors -->
    {sharedAuthorPapers.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">
          Also by these authors
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {sharedAuthorPapers.map((p: any) => (
            <a 
              href={`/paper/${p.id}`}
              class="block p-3 rounded-lg border border-slate-800/50 bg-slate-900/50 hover:border-amber-400/50 hover:bg-slate-800 transition-colors group focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              <h3 class="text-slate-200 font-medium group-hover:text-amber-400 transition-colors line-clamp-2 mb-1">
                {p.title}
              </h3>
              <div class="text-xs text-slate-500">
                {p.authors?.[0] || 'Unknown'} • {p.year || 'n.d.'}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Papers in Same Domain -->
    {sameDomainOthers.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">
          More in {formatDomainName(paper.psi_domain)}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {sameDomainOthers.map((p: any) => (
            <a 
              href={`/paper/${p.id}`}
              class="block p-3 rounded-lg border border-slate-800/50 bg-slate-900/50 hover:border-amber-400/50 hover:bg-slate-800 transition-colors group focus:outline-none focus:ring-2 focus:ring-amber-400"
            >
              <h3 class="text-slate-200 font-medium group-hover:text-amber-400 transition-colors line-clamp-2 mb-1">
                {p.title}
              </h3>
              <div class="text-xs text-slate-500">
                {p.authors?.[0] || 'Unknown'} • {p.year || 'n.d.'}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Cite this paper -->
    <details class="mb-8 bg-slate-900 border border-slate-800 rounded-lg">
      <summary class="px-4 py-3 cursor-pointer text-sm text-slate-400 hover:text-amber-400 transition focus:outline-none focus:ring-2 focus:ring-amber-400 rounded-t-lg">
        📋 Cite this paper
      </summary>
      <div class="px-4 pb-4 space-y-4">
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="text-xs text-slate-500 font-medium">APA</span>
            <button class="copy-btn text-xs text-amber-400 hover:text-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-400 rounded px-1" data-text={apaCitation} aria-label="Copy APA citation">Copy</button>
          </div>
          <pre class="text-xs text-slate-300 bg-slate-800 rounded p-3 whitespace-pre-wrap break-words">{apaCitation}</pre>
        </div>
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="text-xs text-slate-500 font-medium">BibTeX</span>
            <button class="copy-btn text-xs text-amber-400 hover:text-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-400 rounded px-1" data-text={bibtexCitation} aria-label="Copy BibTeX citation">Copy</button>
          </div>
          <pre class="text-xs text-slate-300 bg-slate-800 rounded p-3 whitespace-pre-wrap break-words">{bibtexCitation}</pre>
        </div>
      </div>
    </details>

    <!-- Mark as Read Button -->
    <div class="mb-8 flex justify-center">
      <button 
        id="mark-read-btn" 
        class="text-sm px-4 py-2 rounded-lg bg-slate-800 text-slate-400 border border-slate-700 hover:border-amber-500/30 hover:text-amber-400 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-400"
        aria-label="Mark paper as read"
      >
        Mark as Read
      </button>
    </div>

    <!-- Prev/Next Navigation -->
    {(prevPaper || nextPaper) && (
      <nav class="mt-12 pt-8 border-t border-slate-800">
        <div class="flex justify-between items-center">
          {prevPaper ? (
            <a 
              href={`/paper/${prevPaper.id}`}
              class="flex items-center gap-2 text-slate-400 hover:text-amber-400 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400 rounded p-2 -ml-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              <div class="text-left">
                <span class="text-xs text-slate-500 block">Previous in {paper.psi_domain || 'Domain'}</span>
                <span class="text-sm">{prevPaper.title}</span>
              </div>
            </a>
          ) : (
            <div></div>
          )}
          
          {nextPaper ? (
            <a 
              href={`/paper/${nextPaper.id}`}
              class="flex items-center gap-2 text-slate-400 hover:text-amber-400 transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400 rounded p-2 -mr-2"
            >
              <div class="text-right">
                <span class="text-xs text-slate-500 block">Next in {paper.psi_domain || 'Domain'}</span>
                <span class="text-sm">{nextPaper.title}</span>
              </div>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : (
            <div></div>
          )}
        </div>
      </nav>
    )}
  </article>

  <script>
    // Existing citation copy logic
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-text') || '';
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      });
    });

    const twitterBtn = document.getElementById('share-twitter');
    if (twitterBtn) {
      twitterBtn.addEventListener('click', () => {
        const url = encodeURIComponent(window.location.href);
        const title = twitterBtn.getAttribute('data-title') || 'Psi Research Paper';
        const year = twitterBtn.getAttribute('data-year') || '';
        const yearStr = year ? ` (${year})` : '';
        
        const text = encodeURIComponent(`📄 ${title}${yearStr} — from the Psi Research Library`);
        
        window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank', 'noopener,noreferrer');
      });
    }

    // Copy URL Button (New)
    document.getElementById('copy-url')?.addEventListener('click', async function() {
      await navigator.clipboard.writeText(window.location.href);
      this.textContent = 'Copied!';
      setTimeout(() => { this.textContent = 'Copy Link'; }, 2000);
    });

    // Mark as Read Logic
    const paperId = document.querySelector('[data-paper-id]')?.dataset.paperId;
    const btn = document.getElementById('mark-read-btn');
    const readPapers = JSON.parse(localStorage.getItem('psi-read-papers') || '[]');

    function updateBtn() {
      if (readPapers.includes(paperId)) {
        btn.textContent = '✓ Read';
        btn.className = 'text-sm px-4 py-2 rounded-lg bg-green-500/20 text-green-400 border border-green-500/30 cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-400';
      } else {
        btn.textContent = 'Mark as Read';
        btn.className = 'text-sm px-4 py-2 rounded-lg bg-slate-800 text-slate-400 border border-slate-700 hover:border-amber-500/30 hover:text-amber-400 transition cursor-pointer focus:outline-none focus:ring-2 focus:ring-amber-400';
      }
    }

    btn?.addEventListener('click', () => {
      const idx = readPapers.indexOf(paperId);
      if (idx >= 0) readPapers.splice(idx, 1);
      else readPapers.push(paperId);
      localStorage.setItem('psi-read-papers', JSON.stringify(readPapers));
      updateBtn();
    });

    updateBtn();
  </script>
</Layout>