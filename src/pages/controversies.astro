---
import Layout from '../layouts/Layout.astro';

const controversies = [
  { id: '01', title: 'Ganzfeld Telepathy', desc: 'The most-replicated psi paradigm — and its most persistent critiques' },
  { id: '02', title: "Bem's Feeling the Future", desc: 'Precognition in the lab: the study that shook psychology' },
  { id: '03', title: 'Presentiment', desc: 'Physiological anticipation of random future events' },
  { id: '04', title: 'Double-Slit PK', desc: 'Can consciousness influence quantum-level physical processes?' },
  { id: '05', title: 'Distant Healing & Prayer', desc: 'Intention-based healing at a distance: clinical evidence and critique' },
  { id: '06', title: 'Mediumship', desc: 'Can mediums access information about deceased persons?' },
  { id: '07', title: 'NDEs & Consciousness Survival', desc: 'Near-death experiences and the question of consciousness beyond the brain' },
  { id: '08', title: 'Global Consciousness Project', desc: 'Does collective attention create measurable order in random data?' },
  { id: '09', title: 'Facilitated Communication', desc: 'Who is really communicating? The authorship controversy' },
  { id: '10', title: 'The Meta-Analysis Debate', desc: 'Can you meta-analyze a contested phenomenon?' },
  { id: '11', title: 'Sense of Being Stared At', desc: "Sheldrake's claims about detecting unseen gazes" },
  { id: '12', title: 'Animal Telepathy', desc: 'Pets who know when their owners are coming home' },
  { id: '13', title: 'Telephone & Email Telepathy', desc: 'Knowing who is calling before you check' },
  { id: '14', title: 'Twin Connectedness', desc: 'Anomalous connections between twins at a distance' },
];
---

<Layout title="Controversies">
  <h1 class="text-3xl font-bold mb-2">Controversy Maps</h1>
  <p class="text-slate-400 mb-8">14 debates with papers cited on both sides. Every controversy shows the strongest arguments for and against.</p>
  
  <div class="grid md:grid-cols-2 gap-4">
    {controversies.map((c) => (
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition">
        <div class="flex items-start gap-3">
          <span class="text-amber-400 font-mono text-sm bg-amber-500/10 px-2 py-1 rounded">{c.id}</span>
          <div>
            <h3 class="font-bold text-slate-200 mb-1">{c.title}</h3>
            <p class="text-slate-400 text-sm">{c.desc}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
