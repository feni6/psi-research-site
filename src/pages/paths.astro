---
import Layout from '../layouts/Layout.astro';

const paths = [
  { id: 1, title: 'Steelman Psi', desc: 'The strongest case FOR psi phenomena — the best-designed studies with the most robust results', audience: 'Skeptics willing to engage', icon: '💪' },
  { id: 2, title: 'Weak Spots', desc: 'The strongest critiques, failed replications, and methodological problems — where the evidence fractures', audience: 'Believers willing to question', icon: '🔍' },
  { id: 3, title: 'Newcomer Survey', desc: 'A balanced introduction to the field — key studies from each domain with context from both sides', audience: 'Anyone new to psi research', icon: '🗺️' },
  { id: 4, title: 'Deep Dive: Remote Viewing', desc: 'From STAR GATE to modern replications — the full story of remote viewing research', audience: 'Domain specialists', icon: '👁️' },
  { id: 5, title: 'Deep Dive: Psychokinesis', desc: 'Mind over matter? RNG experiments, the PEAR lab legacy, and the replication question', audience: 'Domain specialists', icon: '🎲' },
  { id: 6, title: 'Deep Dive: NDEs & Consciousness', desc: 'Near-death experiences, the AWARE study, and what they tell us about consciousness', audience: 'Domain specialists', icon: '✨' },
];
---

<Layout title="Reading Paths">
  <h1 class="text-3xl font-bold mb-2">Guided Reading Paths</h1>
  <p class="text-slate-400 mb-8">Curated sequences through the evidence. Pick your starting point — each path shows you the strongest arguments on both sides.</p>
  
  <div class="grid md:grid-cols-2 gap-6">
    {paths.map((path) => (
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition">
        <div class="text-3xl mb-3">{path.icon}</div>
        <h3 class="text-xl font-bold text-amber-400 mb-2">Path {path.id}: {path.title}</h3>
        <p class="text-slate-300 mb-3">{path.desc}</p>
        <p class="text-slate-500 text-sm">Best for: {path.audience}</p>
      </div>
    ))}
  </div>
</Layout>
