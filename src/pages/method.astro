            <span class="count-up" data-target={topJournal?.count}>0</span> papers published
          </div>
        </div>

        <!-- Avg Effect Size -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-emerald-500/30 hover:shadow-lg hover:shadow-emerald-500/5 transition-all duration-300">
          <div class="text-xs text-slate-500 uppercase font-bold mb-1">Avg. Effect Size</div>
          <div class="text-lg font-medium text-slate-200">
            <span class="count-up" data-target={effectSizeStats?.avg} data-decimals="2">0</span>
          </div>
          <div class="text-sm text-emerald-400 mt-1">Across {effectSizeStats?.count} reported papers</div>
        </div>

        <!-- Most Connected -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-pink-500/30 hover:shadow-lg hover:shadow-pink-500/5 transition-all duration-300">
          <div class="text-xs text-slate-500 uppercase font-bold mb-1">Most Connected Paper</div>
          <div class="text-lg font-medium text-slate-200 truncate" title={mostConnected?.title}>{mostConnected?.title || 'No Data'}</div>
          <div class="text-sm text-pink-400 mt-1">
            <span class="count-up" data-target={mostConnected?._connectionCount}>0</span> direct relationships
          </div>
        </div>

        <!-- DOI Coverage -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-orange-500/30 hover:shadow-lg hover:shadow-orange-500/5 transition-all duration-300">
          <div class="text-xs text-slate-500 uppercase font-bold mb-1">DOI Coverage</div>
          <div class="text-lg font-medium text-slate-200">
            <span class="count-up" data-target={doiCount}>0</span>
          </div>
          <div class="text-sm text-orange-400 mt-1">{doiCount} papers have a DOI</div>
        </div>
      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- LEFT COLUMN (2/3 width on large screens) -->
      <div class="lg:col-span-2 space-y-8">
        
        <!-- Domain Distribution (Horizontal Bars) -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm animate-on-scroll opacity-0 translate-y-4">
          <h2 class="text-xl font-semibold text-slate-100 mb-6">Domain Distribution</h2>
          <div class="space-y-4">
            {domainStats.slice(0, 8).map((stat, index) => {
              const widthPercent = (stat.count / totalPapers) * 100;
              const colorClass = getDomainColor(stat.domain);
              
              return (
                <div class="group">
                  <div class="flex justify-between text-sm mb-1">
                    <span class="font-medium text-slate-300 group-hover:text-white transition-colors">{stat.domain}</span>
                    <span class="text-slate-400">
                      <span class="count-up" data-target={stat.count}>0</span> <span class="text-slate-600">({stat.percent})</span>
                    </span>
                  </div>
                  <div class="w-full bg-slate-800 rounded-full h-3 overflow-hidden">
                    <div class={`${colorClass.split(' ')[0]} h-3 rounded-full transition-all duration-1000 ease-out shadow-[0_0_10px_rgba(0,0,0,0.3)]`} style={`width: ${widthPercent}%`}></div>
                  </div>
                </div>
              );
            })}
            {domainStats.length > 8 && (
              <div class="text-center pt-2">
                <span class="text-xs text-slate-500">+ {domainStats.length - 8} other domains</span>
              </div>
            )}
          </div>
        </section>

        <!-- Publication Timeline (Visual Chart) -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm animate-on-scroll opacity-0 translate-y-4">
          <h2 class="text-xl font-semibold text-slate-100 mb-6">Publication Timeline (5-Year Bins)</h2>
          <div class="space-y-3">
            {allBins.filter(b => b.count > 0).map(bin => (
              <div class="flex items-center gap-4 group">
                <span class="text-xs text-slate-500 w-20 text-right font-mono group-hover:text-amber-400 transition-colors">{bin.label}</span>
                <div class="flex-1 bg-slate-800 rounded-full h-8 overflow-hidden relative">
                  <div class="bg-gradient-to-r from-amber-600 to-amber-400 h-full rounded-full transition-all duration-700 ease-out flex items-center justify-end pr-2" style={`width: ${(bin.count / maxBinCount) * 100}%`}>
                    <span class="text-[10px] font-bold text-slate-900 opacity-0 group-hover:opacity-100 transition-opacity">
                      <span class="count-up" data-target={bin.count}>0</span>
                    </span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Domain Comparison Table -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl overflow-hidden shadow-sm animate-on-scroll opacity-0 translate-y-4">
          <div class="p-6 border-b border-slate-800">
            <h2 class="text-xl font-semibold text-slate-100">Domain Comparison</h2>
            <p class="text-sm text-slate-400 mt-1">Detailed metrics per psi domain. <span class="text-amber-400">★</span> indicates highest values.</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full text-sm text-left" id="domain-comparison-table">
              <thead class="text-xs text-slate-400 uppercase bg-slate-950/50">
                <tr>
                  <th class="px-6 py-3 cursor-pointer hover:text-amber-400 transition-colors" data-sort="domain">Domain ↕</th>
                  <th class="px-6 py-3 text-right cursor-pointer hover:text-amber-400 transition-colors" data-sort="count">Paper Count ↕</th>
                  <th class="px-6 py-3 text-right cursor-pointer hover:text-amber-400 transition-colors" data-sort="preRegRate">Pre-Reg Rate ↕</th>
                  <th class="px-6 py-3 text-right cursor-pointer hover:text-amber-400 transition-colors" data-sort="avgYear">Avg. Year ↕</th>
                  <th class="px-6 py-3 text-right cursor-pointer hover:text-amber-400 transition-colors" data-sort="skepticalCount">Skeptical ↕</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-800" id="domain-comparison-body">
                {domainComparisonTable.map(stat => {
                  const isMaxCount = stat.count === maxPaperCount;
                  const isMaxPreReg = stat.preRegRate === maxPreRegRate;
                  
                  return (
                    <tr class="hover:bg-slate-800/50 transition-colors">
                      <td class="px-6 py-4 font-medium text-slate-200">{stat.domain}</td>
                      <td class={`px-6 py-4 text-right font-mono ${isMaxCount ? 'text-amber-400 font-bold' : 'text-slate-400'}`}>
                        <span class="count-up" data-target={stat.count}>0</span>
                        {isMaxCount && <span class="ml-2 text-xs align-top">★</span>}
                      </td>
                      <td class={`px-6 py-4 text-right font-mono ${isMaxPreReg ? 'text-amber-400 font-bold' : 'text-slate-400'}`}>
                        <span class="count-up" data-target={stat.preRegRate} data-suffix="%">0</span>%
                        {isMaxPreReg && <span class="ml-2 text-xs align-top">★</span>}
                      </td>
                      <td class="px-6 py-4 text-right text-slate-400 font-mono">
                        {stat.avgYear ? Math.round(stat.avgYear) : '—'}
                      </td>
                      <td class="px-6 py-4 text-right text-slate-400 font-mono">
                        <span class="count-up" data-target={stat.skepticalCount}>0</span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>

      </div>

      <!-- RIGHT COLUMN (1/3 width on large screens) -->
      <div class="space-y-8">
        
        <!-- Methodology Quality -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm animate-on-scroll opacity-0 translate-y-4">
          <div class="flex justify-between items-center mb-6">
            <h2 class="text-xl font-semibold text-slate-100">Methodology Rigor</h2>
            <div class={`px-3 py-1 rounded-full border text-sm font-bold ${qualityBg} ${qualityColor}`}>
              Grade: {qualityGrade}
            </div>
          </div>
          
          <div class="space-y-6">
            <!-- Pre-registration -->
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300 font-medium">Pre-Registered</span>
                <span class="text-emerald-400 font-mono">
                  <span class="count-up" data-target={(preRegTrue / totalPapers) * 100} data-suffix="%">0</span>%
                </span>
              </div>
              <div class="w-full bg-slate-800 rounded-full h-3">
                <div class="bg-emerald-500 h-3 rounded-full shadow-[0_0_10px_rgba(16,185,129,0.4)]" style={`width: ${formatPercent(preRegTrue, totalPapers)}`}></div>
              </div>
              <div class="flex justify-between text-xs text-slate-500 mt-1">
                <span>{preRegTrue} Yes</span>
                <span>{preRegFalse} No</span>
              </div>
            </div>

            <!-- Double Blind -->
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300 font-medium">Double-Blind</span>
                <span class="text-blue-400 font-mono">
                  <span class="count-up" data-target={(blindDouble / totalPapers) * 100} data-suffix="%">0</span>%
                </span>
              </div>
              <div class="w-full bg-slate-800 rounded-full h-3">
                <div class="bg-blue-500 h-3 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.4)]" style={`width: ${formatPercent(blindDouble, totalPapers)}`}></div>
              </div>
              <div class="flex justify-between text-xs text-slate-500 mt-1">
                <span>{blindDouble} DB</span>
                <span>{blindSingle} SB</span>
                <span>{blindNone} None</span>
              </div>
            </div>

            <!-- DOI Coverage -->
            <div>
              <div class="flex justify-between text-sm mb-2">
                <span class="text-slate-300 font-medium">Has DOI</span>
                <span class="text-amber-400 font-mono">
                  <span class="count-up" data-target={(doiCount / totalPapers) * 100} data-suffix="%">0</span>%
                </span>
              </div>
              <div class="w-full bg-slate-800 rounded-full h-3">
                <div class="bg-amber-500 h-3 rounded-full shadow-[0_0_10px_rgba(245,158,11,0.4)]" style={`width: ${formatPercent(doiCount, totalPapers)}`}></div>
              </div>
            </div>
          </div>

          <!-- Effect Size Stats -->
          {effectSizeStats && (
            <div class="mt-8 pt-6 border-t border-slate-800">
              <h3 class="text-sm font-medium text-slate-300 mb-3">Effect Sizes (n={effectSizeStats.count})</h3>
              <div class="grid grid-cols-3 gap-2">
                <div class="bg-slate-950 rounded-lg p-3 text-center border border-slate-800">
                  <div class="text-[10px] text-slate-500 uppercase">Min</div>
                  <div class="text-amber-400 font-mono font-bold">
                    <span class="count-up" data-target={effectSizeStats.min} data-decimals="2">0</span>
                  </div>
                </div>
                <div class="bg-slate-950 rounded-lg p-3 text-center border border-slate-800">
                  <div class="text-[10px] text-slate-500 uppercase">Median</div>
                  <div class="text-amber-400 font-mono font-bold">
                    <span class="count-up" data-target={effectSizeStats.median} data-decimals="2">0</span>
                  </div>
                </div>
                <div class="bg-slate-950 rounded-lg p-3 text-center border border-slate-800">
                  <div class="text-[10px] text-slate-500 uppercase">Max</div>
                  <div class="text-amber-400 font-mono font-bold">
                    <span class="count-up" data-target={effectSizeStats.max} data-decimals="2">0</span>
                  </div>
                </div>
              </div>
            </div>
          )}
        </section>

        <!-- Sample Size Analysis -->
        <section class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm animate-on-scroll opacity-0 translate-y-4">
          <h2 class="text-xl font-semibold text-slate-100 mb-4">Sample Size Analysis</h2>
          
          {overallSampleStats && (
            <div class="mb-6 bg-slate-950 rounded-lg p-4 border border-slate-800">
              <div class="text-xs text-slate-500 uppercase mb-1">Overall Median N</div>
              <div class="text-2xl font-bold text-slate-200">
                <span class="count-up" data-target={overallSampleStats.medianRaw}>0</span>
              </div>
              <div class="text-xs text-slate-500 mt-1">Range: {overallSampleStats.min} – {overallSampleStats.max}</div>
            </div>
          )}

          <div class="space-y-3">
            <h3 class="text-xs font-semibold text-slate-400 uppercase tracking-wider">By Domain (Median N)</h3>
            {domainSampleTable.slice(0, 5).map(stat => (
              <div class="flex justify-between items-center text-sm py-2 border-b border-slate-800 last:border-0">
                <span class="text-slate-300 truncate pr-2">{stat.domain}</span>
                <span class="font-mono text-amber-400">
                  <span class="count-up" data-target={stat.medianRaw}>0</span>
                </span>
              </div>
            ))}
          </div>
        </section>

        <!-- Skeptical Representation -->
        <div class="bg-gradient-to-br from-slate-800 to-slate-900 border border-slate-700 rounded-xl p-6 flex items-center justify-between shadow-lg animate-on-scroll opacity-0 translate-y-4">
          <div>
            <h3 class="text-lg font-medium text-slate-100">Skeptical Papers</h3>
            <p class="text-xs text-slate-400 mt-1">Critical analysis & replication failures</p>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-amber-400">
              <span class="count-up" data-target={skepticalCount}>0</span>
            </div>
            <div class="text-xs text-slate-500">{skepticalPercent}</div>
          </div>
        </div>

      </div>
    </div>

    <!-- Decade Histogram (Full Width Bottom) -->
    <section class="bg-slate-900 border border-slate-800 rounded-xl p-6 shadow-sm animate-on-scroll opacity-0 translate-y-4">
      <h2 class="text-xl font-semibold text-slate-100 mb-6">Publication Distribution by Decade</h2>
      <div class="overflow-x-auto">
        <div class="min-w-[600px] space-y-2 font-mono">
          {histogramData.map(item => (
            <div class="flex items-center gap-4">
              <span class="w-16 text-right text-slate-400 font-semibold">{item.decade}</span>
              <span class="w-10 text-right text-amber-400 font-bold">
                <span class="count-up" data-target={item.count}>0</span>
              </span>
              <span class="text-amber-500/80 text-lg tracking-widest">{item.bar}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>

  <script define:vars={{ csvData, domainComparisonTable }}>
    // CSV Download
    document.getElementById('download-csv')?.addEventListener('click', () => {
      const blob = new Blob([csvData], { type: 'text/csv' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'psi_research_catalog.csv';
      a.click();
      URL.revokeObjectURL(url);
    });

    // Sortable Table
    const table = document.getElementById('domain-comparison-table');
    const tbody = document.getElementById('domain-comparison-body');
    const headers = table.querySelectorAll('th[data-sort]');
    
    let currentSort = { column: 'count', direction: 'desc' };
    const tableData = JSON.parse(JSON.stringify(domainComparisonTable));

    headers.forEach(header => {
      header.addEventListener('click', () => {
        const column = header.dataset.sort;
        
        // Toggle direction if same column
        if (currentSort.column === column) {
          currentSort.direction = currentSort.direction === 'asc' ? 'desc' : 'asc';
        } else {
          currentSort.column = column;
          currentSort.direction = column === 'domain' ? 'asc' : 'desc';
        }

        // Sort data
        const sorted = [...tableData].sort((a, b) => {
          let valA = a[column];
          let valB = b[column];
          
          // Handle null/undefined
          if (valA === null || valA === undefined) valA = column === 'domain' ? '' : -Infinity;
          if (valB === null || valB === undefined) valB = column === 'domain' ? '' : -Infinity;
          
          if (typeof valA === 'string') {
            return currentSort.direction === 'asc' 
              ? valA.localeCompare(valB) 
              : valB.localeCompare(valA);
          }
          
          return currentSort.direction === 'asc' 
            ? valA - valB 
            : valB - valA;
        });

        // Re-render rows
        tbody.innerHTML = sorted.map(stat => {
          const isMaxCount = stat.count === Math.max(...tableData.map(d => d.count));
          const isMaxPreReg = stat.preRegRate === Math.max(...tableData.map(d => d.preRegRate));
          
          return `
            <tr class="hover:bg-slate-800/50 transition-colors">
              <td class="px-6 py-4 font-medium text-slate-200">${stat.domain}</td>
              <td class="px-6 py-4 text-right font-mono ${isMaxCount ? 'text-amber-400 font-bold' : 'text-slate-400'}">
                ${stat.count}${isMaxCount ? '<span class="ml-2 text-xs align-top">★</span>' : ''}
              </td>
              <td class="px-6 py-4 text-right font-mono ${isMaxPreReg ? 'text-amber-400 font-bold' : 'text-slate-400'}">
                ${stat.preRegRate.toFixed(1)}%${isMaxPreReg ? '<span class="ml-2 text-xs align-top">★</span>' : ''}
              </td>
              <td class="px-6 py-4 text-right text-slate-400 font-mono">
                ${stat.avgYear ? Math.round(stat.avgYear) : '—'}
              </td>
              <td class="px-6 py-4 text-right text-slate-400 font-mono">
                ${stat.skepticalCount}
              </td>
            </tr>
          `;
        }).join('');

        // Update header indicators
        headers.forEach(h => {
          h.textContent = h.textContent.replace(/[↕▲▼]/g, '').trim() + ' ↕';
        });
        header.textContent = header.textContent.replace(/[↕▲▼]/g, '').trim() + (currentSort.direction === 'asc' ? ' ▲' : ' ▼');
      });
    });

    // --- Scroll Animations & Number Counters ---

    // 1. Fade-in Animation Observer
    const fadeObserverOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const fadeObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.remove('opacity-0', 'translate-y-4');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          observer.unobserve(entry.target);
        }
      });
    }, fadeObserverOptions);

    document.querySelectorAll('.animate-on-scroll').forEach((el) => {
      fadeObserver.observe(el);
    });

    // 2. Number Counter Animation
    const animateValue = (el, start, end, duration, decimals, suffix) => {
      let startTimestamp = null;
      const step = (timestamp) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        
        // Ease out cubic
        const easeProgress = 1 - Math.pow(1 - progress, 3);
        
        const currentVal = start + (end - start) * easeProgress;
        
        let formatted;
        if (decimals > 0) {
          formatted = currentVal.toFixed(decimals);
        } else {
          formatted = Math.round(currentVal).toLocaleString();
        }
        
        el.innerHTML = formatted + suffix;
        
        if (progress < 1) {
          window.requestAnimationFrame(step);
        }
      };
      window.requestAnimationFrame(step);
    };

    const countObserverOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.5 // Trigger when 50% visible
    };

    const countObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseFloat(el.dataset.target);
          const suffix = el.dataset.suffix || '';
          const decimals = parseInt(el.dataset.decimals) || 0;
          
          if (!isNaN(target)) {
            animateValue(el, 0, target, 1500, decimals, suffix);
          }
          
          observer.unobserve(el);
        }
      });
    }, countObserverOptions);

    document.querySelectorAll('.count-up').forEach((el) => {
      countObserver.observe(el);
    });

  </script>
</Layout>