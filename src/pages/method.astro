import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// --- Helper Functions ---

const safeNumber = (val) => {
  if (typeof val === 'number') return val;
  if (typeof val === 'string') {
    const parsed = parseFloat(val);
    return isNaN(parsed) ? null : parsed;
  }
  return null;
};

const getMedian = (arr) => {
  if (!arr || arr.length === 0) return null;
  const sorted = [...arr].sort((a, b) => a - b);
  const mid = Math.floor(sorted.length / 2);
  return sorted.length % 2 !== 0 ? sorted[mid] : (sorted[mid - 1] + sorted[mid]) / 2;
};

const formatPercent = (count, total) => {
  if (total === 0) return '0%';
  return ((count / total) * 100).toFixed(1) + '%';
};

// --- CSV Generation ---

const escapeCsv = (field) => {
  if (field === null || field === undefined) return '';
  const str = String(field);
  if (str.includes(',') || str.includes('"') || str.includes('\n') || str.includes('\r')) {
    return `"${str.replace(/"/g, '""')}"`;
  }
  return str;
};

const csvHeaders = [
  'id', 'title', 'first_author', 'year', 'journal', 'psi_domain', 'folder', 'doi',
  'sample_size', 'effect_size', 'blinding', 'pre_registration'
];

const csvRows = catalog.papers.map(p => {
  const m = p.methodology || {};
  // Fallback for first_author if not explicitly defined, take first of authors array
  const firstAuthor = p.first_author || (p.authors && p.authors.length > 0 ? p.authors[0] : '');
  
  return [
    escapeCsv(p.id),
    escapeCsv(p.title),
    escapeCsv(firstAuthor),
    escapeCsv(p.year),
    escapeCsv(p.journal),
    escapeCsv(p.psi_domain),
    escapeCsv(p.folder),
    escapeCsv(p.doi),
    escapeCsv(m.sample_size),
    escapeCsv(m.effect_size),
    escapeCsv(m.blinding),
    escapeCsv(m.pre_registration)
  ].join(',');
});

const csvData = [csvHeaders.join(','), ...csvRows].join('\n');

// --- Data Processing ---

const papers = catalog.papers;
const totalPapers = papers.length;

// 1. Overview Stats
const years = papers.map(p => p.year).filter(y => typeof y === 'number');
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const uniqueDomains = new Set(papers.map(p => p.psi_domain).filter(Boolean)).size;
const uniqueJournals = new Set(papers.map(p => p.journal).filter(Boolean)).size;

// 2. Domain Breakdown
const domainCounts = {};
papers.forEach(p => {
  const domain = p.psi_domain || 'Unknown';
  domainCounts[domain] = (domainCounts[domain] || 0) + 1;
});
const domainStats = Object.entries(domainCounts)
  .map(([domain, count]) => ({ domain, count, percent: formatPercent(count, totalPapers) }))
  .sort((a, b) => b.count - a.count);

// Top domain for insights
const topDomain = domainStats[0];

// 3. Methodology Quality
let preRegTrue = 0, preRegFalse = 0, preRegNull = 0;
let blindDouble = 0, blindSingle = 0, blindNone = 0, blindOther = 0;
let doiCount = 0;
const effectSizes = [];

papers.forEach(p => {
  const m = p.methodology || {};
  
  if (m.pre_registration === true) preRegTrue++;
  else if (m.pre_registration === false) preRegFalse++;
  else preRegNull++;

  const blindVal = String(m.blinding || '').toLowerCase();
  if (blindVal.includes('double')) blindDouble++;
  else if (blindVal.includes('single')) blindSingle++;
  else if (blindVal.includes('none') || blindVal === 'no' || blindVal === 'n/a') blindNone++;
  else blindOther++;

  if (p.doi) doiCount++;

  // FIX: Parse effect_size carefully from methodology
  const es = safeNumber(m.effect_size);
  if (es !== null) effectSizes.push(es);
});

const effectSizeStats = effectSizes.length > 0 ? {
  count: effectSizes.length,
  min: Math.min(...effectSizes).toFixed(2),
  median: getMedian(effectSizes).toFixed(2),
  max: Math.max(...effectSizes).toFixed(2),
  avg: (effectSizes.reduce((a, b) => a + b, 0) / effectSizes.length).toFixed(2)
} : null;

// 4. Sample Size Ranges
const sampleSizes = papers
  .map(p => safeNumber(p.methodology?.sample_size))
  .filter(n => n !== null);

const overallSampleStats = sampleSizes.length > 0 ? {
  count: sampleSizes.length,
  min: Math.min(...sampleSizes).toLocaleString(),
  median: Math.round(getMedian(sampleSizes)).toLocaleString(),
  medianRaw: Math.round(getMedian(sampleSizes)),
  max: Math.max(...sampleSizes).toLocaleString()
} : null;

// Sample Size per Domain
const domainSampleStats = {};
papers.forEach(p => {
  const domain = p.psi_domain || 'Unknown';
  const size = safeNumber(p.methodology?.sample_size);
  if (size !== null) {
    if (!domainSampleStats[domain]) domainSampleStats[domain] = [];
    domainSampleStats[domain].push(size);
  }
});

const domainSampleTable = Object.entries(domainSampleStats).map(([domain, sizes]) => ({
  domain,
  count: sizes.length,
  median: Math.round(getMedian(sizes)).toLocaleString(),
  medianRaw: Math.round(getMedian(sizes))
})).sort((a, b) => b.count - a.count);

// 5. Year Distribution (Decades)
const decadeCounts = {};
papers.forEach(p => {
  if (typeof p.year === 'number') {
    const decade = Math.floor(p.year / 10) * 10;
    decadeCounts[decade] = (decadeCounts[decade] || 0) + 1;
  }
});
const sortedDecades = Object.keys(decadeCounts).map(Number).sort((a, b) => a - b);
const maxDecadeCount = Math.max(...Object.values(decadeCounts));
const histogramData = sortedDecades.map(decade => ({
  decade: `${decade}s`,
  count: decadeCounts[decade],
  bar: '█'.repeat(Math.round((decadeCounts[decade] / maxDecadeCount) * 20))
}));

// 6. Skeptical Representation
const skepticalCount = papers.filter(p => p.folder === '10_Skeptical_and_Critical').length;
const skepticalPercent = formatPercent(skepticalCount, totalPapers);

// 7. Publication Timeline (5-Year Bins for Visual Chart)
const binSize = 5;
const yearBinCounts = {};
papers.forEach(p => {
  if (typeof p.year === 'number') {
    const binStart = Math.floor(p.year / binSize) * binSize;
    yearBinCounts[binStart] = (yearBinCounts[binStart] || 0) + 1;
  }
});

const allBins = [];
if (years.length > 0) {
  const startBin = Math.floor(minYear / binSize) * binSize;
  const endBin = Math.floor(maxYear / binSize) * binSize;
  
  for (let b = startBin; b <= endBin; b += binSize) {
    const count = yearBinCounts[b] || 0;
    if (count > 0) {
      allBins.push({
        label: `${b}-${b + binSize - 1}`,
        count: count
      });
    }
  }
}

const maxBinCount = allBins.length > 0 ? Math.max(...allBins.map(b => b.count)) : 1;

// --- Domain Comparison Stats ---

const domainComparisonData = {};

papers.forEach(p => {
  const domain = p.psi_domain || 'Unknown';
  if (!domainComparisonData[domain]) {
    domainComparisonData[domain] = {
      count: 0,
      preRegTrue: 0,
      years: [],
      skepticalCount: 0
    };
  }

  const data = domainComparisonData[domain];
  data.count++;

  const m = p.methodology || {};
  if (m.pre_registration === true) {
    data.preRegTrue++;
  }

  if (typeof p.year === 'number') {
    data.years.push(p.year);
  }

  if (p.folder === '10_Skeptical_and_Critical') {
    data.skepticalCount++;
  }
});

const domainComparisonTable = Object.entries(domainComparisonData).map(([domain, data]) => {
  const preRegRate = data.count > 0 ? (data.preRegTrue / data.count) * 100 : 0;
  const avgYear = data.years.length > 0 
    ? data.years.reduce((a, b) => a + b, 0) / data.years.length 
    : null;

  return {
    domain,
    count: data.count,
    preRegRate,
    avgYear,
    skepticalCount: data.skepticalCount
  };
}).sort((a, b) => b.count - a.count);

// Find max values for highlighting
const maxPaperCount = Math.max(...domainComparisonTable.map(d => d.count));
const maxPreRegRate = Math.max(...domainComparisonTable.map(d => d.preRegRate));

// --- Key Insights Calculations ---

// Pre-registration percentage
const preRegPercent = formatPercent(preRegTrue, totalPapers);

// Publication rate increase (compare last 5 years to first 5 years)
const papersByYear = {};
papers.forEach(p => {
  if (typeof p.year === 'number') {
    papersByYear[p.year] = (papersByYear[p.year] || 0) + 1;
  }
});

const earlyYears = years.filter(y => y >= minYear && y < minYear + 5);
const lateYears = years.filter(y => y > maxYear - 5 && y <= maxYear);

const earlyCount = earlyYears.reduce((sum, y) => sum + (papersByYear[y] || 0), 0);
const lateCount = lateYears.reduce((sum, y) => sum + (papersByYear[y] || 0), 0);

const growthFactor = earlyCount > 0 ? (lateCount / earlyCount).toFixed(1) : 'N/A';

// Most published domain
const mostPublishedDomain = domainStats[0]?.domain || 'Unknown';
const mostPublishedCount = domainStats[0]?.count || 0;

// --- NEW: Fun Facts & Advanced Stats (FIXED) ---

// 1. Unique Authors & Most Prolific (FIXED: Use p.authors array, normalize names)
const normalizeAuthorName = (name) => {
  return name.replace(/, ([A-Za-z])\s+[A-Za-z]\.?$/, ', $1').trim();
};
const authorCounts = {};
papers.forEach(p => {
  if (p.authors && Array.isArray(p.authors)) {
    p.authors.forEach(author => {
      if (author) {
        const normalized = normalizeAuthorName(author);
        authorCounts[normalized] = (authorCounts[normalized] || 0) + 1;
      }
    });
  }
});
const uniqueAuthors = Object.keys(authorCounts).length;
const sortedAuthors = Object.entries(authorCounts).sort((a, b) => b[1] - a[1]);
const topAuthor = sortedAuthors[0] ? { name: sortedAuthors[0][0], count: sortedAuthors[0][1] } : null;

// 2. Most Used Journal (FIXED: Ensure p.journal is used)
const journalCounts = {};
papers.forEach(p => {
  if (p.journal) {
    journalCounts[p.journal] = (journalCounts[p.journal] || 0) + 1;
  }
});
const sortedJournals = Object.entries(journalCounts).sort((a, b) => b[1] - a[1]);
const topJournal = sortedJournals[0] ? { name: sortedJournals[0][0], count: sortedJournals[0][1] } : null;

// 3. Oldest Paper
const oldestPaper = papers
  .filter(p => typeof p.year === 'number')
  .sort((a, b) => a.year - b.year)[0];

// 4. Most Connected Paper (FIXED: Count entries in p.related_papers object arrays)
const papersWithConnections = papers.map(p => {
  let connectionCount = 0;
  if (p.related_papers && typeof p.related_papers === 'object') {
    // Sum lengths of all arrays in the related_papers object
    connectionCount = Object.values(p.related_papers).reduce((sum, arr) => {
      return sum + (Array.isArray(arr) ? arr.length : 0);
    }, 0);
  }
  return { ...p, _connectionCount: connectionCount };
});

const mostConnected = papersWithConnections
  .sort((a, b) => b._connectionCount - a._connectionCount)[0];

// --- NEW: Methodology Quality Score Calculation ---
const preRegScore = (preRegTrue / totalPapers) * 100;
const blindScore = (blindDouble / totalPapers) * 100;
const qualityScore = Math.round((preRegScore * 0.5) + (blindScore * 0.5));

let qualityGrade = 'F';
let qualityColor = 'text-red-500';
let qualityBg = 'bg-red-500/10 border-red-500/20';

if (qualityScore >= 90) { qualityGrade = 'A+'; qualityColor = 'text-emerald-400'; qualityBg = 'bg-emerald-500/10 border-emerald-500/20'; }
else if (qualityScore >= 80) { qualityGrade = 'A'; qualityColor = 'text-emerald-400'; qualityBg = 'bg-emerald-500/10 border-emerald-500/20'; }
else if (qualityScore >= 70) { qualityGrade = 'B+'; qualityColor = 'text-blue-400'; qualityBg = 'bg-blue-500/10 border-blue-500/20'; }
else if (qualityScore >= 60) { qualityGrade = 'B'; qualityColor = 'text-blue-400'; qualityBg = 'bg-blue-500/10 border-blue-500/20'; }
else if (qualityScore >= 50) { qualityGrade = 'C'; qualityColor = 'text-amber-400'; qualityBg = 'bg-amber-500/10 border-amber-500/20'; }
else if (qualityScore >= 40) { qualityGrade = 'D'; qualityColor = 'text-orange-400'; qualityBg = 'bg-orange-500/10 border-orange-500/20'; }

// Helper for domain colors
const getDomainColor = (domain) => {
  const d = domain.toLowerCase();
  if (d.includes('telepathy')) return 'bg-purple-500 shadow-purple-500/20';
  if (d.includes('psychokinesis') || d.includes('pk')) return 'bg-red-500 shadow-red-500/20';
  if (d.includes('nde') || d.includes('obe')) return 'bg-cyan-500 shadow-cyan-500/20';
  if (d.includes('precog') || d.includes('presentiment')) return 'bg-pink-500 shadow-pink-500/20';
  if (d.includes('remote viewing') || d.includes('rv')) return 'bg-emerald-500 shadow-emerald-500/20';
  if (d.includes('healing')) return 'bg-teal-500 shadow-teal-500/20';
  return 'bg-amber-500 shadow-amber-500/20';
};

