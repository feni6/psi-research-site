---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Helper function to generate URL-safe author IDs
function generateAuthorId(name: string): string {
  return name.toLowerCase().replace(/[ ,.]+/g, '_').replace(/_+/g, '_').replace(/^_|_$/g, '');
}

// Helper function to normalize author names by stripping trailing single-letter initials
function normalizeAuthorName(name: string): string {
  // Remove trailing single-letter initials (with or without period) from the first name portion
  // e.g., "Radin, Dean I" or "Radin, Dean I." becomes "Radin, Dean"
  return name.replace(/, ([A-Za-z]+)\s+[A-Za-z]\.?$/, ', $1').trim();
}

// 1. Process Data
const authorMap: Record<string, { count: number, papers: any[] }> = {};

catalog.papers.forEach((p: any) => {
  (p.authors || []).forEach((author: string) => {
    const normalizedAuthor = normalizeAuthorName(author);
    if (!authorMap[normalizedAuthor]) authorMap[normalizedAuthor] = { count: 0, papers: [] };
    authorMap[normalizedAuthor].count++;
    authorMap[normalizedAuthor].papers.push({ 
      id: p.id, 
      title: p.title, 
      year: p.year
    });
  });
});

// Sort alphabetically for the main list
const authors = Object.entries(authorMap)
  .sort(([a], [b]) => a.localeCompare(b));

// Get top 20 for the highlight section
const topAuthors = [...authors].sort(([,a], [,b]) => b.count - a.count).slice(0, 20);

// Calculate max count for relative bar visualization
const maxPaperCount = Math.max(...authors.map(([, data]) => data.count));

// Group by first letter for the index navigation
const authorsByLetter: Record<string, typeof authors> = {};
const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");

alphabet.forEach(letter => {
  authorsByLetter[letter] = authors.filter(([name]) => name.toUpperCase().startsWith(letter));
});

// Generate unique letters that actually have authors for the jump nav
const activeLetters = alphabet.filter(l => authorsByLetter[l].length > 0);
---

<Layout title="Author Index" description="Browse researchers and authors in the Psi Research Library catalog.">
  <div class="max-w-5xl mx-auto px-4 py-8 space-y-12">
    
    <!-- Header & Breadcrumb -->
    <div class="space-y-4">
      <nav class="text-sm text-slate-400">
        <a href="/" class="hover:text-amber-400 transition-colors focus:ring-2 focus:ring-amber-400 focus:outline-none">Home</a>
        <span class="mx-2">/</span>
        <span class="text-amber-400 font-medium">Authors</span>
      </nav>
      <h1 class="text-4xl font-bold text-slate-100 tracking-tight">Author Index</h1>
      <p class="text-slate-400 max-w-2xl">
        Explore the contributors in our catalog. Click an author's name to view their specific papers.
      </p>
    </div>

    <!-- Search Bar -->
    <div class="relative">
      <input 
        type="text" 
        id="authorSearch"
        placeholder="Filter by author name..." 
        aria-label="Filter authors by name"
        class="w-full bg-slate-900 border border-slate-700 rounded-lg py-3 px-4 text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:border-amber-400 transition-all"
        oninput="filterAuthors()"
      />
      <div class="absolute right-3 top-3.5 text-slate-500 pointer-events-none">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 0114 0z" />
        </svg>
      </div>
    </div>

    <!-- Top Authors Section -->
    <section class="space-y-6">
      <div class="flex items-center space-x-2 border-b border-slate-800 pb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <h2 class="text-xl font-semibold text-slate-200">Most Published</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {topAuthors.map(([name, data]) => {
          const authorId = generateAuthorId(name);
          const percentage = (data.count / maxPaperCount) * 100;
          return (
            <a 
              href={`/author/${authorId}`}
              aria-label={`View papers by ${name}, ${data.count} papers`}
              class="bg-slate-900 border border-slate-800 rounded-lg p-4 hover:border-amber-400/50 hover:bg-slate-900/80 transition-all group block focus:ring-2 focus:ring-amber-400 focus:outline-none"
            >
              <div class="flex items-center justify-between mb-2">
                <div class="text-amber-400 text-2xl font-bold">{data.count}</div>
                <div class="text-xs text-slate-500 font-mono">papers</div>
              </div>
              <div class="text-slate-200 font-medium text-sm truncate mb-3 group-hover:text-amber-200 transition-colors">
                {name}
              </div>
              <div class="w-full bg-slate-800 rounded-full h-2 overflow-hidden">
                <div 
                  class="bg-gradient-to-r from-amber-500 to-amber-400 h-full rounded-full transition-all duration-500"
                  style={`width: ${percentage}%`}
                ></div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Alphabet Jump Links -->
    <nav class="flex flex-wrap gap-2 justify-center md:justify-start" role="navigation" aria-label="Alphabetical navigation">
      {activeLetters.map(letter => (
        <a 
          href={`#letter-${letter}`}
          class="w-8 h-8 flex items-center justify-center rounded bg-slate-900 border border-slate-800 text-slate-400 hover:bg-amber-400 hover:text-slate-950 hover:border-amber-400 transition-all font-mono text-sm font-bold focus:ring-2 focus:ring-amber-400 focus:outline-none"
        >
          {letter}
        </a>
      ))}
    </nav>

    <!-- Author Count Display -->
    <div class="flex items-center justify-between text-sm text-slate-400">
      <span id="author-count-display">Showing {Math.min(50, authors.length)} of {authors.length} authors</span>
    </div>

    <!-- Main Author List -->
    <section class="space-y-12" id="author-list-container">
      {alphabet.map(letter => {
        const letterAuthors = authorsByLetter[letter];
        if (letterAuthors.length === 0) return null;

        return (
          <div class="scroll-mt-24 author-letter-section" id={`letter-${letter}`}>
            <h3 class="text-2xl font-bold text-slate-500 mb-6 border-b border-slate-800 pb-2 font-mono">
              {letter}
            </h3>
            
            <div class="space-y-3">
              {letterAuthors.map(([name, data]) => {
                const authorId = generateAuthorId(name);
                const anchorId = `author-${name.toLowerCase().replace(/[^a-z0-9]/g, '-')}`;
                return (
                  <details class="author-card group bg-slate-900/50 border border-slate-800 rounded-lg overflow-hidden transition-all hover:border-slate-700" data-name={name.toLowerCase()}>
                    <summary class="p-4 flex items-center justify-between cursor-pointer list-none focus:ring-2 focus:ring-amber-400 focus:outline-none" id={anchorId}>
                      <div class="flex items-center space-x-4">
                        <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center text-slate-400 font-bold border border-slate-700 group-hover:border-amber-400/50 transition-colors">
                          {name.charAt(0)}
                        </div>
                        <div>
                          <h4 class="text-lg font-semibold">
                            <a href={`/author/${authorId}`} aria-label={`View papers by ${name}, ${data.count} papers`} class="text-slate-200 hover:text-amber-400 transition-colors focus:ring-2 focus:ring-amber-400 focus:outline-none">
                              {name}
                            </a>
                          </h4>
                          <p class="text-sm text-slate-500">{data.count} {data.count === 1 ? 'paper' : 'papers'} in catalog</p>
                        </div>
                      </div>
                      <div class="flex items-center space-x-2 text-amber-400">
                        <span class="text-sm font-medium hidden group-open:inline">Hide Papers</span>
                        <span class="text-sm font-medium group-open:hidden">Show Papers</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                      </div>
                    </summary>

                    <!-- Expandable Paper List -->
                    <div class="bg-slate-950 border-t border-slate-800/50">
                      <ul class="divide-y divide-slate-800/50" role="list">
                        {data.papers.sort((a, b) => b.year - a.year).map(paper => (
                          <li class="p-4 hover:bg-slate-900 transition-colors" role="listitem">
                            <div class="flex justify-between items-start gap-4">
                              <div>
                                <a href={`/paper/${paper.id}`} class="text-slate-300 hover:text-amber-400 font-medium transition-colors line-clamp-2 focus:ring-2 focus:ring-amber-400 focus:outline-none">
                                  {paper.title}
                                </a>
                              </div>
                              <span class="text-xs font-mono bg-slate-800 text-slate-400 px-2 py-1 rounded whitespace-nowrap">
                                {paper.year}
                              </span>
                            </div>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </details>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>

    <!-- Show More Button -->
    <div class="text-center pt-8" id="show-more-container">
      <button 
        id="show-more-btn"
        class="bg-slate-900 border border-slate-700 text-slate-300 px-6 py-3 rounded-lg hover:border-amber-400 hover:text-amber-400 transition-all focus:ring-2 focus:ring-amber-400 focus:outline-none"
        onclick="showMoreAuthors()"
      >
        Show More Authors
      </button>
    </div>

  </div>

  <script>
    let currentAuthorLimit = 50;
    const authorsPerPage = 50;
    let isSearchActive = false;

    // Initialize pagination on load
    function initPagination() {
      updateVisibleAuthors();
      updateShowMoreButton();
      updateCountDisplay();
    }

    // Update which authors are visible based on current limit
    function updateVisibleAuthors() {
      const container = document.getElementById('author-list-container');
      if (!container) return;

      const allCards = container.querySelectorAll('.author-card');
      const isSearching = document.getElementById('authorSearch')?.value?.trim().length > 0;

      allCards.forEach((card, index) => {
        if (isSearching) {
          // During search, show all matching results (pagination disabled)
          const isHiddenBySearch = card.classList.contains('hidden');
          if (!isHiddenBySearch) {
            card.classList.remove('pagination-hidden');
          }
        } else {
          // During normal browsing, apply pagination
          if (index < currentAuthorLimit) {
            card.classList.remove('pagination-hidden');
          } else {
            card.classList.add('pagination-hidden');
          }
        }
      });

      // Hide letter sections if all authors in that section are hidden
      const sections = container.querySelectorAll('.author-letter-section');
      sections.forEach(section => {
        const cardsInSection = section.querySelectorAll('.author-card');
        const visibleCards = section.querySelectorAll('.author-card:not(.hidden):not(.pagination-hidden)');
        if (visibleCards.length === 0 && cardsInSection.length > 0) {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
        }
      });
    }

    // Update the Show More button visibility
    function updateShowMoreButton() {
      const container = document.getElementById('author-list-container');
      const showMoreContainer = document.getElementById('show-more-container');
      const searchInput = document.getElementById('authorSearch') as HTMLInputElement;
      
      if (!container || !showMoreContainer) return;

      const allCards = container.querySelectorAll('.author-card');
      const isSearching = searchInput?.value?.trim().length > 0;

      // Hide button during search or if all authors are shown
      if (isSearching || currentAuthorLimit >= allCards.length) {
        showMoreContainer.classList.add('hidden');
      } else {
        showMoreContainer.classList.remove('hidden');
      }
    }

    // Update the count display
    function updateCountDisplay() {
      const container = document.getElementById('author-list-container');
      const countDisplay = document.getElementById('author-count-display');
      const searchInput = document.getElementById('authorSearch') as HTMLInputElement;
      
      if (!countDisplay) return;

      const allCards = container?.querySelectorAll('.author-card') || [];
      const totalAuthors = allCards.length;
      const isSearching = searchInput?.value?.trim().length > 0;

      if (isSearching) {
        const visibleCards = container?.querySelectorAll('.author-card:not(.hidden)') || [];
        countDisplay.textContent = `Showing ${visibleCards.length} of ${totalAuthors} authors`;
      } else {
        const shownCount = Math.min(currentAuthorLimit, totalAuthors);
        countDisplay.textContent = `Showing ${shownCount} of ${totalAuthors} authors`;
      }
    }

    // Show more authors function
    function showMoreAuthors() {
      currentAuthorLimit += authorsPerPage;
      updateVisibleAuthors();
      updateShowMoreButton();
      updateCountDisplay();
    }

    // Filter Authors by Search Input
    function filterAuthors() {
      const input = document.getElementById('authorSearch') as HTMLInputElement;
      if (!input) return;
      
      const filter = input.value.toLowerCase();
      const container = document.getElementById('author-list-container');
      if (!container) return;

      const cards = container.querySelectorAll('.author-card');
      let hasVisibleAuthors = false;

      cards.forEach(card => {
        const name = card.getAttribute('data-name') || '';
        if (name.includes(filter)) {
          card.classList.remove('hidden');
          hasVisibleAuthors = true;
        } else {
          card.classList.add('hidden');
        }
      });

      // Hide letter headers if no authors match in that section
      const sections = container.querySelectorAll('.author-letter-section');
      sections.forEach(section => {
        const visibleCards = section.querySelectorAll('.author-card:not(.hidden):not(.pagination-hidden)');
        if (visibleCards.length === 0) {
          section.classList.add('hidden');
        } else {
          section.classList.remove('hidden');
        }
      });

      // Update pagination state based on search
      updateShowMoreButton();
      updateCountDisplay();
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', initPagination);
  </script>
</Layout>