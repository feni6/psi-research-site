---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const pageTitle = "Site Guide";

// Site sections with descriptions
const siteSections = [
  {
    href: "/catalog",
    label: "Catalog",
    icon: "📚",
    description: "Browse all papers in the library"
  },
  {
    href: "/controversies",
    label: "Controversies",
    icon: "⚡",
    description: "Explore the active debates in psi research"
  },
  {
    href: "/stories",
    label: "Featured Experiments",
    icon: "🧪",
    description: "The most striking experiments in psi research, told as stories"
  },
  {
    href: "/timeline",
    label: "Timeline",
    icon: "📅",
    description: "Historical timeline of psi research from pre-modern to today"
  },
  {
    href: "/search",
    label: "Search",
    icon: "🔍",
    description: "Full-text search across all papers"
  },
  {
    href: "/replications",
    label: "Replications",
    icon: "🔄",
    description: "Track which studies have been replicated"
  },
  {
    href: "/stats",
    label: "Stats",
    icon: "📊",
    description: "Statistical overview of the library"
  },
  {
    href: "/trends",
    label: "Trends",
    icon: "📈",
    description: "See how research focus has shifted over decades"
  },
  {
    href: "/glossary",
    label: "Glossary",
    icon: "📖",
    description: "Key terms and definitions"
  },
  {
    href: "/network",
    label: "Network",
    icon: "🔗",
    description: "Visualize connections between papers"
  },
  {
    href: "/authors",
    label: "Authors",
    icon: "✍️",
    description: "Browse researchers and their publications"
  },
  {
    href: "/journals",
    label: "Journals",
    icon: "📰",
    description: "See which journals publish psi research"
  },
  {
    href: "/wishlist",
    label: "Wishlist",
    icon: "📝",
    description: "Papers we're still looking for"
  },
  {
    href: "/compare",
    label: "Compare",
    icon: "⚖️",
    description: "Side-by-side paper comparison tool"
  },
  {
    href: "/method",
    label: "Methodology",
    icon: "🔬",
    description: "How this library was built"
  },
  {
    href: "/about",
    label: "About",
    icon: "ℹ️",
    description: "Background on the project"
  },
  {
    href: "/paths",
    label: "Reading Paths",
    icon: "🛤️",
    description: "Curated guided tours through the literature"
  }
];
---

<Layout title={pageTitle}>
  <div class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Header & Hero -->
    <div class="mb-12">
      <Breadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Guide", href: "/guide" }
      ]} />
      
      <div class="mt-6 border-b border-slate-800 pb-10">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">
          Site <span class="text-amber-400">Guide</span>
        </h1>
        <p class="text-slate-400 text-lg leading-relaxed max-w-3xl">
          Navigate the Psi Research Library with ease. This guide helps visitors explore our comprehensive collection of psi research papers, tools, and resources.
        </p>
      </div>
    </div>

    <!-- Site Sections Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {siteSections.map((section) => (
        <a 
          href={section.href}
          class="group relative bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/40 hover:bg-slate-800/50 hover:shadow-2xl hover:shadow-amber-900/10 transition-all duration-300 flex flex-col h-full"
        >
          <div class="flex items-start gap-4 mb-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-lg bg-amber-500/10 flex items-center justify-center border border-amber-500/20 group-hover:bg-amber-500/20 transition-colors">
              <span class="text-2xl">{section.icon}</span>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-lg font-bold text-slate-200 group-hover:text-amber-400 transition-colors">
                {section.label}
              </h3>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed flex-grow">
            {section.description}
          </p>
          <div class="mt-4 flex items-center text-amber-400 text-sm font-medium opacity-0 group-hover:opacity-100 transition-opacity">
            <span>Explore</span>
            <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </div>
        </a>
      ))}
    </div>

    <!-- Quick Tips Section -->
    <div class="mt-16 bg-gradient-to-r from-slate-900 to-slate-900/50 border border-slate-800 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
        <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        Getting Started
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 text-amber-400 font-bold">
            1
          </div>
          <div>
            <h3 class="text-slate-200 font-semibold mb-1">Browse the Catalog</h3>
            <p class="text-slate-400 text-sm">Start by exploring our complete collection of psi research papers organized by topic and year.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 text-amber-400 font-bold">
            2
          </div>
          <div>
            <h3 class="text-slate-200 font-semibold mb-1">Follow Reading Paths</h3>
            <p class="text-slate-400 text-sm">Use our curated reading paths to build knowledge progressively on specific topics.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-amber-500/10 flex items-center justify-center border border-amber-500/20 text-amber-400 font-bold">
            3
          </div>
          <div>
            <h3 class="text-slate-200 font-semibold mb-1">Check the Timeline</h3>
            <p class="text-slate-400 text-sm">Understand the historical context of psi research from pre-modern times to today.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</Layout>