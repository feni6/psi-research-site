---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

const papers = catalog.papers.sort((a: any, b: any) => (b.year || 0) - (a.year || 0));
const domains = [...new Set(papers.map((p: any) => p.psi_domain).filter(Boolean))].sort();
const folders = [...new Set(papers.map((p: any) => p.folder).filter(Boolean))].sort();

// Get year range for filters
const years = papers.map((p: any) => p.year).filter(Boolean);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

// Helper to format folder names
function formatFolder(folder: string): string {
  return folder.replace(/^\d+_/, '').replace(/_/g, ' ');
}

// Helper to compute pre-registration status
function getPreRegStatus(paper: any): string {
  const prereg = paper.methodology?.pre_registration ?? paper.methodology?.pre_registered;
  if (prereg === null || prereg === undefined) return 'unknown';
  if (typeof prereg === 'boolean') return prereg ? 'true' : 'false';
  if (typeof prereg === 'string') {
    const lower = prereg.toLowerCase();
    if (lower === 'yes' || lower === 'true') return 'true';
    if (lower === 'no' || lower === 'false') return 'false';
  }
  return 'unknown';
}

// Helper to compute blinding status
function getBlindingStatus(paper: any): string {
  const blinding = paper.methodology?.blinding;
  if (!blinding) return 'unknown';
  const lower = blinding.toLowerCase();
  if (lower.includes('double')) return 'double';
  if (lower.includes('single')) return 'single';
  if (lower.includes('none') || lower.includes('not') || lower.includes('open')) return 'none';
  return 'unknown';
}

// Helper to compute DOI status
function getDoiStatus(paper: any): string {
  return paper.doi ? 'yes' : 'no';
}

// Helper to format authors
function formatAuthors(authors: string[]): string {
  if (!authors || authors.length === 0) return 'Unknown Author';
  if (authors.length === 1) return authors[0];
  if (authors.length === 2) return authors.join(' & ');
  return `${authors[0]} et al.`;
}

// Helper to compute epistemic status (Quality Indicator)
function getEpistemicStatus(paper: any): { label: string; color: string; title: string } {
  const prereg = getPreRegStatus(paper);
  const blinding = getBlindingStatus(paper);
  
  // Logic: Green if BOTH, Amber if ONE, Red if NEITHER
  const hasPrereg = prereg === 'true';
  const hasDoubleBlind = blinding === 'double';
  
  if (hasPrereg && hasDoubleBlind) {
    return { label: 'High Rigor', color: 'bg-emerald-500', title: 'Double-blind & Pre-registered' };
  } else if (hasPrereg || hasDoubleBlind) {
    return { label: 'Moderate', color: 'bg-amber-500', title: 'Pre-registered OR Double-blind' };
  } else {
    return { label: 'Low Rigor', color: 'bg-red-500', title: 'Open/Single-blind & Not Pre-registered' };
  }
}

// Helper to get domain border color
function getDomainColor(domain: string): string {
  const map: Record<string, string> = {
    'telepathy': 'border-purple-500',
    'psychokinesis': 'border-red-500',
    'precognition': 'border-violet-500',
    'remote_viewing': 'border-indigo-500',
    'healing': 'border-green-500',
    'nde': 'border-cyan-500',
    'skeptical': 'border-orange-500',
    'methodology': 'border-blue-500',
    'meta_analysis': 'border-pink-500',
    'history': 'border-amber-500',
  };
  return map[domain] || 'border-slate-600';
}

// Helper to get domain gradient
function getDomainGradient(d: string): string {
  const map: Record<string, string> = {
    'telepathy': 'from-purple-600 to-purple-800',
    'psychokinesis': 'from-red-600 to-red-800',
    'nde': 'from-cyan-600 to-cyan-800',
    'healing': 'from-green-600 to-green-800',
    'precognition': 'from-violet-600 to-violet-800',
    'skeptical': 'from-orange-600 to-orange-800',
    'methodology': 'from-blue-600 to-blue-800',
    'overview': 'from-amber-600 to-amber-800',
    'remote_viewing': 'from-teal-600 to-teal-800',
    'mediumship': 'from-indigo-600 to-indigo-800',
    'nonverbal': 'from-pink-600 to-pink-800',
    'meta_analysis': 'from-yellow-600 to-yellow-800',
  };
  return map[d] || 'from-slate-600 to-slate-800';
}

// Helper to get domain icon
function getDomainIcon(d: string): string {
  const map: Record<string, string> = {
    'telepathy': '🧠',
    'psychokinesis': '🎲',
    'nde': '✨',
    'healing': '💚',
    'precognition': '🔮',
    'skeptical': '🔍',
    'methodology': '🔬',
    'overview': '📖',
    'remote_viewing': '👁️',
    'mediumship': '🕯️',
    'nonverbal': '🤝',
    'meta_analysis': '📊',
  };
  return map[d] || '📄';
}
---

<Layout title="Catalog">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2 text-slate-100">Research Catalog</h1>
    <p class="text-slate-400 text-lg">Explore <span id="total-papers-count">{papers.length}</span> papers across {domains.length} domains of psi research</p>
  </div>

  <!-- Sentinel for sticky observer -->
  <div id="scroll-sentinel" class="h-0 absolute -top-1 left-0 w-full"></div>

  <!-- Filters (Sticky) -->
  <div id="filter-container" class="sticky top-0 z-20 bg-slate-950/95 backdrop-blur-md pb-4 pt-4 border-b border-slate-800 transition-shadow duration-300" role="search">
    <div class="flex flex-wrap gap-3 mb-4 items-center">
      <div class="relative flex-1 min-w-[200px]">
        <input 
          type="text" 
          id="search" 
          aria-label="Search papers by title, author, or abstract"
          placeholder="Search title, authors, abstract..." 
          class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-10 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none transition-all"
        />
        <svg class="w-4 h-4 text-slate-500 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      
      <div class="relative">
        <select id="domain-filter" aria-label="Filter by research domain" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition appearance-none pr-8">
          <option value="">All Domains</option>
          {domains.map((d: string) => (
            <option value={d}>{d.replace(/_/g, ' ')}</option>
          ))}
        </select>
        <!-- Custom Arrow for Domain Filter -->
        <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 flex items-center px-2 text-slate-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
      
      <div class="relative">
        <select id="folder-filter" aria-label="Filter by category folder" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition appearance-none pr-8">
          <option value="">All Categories</option>
          {folders.map((f: string) => (
            <option value={f}>{formatFolder(f)}</option>
          ))}
        </select>
        <!-- Custom Arrow for Folder Filter -->
        <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 flex items-center px-2 text-slate-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
      
      <div class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 focus-within:ring-2 focus-within:ring-amber-400 focus-within:border-amber-500 transition">
        <input 
          type="number" 
          id="year-min" 
          aria-label="Minimum publication year"
          placeholder="From" 
          min={minYear}
          max={maxYear}
          class="bg-transparent border-none text-sm w-16 text-slate-300 placeholder-slate-600 focus:ring-0 focus:outline-none"
        />
        <span class="text-slate-600">–</span>
        <input 
          type="number" 
          id="year-max" 
          aria-label="Maximum publication year"
          placeholder="To" 
          min={minYear}
          max={maxYear}
          class="bg-transparent border-none text-sm w-16 text-slate-300 placeholder-slate-600 focus:ring-0 focus:outline-none"
        />
      </div>
      
      <div class="h-6 w-px bg-slate-800 mx-1 hidden md:block"></div>

      <div class="relative">
        <select id="prereg-filter" aria-label="Filter by pre-registration status" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition appearance-none pr-8">
          <option value="">Pre-reg: Any</option>
          <option value="true">Pre-registered</option>
          <option value="false">Not Pre-registered</option>
        </select>
        <!-- Custom Arrow for Prereg Filter -->
        <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 flex items-center px-2 text-slate-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
      
      <div class="relative">
        <select id="blinding-filter" aria-label="Filter by blinding method" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition appearance-none pr-8">
          <option value="">Blinding: Any</option>
          <option value="double">Double-blind</option>
          <option value="single">Single-blind</option>
          <option value="none">Open/None</option>
          <option value="unknown">Not Reported</option>
        </select>
        <!-- Custom Arrow for Blinding Filter -->
        <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 flex items-center px-2 text-slate-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
      
      <label class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 cursor-pointer hover:border-amber-500/30 hover:text-amber-400 transition select-none focus-within:ring-2 focus-within:ring-amber-400 focus-within:border-amber-500">
        <input 
          type="checkbox" 
          id="doi-filter" 
          aria-label="Filter to show only papers with DOI"
          class="accent-amber-500 rounded focus:ring-2 focus:ring-amber-400"
        />
        <span>Has DOI</span>
      </label>
      
      <div class="relative">
        <select id="sort-filter" aria-label="Sort results" class="bg-slate-800 border border-amber-500/30 rounded-lg pl-4 pr-10 py-2.5 text-sm text-amber-100 font-medium focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:bg-slate-750 transition appearance-none">
          <option value="year-desc">Newest First</option>
          <option value="year-asc">Oldest First</option>
          <option value="title-asc">Title (A-Z)</option>
          <option value="title-desc">Title (Z-A)</option>
          <option value="domain">Domain</option>
          <option value="sample-size">By Sample Size</option>
        </select>
        <div class="pointer-events-none absolute right-3 top-3 text-amber-500">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </div>
      </div>
    </div>

    <!-- Active Filters & Results Count -->
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-2 text-sm text-slate-400">
        <span id="result-count">Showing 0 of {papers.length} papers</span>
        <button id="clear-filters" class="text-amber-400 hover:text-amber-300 underline decoration-amber-400/30 hover:decoration-amber-400 underline-offset-4 transition-all hidden">
          Clear all filters
        </button>
      </div>
      <div id="active-filters" class="flex flex-wrap gap-2"></div>
    </div>
  </div>

  <!-- Paper Grid -->
  <div id="paper-list" class="grid grid-cols-1 gap-4 mt-6">
    {papers.map((paper: any) => (
      <div class="paper-card group relative bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-amber-500/50 hover:shadow-lg hover:shadow-amber-500/10 transition-all duration-300 flex gap-4" data-domain={paper.psi_domain} data-folder={paper.folder} data-year={paper.year} data-prereg={getPreRegStatus(paper)} data-blinding={getBlindingStatus(paper)} data-doi={getDoiStatus(paper)} data-title={paper.title.toLowerCase()} data-authors={paper.authors.join(' ').toLowerCase()} data-abstract={paper.abstract.toLowerCase()} data-sample-size={paper.methodology?.n || 0}>
        
        <!-- Domain Icon Square -->
        <div class={`flex-shrink-0 w-10 h-10 rounded flex items-center justify-center text-lg bg-gradient-to-br ${getDomainGradient(paper.psi_domain)}`}>
          {getDomainIcon(paper.psi_domain)}
        </div>

        <!-- Card Content -->
        <div class="flex-1 min-w-0">
          <div class="flex justify-between items-start mb-3">
            <div>
              <a href={`/paper/${paper.id}`} class="text-lg font-semibold text-slate-100 hover:text-amber-400 transition-colors line-clamp-2">{paper.title}</a>
              <p class="text-sm text-slate-400 mt-1">{formatAuthors(paper.authors)} • {paper.year}</p>
            </div>
            <div class="flex-shrink-0 ml-4">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {getEpistemicStatus(paper).color} text-white" title={getEpistemicStatus(paper).title}>
                {getEpistemicStatus(paper).label}
              </span>
            </div>
          </div>
          <p class="text-slate-300 text-sm mb-4 line-clamp-3">{paper.abstract}</p>
          <div class="flex flex-wrap gap-2 mb-4">
            <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700">{paper.psi_domain.replace(/_/g, ' ')}</span>
            {paper.methodology?.n != null && paper.methodology?.n > 0 && (
              <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700">N = {paper.methodology.n}</span>
            )}
          </div>
          <div class="flex items-center justify-between pt-3 border-t border-slate-800">
            <div class="flex items-center gap-2 text-xs text-slate-500">
              {paper.doi && (
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
                  DOI
                </span>
              )}
              {getPreRegStatus(paper) === 'true' && (
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  Pre-reg
                </span>
              )}
            </div>
            <a href={paper.url} target="_blank" rel="noopener noreferrer" class="text-sm text-amber-400 hover:text-amber-300 font-medium flex items-center gap-1 group/link">
              Read Paper
              <svg class="w-4 h-4 transform group-hover/link:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Show More Button -->
  <div class="mt-8 text-center">
    <button id="show-more-btn" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg font-medium transition-colors border border-slate-700 hover:border-amber-500/50">
      Show More Papers
    </button>
  </div>

  <script>
    // Configuration
    const PAGINATION_LIMIT = 30;
    let visibleCount = PAGINATION_LIMIT;
    let isFiltered = false;

    // DOM Elements
    const paperList = document.getElementById('paper-list')!;
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const domainFilter = document.getElementById('domain-filter') as HTMLSelectElement;
    const folderFilter = document.getElementById('folder-filter') as HTMLSelectElement;
    const yearMinInput = document.getElementById('year-min') as HTMLInputElement;
    const yearMaxInput = document.getElementById('year-max') as HTMLInputElement;
    const preregFilter = document.getElementById('prereg-filter') as HTMLSelectElement;
    const blindingFilter = document.getElementById('blinding-filter') as HTMLSelectElement;
    const doiFilter = document.getElementById('doi-filter') as HTMLInputElement;
    const sortFilter = document.getElementById('sort-filter') as HTMLSelectElement;
    const clearButton = document.getElementById('clear-filters')!;
    const resultCount = document.getElementById('result-count')!;
    const activeFiltersContainer = document.getElementById('active-filters')!;
    const showMoreBtn = document.getElementById('show-more-btn')!;
    const filterContainer = document.getElementById('filter-container')!;
    const sentinel = document.getElementById('scroll-sentinel')!;

    // Sticky Header Shadow Logic
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) {
            filterContainer.classList.add('shadow-lg', 'shadow-black/50');
          } else {
            filterContainer.classList.remove('shadow-lg', 'shadow-black/50');
          }
        });
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);

    // Filter Logic
    function triggerFilterChange() {
      visibleCount = PAGINATION_LIMIT;
      filterAndSortCards();
      updateURL();
    }

    function filterAndSortCards() {
      const cards = Array.from(paperList.querySelectorAll('.paper-card')) as HTMLElement[];
      const searchTerm = searchInput.value.toLowerCase();
      const selectedDomain = domainFilter.value;
      const selectedFolder = folderFilter.value;
      const minYear = yearMinInput.value ? parseInt(yearMinInput.value) : -Infinity;
      const maxYear = yearMaxInput.value ? parseInt(yearMaxInput.value) : Infinity;
      const preregStatus = preregFilter.value;
      const blindingStatus = blindingFilter.value;
      const hasDoi = doiFilter.checked;
      const sortMode = sortFilter.value;

      let visibleMatchCount = 0;

      // Sort Cards
      cards.sort((a, b) => {
        if (sortMode === 'year-desc') return parseInt(b.dataset.year!) - parseInt(a.dataset.year!);
        if (sortMode === 'year-asc') return parseInt(a.dataset.year!) - parseInt(b.dataset.year!);
        if (sortMode === 'title-asc') return a.dataset.title!.localeCompare(b.dataset.title!);
        if (sortMode === 'title-desc') return b.dataset.title!.localeCompare(a.dataset.title!);
        if (sortMode === 'domain') return (a.dataset.domain || '').localeCompare(b.dataset.domain || '');
        if (sortMode === 'sample-size') return parseInt(b.dataset.sampleSize!) - parseInt(a.dataset.sampleSize!);
        return 0;
      });

      // Filter & Display
      cards.forEach((card) => {
        const domain = card.dataset.domain || '';
        const folder = card.dataset.folder || '';
        const year = parseInt(card.dataset.year || '0');
        const prereg = card.dataset.prereg || 'unknown';
        const blinding = card.dataset.blinding || 'unknown';
        const doi = card.dataset.doi === 'yes';
        const title = card.dataset.title || '';
        const authors = card.dataset.authors || '';
        const abstract = card.dataset.abstract || '';

        const matchesSearch = !searchTerm || title.includes(searchTerm) || authors.includes(searchTerm) || abstract.includes(searchTerm);
        const matchesDomain = !selectedDomain || domain === selectedDomain;
        const matchesFolder = !selectedFolder || folder === selectedFolder;
        const matchesYear = year >= minYear && year <= maxYear;
        const matchesPrereg = !preregStatus || prereg === preregStatus;
        const matchesBlinding = !blindingStatus || blinding === blindingStatus;
        const matchesDoi = !hasDoi || doi;

        const isMatch = matchesSearch && matchesDomain && matchesFolder && matchesYear && matchesPrereg && matchesBlinding && matchesDoi;

        if (isMatch) {
          visibleMatchCount++;
          if (visibleMatchCount <= visibleCount) {
            card.style.display = 'flex'; // Changed from block to flex
            card.classList.remove('hidden');
          } else {
            card.style.display = 'none';
            card.classList.add('hidden');
          }
        } else {
          card.style.display = 'none';
          card.classList.add('hidden');
        }
        
        // Re-append to reorder in DOM
        paperList.appendChild(card);
      });
      
      // Determine if any filters are active
      isFiltered = searchTerm || selectedDomain || selectedFolder || yearMinInput.value || yearMaxInput.value || preregStatus || blindingStatus || hasDoi;

      // Update UI Text
      const totalFiltered = cards.filter(card => {
        const domain = card.dataset.domain || '';
        const folder = card.dataset.folder || '';
        const year = parseInt(card.dataset.year || '0');
        const prereg = card.dataset.prereg || 'unknown';
        const blinding = card.dataset.blinding || 'unknown';
        const doi = card.dataset.doi === 'yes';
        const title = card.dataset.title || '';
        const authors = card.dataset.authors || '';
        const abstract = card.dataset.abstract || '';

        const matchesSearch = !searchTerm || title.includes(searchTerm) || authors.includes(searchTerm) || abstract.includes(searchTerm);
        const matchesDomain = !selectedDomain || domain === selectedDomain;
        const matchesFolder = !selectedFolder || folder === selectedFolder;
        const matchesYear = year >= minYear && year <= maxYear;
        const matchesPrereg = !preregStatus || prereg === preregStatus;
        const matchesBlinding = !blindingStatus || blinding === blindingStatus;
        const matchesDoi = !hasDoi || doi;

        return matchesSearch && matchesDomain && matchesFolder && matchesYear && matchesPrereg && matchesBlinding && matchesDoi;
      }).length;
      
      const showingCount = Math.min(visibleCount, totalFiltered);
      resultCount.textContent = `Showing ${showingCount} of ${totalFiltered} paper${totalFiltered !== 1 ? 's' : ''}`;
      
      // Update Button Visibility
      if (isFiltered || visibleCount >= visibleMatchCount) {
        showMoreBtn.classList.add('hidden');
      } else {
        showMoreBtn.classList.remove('hidden');
      }

      updateActiveFilters();
    }

    // Show More Button Handler
    showMoreBtn.addEventListener('click', () => {
      visibleCount += PAGINATION_LIMIT;
      filterAndSortCards();
    });

    function clearFilters() {
      domainFilter.value = '';
      folderFilter.value = '';
      yearMinInput.value = '';
      yearMaxInput.value = '';
      preregFilter.value = '';
      blindingFilter.value = '';
      doiFilter.checked = false;
      searchInput.value = '';
      sortFilter.value = 'year-desc'; // Reset sort to default
      triggerFilterChange();
    }

    function updateURL() {
      const params = new URLSearchParams();
      if (domainFilter.value) params.set('domain', domainFilter.value);
      if (folderFilter.value) params.set('folder', folderFilter.value);
      if (yearMinInput.value) params.set('yearMin', yearMinInput.value);
      if (yearMaxInput.value) params.set('yearMax', yearMaxInput.value);
      if (preregFilter.value) params.set('prereg', preregFilter.value);
      if (blindingFilter.value) params.set('blinding', blindingFilter.value);
      if (doiFilter.checked) params.set('doi', 'yes');
      if (searchInput.value) params.set('q', searchInput.value);
      if (sortFilter.value !== 'year-desc') params.set('sort', sortFilter.value);
      
      const newURL = params.toString() ? `?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', newURL);
    }

    domainFilter.addEventListener('change', triggerFilterChange);
    folderFilter.addEventListener('change', triggerFilterChange);
    yearMinInput.addEventListener('input', triggerFilterChange);
    yearMaxInput.addEventListener('input', triggerFilterChange);
    preregFilter.addEventListener('change', triggerFilterChange);
    blindingFilter.addEventListener('change', triggerFilterChange);
    doiFilter.addEventListener('change', triggerFilterChange);
    searchInput.addEventListener('input', triggerFilterChange);
    sortFilter.addEventListener('change', triggerFilterChange);
    clearButton.addEventListener('click', clearFilters);

    // Handle URL params on load
    const params = new URLSearchParams(window.location.search);
    if (params.get('domain')) {
      domainFilter.value = params.get('domain') || '';
    }
    if (params.get('folder')) {
      folderFilter.value = params.get('folder') || '';
    }
    if (params.get('yearMin')) {
      yearMinInput.value = params.get('yearMin') || '';
    }
    if (params.get('yearMax')) {
      yearMaxInput.value = params.get('yearMax') || '';
    }
    if (params.get('prereg')) {
      preregFilter.value = params.get('prereg') || '';
    }
    if (params.get('blinding')) {
      blindingFilter.value = params.get('blinding') || '';
    }
    if (params.get('doi') === 'yes') {
      doiFilter.checked = true;
    }
    if (params.get('q')) {
      searchInput.value = params.get('q') || '';
    }
    if (params.get('sort')) {
      sortFilter.value = params.get('sort') || 'year-desc';
    }
    
    filterAndSortCards();
  </script>
</Layout>