---
import Layout from '../../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

// Read all era markdown files
const timelineDir = join(process.cwd(), 'src/data/timeline');
const eraFiles = readdirSync(timelineDir).filter(f => f.endsWith('.md') && f.startsWith('era_'));

// Color configuration for eras
const eraConfig: Record<string, { bg: string, border: string, text: string, glow: string, gradient: string, icon: string }> = {
  'era_1_pre_modern': { bg: 'bg-purple-500', border: 'border-purple-400', text: 'text-purple-400', glow: 'shadow-purple-500/20', gradient: 'from-purple-600/10 to-purple-900/5', icon: '🔮' },
  'era_2_rhine': { bg: 'bg-blue-500', border: 'border-blue-400', text: 'text-blue-400', glow: 'shadow-blue-500/20', gradient: 'from-blue-600/10 to-blue-900/5', icon: '🔬' },
  'era_3_ganzfeld': { bg: 'bg-cyan-500', border: 'border-cyan-400', text: 'text-cyan-400', glow: 'shadow-cyan-500/20', gradient: 'from-cyan-600/10 to-cyan-900/5', icon: '🧠' },
  'era_4_stargate': { bg: 'bg-green-500', border: 'border-green-400', text: 'text-green-400', glow: 'shadow-green-500/20', gradient: 'from-green-600/10 to-green-900/5', icon: '👁️' },
  'era_5_modern': { bg: 'bg-amber-500', border: 'border-amber-400', text: 'text-amber-400', glow: 'shadow-amber-500/20', gradient: 'from-amber-600/10 to-amber-900/5', icon: '📊' },
  'era_6_current': { bg: 'bg-red-500', border: 'border-red-400', text: 'text-red-400', glow: 'shadow-red-500/20', gradient: 'from-red-600/10 to-red-900/5', icon: '🚀' },
};

const currentYear = new Date().getFullYear();

const eras = eraFiles.map((file) => {
  const filePath = join(timelineDir, file);
  const content = readFileSync(filePath, 'utf-8');
  
  // Extract first non-heading paragraph for "Key Developments"
  const lines = content.split('\n');
  let description = '';
  let inFrontmatter = false;
  
  for (const line of lines) {
    const trimmed = line.trim();
    if (trimmed === '---') {
      inFrontmatter = !inFrontmatter;
      continue;
    }
    if (inFrontmatter) continue;
    if (!trimmed || trimmed.startsWith('#')) continue;
    description = trimmed;
    break;
  }
  
  // Count paper references
  const catalogMatches = content.match(/\[catalog ID: [a-z0-9_]+\]/gi) || [];
  const backtickMatches = content.match(/`[a-z0-9_]+`/gi) || [];
  const paperCount = catalogMatches.length + backtickMatches.length;
  
  const id = file.replace('.md', '');
  
  // Extract title
  const titleMatch = content.match(/^#\s+(.+)$/m);
  let title = titleMatch ? titleMatch[1] : id.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
  
  // Extract and parse years for calculations
  const yearsMatch = content.match(/(\d{4})[–-](\d{4}|present)/i);
  let yearsDisplay = yearsMatch ? yearsMatch[0] : '';
  let startYear = 0;
  let endYear = currentYear;
  let duration = 0;

  if (yearsMatch) {
    startYear = parseInt(yearsMatch[1]);
    const endStr = yearsMatch[2];
    endYear = endStr.toLowerCase() === 'present' ? currentYear : parseInt(endStr);
    duration = endYear - startYear;
  }
  
  const config = eraConfig[id] || { bg: 'bg-slate-500', border: 'border-slate-400', text: 'text-slate-400', glow: 'shadow-slate-500/20', gradient: 'from-slate-600/10 to-slate-900/5', icon: '📜' };
  
  return {
    id,
    title,
    years: yearsDisplay,
    startYear,
    endYear,
    duration,
    desc: description,
    paperCount,
    ...config,
  };
});

// Sort eras chronologically
eras.sort((a, b) => a.startYear - b.startYear);

// Calculate total timeline span for "River of Time" visualization
const minStart = Math.min(...eras.map(e => e.startYear));
const maxEnd = Math.max(...eras.map(e => e.endYear));
const totalSpan = maxEnd - minStart;

// Calculate percentage widths for the river visualization
eras.forEach(era => {
  era.widthPercent = totalSpan > 0 ? (era.duration / totalSpan) * 100 : 0;
});
---

<Layout title="Timeline">
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <ol class="flex items-center gap-2 text-sm text-slate-500">
      <li><a href="/" class="hover:text-amber-400 transition">Home</a></li>
      <li>/</li>
      <li class="text-slate-300">Timeline</li>
    </ol>
  </nav>
  
  <!-- Header Section -->
  <div class="mb-10">
    <h1 class="text-4xl font-bold mb-3 text-slate-100">Historical Timeline</h1>
    <p class="text-slate-400 max-w-2xl text-lg leading-relaxed">
      Trace the evolution of psi research from Victorian séance investigations to modern pre-registered experiments.
    </p>
  </div>

  <!-- Quick Jump Bar -->
  <div class="sticky top-20 z-40 mb-8 overflow-x-auto pb-2 scrollbar-hide">
    <div class="flex gap-2 min-w-max bg-slate-900/80 backdrop-blur-md p-2 rounded-xl border border-slate-800 shadow-xl">
      {eras.map(era => (
        <a 
          href={`#era-${era.id}`} 
          class={`px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300 border border-transparent hover:border-slate-700 hover:bg-slate-800 ${era.text}`}
        >
          {era.title}
        </a>
      ))}
    </div>
  </div>
  
  <!-- River of Time Visualization -->
  <div class="mb-12 bg-slate-900/50 border border-slate-800 rounded-xl p-4 relative overflow-hidden group">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-mono text-slate-500 uppercase tracking-widest">River of Time</span>
      <span class="text-xs font-mono text-slate-500">{minStart} — {maxEnd}</span>
    </div>
    <div class="flex w-full h-8 rounded-lg overflow-hidden shadow-inner bg-slate-950">
      {eras.map(era => (
        <a 
          href={`#era-${era.id}`}
          class={`relative h-full ${era.bg} hover:opacity-100 opacity-80 transition-opacity duration-300 group/river`}
          style={`width: ${era.widthPercent}%`}
          title={`${era.title} (${era.years})`}
        >
          <!-- Tooltip on hover -->
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-1.5 bg-slate-950 border border-slate-700 text-slate-200 text-xs rounded shadow-xl opacity-0 group-hover/river:opacity-100 transition-opacity pointer-events-none whitespace-nowrap z-50">
            {era.title}
          </div>
        </a>
      ))}
    </div>
  </div>
  
  <!-- Timeline Container -->
  <div class="relative max-w-5xl pb-20">
    <!-- Pulsing Timeline Line -->
    <div class="absolute left-[23px] top-4 bottom-0 w-2 bg-gradient-to-b from-purple-600 via-blue-600 via-cyan-600 via-green-600 via-amber-600 to-red-600 rounded-full opacity-60 shadow-[0_0_15px_rgba(59,130,246,0.5)] animate-pulse"></div>
    
    <!-- Era Cards -->
    <div class="space-y-12">
      {eras.map((era, index) => (
        <div id={`era-${era.id}`} class="timeline-item block relative pl-20 group opacity-0 translate-y-12 transition-all duration-700 ease-out" data-index={index}>
          
          <!-- Era Marker Dot -->
          <a href={`/timeline/${era.id}`} class={`absolute left-0 top-2 w-12 h-12 rounded-full bg-slate-950 border-4 ${era.border} flex items-center justify-center z-20 shadow-lg ${era.glow} hover:scale-110 hover:shadow-xl transition-all duration-300 cursor-pointer`}>
            <span class="text-lg filter drop-shadow-md">{era.icon}</span>
          </a>
          
          <!-- Card Content -->
          <a href={`/timeline/${era.id}`} class="block group/card">
            <div class={`relative bg-gradient-to-r ${era.gradient} backdrop-blur-sm border ${era.border} rounded-2xl p-6 hover:border-opacity-80 hover:shadow-2xl hover:shadow-${era.bg.replace('bg-', '')}/10 transition-all duration-300 overflow-hidden`}>
              <!-- Subtle gradient overlay -->
              <div class={`absolute inset-0 bg-gradient-to-r ${era.gradient} opacity-40 pointer-events-none`}></div>
              
              <!-- Card Content (above gradient) -->
              <div class="relative z-10">
                <!-- Header Row -->
                <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-4">
                  <!-- Year Badge -->
                  <span class={`inline-flex items-center gap-2 font-mono text-xs font-bold tracking-wider uppercase ${era.text} bg-slate-950/90 px-3 py-1.5 rounded-lg border ${era.border} shadow-sm whitespace-nowrap`}>
                    <span class={`w-2 h-2 rounded-full ${era.bg} animate-ping`}></span>
                    {era.years}
                  </span>
                  
                  <!-- Title -->
                  <h3 class="text-2xl font-bold text-slate-100 group-hover/card:text-white transition-colors">
                    {era.title}
                  </h3>
                  
                  <!-- Paper Count Badge -->
                  {era.paperCount > 0 && (
                    <span class="sm:ml-auto inline-flex items-center gap-2 text-xs font-semibold text-slate-300 bg-slate-950/90 px-3 py-1.5 rounded-full border border-slate-700 group-hover/card:border-slate-500 transition-colors shadow-sm">
                      <svg class={`w-4 h-4 ${era.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                      <span class="text-slate-100 font-bold text-sm">{era.paperCount}</span>
                      <span class="text-slate-500">{era.paperCount === 1 ? 'paper' : 'papers'}</span>
                    </span>
                  )}
                </div>
                
                <!-- Description Section -->
                <div class="space-y-3">
                  <div class="flex items-center gap-2">
                    <div class={`w-1 h-4 ${era.bg} rounded-full`}></div>
                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Key Developments</p>
                  </div>
                  <p class="text-slate-300 leading-relaxed group-hover/card:text-slate-200 transition-colors text-base">
                    {era.desc}
                  </p>
                </div>
                
                <!-- Hover Indicator -->
                <div class="mt-5 flex items-center gap-2 text-sm">
                  <span class={`font-medium ${era.text} opacity-0 group-hover/card:opacity-100 transition-opacity duration-300 transform translate-x-[-10px] group-hover/card:translate-x-0`}>
                    Explore this era →
                  </span>
                </div>
              </div>
            </div>
          </a>
        </div>
      ))}
    </div>
  </div>

  <!-- Legend Section -->
  <div class="mt-16 max-w-5xl border-t border-slate-800 pt-10">
    <div class="bg-slate-900/30 backdrop-blur-sm border border-slate-800 rounded-xl p-6">
      <h4 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Era Color Legend</h4>
      <div class="flex flex-wrap gap-6">
        {eras.map(era => (
          <div class="flex items-center gap-3 group cursor-default">
            <span class={`w-3 h-3 rounded-full ${era.bg} shadow-sm ${era.glow} group-hover:scale-125 transition-transform`}></span>
            <span class="text-sm text-slate-400 group-hover:text-slate-200 transition-colors">{era.title}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll Animation Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px', // Trigger slightly before element is fully in view
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = parseInt(entry.target.dataset.index || '0');
            // Stagger delay based on global index
            setTimeout(() => {
              entry.target.classList.remove('opacity-0', 'translate-y-12');
              entry.target.classList.add('opacity-100', 'translate-y-0');
            }, index * 100); // 100ms stagger
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      const items = document.querySelectorAll('.timeline-item');
      items.forEach(item => observer.observe(item));
    });
  </script>
</Layout>