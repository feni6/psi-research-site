---
// src/pages/journals.astro
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import catalog from '../data/catalog.json';

// Process catalog to extract journal statistics
const journalMap: Record<string, { count: number, papers: any[], years: number[] }> = {};

catalog.papers.forEach((p: any) => {
  const j = p.journal;
  if (!j || !j.trim()) return; // Skip papers without a valid journal (matches homepage filtering)
  if (!journalMap[j]) {
    journalMap[j] = { count: 0, papers: [], years: [] };
  }
  journalMap[j].count++;
  journalMap[j].papers.push({ id: p.id, title: p.title, year: p.year, domain: p.psi_domain });
  journalMap[j].years.push(p.year);
});

// Sort papers within each journal by year (descending) to get most recent
Object.values(journalMap).forEach((data) => {
  data.papers.sort((a, b) => b.year - a.year);
});

// Convert to array
let allJournals = Object.entries(journalMap);

// Sort by count descending by default for the initial render
allJournals.sort(([, a], [, b]) => b.count - a.count);

// Extract Top 5 for Key Journals section
const top5Journals = allJournals.slice(0, 5);

// Stats
const totalJournals = allJournals.length;
const totalPapers = catalog.papers.length;
---

<Layout title="Journal Index" description="A comprehensive index of journals publishing psi research, ranked by volume of papers in our catalog.">
  <div class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Breadcrumb -->
    <Breadcrumb 
      items={[
        { label: 'Home', href: '/' },
        { label: 'Journals', href: '/journals' }
      ]} 
    />

    <!-- Header & Stats -->
    <header class="mb-12 border-b border-slate-800 pb-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <h1 class="text-4xl font-bold text-white mb-3 tracking-tight">Journal Index</h1>
          <p class="text-slate-400 text-lg max-w-2xl">
            Explore the publication landscape of psi research.
            <span class="text-amber-400 font-medium">{totalJournals} journals</span> across <span class="text-amber-400 font-medium">{totalPapers} papers</span> in our catalog.
          </p>
        </div>
        
        <!-- Quick Stats Block -->
        <div class="flex gap-8 bg-slate-900/50 p-5 rounded-xl border border-slate-800 shadow-lg" role="region" aria-label="Quick Statistics">
          <div class="text-center border-r border-slate-800 pr-8 last:border-0 last:pr-0">
            <div class="text-3xl font-bold text-amber-400 font-mono" aria-label={`${totalJournals} Venues`}>{totalJournals}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Venues</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-white font-mono" aria-label={`${totalPapers} Publications`}>{totalPapers}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mt-1">Publications</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Top 5 Journals Hero Section -->
    <section class="mb-16" aria-labelledby="top-journals-heading">
      <div class="flex items-center gap-3 mb-6">
        <div class="p-2 bg-amber-400/10 rounded-lg border border-amber-400/20">
          <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <h2 id="top-journals-heading" class="text-2xl font-bold text-white">Most Active Venues</h2>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4" role="list">
        {top5Journals.map(([name, data], index) => {
          const minYear = Math.min(...data.years);
          const maxYear = Math.max(...data.years);
          const recentPapers = data.papers.slice(0, 3);
          
          return (
            <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="group relative block h-full bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-amber-400 hover:-translate-y-1 transition-all duration-300 shadow-lg hover:shadow-amber-900/20 overflow-hidden focus:ring-2 focus:ring-amber-400 focus:outline-none" role="listitem" aria-label={`${name}, ${data.count} papers`}>
              <!-- Background Rank Number -->
              <span class="absolute -right-4 -bottom-4 text-8xl font-black text-slate-800/50 group-hover:text-amber-400/10 transition-colors select-none" aria-hidden="true">
                {index + 1}
              </span>

              <div class="relative z-10">
                <div class="flex justify-between items-start mb-4">
                  <span class="bg-amber-400 text-slate-950 text-xs font-bold px-2.5 py-1 rounded uppercase tracking-wide shadow-sm">
                    {data.count} <span class="sr-only">Papers</span>
                  </span>
                </div>
                
                <h3 class="text-lg font-bold text-slate-200 mb-2 line-clamp-2 group-hover:text-amber-400 transition-colors h-14">
                  {name}
                </h3>
                
                <div class="text-xs text-slate-500 font-mono mb-4 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-slate-600"></span>
                  {minYear} — {maxYear}
                </div>

                <div class="space-y-2 border-t border-slate-800 pt-3">
                  <p class="text-[10px] text-slate-500 font-semibold uppercase tracking-wider mb-1">Recent</p>
                  {recentPapers.map((paper: any) => (
                    <div class="text-xs text-slate-400 group-hover:text-slate-300 transition-colors line-clamp-1">
                      <span class="text-amber-400/70 mr-1" aria-hidden="true">•</span>
                      {paper.title} <span class="text-slate-600">({paper.year})</span>
                    </div>
                  ))}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Controls: Search & Sort -->
    <div class="sticky top-4 z-20 mb-8">
      <div class="bg-slate-900/95 backdrop-blur-md border border-slate-800 rounded-xl p-4 shadow-2xl flex flex-col md:flex-row gap-4 items-center justify-between">
        
        <!-- Search Input -->
        <div class="relative w-full md:w-96">
          <label for="journal-search" class="sr-only">Filter journals by name</label>
          <input 
            type="text" 
            id="journal-search" 
            placeholder="Filter journals by name..." 
            aria-label="Filter journals by name"
            class="w-full bg-slate-950 border border-slate-700 text-slate-200 rounded-lg py-2.5 pl-10 pr-4 focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400 transition-all placeholder-slate-600"
          />
          <svg class="w-5 h-5 text-slate-500 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <span id="search-count" class="absolute right-3 top-3 text-xs text-slate-500 font-mono bg-slate-900 px-2 py-0.5 rounded border border-slate-800 hidden" aria-live="polite"></span>
        </div>

        <!-- Sort Toggle -->
        <div class="flex bg-slate-950 rounded-lg p-1 border border-slate-800" role="group" aria-label="Sort journals">
          <button 
            id="sort-count" 
            class="px-4 py-1.5 text-sm font-medium rounded-md bg-slate-800 text-amber-400 shadow-sm transition-all focus:ring-2 focus:ring-amber-400 focus:outline-none"
            onclick="sortJournals('count')"
            aria-pressed="true"
          >
            Most Papers
          </button>
          <button 
            id="sort-alpha" 
            class="px-4 py-1.5 text-sm font-medium rounded-md text-slate-400 hover:text-white transition-all focus:ring-2 focus:ring-amber-400 focus:outline-none"
            onclick="sortJournals('alpha')"
            aria-pressed="false"
          >
            A-Z
          </button>
        </div>
      </div>
    </div>

    <!-- Full Journal Directory -->
    <section aria-labelledby="directory-heading">
      <div class="flex items-center justify-between mb-6">
        <h2 id="directory-heading" class="text-xl font-semibold text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          Complete Directory
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="journal-list" role="list">
        {allJournals.map(([name, data]) => {
          const minYear = Math.min(...data.years);
          const maxYear = Math.max(...data.years);
          const recentPapers = data.papers.slice(0, 3);
          
          return (
            <div 
              class="journal-card group bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-amber-400 hover:-translate-y-1 hover:shadow-amber-900/20 transition-all duration-300 flex flex-col focus-within:ring-2 focus-within:ring-amber-400"
              data-name={name.toLowerCase()}
              data-count={data.count}
              role="listitem"
            >
              <!-- Card Header -->
              <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="p-6 block flex-grow focus:outline-none" aria-label={`View all papers from ${name}`}>
                <div class="flex justify-between items-start mb-4">
                  <span class="inline-flex items-center justify-center px-3 py-1 rounded-full text-xs font-bold bg-slate-800 text-amber-400 border border-slate-700">
                    {data.count} <span class="sr-only">Papers</span>
                  </span>
                  <span class="text-xs text-slate-500 font-mono bg-slate-950 px-2 py-1 rounded border border-slate-800">
                    {minYear}–{maxYear}
                  </span>
                </div>
                
                <h3 class="text-xl font-bold text-slate-200 mb-4 group-hover:text-amber-400 transition-colors line-clamp-2 min-h-[3.5rem]">
                  {name}
                </h3>

                <div class="space-y-3">
                  <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider border-b border-slate-800 pb-2">Latest Publications</p>
                  <ul class="space-y-3" role="list">
                    {recentPapers.map((paper: any) => (
                      <li key={paper.id} class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors" role="listitem">
                        <a href={`/paper/${paper.id}`} class="hover:text-amber-400 hover:underline decoration-amber-400/50 underline-offset-2 block leading-snug focus:outline-none focus:ring-2 focus:ring-amber-400 focus:rounded-sm">
                          {paper.title}
                        </a>
                        <span class="text-xs text-slate-600 block mt-1 font-mono">{paper.year}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </a>
              
              <!-- Card Footer Action -->
              <div class="px-6 py-4 bg-slate-950/50 border-t border-slate-800/50 mt-auto">
                <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="text-xs font-bold text-amber-400 hover:text-amber-300 flex items-center gap-2 group-hover:gap-3 transition-all uppercase tracking-wide focus:outline-none focus:ring-2 focus:ring-amber-400 focus:rounded-sm" aria-label={`View all papers from ${name}`}>
                  View all papers
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          );
        })}
      </div>
      
      <!-- No Results State (Hidden by default) -->
      <div id="no-results" class="hidden text-center py-20" role="status" aria-live="polite">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-900 mb-4 border border-slate-800">
          <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-slate-300">No journals found</h3>
        <p class="text-slate-500 mt-1">Try adjusting your search terms.</p>
      </div>
    </section>

    <!-- Client-side Search & Sort Script -->
    <script>
      const searchInput = document.getElementById('journal-search') as HTMLInputElement;
      const journalCards = Array.from(document.querySelectorAll('.journal-card')) as HTMLElement[];
      const searchCount = document.getElementById('search-count');
      const noResults = document.getElementById('no-results');
      const journalList = document.getElementById('journal-list');
      const btnCount = document.getElementById('sort-count');
      const btnAlpha = document.getElementById('sort-alpha');

      let currentSort = 'count';

      function updateDisplay() {
        const query = searchInput.value.toLowerCase();
        let visibleCount = 0;
        
        journalCards.forEach(card => {
          const name = card.getAttribute('data-name') || '';
          const matchesSearch = name.includes(query);
          
          if (matchesSearch) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });

        // Update count badge
        if (searchCount) {
          if (query) {
            searchCount.textContent = `${visibleCount} found`;
            searchCount.classList.remove('hidden');
          } else {
            searchCount.classList.add('hidden');
          }
        }

        // Toggle no results message
        if (journalList) {
          if (visibleCount === 0) {
            journalList.classList.add('hidden');
            noResults?.classList.remove('hidden');
          } else {
            journalList.classList.remove('hidden');
            noResults?.classList.add('hidden');
          }
        }
      }

      function sortJournals(type: 'count' | 'alpha') {
        currentSort = type;
        
        // Update Button Styles
        if (type === 'count') {
          btnCount?.classList.add('bg-slate-800', 'text-amber-400', 'shadow-sm');
          btnCount?.classList.remove('text-slate-400');
          btnCount?.setAttribute('aria-pressed', 'true');
          btnAlpha?.classList.remove('bg-slate-800', 'text-amber-400', 'shadow-sm');
          btnAlpha?.classList.add('text-slate-400');
          btnAlpha?.setAttribute('aria-pressed', 'false');
        } else {
          btnAlpha?.classList.add('bg-slate-800', 'text-amber-400', 'shadow-sm');
          btnAlpha?.classList.remove('text-slate-400');
          btnAlpha?.setAttribute('aria-pressed', 'true');
          btnCount?.classList.remove('bg-slate-800', 'text-amber-400', 'shadow-sm');
          btnCount?.classList.add('text-slate-400');
          btnCount?.setAttribute('aria-pressed', 'false');
        }

        // Sort DOM Elements
        const sortedCards = [...journalCards].sort((a, b) => {
          if (type === 'count') {
            const countA = parseInt(a.getAttribute('data-count') || '0');
            const countB = parseInt(b.getAttribute('data-count') || '0');
            return countB - countA; // Descending
          } else {
            const nameA = a.getAttribute('data-name') || '';
            const nameB = b.getAttribute('data-name') || '';
            return nameA.localeCompare(nameB); // Ascending
          }
        });

        // Re-append to DOM in new order
        sortedCards.forEach(card => journalList?.appendChild(card));
        
        // Re-run filter in case search is active
        updateDisplay();
      }

      searchInput?.addEventListener('input', updateDisplay);
    </script>

  </div>
</Layout>