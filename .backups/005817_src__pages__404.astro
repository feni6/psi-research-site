---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Helper to get deterministic random papers based on an hour seed
function getPapersForHour(hour: number, allPapers: any[], count: number = 3) {
  const seed = hour;
  const papers = [...allPapers];
  const selected = [];
  
  // Simple seeded shuffle logic
  for (let i = papers.length - 1; i > 0; i--) {
    const j = (seed * (i + 1)) % (i + 1);
    [papers[i], papers[j]] = [papers[j], papers[i]];
  }
  
  return papers.slice(0, count);
}

// We'll pass the catalog to the client script to allow dynamic hour-based selection
const catalogJson = JSON.stringify(catalog);
---

<Layout title="Page Not Found">
  <!-- Background with subtle spotlight effect -->
  <div class="min-h-screen bg-slate-950 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-slate-900 via-slate-950 to-slate-950 flex flex-col items-center justify-center px-4 py-12 relative overflow-hidden">
    
    <!-- Decorative background grid pattern (CSS-only via Tailwind arbitrary values) -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none"></div>

    <div class="relative z-10 w-full max-w-5xl flex flex-col items-center">
    
      <!-- Hero Section -->
      <div class="text-center mb-12 animate-fade-in">
        <div class="text-7xl mb-6 animate-bounce origin-bottom">👻</div>
        <h1 class="text-6xl md:text-7xl font-bold text-amber-400 mb-4 tracking-tight drop-shadow-lg">
          404
        </h1>
        <h2 class="text-2xl md:text-3xl font-semibold text-slate-200 mb-4">
          Signal Lost in the Void
        </h2>
        <p class="text-slate-400 text-lg max-w-lg mx-auto italic leading-relaxed">
          "Even our best remote viewers couldn't locate this page in the spatial-temporal continuum. It may have been redacted, or perhaps it never existed at all."
        </p>
      </div>

      <!-- Enhanced Search Box -->
      <div class="w-full max-w-2xl mb-16 relative group">
        <form action="/search" method="GET" class="relative shadow-2xl shadow-amber-900/10">
          <input 
            type="text" 
            name="q" 
            placeholder="Search the archives for answers..." 
            class="w-full bg-slate-900/80 backdrop-blur border border-slate-700 text-slate-200 rounded-xl py-5 pl-8 pr-36 text-lg focus:outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-400/50 transition-all placeholder:text-slate-600 shadow-inner"
            autofocus
            required
          />
          <button 
            type="submit" 
            class="absolute right-3 top-3 bottom-3 bg-amber-400 hover:bg-amber-300 text-slate-950 font-bold px-6 rounded-lg transition-all hover:scale-105 active:scale-95 flex items-center gap-2"
          >
            <span>Search</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Popular Pages Section -->
      <div class="w-full mb-16">
        <h3 class="text-slate-500 text-xs font-bold uppercase tracking-widest mb-6 text-center">
          Popular Destinations
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <a href="/catalog" class="group flex flex-col items-center justify-center p-6 bg-slate-900/50 border border-slate-800 hover:border-amber-400/50 hover:bg-slate-800/50 rounded-xl transition-all hover:-translate-y-1">
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">📚</div>
            <span class="text-slate-300 font-medium group-hover:text-amber-400 transition-colors">Catalog</span>
          </a>
          <a href="/paths" class="group flex flex-col items-center justify-center p-6 bg-slate-900/50 border border-slate-800 hover:border-amber-400/50 hover:bg-slate-800/50 rounded-xl transition-all hover:-translate-y-1">
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">🗺️</div>
            <span class="text-slate-300 font-medium group-hover:text-amber-400 transition-colors">Reading Paths</span>
          </a>
          <a href="/controversies" class="group flex flex-col items-center justify-center p-6 bg-slate-900/50 border border-slate-800 hover:border-amber-400/50 hover:bg-slate-800/50 rounded-xl transition-all hover:-translate-y-1">
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">⚡</div>
            <span class="text-slate-300 font-medium group-hover:text-amber-400 transition-colors">Controversies</span>
          </a>
          <a href="/stats" class="group flex flex-col items-center justify-center p-6 bg-slate-900/50 border border-slate-800 hover:border-amber-400/50 hover:bg-slate-800/50 rounded-xl transition-all hover:-translate-y-1">
            <div class="text-3xl mb-3 group-hover:scale-110 transition-transform">📊</div>
            <span class="text-slate-300 font-medium group-hover:text-amber-400 transition-colors">Stats</span>
          </a>
        </div>
      </div>

      <!-- Dynamic Suggestions (Hourly) -->
      <div class="w-full mb-16">
        <h3 class="text-slate-400 text-sm font-bold uppercase tracking-widest mb-6 text-center">
          Maybe you were looking for...
        </h3>
        <div id="suggestions-grid" class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <!-- Fallback content while JS loads -->
          <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
          <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
          <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
        </div>
      </div>

      <!-- Random Discovery Section (Daily) -->
      <div class="w-full mb-16 bg-slate-900/30 border border-slate-800/50 rounded-2xl p-8 backdrop-blur-sm">
        <div class="flex items-center gap-3 mb-6 justify-center">
          <span class="text-amber-400">✨</span>
          <h3 class="text-slate-300 font-semibold text-lg">
            While you're here, discover something unexpected:
          </h3>
          <span class="text-amber-400">✨</span>
        </div>
        <div id="daily-discovery-grid" class="grid grid-cols-1 md:grid-cols-3 gap-4">
           <!-- Fallback content -->
           <div class="h-20 bg-slate-800/50 rounded animate-pulse"></div>
           <div class="h-20 bg-slate-800/50 rounded animate-pulse"></div>
           <div class="h-20 bg-slate-800/50 rounded animate-pulse"></div>
        </div>
      </div>

      <!-- Random Button -->
      <button 
        id="random-btn"
        class="group flex items-center gap-3 px-8 py-4 bg-amber-400/10 hover:bg-amber-400/20 border border-amber-400/50 text-amber-400 rounded-full font-bold transition-all hover:scale-105 active:scale-95 shadow-lg shadow-amber-900/20"
      >
        <span class="text-xl group-hover:rotate-180 transition-transform duration-500">🎲</span>
        <span>Take me somewhere random</span>
      </button>

      <div class="mt-12 text-slate-600 text-sm">
        <a href="/" class="hover:text-amber-400 transition-colors">Return to Base</a>
      </div>

    </div>
  </div>

  <!-- Client-side logic for dynamic content -->
  <script>
    const catalog = JSON.parse(`${catalogJson}`);

    // 1. Dynamic Suggestions based on current hour
    function renderSuggestions() {
      const hour = new Date().getHours();
      const seed = hour;
      
      // Deterministic shuffle based on hour
      const shuffled = [...catalog].sort(() => 0.5 - Math.sin(seed + Math.random()));
      const suggestions = shuffled.slice(0, 3);
      
      const grid = document.getElementById('suggestions-grid');
      if (!grid) return;

      grid.innerHTML = suggestions.map(paper => `
        <a href="/paper/${paper.slug}" class="block bg-slate-900 border border-slate-800 hover:border-amber-400/50 rounded-lg p-5 transition-all hover:-translate-y-1 group shadow-lg shadow-black/20">
          <div class="text-xs text-amber-400/80 font-mono mb-2">${paper.year}</div>
          <h4 class="text-slate-200 font-semibold leading-snug group-hover:text-amber-400 transition-colors line-clamp-2">
            ${paper.title}
          </h4>
          <div class="mt-3 text-xs text-slate-500 truncate">
            ${paper.author}
          </div>
        </a>
      `).join('');
    }

    // 2. Daily Discovery (Deterministic based on Day of Year)
    function renderDailyDiscovery() {
      const now = new Date();
      const start = new Date(now.getFullYear(), 0, 0);
      const diff = now - start;
      const oneDay = 1000 * 60 * 60 * 24;
      const dayOfYear = Math.floor(diff / oneDay);
      
      // Seed based on day of year
      const seed = dayOfYear;
      const shuffled = [...catalog].sort(() => 0.5 - Math.sin(seed + Math.random()));
      const discoveries = shuffled.slice(0, 3);

      const grid = document.getElementById('daily-discovery-grid');
      if (!grid) return;

      grid.innerHTML = discoveries.map(paper => `
        <a href="/paper/${paper.slug}" class="flex items-center gap-4 p-4 rounded-lg hover:bg-slate-800/50 transition-colors border border-transparent hover:border-slate-700">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-400 font-bold font-mono text-sm border border-amber-400/20">
            ${paper.year.toString().slice(-2)}
          </div>
          <div class="min-w-0">
            <h4 class="text-slate-300 font-medium text-sm truncate hover:text-amber-400 transition-colors">
              ${paper.title}
            </h4>
            <p class="text-slate-500 text-xs truncate">${paper.author}</p>
          </div>
        </a>
      `).join('');
    }

    // 3. Random Paper Navigation
    document.getElementById('random-btn')?.addEventListener('click', () => {
      const randomPaper = catalog[Math.floor(Math.random() * catalog.papers.length)];
      window.location.href = `/papers/${randomPaper.slug}`;
    });

    // Initialize
    renderSuggestions();
    renderDailyDiscovery();
  </script>
</Layout>