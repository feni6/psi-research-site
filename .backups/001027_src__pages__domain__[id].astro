---
// src/pages/domain/[id].astro
import Layout from '../../layouts/Layout.astro';
import catalog from '../../data/catalog.json';
import Breadcrumb from '../../components/Breadcrumb.astro';

export function getStaticPaths() {
  const domainConfig = {
    methodology: { icon: '🔬', color: 'blue', label: 'Methodology & Theory' },
    telepathy: { icon: '🧠', color: 'purple', label: 'Telepathy' },
    psychokinesis: { icon: '🎲', color: 'red', label: 'Psychokinesis' },
    nde: { icon: '✨', color: 'cyan', label: 'NDE & OBE' },
    skeptical: { icon: '🔍', color: 'orange', label: 'Skeptical & Critical' },
    precognition: { icon: '🔮', color: 'violet', label: 'Precognition' },
    healing: { icon: '💚', color: 'green', label: 'Healing & Intention' },
    overview: { icon: '📖', color: 'amber', label: 'Books & Overviews' },
    remote_viewing: { icon: '👁️', color: 'teal', label: 'Remote Viewing' },
    mediumship: { icon: '🕯️', color: 'indigo', label: 'Mediumship & Survival' },
    nonverbal: { icon: '🤝', color: 'pink', label: 'Autism & Nonverbal' },
    meta_analysis: { icon: '📊', color: 'yellow', label: 'Meta-Analyses' },
  };

  // Helper: Calculate decade distribution
  function getDecadeDistribution(papers: any[]) {
    const decades: Record<string, number> = {};
    papers.forEach(p => {
      if (!p.year) return;
      const decade = Math.floor(p.year / 10) * 10;
      const label = `${decade}s`;
      decades[label] = (decades[label] || 0) + 1;
    });
    // Sort by decade
    return Object.entries(decades)
      .sort((a, b) => parseInt(a[0]) - parseInt(b[0]))
      .map(([decade, count]) => ({ decade, count }));
  }

  // Helper: Get top authors
  function getTopAuthors(papers: any[]) {
    const authorCounts: Record<string, number> = {};
    papers.forEach(p => {
      if (!p.authors || !Array.isArray(p.authors)) return;
      p.authors.forEach((name: string) => {
        if (name) authorCounts[name] = (authorCounts[name] || 0) + 1;
      });
    });
    return Object.entries(authorCounts)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 3)
      .map(entry => entry[0]);
  }

  // Helper: Get key papers (most connections)
  function getKeyPapers(papers: any[]) {
    return [...papers]
      .sort((a, b) => (b.related_papers?.length || 0) - (a.related_papers?.length || 0))
      .slice(0, 3);
  }

  const domains = [...new Set(catalog.papers.map((p: any) => p.psi_domain).filter(Boolean))];
  
  return domains.map(domain => {
    const domainPapers = catalog.papers.filter((p: any) => p.psi_domain === domain);
    const config = domainConfig[domain as keyof typeof domainConfig] || { icon: '📄', color: 'slate', label: domain };
    
    return {
      params: { id: domain },
      props: { 
        domain, 
        config,
        stats: {
          count: domainPapers.length,
          topAuthors: getTopAuthors(domainPapers),
          decadeDist: getDecadeDistribution(domainPapers),
          keyPapers: getKeyPapers(domainPapers)
        },
        // Pass all papers for client-side sorting
        allPapers: domainPapers
      },
    };
  });
}

const { domain, config, stats, allPapers } = Astro.props;

// Default sort: Year Descending
const defaultSortedPapers = [...allPapers].sort((a: any, b: any) => (b.year || 0) - (a.year || 0));

// Dynamic color classes
const borderColor = `border-${config.color}-500`;
const textColor = `text-${config.color}-400`;
const bgColor = `bg-${config.color}-500/10`;
const gradientFrom = `from-${config.color}-900/40`;
const gradientTo = `to-slate-950`;

// Helper to determine quality dot color
function getQualityColor(methodology: any = {}) {
  if (!methodology || typeof methodology !== 'object') return 'bg-slate-500';
  const blinding = String(methodology.blinding || '').toLowerCase();
  const prereg = methodology.pre_registered || methodology.pre_registration;
  if (blinding.includes('double') || prereg === true || prereg === 'yes') {
    return 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]'; // Green
  }
  if (blinding.includes('single') || blinding.includes('control')) {
    return 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.6)]'; // Amber
  }
  return 'bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.6)]'; // Red
}
---

<Layout title={`${config.label} - Psi Research Library`} description={`Papers in the ${config.label} domain`}>
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <div class="max-w-6xl mx-auto px-4 py-8">
      
      <!-- Breadcrumb -->
      <div class="mb-6">
        <Breadcrumb 
          items={[
            { label: 'Home', href: '/' },
            { label: 'Domains', href: '/catalog' },
            { label: config.label, href: '#' }
          ]} 
        />
      </div>

      <!-- Domain Hero Section -->
      <section class={`relative overflow-hidden rounded-3xl border border-${config.color}-500/30 p-8 md:p-12 mb-10 bg-gradient-to-br ${gradientFrom} ${gradientTo}`}>
        <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">
          <!-- Icon -->
          <div class={`text-7xl md:text-8xl drop-shadow-2xl filter brightness-110`}>
            {config.icon}
          </div>
          
          <!-- Title & Desc -->
          <div class="flex-1">
            <h1 class={`text-4xl md:text-6xl font-bold ${textColor} mb-4 tracking-tight`}>
              {config.label}
            </h1>
            <p class="text-slate-300 text-lg md:text-xl max-w-3xl leading-relaxed">
              A curated collection of research papers focusing on {config.label.toLowerCase()}.
              Explore the methodology, key findings, and ongoing debates in this field.
            </p>
          </div>
        </div>
        
        <!-- Decorative background glow -->
        <div class={`absolute -right-20 -bottom-20 w-96 h-96 ${bgColor} blur-[100px] rounded-full opacity-40 pointer-events-none`}></div>
      </section>

      <!-- Stats Bar -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-5 flex flex-col items-center justify-center text-center backdrop-blur-sm">
          <span class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1">Total Papers</span>
          <span class={`text-4xl font-bold ${textColor}`}>{stats.count}</span>
        </div>
        
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-5 flex flex-col items-center justify-center text-center backdrop-blur-sm">
          <span class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1">Top Contributors</span>
          <div class="flex flex-wrap justify-center gap-2 mt-1">
            {stats.topAuthors.map((author: string) => (
              <span class="text-xs font-medium text-slate-300 bg-slate-800 px-2 py-1 rounded border border-slate-700">{author}</span>
            ))}
          </div>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-5 flex flex-col justify-center backdrop-blur-sm lg:col-span-2">
          <span class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-3 text-center">Publication Timeline</span>
          <div class="flex items-end justify-between gap-1 h-12">
            {stats.decadeDist.map((d: any) => {
              // Normalize height for visualization (max height 100%)
              const maxCount = Math.max(...stats.decadeDist.map((x: any) => x.count));
              const heightPercent = Math.max(10, (d.count / maxCount) * 100);
              return (
                <div class="flex flex-col items-center gap-1 group relative flex-1">
                  <div 
                    class={`w-full rounded-t-sm ${bgColor} opacity-60 group-hover:opacity-100 transition-opacity`}
                    style={`height: ${heightPercent}%`}
                  ></div>
                  <span class="text-[10px] text-slate-500 font-mono">{d.decade.slice(2)}</span>
                  <!-- Tooltip -->
                  <div class="absolute -top-8 bg-slate-800 text-white text-xs px-2 py-1 rounded opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none whitespace-nowrap z-20">
                    {d.count} papers
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Key Papers Section -->
      {stats.keyPapers.length > 0 && (
        <div class="mb-12">
          <h2 class="text-xl font-bold text-slate-200 flex items-center gap-2 mb-4">
            <svg class={`w-5 h-5 ${textColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
            Highly Connected Papers
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {stats.keyPapers.map((paper: any) => (
              <a href={`/paper/${paper.id}`} class="block group">
                <div class="h-full bg-slate-900 border border-slate-800 hover:border-amber-500/50 rounded-xl p-5 transition-all duration-300 hover:-translate-y-1">
                  <div class="flex justify-between items-start mb-2">
                    <span class="text-xs font-mono text-amber-500 bg-amber-500/10 px-2 py-0.5 rounded">
                      {paper.related_papers?.length || 0} Connections
                    </span>
                    <span class="text-xs text-slate-500">{paper.year}</span>
                  </div>
                  <h3 class="text-lg font-semibold text-slate-200 group-hover:text-amber-400 mb-2 line-clamp-2">
                    {paper.title}
                  </h3>
                  <p class="text-sm text-slate-400">
                    {Array.isArray(paper.authors) ? paper.authors[0] : paper.authors} {Array.isArray(paper.authors) && paper.authors.length > 1 ? 'et al.' : ''}
                  </p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Papers List Controls -->
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
        <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-3">
          <svg class={`w-6 h-6 ${textColor}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          Publications
        </h2>
        
        <div class="flex items-center gap-3">
          <label for="sort-select" class="text-sm text-slate-400">Sort by:</label>
          <select id="sort-select" class="bg-slate-900 border border-slate-700 text-slate-200 text-sm rounded-lg focus:ring-amber-500 focus:border-amber-500 block p-2.5">
            <option value="year-desc">Year (Newest)</option>
            <option value="year-asc">Year (Oldest)</option>
            <option value="title-asc">Title (A-Z)</option>
            <option value="sample-desc">Sample Size (Largest)</option>
          </select>
        </div>
      </div>

      <!-- Papers List -->
      <div id="papers-container" class="space-y-4">
        {defaultSortedPapers.map((paper: any) => {
          const qualityClass = getQualityColor(paper.methodology);
          const authorDisplay = Array.isArray(paper.authors) 
            ? `${paper.authors[0]}${paper.authors.length > 1 ? ' et al.' : ''}` 
            : paper.authors || 'Unknown Author';
            
          return (
            <article class="group bg-slate-900 border border-slate-800 hover:border-slate-600 rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-black/50 relative overflow-hidden">
              <!-- Quality Indicator Strip -->
              <div class={`absolute left-0 top-0 bottom-0 w-1 ${qualityClass}`}></div>
              
              <div class="flex flex-col gap-3 pl-3">
                <!-- Header: Title & Year -->
                <div class="flex justify-between items-start gap-4">
                  <h3 class="text-xl font-semibold text-slate-100 group-hover:text-amber-400 transition-colors leading-snug">
                    <a href={`/paper/${paper.id}`} class="hover:underline decoration-amber-500/50 underline-offset-4">
                      {paper.title}
                    </a>
                  </h3>
                  <span class="text-sm font-mono text-slate-500 whitespace-nowrap bg-slate-950 px-2 py-1 rounded border border-slate-800">
                    {paper.year || 'n.d.'}
                  </span>
                </div>

                <!-- Meta: Authors, Journal, Sample -->
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
                  <span class="text-slate-300 font-medium">{authorDisplay}</span>
                  
                  {paper.journal && (
                    <>
                      <span class="text-slate-700">•</span>
                      <span class="text-slate-400 italic">{paper.journal}</span>
                    </>
                  )}
                  
                  {paper.sample_size && (
                    <>
                      <span class="text-slate-700">•</span>
                      <span class="text-slate-400 flex items-center gap-1" title="Sample Size">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        N={paper.sample_size}
                      </span>
                    </>
                  )}
                </div>

                <!-- Abstract Excerpt -->
                {paper.abstract && (
                  <p class="text-slate-400 text-sm leading-relaxed line-clamp-2 mt-1">
                    {paper.abstract}
                  </p>
                )}

                <!-- Tags -->
                <div class="flex flex-wrap gap-2 pt-2">
                  {paper.tags?.slice(0, 4).map((tag: string) => (
                    <span class="px-2 py-0.5 bg-slate-800 text-slate-400 text-xs rounded border border-slate-700">
                      #{tag}
                    </span>
                  ))}
                  {paper.methodology?.blinding && String(paper.methodology.blinding).toLowerCase().includes('blind') && (
                    <span class="px-2 py-0.5 bg-emerald-900/30 text-emerald-400 text-xs rounded border border-emerald-900/50">
                      Blinded
                    </span>
                  )}
                </div>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Back Link -->
      <div class="mt-12 pt-8 border-t border-slate-800">
        <a 
          href="/catalog" 
          class="inline-flex items-center gap-2 text-slate-400 hover:text-amber-400 transition-colors font-medium"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to All Domains
        </a>
      </div>
    </div>
  </main>

  <!-- Client-side Sorting Script -->
  <script>
    // Data passed from Astro props
    const papersData = {
      papers: JSON.parse(`${JSON.stringify(allPapers)}`)
    };

    const sortSelect = document.getElementById('sort-select');
    const container = document.getElementById('papers-container');

    if (sortSelect && container) {
      sortSelect.addEventListener('change', (e) => {
        const sortValue = (e.target as HTMLSelectElement).value;
        let sorted = [...papersData.papers];

        if (sortValue === 'year-desc') {
          sorted.sort((a, b) => (b.year || 0) - (a.year || 0));
        } else if (sortValue === 'year-asc') {
          sorted.sort((a, b) => (a.year || 0) - (b.year || 0));
        } else if (sortValue === 'title-asc') {
          sorted.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
        } else if (sortValue === 'sample-desc') {
          sorted.sort((a, b) => (b.sample_size || 0) - (a.sample_size || 0));
        }

        // Re-render list (simplified for static site)
        // In a real framework we'd use state, here we rebuild HTML string
        let html = '';
        sorted.forEach((paper: any) => {
          // Re-use logic for quality dot
          const methodString = (paper.methodology || []).join(' ').toLowerCase();
          let qualityClass = 'bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.6)]';
          if (methodString.includes('double-blind') || methodString.includes('pre-registered')) {
            qualityClass = 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.6)]';
          } else if (methodString.includes('control') || methodString.includes('randomized') || methodString.includes('single-blind')) {
            qualityClass = 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.6)]';
          }

          const authorDisplay = Array.isArray(paper.authors) 
            ? `${paper.authors[0]}${paper.authors.length > 1 ? ' et al.' : ''}` 
            : paper.authors || 'Unknown Author';

          const tagsHtml = (paper.tags || []).slice(0, 4).map((tag: string) => 
            `<span class="px-2 py-0.5 bg-slate-800 text-slate-400 text-xs rounded border border-slate-700">#${tag}</span>`
          ).join('');

          const blindedBadge = (paper.methodology || []).some((m: string) => m.toLowerCase().includes('blind'))
            ? `<span class="px-2 py-0.5 bg-emerald-900/30 text-emerald-400 text-xs rounded border border-emerald-900/50">Blinded</span>` 
            : '';

          const sampleHtml = paper.sample_size 
            ? `<span class="text-slate-700">•</span><span class="text-slate-400 flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>N=${paper.sample_size}</span>` 
            : '';

          const journalHtml = paper.journal 
            ? `<span class="text-slate-700">•</span><span class="text-slate-400 italic">${paper.journal}</span>` 
            : '';

          const abstractHtml = paper.abstract 
            ? `<p class="text-slate-400 text-sm leading-relaxed line-clamp-2 mt-1">${paper.abstract}</p>` 
            : '';

          html += `
            <article class="group bg-slate-900 border border-slate-800 hover:border-slate-600 rounded-xl p-6 transition-all duration-300 hover:shadow-lg hover:shadow-black/50 relative overflow-hidden">
              <div class="absolute left-0 top-0 bottom-0 w-1 ${qualityClass}"></div>
              <div class="flex flex-col gap-3 pl-3">
                <div class="flex justify-between items-start gap-4">
                  <h3 class="text-xl font-semibold text-slate-100 group-hover:text-amber-400 transition-colors leading-snug">
                    <a href="/paper/${paper.id}" class="hover:underline decoration-amber-500/50 underline-offset-4">${paper.title}</a>
                  </h3>
                  <span class="text-sm font-mono text-slate-500 whitespace-nowrap bg-slate-950 px-2 py-1 rounded border border-slate-800">${paper.year || 'n.d.'}</span>
                </div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
                  <span class="text-slate-300 font-medium">${authorDisplay}</span>
                  ${journalHtml}
                  ${sampleHtml}
                </div>
                ${abstractHtml}
                <div class="flex flex-wrap gap-2 pt-2">
                  ${tagsHtml}
                  ${blindedBadge}
                </div>
              </div>
            </article>
          `;
        });
        container.innerHTML = html;
      });
    }
  </script>
</Layout>