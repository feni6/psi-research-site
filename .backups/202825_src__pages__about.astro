---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Compute stats dynamically
const papers = catalog.papers;
const totalPapers = papers.length;

// Unique Authors
const allAuthors = papers.flatMap(p => p.authors || []);
const totalAuthors = new Set(allAuthors).size;

// Unique Journals
const allJournals = papers.map(p => p.journal).filter(Boolean);
const totalJournals = new Set(allJournals).size;

// Year Range
const years = papers.map(p => p.year).filter(y => typeof y === 'number');
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

// Domains/Categories
const allDomains = papers.map(p => p.psi_domain).filter(Boolean);
const totalDomains = new Set(allDomains).size;
---

<Layout title="About" description="Learn about the mission, methodology, and epistemic principles of the Psi Research Library.">
  <main class="max-w-6xl mx-auto px-4 py-12 space-y-24">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 font-medium">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-amber-400 transition-colors">Home</a></li>
        <li class="text-slate-700">/</li>
        <li class="text-amber-400">About</li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <section class="relative text-center space-y-8 py-12">
      <!-- Background Glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-amber-500/5 blur-[120px] rounded-full -z-10 pointer-events-none"></div>
      
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-xs font-semibold uppercase tracking-wider mb-4">
        <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
        Project Overview
      </div>

      <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-tight">
        About the <br class="hidden md:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 via-amber-400 to-amber-600">Psi Research Library</span>
      </h1>
      
      <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto leading-relaxed font-light">
        A curated, machine-readable archive of peer-reviewed research on psi phenomena, built for <span class="text-white font-medium">epistemic transparency</span> and rigorous inquiry.
      </p>
    </section>

    <!-- At A Glance Stats -->
    <section class="grid grid-cols-2 md:grid-cols-5 gap-4 md:gap-6">
      <!-- Stat 1 -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:border-amber-400/30 transition-colors group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-1 group-hover:text-amber-400 transition-colors">{totalPapers}</div>
        <div class="text-xs text-slate-500 font-medium uppercase tracking-wider">Total Papers</div>
      </div>
      <!-- Stat 2 -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:border-amber-400/30 transition-colors group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-1 group-hover:text-amber-400 transition-colors">{totalAuthors}</div>
        <div class="text-xs text-slate-500 font-medium uppercase tracking-wider">Authors</div>
      </div>
      <!-- Stat 3 -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:border-amber-400/30 transition-colors group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-1 group-hover:text-amber-400 transition-colors">{totalJournals}</div>
        <div class="text-xs text-slate-500 font-medium uppercase tracking-wider">Journals</div>
      </div>
      <!-- Stat 4 -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:border-amber-400/30 transition-colors group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-1 group-hover:text-amber-400 transition-colors">{minYear}–{maxYear}</div>
        <div class="text-xs text-slate-500 font-medium uppercase tracking-wider">Year Range</div>
      </div>
      <!-- Stat 5 -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:border-amber-400/30 transition-colors group">
        <div class="text-3xl md:text-4xl font-bold text-white mb-1 group-hover:text-amber-400 transition-colors">{totalDomains}</div>
        <div class="text-xs text-slate-500 font-medium uppercase tracking-wider">Domains</div>
      </div>
    </section>

    <!-- Mission Statement -->
    <section class="bg-gradient-to-br from-slate-900 to-slate-950 border border-slate-800 rounded-2xl p-8 md:p-12 shadow-2xl shadow-black/40 relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-amber-500/5 blur-[80px] rounded-full pointer-events-none"></div>
      
      <div class="relative z-10 flex flex-col md:flex-row items-start gap-8">
        <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-amber-400/10 flex items-center justify-center text-4xl border border-amber-400/20">
          🎯
        </div>
        <div class="space-y-4">
          <h2 class="text-3xl font-bold text-white">Our Mission</h2>
          <p class="text-lg text-slate-300 leading-relaxed">
            The Psi Research Library is a curated collection of peer-reviewed research on psi phenomena, built with <strong class="text-amber-400">epistemic transparency</strong>. Our goal is not to advocate for or against psi claims, but to present the evidence — both supportive and critical — in a structured, searchable format.
          </p>
          <p class="text-slate-400 leading-relaxed">
            We serve researchers, students, curious skeptics, and AI agents alike by providing a neutral ground for examining the data. By standardizing metadata and methodology scores, we make it easier to compare studies across decades of research.
          </p>
        </div>
      </div>
    </section>

    <!-- What Makes This Library Different -->
    <section>
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-4">What Makes This Library Different</h2>
        <p class="text-slate-400 max-w-2xl mx-auto">
          Most archives are passive. We actively structure data to highlight methodological quality and debate context.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <!-- Diff 1 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-2xl mb-4">⚖️</div>
          <h3 class="text-xl font-semibold text-white mb-2">Both Sides Included</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Every major controversy includes papers arguing <em>for</em> and <em>against</em> the phenomenon. We do not hide negative results or replication failures.
          </p>
        </div>
        <!-- Diff 2 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-2xl mb-4">📊</div>
          <h3 class="text-xl font-semibold text-white mb-2">Methodology Scores</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Every paper is tagged with methodological metadata (sample size, controls, blinding) allowing you to filter by rigor, not just conclusion.
          </p>
        </div>
        <!-- Diff 3 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 transition-all duration-300">
          <div class="w-12 h-12 rounded-lg bg-slate-800 flex items-center justify-center text-2xl mb-4">🛡️</div>
          <h3 class="text-xl font-semibold text-white mb-2">Skeptic Prominence</h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            Critical papers and skeptical analyses are given equal prominence in search results and controversy maps to ensure balanced viewing.
          </p>
        </div>
      </div>
    </section>

    <!-- Epistemic Principles -->
    <section class="bg-slate-900/30 border border-slate-800 rounded-2xl p-8 md:p-12">
      <h2 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
        <span class="text-amber-400">🛡️</span> Core Principles
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Principle 1 -->
        <div class="flex gap-4 p-4 rounded-lg hover:bg-slate-900/50 transition-colors">
          <div class="text-3xl">🧐</div>
          <div>
            <h3 class="text-white font-semibold text-lg">Epistemic Balance</h3>
            <p class="text-slate-400 text-sm mt-1">We prioritize neutral categorization over advocacy. The library is a tool for inquiry, not a manifesto.</p>
          </div>
        </div>
        <!-- Principle 2 -->
        <div class="flex gap-4 p-4 rounded-lg hover:bg-slate-900/50 transition-colors">
          <div class="text-3xl">🔍</div>
          <div>
            <h3 class="text-white font-semibold text-lg">Methodological Transparency</h3>
            <p class="text-slate-400 text-sm mt-1">Full documentation of how papers were selected, processed, and categorized, including known biases.</p>
          </div>
        </div>
        <!-- Principle 3 -->
        <div class="flex gap-4 p-4 rounded-lg hover:bg-slate-900/50 transition-colors">
          <div class="text-3xl">🔓</div>
          <div>
            <h3 class="text-white font-semibold text-lg">Open Access Data</h3>
            <p class="text-slate-400 text-sm mt-1">The underlying catalog is available as JSON. We believe data about science should be open to all.</p>
          </div>
        </div>
        <!-- Principle 4 -->
        <div class="flex gap-4 p-4 rounded-lg hover:bg-slate-900/50 transition-colors">
          <div class="text-3xl">🤖</div>
          <div>
            <h3 class="text-white font-semibold text-lg">Machine Readable</h3>
            <p class="text-slate-400 text-sm mt-1">Structured specifically for LLM consumption via llms.txt and API, enabling advanced AI analysis.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Was Built -->
    <section class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-white flex items-center gap-3">
          <span class="text-amber-400">🏗️</span> How It Was Built
        </h2>
        <div class="prose prose-invert prose-slate">
          <p class="text-slate-300 leading-relaxed text-lg">
            The library was curated using a hybrid approach: systematic literature review combined with <strong class="text-white">AI-assisted processing</strong>.
          </p>
          <p class="text-slate-400 leading-relaxed">
            Paper metadata was extracted and structured using large language models (Claude 3.5, Qwen 2.5), then rigorously validated against original sources by human curators. This allowed us to process a vast volume of literature while maintaining high accuracy in categorization and summarization.
          </p>
          <ul class="space-y-2 text-slate-400 mt-4">
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
              Sources: PubMed, PsycINFO, JPAR, Google Scholar
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
              Validation: Human-in-the-loop verification
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
              Bias Check: Automated flagging of potential conflicts
            </li>
          </ul>
        </div>
        <a href="/method" class="inline-flex items-center text-amber-400 hover:text-amber-300 font-medium transition-colors group">
          Read the full methodology 
          <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>
      
      <!-- Code Visual -->
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 font-mono text-xs md:text-sm text-slate-400 overflow-hidden shadow-2xl">
        <div class="flex gap-2 mb-4 border-b border-slate-800 pb-3">
          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
          <span class="ml-2 text-slate-600">curation_pipeline.log</span>
        </div>
        <div class="space-y-1 opacity-90">
          <p><span class="text-purple-400">const</span> <span class="text-blue-400">pipeline</span> = <span class="text-yellow-400">new</span> CurationPipeline();</p>
          <p class="pl-4"><span class="text-purple-400">await</span> pipeline.<span class="text-blue-400">ingest</span>(<span class="text-green-400">'peer_reviewed_sources'</span>);</p>
          <p class="pl-8">model: <span class="text-green-400">'claude-3.5-sonnet'</span>,</p>
          <p class="pl-8">fields: [<span class="text-green-400">'abstract'</span>, <span class="text-green-400">'methodology'</span>, <span class="text-green-400">'results'</span>]</p>
          <p class="pl-8">human_review: <span class="text-orange-400">true</span>,</p>
          <p class="pl-8">bias_check: <span class="text-orange-400">true</span></p>
        </div>
      </div>
    </section>

    <!-- Use This Library -->
    <section>
      <h2 class="text-2xl font-bold text-white mb-8 text-center">Use This Library</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Link 1 -->
        <a href="/paths" class="group block p-6 bg-slate-900 border border-slate-800 rounded-xl hover:border-amber-400/50 hover:bg-slate-800 transition-all">
          <div class="text-amber-400 text-2xl mb-3 group-hover:scale-110 transition-transform">🛤️</div>
          <h3 class="text-white font-semibold mb-1">Reading Paths</h3>
          <p class="text-slate-400 text-sm">Curated journeys for beginners and researchers.</p>
        </a>
        <!-- Link 2 -->
        <a href="/api" class="group block p-6 bg-slate-900 border border-slate-800 rounded-xl hover:border-cyan-400/50 hover:bg-slate-800 transition-all">
          <div class="text-cyan-400 text-2xl mb-3 group-hover:scale-110 transition-transform">⚡</div>
          <h3 class="text-white font-semibold mb-1">JSON API</h3>
          <p class="text-slate-400 text-sm">Access the full catalog programmatically.</p>
        </a>
        <!-- Link 3 -->
        <a href="/llms.txt" class="group block p-6 bg-slate-900 border border-slate-800 rounded-xl hover:border-purple-400/50 hover:bg-slate-800 transition-all">
          <div class="text-purple-400 text-2xl mb-3 group-hover:scale-110 transition-transform">🤖</div>
          <h3 class="text-white font-semibold mb-1">llms.txt</h3>
          <p class="text-slate-400 text-sm">Optimized context for AI agents and LLMs.</p>
        </a>
        <!-- Link 4 -->
        <a href="/guide" class="group block p-6 bg-slate-900 border border-slate-800 rounded-xl hover:border-emerald-400/50 hover:bg-slate-800 transition-all">
          <div class="text-emerald-400 text-2xl mb-3 group-hover:scale-110 transition-transform">📘</div>
          <h3 class="text-white font-semibold mb-1">User Guide</h3>
          <p class="text-slate-400 text-sm">How to search, filter, and interpret data.</p>
        </a>
      </div>
    </section>

    <!-- Contributors -->
    <section class="border-t border-slate-800 pt-12">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="text-center md:text-left">
          <h3 class="text-white font-bold text-lg mb-2">Curated By</h3>
          <div class="flex items-center justify-center md:justify-start gap-4">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-amber-400/20 flex items-center justify-center text-amber-400 font-bold border border-amber-400/30">J</div>
              <div>
                <div class="text-white font-medium text-sm">Jay</div>
                <div class="text-xs text-slate-500">Lead Curator</div>
              </div>
            </div>
            <div class="h-8 w-px bg-slate-800"></div>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 border border-blue-400/30">🤖</div>
              <div>
                <div class="text-white font-medium text-sm">AI Assistants</div>
                <div class="text-xs text-slate-500">Data Processing</div>
              </div>
            </div>
          </div>
        </div>
        
        <div class="text-center md:text-right">
          <p class="text-slate-500 text-sm max-w-md">
            This project represents a collaboration between human critical thinking and machine efficiency to organize complex scientific data.
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>