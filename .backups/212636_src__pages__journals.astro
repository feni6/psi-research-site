---
// src/pages/journals.astro
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Process catalog to extract journal statistics
const journalMap: Record<string, { count: number, papers: any[] }> = {};
catalog.papers.forEach((p: any) => {
  const j = p.journal || 'Unknown';
  if (!journalMap[j]) journalMap[j] = { count: 0, papers: [] };
  journalMap[j].count++;
  journalMap[j].papers.push({ id: p.id, title: p.title, year: p.year, domain: p.psi_domain });
});

// Sort by count descending
const journals = Object.entries(journalMap).sort(([,a], [,b]) => b.count - a.count);
---

<Layout title="Journal Index" description="A comprehensive index of journals publishing psi research, ranked by volume of papers in our catalog.">
  <div class="max-w-4xl mx-auto px-4 py-8">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-400 mb-6">
      <a href="/" class="hover:text-amber-400 transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-slate-200">Journals</span>
    </nav>

    <!-- Header -->
    <header class="mb-8 border-b border-slate-800 pb-6">
      <h1 class="text-3xl font-bold text-white mb-2">Journal Index</h1>
      <p class="text-slate-400">
        Exploring <span class="text-amber-400 font-semibold">{journals.length}</span> unique publication venues 
        containing <span class="text-amber-400 font-semibold">{catalog.papers.length}</span> papers.
      </p>
    </header>

    <!-- Search Input -->
    <div class="mb-8 relative">
      <input 
        type="text" 
        id="journal-search" 
        placeholder="Filter journals by name..." 
        class="w-full bg-slate-900 border border-slate-700 text-slate-200 rounded-lg py-3 px-4 focus:outline-none focus:border-amber-400 focus:ring-1 focus:ring-amber-400 transition-all placeholder-slate-600"
      />
      <svg class="w-5 h-5 text-slate-500 absolute right-3 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </div>

    <!-- Journal List -->
    <div class="space-y-4" id="journal-list">
      {journals.map(([name, data]) => (
        <div class="journal-entry bg-slate-900 border border-slate-800 rounded-lg overflow-hidden transition-all hover:border-slate-700">
          <details class="group">
            <summary class="flex justify-between items-center p-4 cursor-pointer list-none select-none bg-slate-900 hover:bg-slate-800/50 transition-colors">
              <div class="flex items-center gap-3">
                <span class="flex items-center justify-center w-8 h-8 rounded bg-slate-800 text-amber-400 text-sm font-mono font-bold">
                  {data.count}
                </span>
                <h3 class="text-lg font-medium text-slate-200 group-open:text-amber-400 transition-colors">
                  {name}
                </h3>
              </div>
              <svg class="w-5 h-5 text-slate-500 transform group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </summary>
            
            <div class="p-4 pt-0 border-t border-slate-800/50 bg-slate-900/50">
              <ul class="divide-y divide-slate-800/50 mt-2">
                {data.papers.map((paper: any) => (
                  <li class="py-3 first:pt-4 last:pb-0">
                    <a href={`/paper/${paper.id}`} class="group flex flex-col sm:flex-row sm:items-baseline gap-2 hover:text-amber-400 transition-colors">
                      <span class="font-medium text-slate-300 group-hover:text-amber-400 line-clamp-1">{paper.title}</span>
                      <div class="flex items-center gap-2 text-xs text-slate-500 shrink-0">
                        <span>({paper.year})</span>
                        {paper.domain && (
                          <span class="px-2 py-0.5 rounded-full bg-slate-800 text-slate-400 border border-slate-700">
                            {paper.domain}
                          </span>
                        )}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        </div>
      ))}
    </div>

    <!-- Client-side Search Script -->
    <script>
      const searchInput = document.getElementById('journal-search') as HTMLInputElement;
      const journalEntries = document.querySelectorAll('.journal-entry');

      searchInput?.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        
        journalEntries.forEach(entry => {
          const summary = entry.querySelector('summary');
          const journalName = summary?.textContent?.toLowerCase() || '';
          
          if (journalName.includes(query)) {
            (entry as HTMLElement).classList.remove('hidden');
          } else {
            (entry as HTMLElement).classList.add('hidden');
          }
        });
      });
    </script>

  </div>
</Layout>