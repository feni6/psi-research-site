---
// src/pages/journals.astro
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import catalog from '../data/catalog.json';

// Process catalog to extract journal statistics
const journalMap: Record<string, { count: number, papers: any[], years: number[] }> = {};

catalog.papers.forEach((p: any) => {
  const j = p.journal || 'Unknown Journal';
  if (!journalMap[j]) {
    journalMap[j] = { count: 0, papers: [], years: [] };
  }
  journalMap[j].count++;
  journalMap[j].papers.push({ id: p.id, title: p.title, year: p.year, domain: p.psi_domain });
  journalMap[j].years.push(p.year);
});

// Sort papers within each journal by year (descending) to get most recent
Object.values(journalMap).forEach((data) => {
  data.papers.sort((a, b) => b.year - a.year);
});

// Convert to array and sort by count descending
const allJournals = Object.entries(journalMap).sort(([, a], [, b]) => b.count - a.count);

// Extract Top 5 for Key Journals section
const top5Journals = allJournals.slice(0, 5);

// Stats
const totalJournals = allJournals.length;
const totalPapers = catalog.papers.length;
---

<Layout title="Journal Index" description="A comprehensive index of journals publishing psi research, ranked by volume of papers in our catalog.">
  <div class="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Breadcrumb -->
    <Breadcrumb 
      items={[
        { label: 'Home', href: '/' },
        { label: 'Journals', href: '/journals' }
      ]} 
    />

    <!-- Header & Stats -->
    <header class="mb-10 border-b border-slate-800 pb-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
          <h1 class="text-4xl font-bold text-white mb-3 tracking-tight">Journal Index</h1>
          <p class="text-slate-400 text-lg max-w-2xl">
            Explore the publication landscape of psi research. Filter by venue to see specific contributions to the field.
          </p>
        </div>
        <div class="flex gap-6 bg-slate-900/50 p-4 rounded-lg border border-slate-800">
          <div class="text-center">
            <div class="text-2xl font-bold text-amber-400 font-mono">{totalJournals}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider">Journals</div>
          </div>
          <div class="w-px bg-slate-800"></div>
          <div class="text-center">
            <div class="text-2xl font-bold text-white font-mono">{totalPapers}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider">Total Papers</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Key Journals Section (Top 5) -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-6">
        <div class="p-2 bg-amber-400/10 rounded-lg">
          <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-white">Key Journals</h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
        {top5Journals.map(([name, data], index) => {
          const minYear = Math.min(...data.years);
          const maxYear = Math.max(...data.years);
          const recentPapers = data.papers.slice(0, 3);
          
          return (
            <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="group block h-full bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300 shadow-lg shadow-black/20">
              <div class="flex justify-between items-start mb-4">
                <span class="text-4xl font-black text-slate-800 group-hover:text-amber-400/20 transition-colors">#{index + 1}</span>
                <span class="bg-amber-400/10 text-amber-400 text-xs font-bold px-2 py-1 rounded uppercase tracking-wide">{data.count} Papers</span>
              </div>
              
              <h3 class="text-lg font-bold text-slate-200 mb-1 line-clamp-2 group-hover:text-amber-400 transition-colors h-14">
                {name}
              </h3>
              
              <div class="text-xs text-slate-500 font-mono mb-4">
                {minYear} — {maxYear}
              </div>

              <div class="space-y-2 border-t border-slate-800 pt-3">
                <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider mb-2">Recent</p>
                {recentPapers.map((paper: any) => (
                  <div class="text-xs text-slate-400 group-hover:text-slate-300 transition-colors line-clamp-1">
                    <span class="text-amber-400/70 mr-1">•</span>
                    {paper.title} <span class="text-slate-600">({paper.year})</span>
                  </div>
                ))}
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <!-- Search & Filter -->
    <div class="sticky top-4 z-20 mb-8">
      <div class="relative max-w-2xl mx-auto">
        <input 
          type="text" 
          id="journal-search" 
          placeholder="Search journals by name..." 
          class="w-full bg-slate-900/90 backdrop-blur border border-slate-700 text-slate-200 rounded-xl py-4 pl-12 pr-4 focus:outline-none focus:border-amber-400 focus:ring-1 focus:ring-amber-400 transition-all placeholder-slate-600 shadow-xl"
        />
        <svg class="w-6 h-6 text-slate-500 absolute left-4 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <span id="search-count" class="absolute right-4 top-4 text-xs text-slate-500 font-mono bg-slate-950 px-2 py-1 rounded border border-slate-800"></span>
      </div>
    </div>

    <!-- Full Journal Directory -->
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-semibold text-white flex items-center gap-2">
          <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
          Complete Directory
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="journal-list">
        {allJournals.map(([name, data]) => {
          const minYear = Math.min(...data.years);
          const maxYear = Math.max(...data.years);
          const recentPapers = data.papers.slice(0, 3);
          
          return (
            <div class="journal-card group bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-slate-700 transition-all duration-300 flex flex-col">
              <!-- Card Header -->
              <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="p-5 block flex-grow">
                <div class="flex justify-between items-start mb-3">
                  <span class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700">
                    {data.count} Papers
                  </span>
                  <span class="text-xs text-slate-500 font-mono">
                    {minYear}–{maxYear}
                  </span>
                </div>
                
                <h3 class="text-xl font-bold text-slate-200 mb-4 group-hover:text-amber-400 transition-colors line-clamp-2">
                  {name}
                </h3>

                <div class="space-y-2">
                  <p class="text-xs text-slate-500 font-semibold uppercase tracking-wider">Latest Publications</p>
                  <ul class="space-y-2">
                    {recentPapers.map((paper: any) => (
                      <li key={paper.id} class="text-sm text-slate-400 group-hover:text-slate-300 transition-colors">
                        <a href={`/paper/${paper.id}`} class="hover:text-amber-400 hover:underline decoration-amber-400/50 underline-offset-2 block">
                          {paper.title}
                        </a>
                        <span class="text-xs text-slate-600 block mt-0.5">{paper.year}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </a>
              
              <!-- Card Footer Action -->
              <div class="px-5 py-3 bg-slate-950/50 border-t border-slate-800/50">
                <a href={`/catalog?journal=${encodeURIComponent(name)}`} class="text-xs font-medium text-amber-400 hover:text-amber-300 flex items-center gap-1 group-hover:gap-2 transition-all">
                  View all papers from this journal
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
          );
        })}
      </div>
      
      <!-- No Results State (Hidden by default) -->
      <div id="no-results" class="hidden text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-900 mb-4">
          <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-slate-300">No journals found</h3>
        <p class="text-slate-500 mt-1">Try adjusting your search terms.</p>
      </div>
    </section>

    <!-- Client-side Search Script -->
    <script>
      const searchInput = document.getElementById('journal-search') as HTMLInputElement;
      const journalCards = document.querySelectorAll('.journal-card');
      const searchCount = document.getElementById('search-count');
      const noResults = document.getElementById('no-results');
      const journalList = document.getElementById('journal-list');

      searchInput?.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        let visibleCount = 0;
        
        journalCards.forEach(card => {
          const titleElement = card.querySelector('h3');
          const journalName = titleElement?.textContent?.toLowerCase() || '';
          
          if (journalName.includes(query)) {
            (card as HTMLElement).classList.remove('hidden');
            visibleCount++;
          } else {
            (card as HTMLElement).classList.add('hidden');
          }
        });

        // Update count badge
        if (searchCount) {
          if (query) {
            searchCount.textContent = `${visibleCount} found`;
            searchCount.classList.remove('hidden');
          } else {
            searchCount.classList.add('hidden');
          }
        }

        // Toggle no results message
        if (journalList) {
          if (visibleCount === 0) {
            journalList.classList.add('hidden');
            noResults?.classList.remove('hidden');
          } else {
            journalList.classList.remove('hidden');
            noResults?.classList.add('hidden');
          }
        }
      });
    </script>

  </div>
</Layout>