---
import Layout from '../../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

// Read all era markdown files
const timelineDir = join(process.cwd(), 'src/data/timeline');
const eraFiles = readdirSync(timelineDir).filter(f => f.endsWith('.md') && f.startsWith('era_'));

// Color configuration for eras (bg, border, text, glow, gradient)
const eraConfig: Record<string, { bg: string, border: string, text: string, glow: string, gradient: string, icon: string }> = {
  'era_1_pre_modern': { bg: 'bg-purple-500', border: 'border-purple-400', text: 'text-purple-400', glow: 'shadow-purple-500/20', gradient: 'from-purple-600/10 to-purple-900/5', icon: '🔮' },
  'era_2_rhine': { bg: 'bg-blue-500', border: 'border-blue-400', text: 'text-blue-400', glow: 'shadow-blue-500/20', gradient: 'from-blue-600/10 to-blue-900/5', icon: '🔬' },
  'era_3_ganzfeld': { bg: 'bg-cyan-500', border: 'border-cyan-400', text: 'text-cyan-400', glow: 'shadow-cyan-500/20', gradient: 'from-cyan-600/10 to-cyan-900/5', icon: '🧠' },
  'era_4_stargate': { bg: 'bg-green-500', border: 'border-green-400', text: 'text-green-400', glow: 'shadow-green-500/20', gradient: 'from-green-600/10 to-green-900/5', icon: '👁️' },
  'era_5_modern': { bg: 'bg-amber-500', border: 'border-amber-400', text: 'text-amber-400', glow: 'shadow-amber-500/20', gradient: 'from-amber-600/10 to-amber-900/5', icon: '📊' },
  'era_6_current': { bg: 'bg-red-500', border: 'border-red-400', text: 'text-red-400', glow: 'shadow-red-500/20', gradient: 'from-red-600/10 to-red-900/5', icon: '🚀' },
};

const eras = eraFiles.map((file) => {
  const filePath = join(timelineDir, file);
  const content = readFileSync(filePath, 'utf-8');
  
  // Extract first non-heading paragraph for "Key Developments"
  const lines = content.split('\n');
  let description = '';
  let inFrontmatter = false;
  
  for (const line of lines) {
    const trimmed = line.trim();
    
    // Track frontmatter
    if (trimmed === '---') {
      inFrontmatter = !inFrontmatter;
      continue;
    }
    
    // Skip if in frontmatter
    if (inFrontmatter) continue;
    
    // Skip empty lines and headings
    if (!trimmed || trimmed.startsWith('#')) continue;
    
    // Found first paragraph
    description = trimmed;
    break;
  }
  
  // Count paper references: [catalog ID: xxx] or backtick-wrapped IDs
  const catalogMatches = content.match(/\[catalog ID: [a-z0-9_]+\]/gi) || [];
  const backtickMatches = content.match(/`[a-z0-9_]+`/gi) || [];
  const paperCount = catalogMatches.length + backtickMatches.length;
  
  // Extract ID from filename
  const id = file.replace('.md', '');
  
  // Try to extract title from first heading
  const titleMatch = content.match(/^#\s+(.+)$/m);
  let title = titleMatch ? titleMatch[1] : id.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
  
  // Try to extract years from content
  const yearsMatch = content.match(/(\d{4}[–-]\d{4}|\d{4}[–-]present)/i);
  const years = yearsMatch ? yearsMatch[1] : '';
  
  // Get config or fallback
  const config = eraConfig[id] || { bg: 'bg-slate-500', border: 'border-slate-400', text: 'text-slate-400', glow: 'shadow-slate-500/20', gradient: 'from-slate-600/10 to-slate-900/5', icon: '📜' };
  
  return {
    id,
    title,
    years,
    desc: description,
    paperCount,
    ...config,
  };
});

// Sort eras by ID to maintain chronological order
eras.sort((a, b) => a.id.localeCompare(b.id));
---

<Layout title="Timeline">
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <ol class="flex items-center gap-2 text-sm text-slate-500">
      <li><a href="/" class="hover:text-amber-400 transition">Home</a></li>
      <li>/</li>
      <li class="text-slate-300">Timeline</li>
    </ol>
  </nav>
  
  <!-- Header Section -->
  <div class="mb-12">
    <h1 class="text-4xl font-bold mb-3 text-slate-100">Historical Timeline</h1>
    <p class="text-slate-400 max-w-2xl text-lg leading-relaxed">
      Trace the evolution of psi research from Victorian séance investigations to modern pre-registered experiments.
    </p>
  </div>
  
  <!-- Timeline Container -->
  <div class="relative max-w-5xl">
    <!-- Gradient Timeline Line -->
    <div class="absolute left-[23px] top-4 bottom-0 w-2 bg-gradient-to-b from-purple-600 via-blue-600 via-cyan-600 via-green-600 via-amber-600 to-red-600 rounded-full opacity-70 shadow-lg"></div>
    
    <!-- Era Cards -->
    <div class="space-y-10">
      {eras.map((era, index) => (
        <a href={`/timeline/${era.id}`} class="timeline-item block relative pl-20 group opacity-0 translate-y-8 transition-all duration-700 ease-out">
          
          <!-- Era Marker Dot -->
          <div class={`absolute left-0 top-2 w-12 h-12 rounded-full bg-slate-950 border-4 ${era.border} flex items-center justify-center z-10 shadow-lg ${era.glow} group-hover:scale-110 group-hover:shadow-xl transition-all duration-300`}>
            <span class="text-lg">{era.icon}</span>
          </div>
          
          <!-- Card Content -->
          <div class={`relative bg-gradient-to-r ${era.gradient} backdrop-blur-sm border ${era.border} rounded-2xl p-6 group-hover:border-opacity-60 group-hover:shadow-lg transition-all duration-300 overflow-hidden`}>
            <!-- Subtle gradient overlay -->
            <div class={`absolute inset-0 bg-gradient-to-r ${era.gradient} opacity-50 pointer-events-none`}></div>
            
            <!-- Card Content (above gradient) -->
            <div class="relative z-10">
              <!-- Header Row -->
              <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 mb-4">
                <!-- Era Badge -->
                <span class={`inline-flex items-center gap-2 font-mono text-xs font-bold tracking-wider uppercase ${era.text} bg-slate-950/80 px-3 py-1.5 rounded-lg border ${era.border} shadow-sm`}>
                  <span class={`w-2 h-2 rounded-full ${era.bg} animate-pulse`}></span>
                  {era.years}
                </span>
                
                <!-- Title -->
                <h3 class="text-2xl font-bold text-slate-100 group-hover:text-white transition-colors">
                  {era.title}
                </h3>
                
                <!-- Paper Count Badge -->
                {era.paperCount > 0 && (
                  <span class="sm:ml-auto inline-flex items-center gap-2 text-xs font-semibold text-slate-300 bg-slate-950/80 px-3 py-1.5 rounded-full border border-slate-700 group-hover:border-slate-600 transition-colors">
                    <svg class={`w-4 h-4 ${era.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                    {era.paperCount} paper{era.paperCount !== 1 ? 's' : ''}
                  </span>
                )}
              </div>
              
              <!-- Description Section -->
              <div class="space-y-3">
                <div class="flex items-center gap-2">
                  <div class={`w-1 h-4 ${era.bg} rounded-full`}></div>
                  <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest">Key Developments</p>
                </div>
                <p class="text-slate-300 leading-relaxed group-hover:text-slate-200 transition-colors text-base">
                  {era.desc}
                </p>
              </div>
              
              <!-- Hover Indicator -->
              <div class="mt-4 flex items-center gap-2 text-sm">
                <span class={`font-medium ${era.text} opacity-0 group-hover:opacity-100 transition-opacity duration-300`}>
                  Explore this era →
                </span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Legend Section -->
  <div class="mt-16 max-w-5xl">
    <div class="bg-slate-900/50 backdrop-blur-sm border border-slate-800 rounded-xl p-6">
      <h4 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Era Color Legend</h4>
      <div class="flex flex-wrap gap-4">
        {eras.map(era => (
          <div class="flex items-center gap-2">
            <span class={`w-3 h-3 rounded-full ${era.bg} shadow-sm ${era.glow}`}></span>
            <span class="text-xs text-slate-400">{era.title}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll Animation Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.remove('opacity-0', 'translate-y-8');
              entry.target.classList.add('opacity-100', 'translate-y-0');
            }, index * 50); 
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      const items = document.querySelectorAll('.timeline-item');
      items.forEach(item => observer.observe(item));
    });
  </script>
</Layout>