---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import catalog from '../data/catalog.json';

// --- Methodology Stats Calculation ---
const papersWithMethodology = catalog.papers.filter(p => p.methodology);
const totalPapers = catalog.papers.length;

// Blinding Distribution
const blindingCounts = {
  double: papersWithMethodology.filter(p => p.methodology?.blinding === 'double').length,
  single: papersWithMethodology.filter(p => p.methodology?.blinding === 'single').length,
  none: papersWithMethodology.filter(p => p.methodology?.blinding === 'none').length,
  unknown: papersWithMethodology.filter(p => !p.methodology?.blinding || p.methodology?.blinding === 'unknown').length,
};

// Pre-registration Stats
const preregYes = papersWithMethodology.filter(p => p.methodology?.preregistered === true).length;
const preregNo = papersWithMethodology.filter(p => p.methodology?.preregistered === false).length;
const preregUnknown = papersWithMethodology.filter(p => p.methodology?.preregistered === undefined || p.methodology?.preregistered === null).length;
const preregPercentage = papersWithMethodology.length > 0 ? Math.round((preregYes / papersWithMethodology.length) * 100) : 0;

// --- Quality Distribution Calculation ---
// Strong: Double-blind + Pre-registered + n > 100
// Moderate: Meets 2/3 criteria
// Weak: Meets 0-1 criteria
let qualityStrong = 0;
let qualityModerate = 0;
let qualityWeak = 0;

papersWithMethodology.forEach(p => {
  const m = p.methodology;
  if (!m) return;

  let score = 0;
  
  // Criterion 1: Double Blind
  if (m.blinding === 'double') score++;
  
  // Criterion 2: Pre-registered
  if (m.preregistered === true) score++;
  
  // Criterion 3: Sample Size > 100
  const n = typeof m.sampleSize === 'number' ? m.sampleSize : parseInt(m.sampleSize || '0');
  if (n > 100) score++;

  if (score === 3) qualityStrong++;
  else if (score === 2) qualityModerate++;
  else qualityWeak++;
});

const totalAnalyzed = papersWithMethodology.length;
const qualityStrongPct = totalAnalyzed > 0 ? Math.round((qualityStrong / totalAnalyzed) * 100) : 0;
const qualityModeratePct = totalAnalyzed > 0 ? Math.round((qualityModerate / totalAnalyzed) * 100) : 0;
const qualityWeakPct = totalAnalyzed > 0 ? Math.round((qualityWeak / totalAnalyzed) * 100) : 0;

// --- Markdown Processing ---
function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

const methodPath = path.join(process.cwd(), 'src/data/method.md');
let content = fs.readFileSync(methodPath, 'utf-8');

// Extract headings for ToC
const headingRegex = /^## (.*?)$/gm;
const tocItems: { id: string; text: string }[] = [];
let match;
let sectionCount = 0;

const scanContent = content;
while ((match = headingRegex.exec(scanContent)) !== null) {
  sectionCount++;
  const text = match[1].trim();
  tocItems.push({
    id: slugify(text),
    text: `${sectionCount}. ${text}`,
  });
}

// Inject IDs and Section Numbers
sectionCount = 0;
content = content.replace(/^## (.*?)$/gm, (match, p1) => {
  sectionCount++;
  const id = slugify(p1.trim());
  return `## <span id="${id}">${sectionCount}. ${p1}</span>`;
});

const html = marked(content);
---

<Layout title="Methodology & Scoring">
  <!-- Breadcrumbs -->
  <div class="mb-6">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Methodology', href: '/methodology' }]} />
  </div>

  <!-- Page Header -->
  <div class="mb-10">
    <h1 class="text-4xl font-bold text-slate-100 mb-4">Library Methodology</h1>
    <p class="text-slate-400 text-lg max-w-3xl">
      Understanding how papers are evaluated, scored, and categorized within the Psi Research Library.
      Our scoring system prioritizes methodological rigor to help researchers identify high-quality evidence.
    </p>
  </div>

  <!-- 1. Why This Matters Callout -->
  <div class="mb-12 bg-gradient-to-r from-amber-500/10 to-slate-900 border border-amber-500/30 rounded-2xl p-8 relative overflow-hidden">
    <div class="absolute top-0 right-0 p-4 opacity-10">
      <svg class="w-32 h-32 text-amber-500" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.5L18.5 19H5.5L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"/></svg>
    </div>
    <div class="relative z-10">
      <h2 class="text-2xl font-bold text-amber-400 mb-3 flex items-center gap-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Why Methodology Transparency Matters
      </h2>
      <p class="text-slate-300 text-lg leading-relaxed max-w-4xl">
        In controversial fields like parapsychology, <strong class="text-white">how</strong> a study is conducted is often more important than the result itself. 
        By explicitly scoring blinding, pre-registration, and sample size, we separate signal from noise. 
        This library doesn't just collect papers; it filters for <span class="text-amber-400">reproducibility</span> and <span class="text-amber-400">rigor</span>.
      </p>
    </div>
  </div>

  <!-- 2. Interactive "Rate a Study" Walkthrough -->
  <section class="mb-16">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-8 w-1 bg-blue-500 rounded-full"></div>
      <h2 class="text-2xl font-bold text-slate-100">Interactive: How We Score</h2>
    </div>
    
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden shadow-2xl">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Left: The "Paper" Card -->
        <div class="p-8 border-b lg:border-b-0 lg:border-r border-slate-800 bg-slate-950/50">
          <div class="flex items-center justify-between mb-6">
            <span class="text-xs font-bold text-blue-400 uppercase tracking-widest">Sample Study Metadata</span>
            <span class="px-2 py-1 bg-slate-800 rounded text-xs text-slate-400 font-mono">ID: #8492</span>
          </div>
          
          <h3 class="text-xl font-bold text-slate-200 mb-2">"Remote Viewing and Target Identification"</h3>
          <p class="text-slate-500 text-sm mb-6">Journal of Parapsychology, 1998</p>

          <div class="space-y-6">
            <!-- Step 1: Sample Size -->
            <div class="group">
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-medium text-slate-300">1. Sample Size (N)</label>
                <span class="text-sm font-mono text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded">N = 150</span>
              </div>
              <div class="h-2 bg-slate-800 rounded-full overflow-hidden">
                <div class="h-full bg-blue-500 w-3/4"></div>
              </div>
              <p class="text-xs text-slate-500 mt-1">Large sample (>100) adds significant weight to findings.</p>
            </div>

            <!-- Step 2: Blinding -->
            <div class="group">
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-medium text-slate-300">2. Blinding Protocol</label>
                <span class="text-sm font-mono text-emerald-400 bg-emerald-500/10 px-2 py-0.5 rounded">Double-Blind</span>
              </div>
              <div class="flex gap-2 mt-2">
                <div class="h-1.5 flex-1 bg-emerald-500 rounded-full"></div>
                <div class="h-1.5 flex-1 bg-slate-800 rounded-full"></div>
                <div class="h-1.5 flex-1 bg-slate-800 rounded-full"></div>
              </div>
              <p class="text-xs text-slate-500 mt-1">Neither participant nor experimenter knew the target.</p>
            </div>

            <!-- Step 3: Pre-Registration -->
            <div class="group">
              <div class="flex justify-between items-center mb-2">
                <label class="text-sm font-medium text-slate-300">3. Pre-Registration</label>
                <span class="text-sm font-mono text-red-400 bg-red-500/10 px-2 py-0.5 rounded">Not Found</span>
              </div>
              <div class="flex gap-2 mt-2">
                <div class="h-1.5 flex-1 bg-slate-800 rounded-full"></div>
                <div class="h-1.5 flex-1 bg-slate-800 rounded-full"></div>
                <div class="h-1.5 flex-1 bg-slate-800 rounded-full"></div>
              </div>
              <p class="text-xs text-slate-500 mt-1">No public protocol found prior to data collection.</p>
            </div>
          </div>
        </div>

        <!-- Right: The Scoring Logic -->
        <div class="p-8 bg-slate-900 flex flex-col justify-center">
          <h3 class="text-lg font-bold text-slate-200 mb-6">Scoring Interpretation</h3>
          
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 font-bold shrink-0">1</div>
              <div>
                <h4 class="text-slate-200 font-bold text-sm">Sample Size Score: High</h4>
                <p class="text-slate-400 text-xs mt-1">N=150 exceeds the threshold for statistical power in this domain.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-emerald-500/20 flex items-center justify-center text-emerald-400 font-bold shrink-0">2</div>
              <div>
                <h4 class="text-slate-200 font-bold text-sm">Blinding Score: Maximum</h4>
                <p class="text-slate-400 text-xs mt-1">Double-blind protocols eliminate experimenter bias, the gold standard.</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center text-red-400 font-bold shrink-0">3</div>
              <div>
                <h4 class="text-slate-200 font-bold text-sm">Pre-Reg Score: Zero</h4>
                <p class="text-slate-400 text-xs mt-1">Lack of pre-registration increases risk of p-hacking or HARKing.</p>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-slate-800">
              <div class="flex justify-between items-end">
                <span class="text-slate-400 text-sm">Overall Quality Rating</span>
                <span class="text-2xl font-bold text-amber-400">Moderate</span>
              </div>
              <div class="w-full bg-slate-800 h-3 rounded-full mt-2 overflow-hidden">
                <div class="bg-gradient-to-r from-blue-500 via-emerald-500 to-amber-500 h-full w-2/3"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Library Statistics Dashboard -->
  <section class="mb-16">
    <div class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
          <h2 class="text-2xl font-bold text-slate-100">Library Coverage Statistics</h2>
          <p class="text-slate-400 text-sm mt-1">Based on {totalPapers.toLocaleString()} total papers in the catalog</p>
        </div>
        <div class="flex gap-4">
          <div class="text-center px-4 py-2 bg-slate-950 rounded-lg border border-slate-800">
            <div class="text-2xl font-bold text-amber-400">{papersWithMethodology.length.toLocaleString()}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide">Analyzed</div>
          </div>
          <div class="text-center px-4 py-2 bg-slate-950 rounded-lg border border-slate-800">
            <div class="text-2xl font-bold text-emerald-400">{preregPercentage}%</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide">Pre-Reg</div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Left Column: Blinding & Pre-Reg -->
        <div class="space-y-8">
          <!-- Blinding Distribution -->
          <div>
            <h3 class="text-sm font-bold text-slate-300 uppercase tracking-wider mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              Blinding Distribution
            </h3>
            <div class="space-y-3">
              <!-- Double Blind -->
              <div>
                <div class="flex justify-between text-xs mb-1 font-mono">
                  <span class="text-emerald-400">Double-Blind</span>
                  <span class="text-slate-300">{blindingCounts.double} ({(blindingCounts.double / papersWithMethodology.length * 100).toFixed(0)}%)</span>
                </div>
                <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                  <div class="bg-emerald-500 h-full transition-all duration-1000" style="width: {(blindingCounts.double / papersWithMethodology.length * 100).toFixed(1)}%"></div>
                </div>
              </div>
              <!-- Single Blind -->
              <div>
                <div class="flex justify-between text-xs mb-1 font-mono">
                  <span class="text-amber-400">Single-Blind</span>
                  <span class="text-slate-300">{blindingCounts.single} ({(blindingCounts.single / papersWithMethodology.length * 100).toFixed(0)}%)</span>
                </div>
                <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                  <div class="bg-amber-500 h-full transition-all duration-1000" style="width: {(blindingCounts.single / papersWithMethodology.length * 100).toFixed(1)}%"></div>
                </div>
              </div>
              <!-- None/Open -->
              <div>
                <div class="flex justify-between text-xs mb-1 font-mono">
                  <span class="text-red-400">Open / None</span>
                  <span class="text-slate-300">{blindingCounts.none} ({(blindingCounts.none / papersWithMethodology.length * 100).toFixed(0)}%)</span>
                </div>
                <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                  <div class="bg-red-500 h-full transition-all duration-1000" style="width: {(blindingCounts.none / papersWithMethodology.length * 100).toFixed(1)}%"></div>
                </div>
              </div>
               <!-- Unknown -->
               <div>
                <div class="flex justify-between text-xs mb-1 font-mono">
                  <span class="text-slate-500">Unknown</span>
                  <span class="text-slate-400">{blindingCounts.unknown} ({(blindingCounts.unknown / papersWithMethodology.length * 100).toFixed(0)}%)</span>
                </div>
                <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                  <div class="bg-slate-600 h-full transition-all duration-1000" style="width: {(blindingCounts.unknown / papersWithMethodology.length * 100).toFixed(1)}%"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Pre-Registration Breakdown -->
          <div>
            <h3 class="text-sm font-bold text-slate-300 uppercase tracking-wider mb-4 flex items-center gap-2">
              <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              Pre-Registration Status
            </h3>
            <div class="grid grid-cols-3 gap-3">
              <div class="bg-slate-950 rounded-lg p-3 flex flex-col items-center justify-center border border-slate-800">
                <div class="text-2xl font-bold text-emerald-400 mb-1">{preregYes}</div>
                <div class="text-[10px] text-slate-500 uppercase tracking-wide text-center">Registered</div>
              </div>
              <div class="bg-slate-950 rounded-lg p-3 flex flex-col items-center justify-center border border-slate-800">
                <div class="text-2xl font-bold text-red-400 mb-1">{preregNo}</div>
                <div class="text-[10px] text-slate-500 uppercase tracking-wide text-center">Not Reg</div>
              </div>
              <div class="bg-slate-950 rounded-lg p-3 flex flex-col items-center justify-center border border-slate-800">
                <div class="text-2xl font-bold text-slate-400 mb-1">{preregUnknown}</div>
                <div class="text-[10px] text-slate-500 uppercase tracking-wide text-center">Unknown</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Quality Distribution -->
        <div class="bg-slate-950/50 rounded-xl p-6 border border-slate-800">
          <h3 class="text-sm font-bold text-slate-300 uppercase tracking-wider mb-6 flex items-center gap-2">
            <svg class="w-4 h-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            Methodology Quality Distribution
          </h3>
          
          <p class="text-xs text-slate-400 mb-6 leading-relaxed">
            Papers are categorized based on three key criteria: <br/>
            <span class="text-slate-300">1. Double-Blind</span> • <span class="text-slate-300">2. Pre-Registered</span> • <span class="text-slate-300">3. Sample Size &gt; 100</span>
          </p>

          <div class="space-y-6">
            <!-- Strong -->
            <div>
              <div class="flex justify-between items-end mb-2">
                <div>
                  <div class="text-sm font-bold text-emerald-400">Strong Methodology</div>
                  <div class="text-xs text-slate-500">Meets all 3 criteria</div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-mono font-bold text-slate-200">{qualityStrong}</div>
                  <div class="text-xs text-slate-500">{qualityStrongPct}% of analyzed</div>
                </div>
              </div>
              <div class="w-full bg-slate-800 h-4 rounded-full overflow-hidden flex">
                <div class="bg-emerald-500 h-full" style="width: {qualityStrongPct}%"></div>
              </div>
            </div>

            <!-- Moderate -->
            <div>
              <div class="flex justify-between items-end mb-2">
                <div>
                  <div class="text-sm font-bold text-amber-400">Moderate Methodology</div>
                  <div class="text-xs text-slate-500">Meets 2 criteria</div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-mono font-bold text-slate-200">{qualityModerate}</div>
                  <div class="text-xs text-slate-500">{qualityModeratePct}% of analyzed</div>
                </div>
              </div>
              <div class="w-full bg-slate-800 h-4 rounded-full overflow-hidden flex">
                <div class="bg-amber-500 h-full" style="width: {qualityModeratePct}%"></div>
              </div>
            </div>

            <!-- Weak -->
            <div>
              <div class="flex justify-between items-end mb-2">
                <div>
                  <div class="text-sm font-bold text-red-400">Weak Methodology</div>
                  <div class="text-xs text-slate-500">Meets 0-1 criteria</div>
                </div>
                <div class="text-right">
                  <div class="text-lg font-mono font-bold text-slate-200">{qualityWeak}</div>
                  <div class="text-xs text-slate-500">{qualityWeakPct}% of analyzed</div>
                </div>
              </div>
              <div class="w-full bg-slate-800 h-4 rounded-full overflow-hidden flex">
                <div class="bg-red-500 h-full" style="width: {qualityWeakPct}%"></div>
              </div>
            </div>
          </div>

          <div class="mt-6 p-3 bg-slate-900 rounded border border-slate-800">
            <p class="text-xs text-slate-400 italic">
              "Strong" papers represent the highest tier of evidence currently available in the field.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Visual Methodology Scoring System (Existing Cards) -->
  <section class="mb-16">
    <div class="flex items-center gap-3 mb-6">
      <div class="h-8 w-1 bg-amber-500 rounded-full"></div>
      <h2 class="text-2xl font-bold text-slate-100">Scoring Criteria Details</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- Sample Size Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/50 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="p-2 bg-blue-500/10 rounded-lg">
            <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656-.126-1.283-.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
          </div>
          <h3 class="font-bold text-slate-200">Sample Size</h3>
        </div>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between items-center">
            <span class="text-slate-400">Small</span>
            <span class="text-slate-300 font-mono">&lt; 50</span>
          </div>
          <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-blue-500/50 h-full w-1/3"></div>
          </div>
          
          <div class="flex justify-between items-center mt-2">
            <span class="text-slate-400">Medium</span>
            <span class="text-slate-300 font-mono">50 - 200</span>
          </div>
          <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-blue-400 h-full w-2/3"></div>
          </div>

          <div class="flex justify-between items-center mt-2">
            <span class="text-slate-400">Large</span>
            <span class="text-slate-300 font-mono">200+</span>
          </div>
          <div class="w-full bg-slate-800 h-1.5 rounded-full overflow-hidden">
            <div class="bg-blue-300 h-full w-full"></div>
          </div>
        </div>
      </div>

      <!-- Blinding Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/50 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="p-2 bg-emerald-500/10 rounded-lg">
            <svg class="w-6 h-6 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
          </div>
          <h3 class="font-bold text-slate-200">Blinding</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-center justify-between p-2 rounded bg-slate-950/50 border border-slate-800">
            <span class="text-sm text-slate-300">Double-Blind</span>
            <span class="px-2 py-0.5 text-xs font-bold rounded bg-emerald-500/20 text-emerald-400 border border-emerald-500/30">HIGH</span>
          </div>
          <div class="flex items-center justify-between p-2 rounded bg-slate-950/50 border border-slate-800">
            <span class="text-sm text-slate-300">Single-Blind</span>
            <span class="px-2 py-0.5 text-xs font-bold rounded bg-amber-500/20 text-amber-400 border border-amber-500/30">MED</span>
          </div>
          <div class="flex items-center justify-between p-2 rounded bg-slate-950/50 border border-slate-800">
            <span class="text-sm text-slate-300">Open / None</span>
            <span class="px-2 py-0.5 text-xs font-bold rounded bg-red-500/20 text-red-400 border border-red-500/30">LOW</span>
          </div>
        </div>
      </div>

      <!-- Pre-Registration Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/50 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="p-2 bg-purple-500/10 rounded-lg">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="font-bold text-slate-200">Pre-Registration</h3>
        </div>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
            <span class="text-sm text-slate-300">Protocol Registered</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]"></div>
            <span class="text-sm text-slate-300">Not Registered</span>
          </div>
          <div class="flex items-center gap-3">
            <div class="w-3 h-3 rounded-full bg-slate-600"></div>
            <span class="text-sm text-slate-400">Status Unknown</span>
          </div>
          <p class="text-xs text-slate-500 mt-4 pt-4 border-t border-slate-800">
            Pre-registration reduces publication bias and p-hacking by defining hypotheses before data collection.
          </p>
        </div>
      </div>

      <!-- Effect Size Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/50 transition-colors">
        <div class="flex items-center gap-3 mb-4">
          <div class="p-2 bg-amber-500/10 rounded-lg">
            <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
          </div>
          <h3 class="font-bold text-slate-200">Effect Size (Cohen's d)</h3>
        </div>
        <div class="relative pt-6 pb-2">
          <div class="overflow-hidden h-4 mb-4 text-xs flex rounded bg-slate-800">
            <div style="width: 20%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-slate-600"></div>
            <div style="width: 30%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-amber-500"></div>
            <div style="width: 50%" class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-emerald-500"></div>
          </div>
          <div class="flex justify-between text-xs font-mono text-slate-400">
            <span>0.2 (Small)</span>
            <span>0.5 (Med)</span>
            <span>0.8+ (Large)</span>
          </div>
        </div>
        <p class="text-xs text-slate-500 mt-2">
          Standard interpretation of Cohen's d. In psi research, even small effect sizes (0.1-0.2) can be significant due to large sample meta-analyses.
        </p>
      </div>
    </div>
  </section>

  <!-- 5. Main Content with Typography -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
    <!-- Main Content Column -->
    <div class="lg:col-span-9">
      <article class="prose prose-invert prose-amber max-w-4xl prose-headings:scroll-mt-24 prose-a:text-amber-400 hover:prose-a:text-amber-300 prose-strong:text-slate-200">
        <!-- Executive Summary Box inside Prose context -->
        <div class="not-prose bg-slate-900 border-l-4 border-amber-500 rounded-r-lg p-6 mb-8 shadow-lg">
          <h3 class="text-amber-400 font-bold text-lg mb-4 flex items-center gap-2 !mt-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            Executive Summary
          </h3>
          <ul class="space-y-3 text-slate-300 !mb-0">
            <li class="flex items-start gap-3">
              <span class="text-amber-500 mt-1">•</span>
              <span>354 papers curated from PubMed, PsycINFO, JPAR, and specialized parapsychology journals</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 mt-1">•</span>
              <span>AI-assisted metadata extraction with human-in-the-loop validation</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 mt-1">•</span>
              <span>Both supportive and skeptical papers included — 13.8% from skeptical/critical sources</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-500 mt-1">•</span>
              <span>Full bias documentation including known limitations of the curation process</span>
            </li>
          </ul>
        </div>

        <div class="not-prose bg-amber-500/10 border border-amber-500/30 rounded-lg p-6 mb-8">
          <h3 class="text-amber-400 font-bold mb-2 !mt-0">⚠️ Transparency Notice</h3>
          <p class="text-slate-300 text-sm !mb-0">This page renders the complete, unedited <code class="bg-slate-950 px-1 py-0.5 rounded text-amber-200">_METHOD.md</code> from the library repository. It documents how the library was built, including known biases and limitations.</p>
        </div>

        <div set:html={html} />
      </article>
    </div>

    <!-- Sidebar ToC Column (Desktop Only) -->
    <aside class="hidden lg:block lg:col-span-3">
      <div class="sticky top-24 bg-slate-900/95 backdrop-blur-sm border border-slate-700 rounded-lg p-5 shadow-xl">
        <h4 class="text-slate-200 font-bold mb-4 text-sm uppercase tracking-wider border-b border-slate-800 pb-2">
          Table of Contents
        </h4>
        <nav>
          <ul class="space-y-2">
            {tocItems.map((item) => (
              <li>
                <a 
                  href={`#${item.id}`} 
                  class="text-sm text-slate-400 hover:text-amber-400 hover:bg-slate-800/50 transition-all block truncate py-1 px-2 rounded"
                >
                  {item.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </aside>
  </div>

  <!-- Back to Top Button -->
  <button 
    id="backToTop"
    class="fixed bottom-8 right-8 bg-amber-500 text-slate-950 p-3 rounded-full shadow-lg hover:bg-amber-400 transition-all opacity-0 pointer-events-none transform translate-y-4 z-50"
    aria-label="Back to top"
    onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
  >
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
    </svg>
  </button>

  <script>
    const backToTopBtn = document.getElementById('backToTop');
    
    if (backToTopBtn) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          backToTopBtn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
        } else {
          backToTopBtn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
        }
      });
    }
  </script>
</Layout>