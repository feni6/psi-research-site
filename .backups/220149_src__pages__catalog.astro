---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

const papers = catalog.papers.sort((a: any, b: any) => (b.year || 0) - (a.year || 0));
const domains = [...new Set(papers.map((p: any) => p.psi_domain).filter(Boolean))].sort();
const folders = [...new Set(papers.map((p: any) => p.folder).filter(Boolean))].sort();

// Get year range for filters
const years = papers.map((p: any) => p.year).filter(Boolean);
const minYear = Math.min(...years);
const maxYear = Math.max(...years);

// Helper to format folder names
function formatFolder(folder: string): string {
  return folder.replace(/^\d+_/, '').replace(/_/g, ' ');
}

// Helper to compute pre-registration status
function getPreRegStatus(paper: any): string {
  const prereg = paper.methodology?.pre_registration ?? paper.methodology?.pre_registered;
  if (prereg === null || prereg === undefined) return 'unknown';
  if (typeof prereg === 'boolean') return prereg ? 'true' : 'false';
  if (typeof prereg === 'string') {
    const lower = prereg.toLowerCase();
    if (lower === 'yes' || lower === 'true') return 'true';
    if (lower === 'no' || lower === 'false') return 'false';
  }
  return 'unknown';
}

// Helper to compute blinding status
function getBlindingStatus(paper: any): string {
  const blinding = paper.methodology?.blinding;
  if (!blinding) return 'unknown';
  const lower = blinding.toLowerCase();
  if (lower.includes('double')) return 'double';
  if (lower.includes('single')) return 'single';
  if (lower.includes('none') || lower.includes('not') || lower.includes('open')) return 'none';
  return 'unknown';
}

// Helper to compute DOI status
function getDoiStatus(paper: any): string {
  return paper.doi ? 'yes' : 'no';
}

// Helper to format authors
function formatAuthors(authors: string[]): string {
  if (!authors || authors.length === 0) return 'Unknown Author';
  if (authors.length === 1) return authors[0];
  if (authors.length === 2) return authors.join(' & ');
  return `${authors[0]} et al.`;
}

// Helper to compute epistemic status
function getEpistemicStatus(paper: any): { label: string; color: string } {
  const prereg = getPreRegStatus(paper);
  const blinding = getBlindingStatus(paper);
  const sampleSize = paper.methodology?.sample_size || 0;
  
  let score = 0;
  if (prereg === 'true') score += 2;
  if (blinding === 'double') score += 2;
  else if (blinding === 'single') score += 1;
  if (sampleSize > 100) score += 1;
  if (sampleSize > 500) score += 1;

  if (score >= 4) return { label: 'Strong', color: 'bg-emerald-500' };
  if (score >= 2) return { label: 'Mixed', color: 'bg-amber-500' };
  if (score >= 1) return { label: 'Weak', color: 'bg-red-500' };
  return { label: 'Unknown', color: 'bg-slate-500' };
}

// Helper to get domain border color
function getDomainColor(domain: string): string {
  const map: Record<string, string> = {
    'telepathy': 'border-purple-500',
    'psychokinesis': 'border-red-500',
    'precognition': 'border-violet-500',
    'remote_viewing': 'border-indigo-500',
    'healing': 'border-green-500',
    'nde': 'border-cyan-500',
    'skeptical': 'border-orange-500',
    'methodology': 'border-blue-500',
    'meta_analysis': 'border-pink-500',
    'history': 'border-amber-500',
  };
  return map[domain] || 'border-slate-600';
}
---

<Layout title="Catalog">
  <div class="mb-8">
    <h1 class="text-4xl font-bold mb-2 text-slate-100">Research Catalog</h1>
    <p class="text-slate-400 text-lg">Explore {papers.length} papers across {domains.length} domains of psi research</p>
  </div>

  <!-- Sentinel for sticky observer -->
  <div id="scroll-sentinel" class="h-0 absolute -top-1 left-0 w-full"></div>

  <!-- Filters (Sticky) -->
  <div id="filter-container" class="sticky top-0 z-20 bg-slate-950/95 backdrop-blur-md pb-4 pt-4 border-b border-slate-800 transition-shadow duration-300" role="search">
    <div class="flex flex-wrap gap-3 mb-4 items-center">
      <div class="relative flex-1 min-w-[200px]">
        <input 
          type="text" 
          id="search" 
          aria-label="Search papers by title, author, or abstract"
          placeholder="Search title, authors, abstract..." 
          class="w-full bg-slate-900 border border-slate-700 rounded-lg pl-10 pr-4 py-2.5 text-sm text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none transition-all"
        />
        <svg class="w-4 h-4 text-slate-500 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      
      <select id="domain-filter" aria-label="Filter by research domain" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition">
        <option value="">All Domains</option>
        {domains.map((d: string) => (
          <option value={d}>{d.replace(/_/g, ' ')}</option>
        ))}
      </select>
      
      <select id="folder-filter" aria-label="Filter by category folder" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition">
        <option value="">All Categories</option>
        {folders.map((f: string) => (
          <option value={f}>{formatFolder(f)}</option>
        ))}
      </select>
      
      <div class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-lg px-3 py-2 focus-within:ring-2 focus-within:ring-amber-400 focus-within:border-amber-500 transition">
        <input 
          type="number" 
          id="year-min" 
          aria-label="Minimum publication year"
          placeholder="From" 
          min={minYear}
          max={maxYear}
          class="bg-transparent border-none text-sm w-16 text-slate-300 placeholder-slate-600 focus:ring-0 focus:outline-none"
        />
        <span class="text-slate-600">–</span>
        <input 
          type="number" 
          id="year-max" 
          aria-label="Maximum publication year"
          placeholder="To" 
          min={minYear}
          max={maxYear}
          class="bg-transparent border-none text-sm w-16 text-slate-300 placeholder-slate-600 focus:ring-0 focus:outline-none"
        />
      </div>
      
      <div class="h-6 w-px bg-slate-800 mx-1 hidden md:block"></div>

      <select id="prereg-filter" aria-label="Filter by pre-registration status" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition">
        <option value="">Pre-reg: Any</option>
        <option value="true">Pre-registered</option>
        <option value="false">Not Pre-registered</option>
      </select>
      
      <select id="blinding-filter" aria-label="Filter by blinding method" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition">
        <option value="">Blinding: Any</option>
        <option value="double">Double-blind</option>
        <option value="single">Single-blind</option>
        <option value="none">Open/None</option>
      </select>
      
      <label class="flex items-center gap-2 bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 cursor-pointer hover:border-amber-500/30 hover:text-amber-400 transition select-none focus-within:ring-2 focus-within:ring-amber-400 focus-within:border-amber-500">
        <input 
          type="checkbox" 
          id="doi-filter" 
          aria-label="Filter to show only papers with DOI"
          class="accent-amber-500 rounded focus:ring-2 focus:ring-amber-400"
        />
        <span>Has DOI</span>
      </label>
      
      <select id="sort-filter" aria-label="Sort results" class="bg-slate-900 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-300 focus:border-amber-500 focus:ring-2 focus:ring-amber-400 focus:outline-none cursor-pointer hover:border-slate-600 transition">
        <option value="year-desc">Newest First</option>
        <option value="year-asc">Oldest First</option>
        <option value="title-asc">Title (A-Z)</option>
        <option value="title-desc">Title (Z-A)</option>
        <option value="domain">Domain</option>
        <option value="effect-size">By Effect Size</option>
        <option value="sample-size">By Sample Size</option>
      </select>
      
      <button 
        id="clear-filters" 
        aria-label="Clear all filters and reset search"
        class="bg-slate-800 hover:bg-red-900/30 hover:text-red-400 hover:border-red-900/50 border border-slate-700 rounded-lg px-4 py-2.5 text-sm text-slate-400 transition focus:outline-none focus:ring-2 focus:ring-amber-400"
      >
        Reset All
      </button>
    </div>

    <!-- Active Filter Chips -->
    <div id="active-filters-container" class="flex flex-wrap gap-2 mb-4 min-h-[2rem]" aria-live="polite">
      <!-- Populated by JS -->
    </div>

    <!-- Result count & Pagination Controls -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <span id="result-count" aria-live="polite" class="text-sm font-medium text-amber-500/80">Loading...</span>
      <div class="flex items-center gap-4 w-full sm:w-auto">
        <span class="text-xs text-slate-600 hidden sm:inline-block">Tip: Hover over cards for quick actions</span>
        <button 
          id="show-more-btn"
          class="hidden w-full sm:w-auto bg-amber-600 hover:bg-amber-500 text-white font-medium py-2 px-6 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2 focus:ring-offset-slate-950"
        >
          Show More Papers
        </button>
      </div>
    </div>
  </div>

  <!-- Paper list -->
  <div id="paper-list" role="list" class="space-y-4 mt-6 border border-transparent transition-colors duration-300">
    {papers.map((paper: any, index: number) => {
      const domainColor = getDomainColor(paper.psi_domain);
      const epistemic = getEpistemicStatus(paper);
      // Initially hide cards beyond index 49 (first 50) using Tailwind 'hidden' class
      const isInitiallyHidden = index >= 50 ? 'hidden' : '';
      
      return (
        <article 
          class={`paper-card group relative bg-slate-900 border border-slate-800 rounded-xl p-5 hover:border-amber-500/50 hover:shadow-lg hover:shadow-amber-500/5 hover:-translate-y-0.5 transition-all duration-300 flex flex-col gap-3 border-l-4 ${domainColor} ${isInitiallyHidden} focus-within:ring-2 focus-within:ring-amber-400 focus-within:border-amber-500 outline-none`}
          role="listitem"
          tabindex="0"
          data-domain={paper.psi_domain}
          data-folder={paper.folder}
          data-title={paper.title?.toLowerCase()}
          data-authors={paper.authors?.join(' ').toLowerCase()}
          data-abstract={paper.abstract?.toLowerCase()}
          data-year={paper.year}
          data-prereg={getPreRegStatus(paper)}
          data-blinding={getBlindingStatus(paper)}
          data-doi={getDoiStatus(paper)}
          data-effect-size={paper.methodology?.effect_size || 0}
          data-sample-size={paper.methodology?.sample_size || 0}
          data-link={`/paper/${paper.id}`}
        >
          <!-- Header: Title + Quick Actions -->
          <div class="flex justify-between items-start gap-4">
            <div class="flex-1 min-w-0">
              <a 
                href={`/paper/${paper.id}`}
                class="block font-bold text-slate-100 text-xl leading-tight group-hover:text-amber-400 transition-colors line-clamp-2 focus:text-amber-400 focus:outline-none"
                tabindex="-1"
              >
                {paper.title}
              </a>
            </div>
            
            <!-- Quick Actions (Visible on hover or focus) -->
            <div class="flex gap-2 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity duration-200 sm:opacity-0">
              <button 
                class="copy-citation-btn p-2 text-slate-500 hover:text-amber-400 hover:bg-slate-800 rounded-lg transition tooltip-trigger focus:outline-none focus:ring-2 focus:ring-amber-400"
                title="Copy Citation"
                data-citation={`${paper.authors?.slice(0, 3).join(', ')}${paper.authors?.length > 3 ? ' et al.' : ''} (${paper.year}). ${paper.title}. ${paper.journal}.`}
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
              </button>
              <a 
                href={`/paper/${paper.id}`}
                class="p-2 text-slate-500 hover:text-amber-400 hover:bg-slate-800 rounded-lg transition focus:outline-none focus:ring-2 focus:ring-amber-400"
                title="View Details"
                tabindex="-1"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
              </a>
              {paper.doi && (
                <a 
                  href={`https://doi.org/${paper.doi}`} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  class="p-2 text-slate-500 hover:text-amber-400 hover:bg-slate-800 rounded-lg transition focus:outline-none focus:ring-2 focus:ring-amber-400"
                  title="Open DOI"
                  tabindex="-1"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                </a>
              )}
            </div>
          </div>
          
          <!-- Meta: Authors, Year, Journal -->
          <div class="text-sm text-slate-400 flex flex-wrap gap-x-3 gap-y-1 items-center">
            <span class="font-medium text-slate-300">{formatAuthors(paper.authors)}</span>
            <span class="text-slate-600">•</span>
            <span>{paper.year}</span>
            <span class="text-slate-600">•</span>
            <span class="italic text-slate-500">{paper.journal}</span>
          </div>
          
          <!-- Body: Abstract + Badges -->
          <div class="flex flex-col md:flex-row gap-4 mt-1">
            <div class="flex-1 relative overflow-hidden">
              <!-- Quick Preview (Hidden by default, shown on hover) -->
              <div class="absolute inset-0 bg-slate-900/95 backdrop-blur-sm p-2 rounded border border-slate-700 opacity-0 group-hover:opacity-100 transition-opacity duration-200 z-10 pointer-events-none">
                <p class="text-xs text-slate-300 font-semibold mb-1 uppercase tracking-wider">Quick Preview</p>
                <p class="text-slate-400 text-sm leading-relaxed line-clamp-4">
                  {paper.abstract || "No abstract available."}
                </p>
              </div>

              {paper.abstract ? (
                <p class="text-slate-400 text-sm leading-relaxed line-clamp-3 group-hover:opacity-0 transition-opacity duration-200">
                  {paper.abstract}
                </p>
              ) : (
                <p class="text-slate-600 text-sm italic">No abstract available</p>
              )}
            </div>
            
            <div class="flex flex-wrap gap-2 md:flex-col md:items-end shrink-0">
              {paper.psi_domain && (
                <span class="text-xs font-medium bg-amber-500/10 text-amber-400 border border-amber-500/20 px-2.5 py-1 rounded-full capitalize whitespace-nowrap">
                  {paper.psi_domain.replace(/_/g, ' ')}
                </span>
              )}
              
              {paper.folder === '10_Skeptical_and_Critical' && (
                <span class="text-xs font-medium bg-red-500/10 text-red-400 border border-red-500/20 px-2.5 py-1 rounded-full whitespace-nowrap">
                  Critical View
                </span>
              )}
              
              {getPreRegStatus(paper) === 'true' && (
                <span class="text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2.5 py-1 rounded-full whitespace-nowrap">
                  Pre-registered
                </span>
              )}

              {/* Epistemic Status Badge */}
              <div class="flex items-center gap-1.5 bg-slate-800/50 px-2.5 py-1 rounded-full border border-slate-700/50">
                <span class={`w-2 h-2 rounded-full ${epistemic.color}`}></span>
                <span class="text-xs font-medium text-slate-400">{epistemic.label}</span>
              </div>
            </div>
          </div>
        </article>
      );
    })}
  </div>

  <script>
    const domainFilter = document.getElementById('domain-filter') as HTMLSelectElement;
    const folderFilter = document.getElementById('folder-filter') as HTMLSelectElement;
    const yearMinInput = document.getElementById('year-min') as HTMLInputElement;
    const yearMaxInput = document.getElementById('year-max') as HTMLInputElement;
    const preregFilter = document.getElementById('prereg-filter') as HTMLSelectElement;
    const blindingFilter = document.getElementById('blinding-filter') as HTMLSelectElement;
    const doiFilter = document.getElementById('doi-filter') as HTMLInputElement;
    const searchInput = document.getElementById('search') as HTMLInputElement;
    const sortFilter = document.getElementById('sort-filter') as HTMLSelectElement;
    const clearButton = document.getElementById('clear-filters') as HTMLButtonElement;
    const resultCount = document.getElementById('result-count') as HTMLElement;
    const paperList = document.getElementById('paper-list') as HTMLElement;
    const filterContainer = document.getElementById('filter-container') as HTMLElement;
    const sentinel = document.getElementById('scroll-sentinel') as HTMLElement;
    const activeFiltersContainer = document.getElementById('active-filters-container') as HTMLElement;
    const showMoreBtn = document.getElementById('show-more-btn') as HTMLButtonElement;

    // Pagination Config
    const PAGINATION_LIMIT = 50;
    let visibleCount = PAGINATION_LIMIT;
    let isFiltered = false;

    // Get initial static list of cards
    let cards = Array.from(document.querySelectorAll('.paper-card')) as HTMLElement[];
    const totalPapers = cards.length;

    // Copy Citation Functionality
    document.querySelectorAll('.copy-citation-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const citation = (btn as HTMLElement).dataset.citation || '';
        navigator.clipboard.writeText(citation).then(() => {
          const originalHTML = btn.innerHTML;
          btn.innerHTML = '<svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>';
          setTimeout(() => {
            btn.innerHTML = originalHTML;
          }, 2000);
        });
      });
    });

    // Keyboard Navigation for Cards
    document.querySelectorAll('.paper-card').forEach(card => {
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          // Prevent default if focusing a button inside
          if (e.target !== card) return;
          
          e.preventDefault();
          const link = card.dataset.link;
          if (link) {
            window.location.href = link;
          }
        }
      });
    });

    // Sticky Shadow Logic
    if ('IntersectionObserver' in window && sentinel && filterContainer) {
      const observer = new IntersectionObserver(([entry]) => {
        // If sentinel is not intersecting, it means we've scrolled past it, so filter is stuck
        if (!entry.isIntersecting) {
          filterContainer.classList.add('shadow-[0_4px_6px_-1px_rgba(0,0,0,0.5)]', 'shadow-slate-950');
          filterContainer.classList.add('border-slate-800');
        } else {
          filterContainer.classList.remove('shadow-[0_4px_6px_-1px_rgba(0,0,0,0.5)]', 'shadow-slate-950');
          filterContainer.classList.remove('border-slate-800');
        }
      }, { threshold: 0 });
      
      observer.observe(sentinel);
    }

    function updateActiveFilters() {
      activeFiltersContainer.innerHTML = '';
      const filters = [
        { id: 'domain-filter', label: 'Domain', type: 'select' },
        { id: 'folder-filter', label: 'Category', type: 'select' },
        { id: 'prereg-filter', label: 'Pre-reg', type: 'select' },
        { id: 'blinding-filter', label: 'Blinding', type: 'select' },
        { id: 'year-min', label: 'From Year', type: 'input' },
        { id: 'year-max', label: 'To Year', type: 'input' },
        { id: 'doi-filter', label: 'Has DOI', type: 'checkbox' },
      ];

      filters.forEach(f => {
        const el = document.getElementById(f.id);
        let value = '';
        let displayValue = '';

        if (f.type === 'select') {
          value = (el as HTMLSelectElement).value;
          displayValue = (el as HTMLSelectElement).options[(el as HTMLSelectElement).selectedIndex]?.text;
        } else if (f.type === 'input') {
          value = (el as HTMLInputElement).value;
          displayValue = value;
        } else if (f.type === 'checkbox') {
          if ((el as HTMLInputElement).checked) {
            value = 'true';
            displayValue = f.label;
          }
        }

        if (value && value !== '' && value !== 'false') {
          const chip = document.createElement('div');
          chip.className = 'flex items-center gap-2 bg-slate-800 border border-slate-700 text-slate-300 text-xs px-3 py-1.5 rounded-full animate-fade-in';
          chip.innerHTML = `
            <span class="font-medium text-slate-500">${f.label}:</span>
            <span>${displayValue}</span>
            <button class="hover:text-red-400 transition" data-filter-id="${f.id}" aria-label="Remove ${f.label} filter">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          `;
          activeFiltersContainer.appendChild(chip);
        }
      });

      // Add event listeners to remove buttons
      activeFiltersContainer.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const filterId = (btn as HTMLElement).dataset.filterId;
          if (!filterId) return;
          
          const el = document.getElementById(filterId);
          if (el) {
            if (el instanceof HTMLInputElement && el.type === 'checkbox') {
              el.checked = false;
            } else {
              el.value = '';
            }
            triggerFilterChange();
          }
        });
      });
    }

    function triggerFilterChange() {
      // Visual loading state
      paperList.classList.add('border-amber-500');
      setTimeout(() => {
        paperList.classList.remove('border-amber-500');
      }, 300);

      // Reset pagination when filtering
      visibleCount = PAGINATION_LIMIT;
      filterAndSortCards();
      updateURL();
    }

    function filterAndSortCards() {
      const domain = domainFilter.value;
      const folder = folderFilter.value;
      const yearMin = yearMinInput.value ? parseInt(yearMinInput.value) : null;
      const yearMax = yearMaxInput.value ? parseInt(yearMaxInput.value) : null;
      const prereg = preregFilter.value;
      const blinding = blindingFilter.value;
      const hasDoi = doiFilter.checked;
      const query = searchInput.value.toLowerCase();
      const sortValue = sortFilter.value;
      
      let visibleMatchCount = 0;
      
      // Check if any filter is active
      isFiltered = !!(domain || folder || yearMin || yearMax || prereg || blinding || hasDoi || query);

      // 1. Sort the cards array based on selection
      cards.sort((a, b) => {
        if (sortValue === 'year-desc') {
          const yearA = a.dataset.year ? parseInt(a.dataset.year) : 0;
          const yearB = b.dataset.year ? parseInt(b.dataset.year) : 0;
          return yearB - yearA;
        }
        if (sortValue === 'year-asc') {
          const yearA = a.dataset.year ? parseInt(a.dataset.year) : 0;
          const yearB = b.dataset.year ? parseInt(b.dataset.year) : 0;
          return yearA - yearB;
        }
        if (sortValue === 'title-asc') {
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        }
        if (sortValue === 'title-desc') {
          return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        }
        if (sortValue === 'domain') {
          return (a.dataset.domain || '').localeCompare(b.dataset.domain || '');
        }
        if (sortValue === 'effect-size') {
          const sizeA = parseFloat(a.dataset.effectSize || '0');
          const sizeB = parseFloat(b.dataset.effectSize || '0');
          return sizeB - sizeA; // Descending
        }
        if (sortValue === 'sample-size') {
          const sizeA = parseInt(a.dataset.sampleSize || '0');
          const sizeB = parseInt(b.dataset.sampleSize || '0');
          return sizeB - sizeA; // Descending
        }
        return 0;
      });

      // 2. Filter and Re-append to DOM
      cards.forEach((card, index) => {
        const cardYear = card.dataset.year ? parseInt(card.dataset.year) : null;
        
        const matchDomain = !domain || card.dataset.domain === domain;
        const matchFolder = !folder || card.dataset.folder === folder;
        const matchYear = (!yearMin || (cardYear && cardYear >= yearMin)) && 
                          (!yearMax || (cardYear && cardYear <= yearMax));
        const matchPrereg = !prereg || card.dataset.prereg === prereg;
        const matchBlinding = !blinding || card.dataset.blinding === blinding;
        const matchDoi = !hasDoi || card.dataset.doi === 'yes';
        const matchSearch = !query || 
          card.dataset.title?.includes(query) || 
          card.dataset.authors?.includes(query) ||
          card.dataset.abstract?.includes(query);
        
        const isVisible = matchDomain && matchFolder && matchYear && matchPrereg && matchBlinding && matchDoi && matchSearch;
        
        if (isVisible) {
          visibleMatchCount++;
          
          // Pagination Logic:
          // If filtered, show all matches.
          // If not filtered, only show up to 'visibleCount'.
          const shouldShow = isFiltered || (index < visibleCount);
          
          if (shouldShow) {
            card.style.display = 'flex';
            card.classList.remove('hidden');
          } else {
            card.style.display = 'none'; // Ensure hidden via style too
            card.classList.add('hidden');
          }
        } else {
          card.style.display = 'none';
          card.classList.add('hidden');
        }
        
        // Re-append to reorder in DOM
        paperList.appendChild(card);
      });
      
      // Update UI Text
      resultCount.textContent = `Showing ${Math.min(visibleMatchCount, isFiltered ? visibleMatchCount : visibleCount)} of ${totalPapers} papers`;
      
      // Update Button Visibility
      if (isFiltered || visibleCount >= visibleMatchCount) {
        showMoreBtn.classList.add('hidden');
      } else {
        showMoreBtn.classList.remove('hidden');
      }

      updateActiveFilters();
    }

    // Show More Button Handler
    showMoreBtn.addEventListener('click', () => {
      visibleCount += PAGINATION_LIMIT;
      filterAndSortCards();
    });

    function clearFilters() {
      domainFilter.value = '';
      folderFilter.value = '';
      yearMinInput.value = '';
      yearMaxInput.value = '';
      preregFilter.value = '';
      blindingFilter.value = '';
      doiFilter.checked = false;
      searchInput.value = '';
      sortFilter.value = 'year-desc'; // Reset sort to default
      triggerFilterChange();
    }

    function updateURL() {
      const params = new URLSearchParams();
      if (domainFilter.value) params.set('domain', domainFilter.value);
      if (folderFilter.value) params.set('folder', folderFilter.value);
      if (yearMinInput.value) params.set('yearMin', yearMinInput.value);
      if (yearMaxInput.value) params.set('yearMax', yearMaxInput.value);
      if (preregFilter.value) params.set('prereg', preregFilter.value);
      if (blindingFilter.value) params.set('blinding', blindingFilter.value);
      if (doiFilter.checked) params.set('doi', 'yes');
      if (searchInput.value) params.set('q', searchInput.value);
      if (sortFilter.value !== 'year-desc') params.set('sort', sortFilter.value);
      
      const newURL = params.toString() ? `?${params.toString()}` : window.location.pathname;
      window.history.replaceState({}, '', newURL);
    }

    domainFilter.addEventListener('change', triggerFilterChange);
    folderFilter.addEventListener('change', triggerFilterChange);
    yearMinInput.addEventListener('input', triggerFilterChange);
    yearMaxInput.addEventListener('input', triggerFilterChange);
    preregFilter.addEventListener('change', triggerFilterChange);
    blindingFilter.addEventListener('change', triggerFilterChange);
    doiFilter.addEventListener('change', triggerFilterChange);
    searchInput.addEventListener('input', triggerFilterChange);
    sortFilter.addEventListener('change', triggerFilterChange);
    clearButton.addEventListener('click', clearFilters);

    // Handle URL params on load
    const params = new URLSearchParams(window.location.search);
    if (params.get('domain')) {
      domainFilter.value = params.get('domain') || '';
    }
    if (params.get('folder')) {
      folderFilter.value = params.get('folder') || '';
    }
    if (params.get('yearMin')) {
      yearMinInput.value = params.get('yearMin') || '';
    }
    if (params.get('yearMax')) {
      yearMaxInput.value = params.get('yearMax') || '';
    }
    if (params.get('prereg')) {
      preregFilter.value = params.get('prereg') || '';
    }
    if (params.get('blinding')) {
      blindingFilter.value = params.get('blinding') || '';
    }
    if (params.get('doi') === 'yes') {
      doiFilter.checked = true;
    }
    if (params.get('q')) {
      searchInput.value = params.get('q') || '';
    }
    if (params.get('sort')) {
      sortFilter.value = params.get('sort') || 'year-desc';
    }
    
    filterAndSortCards();
  </script>
</Layout>