---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Build the search index on the server
const searchIndex = [
  // Papers from catalog
  ...catalog.papers.map(p => ({ 
    type: 'paper', 
    id: p.id, 
    title: p.title, 
    text: p.abstract || '', 
    url: `/paper/${p.id}` 
  })),
  
  // Static Pages
  { type: 'page', id: 'method', title: 'Methodology', text: 'How the library was curated and scored', url: '/method' },
  { type: 'page', id: 'replications', title: 'Replication Map', text: 'Track replication attempts across studies', url: '/replications' },
  { type: 'page', id: 'stats', title: 'Statistics', text: 'Aggregate methodology data and success rates', url: '/stats' },
  { type: 'page', id: 'glossary', title: 'Glossary', text: 'Definitions of key parapsychology terms', url: '/glossary' },
  
  // Note: To add Controversies, you would map over your controversy markdown files or JSON here
  // Example: ...controversies.map(c => ({ type: 'controversy', title: c.data.title, text: c.body, url: c.url }))
];

// Sort index alphabetically by title for consistency
searchIndex.sort((a, b) => a.title.localeCompare(b.title));
---

<Layout title="Search Library">
  <div class="max-w-4xl mx-auto px-4 py-12">
    
    <!-- Header & Input -->
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-slate-100 mb-4">
        Search the <span class="text-amber-400">Archive</span>
      </h1>
      <p class="text-slate-400 mb-8">
        Search across paper titles, abstracts, glossary terms, and site pages.
      </p>
      
      <div class="relative max-w-2xl mx-auto">
        <input 
          type="text" 
          id="search-input"
          placeholder="Type to search..." 
          class="w-full bg-slate-900 border border-slate-700 text-slate-100 text-lg rounded-lg px-6 py-4 focus:outline-none focus:ring-2 focus:ring-amber-400/50 focus:border-amber-400 transition-all shadow-lg placeholder-slate-500"
          autocomplete="off"
        />
        <div class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Results Area -->
    <div id="results-container" class="space-y-4">
      <!-- Results injected via JS -->
      <div class="text-center text-slate-500 py-12" id="empty-state">
        Start typing to search the library...
      </div>
    </div>

  </div>

  <script define:vars={{ searchIndex }}>
    const input = document.getElementById('search-input');
    const container = document.getElementById('results-container');
    const emptyState = document.getElementById('empty-state');

    // Helper to highlight search terms
    function highlightText(text, term) {
      if (!term) return text;
      const regex = new RegExp(`(${term})`, 'gi');
      return text.replace(regex, '<mark class="bg-amber-400/20 text-amber-300 px-0.5 rounded">$1</mark>');
    }

    // Helper to get badge color
    function getBadgeColor(type) {
      switch(type) {
        case 'paper': return 'bg-blue-900/30 text-blue-300 border-blue-800';
        case 'page': return 'bg-emerald-900/30 text-emerald-300 border-emerald-800';
        case 'controversy': return 'bg-red-900/30 text-red-300 border-red-800';
        case 'glossary': return 'bg-purple-900/30 text-purple-300 border-purple-800';
        default: return 'bg-slate-800 text-slate-300 border-slate-700';
      }
    }

    function renderResults(results, term) {
      container.innerHTML = '';
      
      if (results.length === 0) {
        container.innerHTML = `
          <div class="text-center text-slate-500 py-12">
            <p class="text-lg">No results found for "<span class="text-slate-300">${term}</span>"</p>
            <p class="text-sm mt-2">Try different keywords or check spelling.</p>
          </div>
        `;
        return;
      }

      results.forEach(item => {
        // Create excerpt (first 160 chars of text)
        let excerpt = item.text.substring(0, 160);
        if (item.text.length > 160) excerpt += '...';
        
        // Highlight terms in title and excerpt
        const highlightedTitle = highlightText(item.title, term);
        const highlightedExcerpt = highlightText(excerpt, term);
        const badgeClass = getBadgeColor(item.type);

        const card = document.createElement('a');
        card.href = item.url;
        card.className = 'block bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all group';
        
        card.innerHTML = `
          <div class="flex items-start justify-between mb-2">
            <span class="text-xs font-mono uppercase tracking-wider px-2 py-1 rounded border ${badgeClass}">
              ${item.type}
            </span>
            <svg class="w-5 h-5 text-slate-600 group-hover:text-amber-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-slate-100 mb-2 group-hover:text-amber-400 transition-colors">
            ${highlightedTitle}
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed">
            ${highlightedExcerpt}
          </p>
        `;
        
        container.appendChild(card);
      });
    }

    input.addEventListener('input', (e) => {
      const term = e.target.value.trim().toLowerCase();
      
      if (term.length === 0) {
        container.innerHTML = '';
        container.appendChild(emptyState);
        emptyState.style.display = 'block';
        return;
      }

      // Filter logic
      const results = searchIndex.filter(item => {
        const titleMatch = item.title.toLowerCase().includes(term);
        const textMatch = item.text.toLowerCase().includes(term);
        return titleMatch || textMatch;
      });

      renderResults(results, e.target.value.trim());
    });
  </script>
</Layout>