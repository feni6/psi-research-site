---
import Layout from '../../layouts/Layout.astro';
import catalog from '../../data/catalog.json';

export function getStaticPaths() {
  return catalog.papers.map((paper: any) => ({
    params: { id: paper.id },
    props: { paper },
  }));
}

const { paper } = Astro.props;
const relatedPapersRaw = paper.related_papers || {};
const relatedEntries: { type: string; paper: any }[] = [];
if (typeof relatedPapersRaw === 'object' && !Array.isArray(relatedPapersRaw)) {
  for (const [relType, ids] of Object.entries(relatedPapersRaw)) {
    if (Array.isArray(ids)) {
      for (const id of ids as string[]) {
        const found = catalog.papers.find((p: any) => p.id === id);
        if (found) relatedEntries.push({ type: relType, paper: found });
      }
    }
  }
}
const relatedPapers = relatedEntries;

const folderLabels: Record<string, string> = {
  '01_Meta-Analyses': 'Meta-Analyses',
  '02_Telepathy': 'Telepathy',
  '03_Precognition': 'Precognition',
  '04_Remote_Viewing': 'Remote Viewing',
  '05_Psychokinesis': 'Psychokinesis',
  '06_Healing_and_Intention': 'Healing & Intention',
  '07_Mediumship_and_Survival': 'Mediumship & Survival',
  '08_NDE_and_OBE': 'NDE & OBE',
  '09_Methodology_and_Theory': 'Methodology & Theory',
  '10_Skeptical_and_Critical': 'Skeptical & Critical',
  '11_Autism_and_Nonverbal': 'Autism & Nonverbal',
  '12_Books_and_Overviews': 'Books & Overviews',
  '13_Podcast_References': 'Podcast References',
};

// Find prev/next in same domain
const sameDomain = catalog.papers
  .filter((p: any) => p.psi_domain === paper.psi_domain)
  .sort((a: any, b: any) => (a.year || 0) - (b.year || 0));
const currentIndex = sameDomain.findIndex((p: any) => p.id === paper.id);
const prevPaper = currentIndex > 0 ? sameDomain[currentIndex - 1] : null;
const nextPaper = currentIndex < sameDomain.length - 1 ? sameDomain[currentIndex + 1] : null;

// Compute same domain papers (excluding related ones)
const sameDomainOthers = catalog.papers
  .filter((p: any) => p.psi_domain === paper.psi_domain && p.id !== paper.id)
  .filter((p: any) => !relatedPapers.some(rp => rp.paper.id === p.id))
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0))
  .slice(0, 5);

// Format domain name for display
const formatDomainName = (domain: string) => {
  return domain
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (l) => l.toUpperCase());
};

// Group related papers by type
const groupedRelated: Record<string, any[]> = {};
relatedPapers.forEach((entry) => {
  if (!groupedRelated[entry.type]) {
    groupedRelated[entry.type] = [];
  }
  groupedRelated[entry.type].push(entry.paper);
});

// Relationship type colors
const relationColors: Record<string, string> = {
  critiques: 'text-red-400 border-red-400/30 bg-red-400/10',
  critiqued_by: 'text-red-400 border-red-400/30 bg-red-400/10',
  extends: 'text-blue-400 border-blue-400/30 bg-blue-400/10',
  extended_by: 'text-blue-400 border-blue-400/30 bg-blue-400/10',
  replicated_by: 'text-green-400 border-green-400/30 bg-green-400/10',
  replication_of: 'text-green-400 border-green-400/30 bg-green-400/10',
  precursor: 'text-purple-400 border-purple-400/30 bg-purple-400/10',
};

const getRelationColor = (type: string) => {
  return relationColors[type] || 'text-slate-400 border-slate-400/30 bg-slate-400/10';
};

const formatRelationLabel = (type: string) => {
  return type.replace(/_/g, ' ').replace(/\b\w/g, (l) => l.toUpperCase());
};

// Effect size color
const getEffectSizeColor = (es: number) => {
  if (es > 0.3) return 'bg-green-500';
  if (es >= 0.1) return 'bg-amber-500';
  return 'bg-red-500';
};

// Blinding badge
const getBlindingBadge = (blinding: string) => {
  if (!blinding) return null;
  const lower = blinding.toLowerCase();
  if (lower.includes('double')) {
    return { text: 'Double-Blind', color: 'bg-green-500/20 text-green-400 border-green-500/30' };
  }
  if (lower.includes('single')) {
    return { text: 'Single-Blind', color: 'bg-amber-500/20 text-amber-400 border-amber-500/30' };
  }
  return { text: 'Not Blinded', color: 'bg-red-500/20 text-red-400 border-red-500/30' };
};

// Era Badge Logic
const getEraBadge = (year: number) => {
  if (!year) return null;
  if (year < 1930) return { text: 'Pre-Modern', color: 'bg-purple-400/20 text-purple-400 border-purple-400/30' };
  if (year >= 1930 && year <= 1965) return { text: 'Rhine Era', color: 'bg-blue-400/20 text-blue-400 border-blue-400/30' };
  if (year > 1965 && year <= 1985) return { text: 'Ganzfeld Era', color: 'bg-cyan-400/20 text-cyan-400 border-cyan-400/30' };
  if (year > 1972 && year <= 1995) return { text: 'STAR GATE Era', color: 'bg-green-400/20 text-green-400 border-green-400/30' };
  if (year > 1995 && year <= 2015) return { text: 'Modern Era', color: 'bg-amber-400/20 text-amber-400 border-amber-400/30' };
  if (year > 2015) return { text: 'Current Era', color: 'bg-red-400/20 text-red-400 border-red-400/30' };
  return null;
};

const eraBadge = paper.year ? getEraBadge(paper.year) : null;

// Epistemic Status Logic
const isSkepticalFolder = paper.folder === '10_Skeptical_and_Critical';
const hasCritiques = relatedPapers.some(r => r.type === 'critiques');
const isCritiqued = relatedPapers.some(r => r.type === 'critiqued_by');
const hasReplications = relatedPapers.some(r => r.type === 'replicated_by');
const isReplicationOf = relatedPapers.some(r => r.type === 'replication_of');

let epistemicStatus = {
  label: 'Original study',
  icon: '📄',
  color: 'bg-slate-700/50 text-slate-400 border-slate-600/30'
};

if (hasCritiques || isCritiqued) {
  epistemicStatus = {
    label: 'Contested',
    icon: '⚡',
    color: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30'
  };
} else if (hasReplications) {
  epistemicStatus = {
    label: 'Has replications',
    icon: '✅',
    color: 'bg-green-500/20 text-green-400 border-green-500/30'
  };
} else if (isReplicationOf && isSkepticalFolder) {
  epistemicStatus = {
    label: 'Critical replication',
    icon: '🛡️',
    color: 'bg-red-500/20 text-red-400 border-red-500/30'
  };
} else if (isSkepticalFolder) {
  epistemicStatus = {
    label: 'Skeptical/Critical',
    icon: '🧐',
    color: 'bg-red-500/20 text-red-400 border-red-500/30'
  };
}

// Generate JSON-LD structured data
const jsonLdData = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  "name": paper.title,
  "author": (paper.authors || []).map((name: string) => ({
    "@type": "Person",
    "name": name
  })),
  "datePublished": String(paper.year || ""),
  "description": paper.abstract || "",
  ...(paper.journal ? { "isPartOf": { "@type": "Periodical", "name": paper.journal } } : {}),
  ...(paper.doi ? { "sameAs": `https://doi.org/${paper.doi}` } : {}),
  ...(paper.source_url ? { "url": paper.source_url } : {})
};
const jsonLd = JSON.stringify(jsonLdData);

// Citation Generation
const authorList = (paper.authors || []).join(', ');
const apaYear = paper.year ? `(${paper.year})` : '(n.d.)';
const apaDoi = paper.doi ? ` https://doi.org/${paper.doi}` : '';
const apaCitation = `${authorList} ${apaYear}. ${paper.title}. ${paper.journal || ''}.${apaDoi}`;

const bibtexAuthors = (paper.authors || []).join(' and ');
const bibtexCitation = `@article{${paper.id},
  title = {${paper.title}},
  author = {${bibtexAuthors}},
  year = {${paper.year || ''}},
  journal = {${paper.journal || ''}},${paper.doi ? `\n  doi = {${paper.doi}},` : ''}
}`;
---

<Layout title={paper.title} description={paper.abstract?.substring(0, 160) || 'Psi Research Paper'} jsonLd={jsonLd}>
  <article class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-6">
      <a href="/" class="hover:text-amber-400">Home</a>
      <span class="mx-1">/</span>
      <a href="/catalog" class="hover:text-amber-400">Catalog</a>
      <span class="mx-1">/</span>
      <span class="text-slate-300">{paper.title}</span>
    </nav>

    <!-- Paper Header -->
    <header class="mb-8">
      <div class="flex flex-col sm:flex-row sm:items-start gap-3 mb-2">
        <h1 class="text-3xl font-bold text-slate-100">{paper.title}</h1>
        <span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium border whitespace-nowrap self-start sm:self-center ${epistemicStatus.color}`}>
          <span>{epistemicStatus.icon}</span>
          <span>{epistemicStatus.label}</span>
        </span>
      </div>
      
      <!-- Copy Link Button -->
      <div class="flex gap-2 mb-4">
        <button id="copy-url" class="text-xs bg-slate-800 text-slate-400 px-3 py-1.5 rounded hover:bg-slate-700 hover:text-amber-400 transition">
          Copy Link
        </button>
      </div>

      <div class="flex flex-wrap items-center gap-3 text-slate-400">
        <span class="text-amber-400">{paper.authors?.join(', ')}</span>
        {paper.year && (
          <>
            <span>•</span>
            <span>{paper.year}</span>
            {eraBadge && (
              <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium border ${eraBadge.color}`}>
                {eraBadge.text}
              </span>
            )}
          </>
        )}
        {paper.psi_domain && (
          <>
            <span>•</span>
            <span class="px-2 py-0.5 rounded-full text-xs bg-amber-400/20 text-amber-400 border border-amber-400/30">
              {paper.psi_domain}
            </span>
          </>
        )}
      </div>

      <!-- Social Sharing -->
      <div class="flex items-center gap-4 mt-5 pt-4 border-t border-slate-800/50">
        <span class="text-xs text-slate-500 font-medium uppercase tracking-wider">Share</span>
        <div class="flex gap-4">
          <!-- Copy Link -->
          <button id="share-copy" class="flex items-center gap-1.5 text-xs text-slate-500 hover:text-amber-400 transition-colors focus:outline-none">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
            <span>Copy Link</span>
          </button>
          
          <!-- Share on X -->
          <button 
            id="share-twitter" 
            class="flex items-center gap-1.5 text-xs text-slate-500 hover:text-amber-400 transition-colors focus:outline-none"
            data-title={paper.title}
            data-year={paper.year || ''}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
            </svg>
            <span>Share on X</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Methodology Indicators -->
    {(paper.pre_registered !== undefined || paper.effect_size !== undefined || paper.blinding) && (
      <>
        <section class="mb-8 p-4 rounded-lg bg-slate-900 border border-slate-800">
          <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wide mb-3">Methodology</h2>
          <div class="flex flex-wrap gap-4">
            <!-- Pre-registration -->
            {paper.pre_registered !== undefined && (
              <div class="flex items-center gap-2">
                {paper.pre_registered ? (
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                ) : (
                  <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                )}
                <span class="text-slate-300 text-sm">
                  Pre-registered: <span class={paper.pre_registered ? 'text-green-400' : 'text-slate-500'}>
                    {paper.pre_registered ? 'Yes' : 'No'}
                  </span>
                </span>
              </div>
            )}

            <!-- Effect Size -->
            {typeof paper.effect_size === 'number' && (
              <div class="flex items-center gap-2">
                <span class="text-slate-300 text-sm">Effect Size:</span>
                <div class="flex items-center gap-2">
                  <div class="w-16 h-2 rounded-full bg-slate-700 overflow-hidden">
                    <div 
                      class={`h-full ${getEffectSizeColor(paper.effect_size)}`} 
                      style={`width: ${Math.min(Math.abs(paper.effect_size) * 100, 100)}%`}
                    ></div>
                  </div>
                  <span class="text-slate-300 text-sm font-mono">{paper.effect_size.toFixed(2)}</span>
                </div>
              </div>
            )}

            <!-- Blinding -->
            {paper.blinding && (() => {
              const badge = getBlindingBadge(paper.blinding);
              if (!badge) return null;
              return (
                <span class={`px-2 py-0.5 rounded text-xs border ${badge.color}`}>
                  {badge.text}
                </span>
              );
            })()}
          </div>
        </section>

        <div class="bg-amber-500/5 border border-amber-500/20 rounded-lg p-3 mb-6 text-sm">
          <p class="text-slate-400">
            <span class="text-amber-400 font-medium">⚠️ Data note:</span> 
            Methodology fields were AI-extracted and may contain errors. 
            <a href="/method" class="text-amber-400 hover:underline">Read about our extraction process</a> 
            and verify against the source paper.
          </p>
        </div>
      </>
    )}

    <!-- Curator's Notes -->
    {paper.notes && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-3">📝 Curator's Notes</h2>
        <div class="bg-slate-900/50 border-l-4 border-amber-500/50 rounded-r-lg p-4">
          <p class="text-slate-300 leading-relaxed text-sm">{paper.notes}</p>
        </div>
      </section>
    )}

    <!-- Abstract -->
    {paper.abstract && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Abstract</h2>
        <blockquote class="border-l-4 border-slate-700 pl-4 italic">
          <p class="text-slate-400 leading-relaxed">{paper.abstract}</p>
        </blockquote>
        <p class="text-xs text-slate-600 mt-2">From the original paper</p>
      </section>
    )}

    <!-- Links -->
    {(paper.doi || paper.url || paper.pdf_url) && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-3">Links</h2>
        <div class="flex flex-wrap gap-3">
          {paper.doi && (
            <a 
              href={`https://doi.org/${paper.doi}`} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-amber-400/20 text-amber-400 border border-amber-400/30 hover:bg-amber-400/30 transition-colors text-sm"
            >
              DOI: {paper.doi}
            </a>
          )}
          {paper.url && (
            <a 
              href={paper.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:bg-slate-700 transition-colors text-sm"
            >
              Publisher Page
            </a>
          )}
          {paper.pdf_url && (
            <a 
              href={paper.pdf_url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="px-4 py-2 rounded-lg bg-slate-800 text-slate-300 border border-slate-700 hover:bg-slate-700 transition-colors text-sm"
            >
              PDF
            </a>
          )}
        </div>
      </section>
    )}

    <!-- Related Papers -->
    {Object.keys(groupedRelated).length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">Related Papers</h2>
        <div class="space-y-6">
          {Object.entries(groupedRelated).map(([relType, papers]) => (
            <div key={relType} class={`p-4 rounded-lg border ${getRelationColor(relType)}`}>
              <h3 class="text-sm font-semibold mb-3 uppercase tracking-wide">
                {formatRelationLabel(relType)}
              </h3>
              <ul class="space-y-2">
                {papers.map((relatedPaper: any) => (
                  <li key={relatedPaper.id}>
                    <a 
                      href={`/paper/${relatedPaper.id}`}
                      class="block text-slate-300 hover:text-amber-400 transition-colors"
                    >
                      <span class="font-medium">{relatedPaper.title}</span>
                      <span class="text-slate-500 text-sm"> — {relatedPaper.authors?.[0] || 'Unknown'} ({relatedPaper.year || 'n.d.'})</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Papers in Same Domain -->
    {sameDomainOthers.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold text-slate-200 mb-4">
          More in {formatDomainName(paper.psi_domain)}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {sameDomainOthers.map((p: any) => (
            <a 
              href={`/paper/${p.id}`}
              class="block p-3 rounded-lg border border-slate-800/50 bg-slate-900/50 hover:border-amber-400/50 hover:bg-slate-800 transition-colors group"
            >
              <h3 class="text-slate-200 font-medium group-hover:text-amber-400 transition-colors line-clamp-2 mb-1">
                {p.title}
              </h3>
              <div class="text-xs text-slate-500">
                {p.authors?.[0] || 'Unknown'} • {p.year || 'n.d.'}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Cite this paper -->
    <details class="mb-8 bg-slate-900 border border-slate-800 rounded-lg">
      <summary class="px-4 py-3 cursor-pointer text-sm text-slate-400 hover:text-amber-400 transition">
        📋 Cite this paper
      </summary>
      <div class="px-4 pb-4 space-y-4">
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="text-xs text-slate-500 font-medium">APA</span>
            <button class="copy-btn text-xs text-amber-400 hover:text-amber-300" data-text={apaCitation}>Copy</button>
          </div>
          <pre class="text-xs text-slate-300 bg-slate-800 rounded p-3 whitespace-pre-wrap break-words">{apaCitation}</pre>
        </div>
        <div>
          <div class="flex justify-between items-center mb-1">
            <span class="text-xs text-slate-500 font-medium">BibTeX</span>
            <button class="copy-btn text-xs text-amber-400 hover:text-amber-300" data-text={bibtexCitation}>Copy</button>
          </div>
          <pre class="text-xs text-slate-300 bg-slate-800 rounded p-3 whitespace-pre-wrap break-words">{bibtexCitation}</pre>
        </div>
      </div>
    </details>

    <!-- Prev/Next Navigation -->
    {(prevPaper || nextPaper) && (
      <nav class="mt-12 pt-8 border-t border-slate-800">
        <div class="flex justify-between items-center">
          {prevPaper ? (
            <a 
              href={`/paper/${prevPaper.id}`}
              class="flex items-center gap-2 text-slate-400 hover:text-amber-400 transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              <div class="text-left">
                <span class="text-xs text-slate-500 block">Previous in {paper.psi_domain || 'Domain'}</span>
                <span class="text-sm">{prevPaper.title}</span>
              </div>
            </a>
          ) : (
            <div></div>
          )}
          
          {nextPaper ? (
            <a 
              href={`/paper/${nextPaper.id}`}
              class="flex items-center gap-2 text-slate-400 hover:text-amber-400 transition-colors"
            >
              <div class="text-right">
                <span class="text-xs text-slate-500 block">Next in {paper.psi_domain || 'Domain'}</span>
                <span class="text-sm">{nextPaper.title}</span>
              </div>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ) : (
            <div></div>
          )}
        </div>
      </nav>
    )}
  </article>

  <script>
    // Existing citation copy logic
    document.querySelectorAll('.copy-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-text') || '';
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = orig; }, 2000);
      });
    });

    // New Share Logic
    const copyLinkBtn = document.getElementById('share-copy');
    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', async () => {
        const url = window.location.href;
        await navigator.clipboard.writeText(url);
        
        const originalHTML = copyLinkBtn.innerHTML;
        copyLinkBtn.innerHTML = '<span>Copied!</span>';
        
        setTimeout(() => { 
          copyLinkBtn.innerHTML = originalHTML; 
        }, 2000);
      });
    }

    const twitterBtn = document.getElementById('share-twitter');
    if (twitterBtn) {
      twitterBtn.addEventListener('click', () => {
        const url = encodeURIComponent(window.location.href);
        const title = twitterBtn.getAttribute('data-title') || 'Psi Research Paper';
        const year = twitterBtn.getAttribute('data-year') || '';
        const yearStr = year ? ` (${year})` : '';
        
        const text = encodeURIComponent(`📄 ${title}${yearStr} — from the Psi Research Library`);
        
        window.open(`https://twitter.com/intent/tweet?text=${text}&url=${url}`, '_blank', 'noopener,noreferrer');
      });
    }

    // Copy URL Button (New)
    document.getElementById('copy-url')?.addEventListener('click', async function() {
      await navigator.clipboard.writeText(window.location.href);
      this.textContent = 'Copied!';
      setTimeout(() => { this.textContent = 'Copy Link'; }, 2000);
    });
  </script>
</Layout>