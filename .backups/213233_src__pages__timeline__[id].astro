---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import catalog from '../../data/catalog.json';

// Era Configuration
const eraConfig = {
  era_1_pre_modern: { color: 'purple', icon: '🔮', label: 'Pre-Modern' },
  era_2_rhine: { color: 'blue', icon: '🔬', label: 'Rhine Era' },
  era_3_ganzfeld: { color: 'cyan', icon: '🧠', label: 'Ganzfeld Era' },
  era_4_stargate: { color: 'green', icon: '👁️', label: 'Stargate Era' },
  era_5_modern: { color: 'amber', icon: '📊', label: 'Modern Era' },
  era_6_current: { color: 'red', icon: '🚀', label: 'Current Frontiers' },
};

// Helper to get color classes
const getColorClasses = (colorName) => {
  const colors = {
    purple: { bg: 'bg-purple-500', text: 'text-purple-400', border: 'border-purple-500/30', gradient: 'from-purple-900/40' },
    blue: { bg: 'bg-blue-500', text: 'text-blue-400', border: 'border-blue-500/30', gradient: 'from-blue-900/40' },
    cyan: { bg: 'bg-cyan-500', text: 'text-cyan-400', border: 'border-cyan-500/30', gradient: 'from-cyan-900/40' },
    green: { bg: 'bg-green-500', text: 'text-green-400', border: 'border-green-500/30', gradient: 'from-green-900/40' },
    amber: { bg: 'bg-amber-500', text: 'text-amber-400', border: 'border-amber-500/30', gradient: 'from-amber-900/40' },
    red: { bg: 'bg-red-500', text: 'text-red-400', border: 'border-red-500/30', gradient: 'from-red-900/40' },
  };
  return colors[colorName] || colors.purple;
};

export function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/data/timeline');
  const files = fs.readdirSync(dir)
    .filter(f => f.startsWith('era_') && f.endsWith('.md'))
    .sort(); // Ensure chronological order for prev/next logic

  return files.map((f, index) => {
    const id = f.replace('.md', '');
    const content = fs.readFileSync(path.join(dir, f), 'utf-8');
    
    return {
      params: { id },
      props: {
        content,
        index,
        total: files.length,
        prevId: index > 0 ? files[index - 1].replace('.md', '') : null,
        nextId: index < files.length - 1 ? files[index + 1].replace('.md', '') : null,
      },
    };
  });
}

const { id } = Astro.params;
const { content, index, total, prevId, nextId } = Astro.props;

// Get Era Config
const config = eraConfig[id] || eraConfig.era_1_pre_modern;
const colors = getColorClasses(config.color);

// Extract catalog IDs from content
const catalogIdRegex = /\[catalog ID: ([^\]]+)\]/g;
const matches = [...content.matchAll(catalogIdRegex)];
const catalogIds = matches.map(m => m[1].trim());

// Look up papers in catalog
const papers = catalogIds
  .map(id => catalog.papers.find(p => p.id === id))
  .filter(p => p !== undefined);

// Calculate Stats
// 1. Year Range
const years = papers
  .map(p => parseInt(p.year))
  .filter(y => !isNaN(y));
const minYear = years.length ? Math.min(...years) : '?';
const maxYear = years.length ? Math.max(...years) : '?';

// 2. Key Researchers (Top 3 authors)
const authorCounts = {};
papers.forEach(p => {
  if (p.author) {
    // Handle multiple authors if separated by comma or 'and'
    const authors = p.author.split(/,| and /i).map(a => a.trim()).filter(a => a);
    authors.forEach(author => {
      authorCounts[author] = (authorCounts[author] || 0) + 1;
    });
  }
});
const topResearchers = Object.entries(authorCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(entry => entry[0]);

// Replace catalog ID references with links in markdown
const linkedContent = content.replace(
  /\[catalog ID: ([^\]]+)\]/g,
  (_, id) => `[📄 ${id.trim()}](/paper/${id.trim()})`
);

// Remove the H1 from markdown content since we render it in the banner
const markdownBody = linkedContent.replace(/^#\s*.+\n/, '');
const html = marked(markdownBody);

// Extract Title for SEO/Meta (first line of original content)
const rawTitle = content.split('\n')[0].replace(/^#\s*/, '').trim();
const pageTitle = `${config.label} Era | Psi Research Library`;
---

<Layout title={pageTitle}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    
    <!-- Breadcrumbs -->
    <Breadcrumb 
      items={[
        { label: 'Home', href: '/' },
        { label: 'Timeline', href: '/timeline' },
        { label: config.label, href: '#' }
      ]} 
    />

    <!-- Era Header Banner -->
    <div class={`relative overflow-hidden rounded-xl border ${colors.border} bg-slate-900/50 mb-8`}>
      <!-- Background Gradient -->
      <div class={`absolute inset-0 bg-gradient-to-r ${colors.gradient} to-slate-950 opacity-50`}></div>
      
      <div class="relative p-6 md:p-8 flex flex-col md:flex-row md:items-center justify-between gap-6">
        <div class="flex items-start gap-4">
          <div class={`text-5xl md:text-6xl bg-slate-950/50 p-3 rounded-lg border ${colors.border} shadow-lg`}>
            {config.icon}
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <span class={`text-xs font-bold uppercase tracking-wider ${colors.text} bg-slate-950/50 px-2 py-0.5 rounded`}>
                Era {index + 1} of {total}
              </span>
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{config.label} Era</h1>
            <p class="text-slate-400 max-w-xl">
              Exploring the key developments, methodologies, and paradigm shifts in psi research during this period.
            </p>
          </div>
        </div>

        <!-- Quick Stats in Header -->
        <div class="flex flex-col items-end gap-2 min-w-[140px]">
          <div class="text-right">
            <div class="text-3xl font-bold text-white">{papers.length}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide">Papers</div>
          </div>
          <div class="text-right">
            <div class="text-xl font-semibold text-slate-300">{minYear}–{maxYear}</div>
            <div class="text-xs text-slate-500 uppercase tracking-wide">Timeframe</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Detailed Stats Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
      <!-- Paper Count Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4 flex items-center gap-4">
        <div class={`p-3 rounded-full ${colors.bg}/10 ${colors.text}`}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">{papers.length}</div>
          <div class="text-sm text-slate-400">Referenced Papers</div>
        </div>
      </div>

      <!-- Year Range Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4 flex items-center gap-4">
        <div class={`p-3 rounded-full ${colors.bg}/10 ${colors.text}`}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </div>
        <div>
          <div class="text-2xl font-bold text-white">{minYear} – {maxYear}</div>
          <div class="text-sm text-slate-400">Active Years</div>
        </div>
      </div>

      <!-- Key Researchers Card -->
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-4 flex flex-col justify-center">
        <div class="text-xs text-slate-500 uppercase tracking-wide mb-1">Key Researchers</div>
        <div class="flex flex-wrap gap-2">
          {topResearchers.length > 0 ? (
            topResearchers.map(name => (
              <span class="text-sm text-slate-300 bg-slate-800 px-2 py-1 rounded border border-slate-700">
                {name}
              </span>
            ))
          ) : (
            <span class="text-sm text-slate-500 italic">No author data</span>
          )}
        </div>
      </div>
    </div>

    <!-- Referenced Papers Cards -->
    {papers.length > 0 && (
      <div class="mb-10">
        <h2 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
          <span class={colors.text}>📚</span> Key Papers from this Era
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {papers.map(paper => (
            <a 
              href={`/paper/${paper.id}`} 
              class={`group block bg-slate-900 border border-slate-800 hover:${colors.border} rounded-lg p-4 transition-all duration-200 hover:shadow-lg hover:shadow-${config.color}-900/10`}
            >
              <div class="flex justify-between items-start mb-2">
                <span class={`text-xs font-mono ${colors.text} bg-slate-950 px-2 py-0.5 rounded`}>
                  {paper.id}
                </span>
                {paper.year && (
                  <span class="text-xs text-slate-500">{paper.year}</span>
                )}
              </div>
              <h3 class="text-slate-200 font-medium mb-2 group-hover:text-amber-400 transition-colors line-clamp-2">
                {paper.title}
              </h3>
              {paper.author && (
                <p class="text-sm text-slate-500 line-clamp-1">
                  {paper.author}
                </p>
              )}
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Main Content -->
    <article class="prose prose-invert prose-amber max-w-4xl mb-12 bg-slate-900/30 p-6 md:p-10 rounded-xl border border-slate-800">
      <div set:html={html} />
    </article>

    <!-- Navigation -->
    <div class="flex justify-between items-center border-t border-slate-800 pt-8">
      {prevId ? (
        <a 
          href={`/timeline/${prevId}`} 
          class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors group"
        >
          <span class="group-hover:-translate-x-1 transition-transform">←</span>
          <div class="text-left">
            <div class="text-xs text-slate-500 uppercase">Previous Era</div>
            <div class="font-medium">
              {eraConfig[prevId]?.label || 'Previous'}
            </div>
          </div>
        </a>
      ) : (
        <div></div> /* Spacer */
      )}

      {nextId ? (
        <a 
          href={`/timeline/${nextId}`} 
          class="flex items-center gap-2 text-slate-400 hover:text-white transition-colors group"
        >
          <div class="text-right">
            <div class="text-xs text-slate-500 uppercase">Next Era</div>
            <div class="font-medium">
              {eraConfig[nextId]?.label || 'Next'}
            </div>
          </div>
          <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
      ) : (
        <div></div> /* Spacer */
      )}
    </div>

  </div>
</Layout>