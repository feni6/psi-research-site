<!-- src/pages/paths/[id].astro -->
---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import catalog from '../../data/catalog.json';

export function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/data/reading_paths');
  const files = fs.readdirSync(dir).filter(f => f.startsWith('path_') && f.endsWith('.md'));
  return files.map(f => {
    const id = f.replace('.md', '');
    const content = fs.readFileSync(path.join(dir, f), 'utf-8');
    return { params: { id }, props: { content } };
  });
}

const { id } = Astro.params;
const { content } = Astro.props;

// 1. Parse Content into Steps based on ## Headings
// We split by regex to keep the delimiter if needed, but simpler to just split and reconstruct.
const rawSteps = content.split(/^##\s+/m);
const title = rawSteps[0].replace(/^#\s*/, '').trim(); // First part is usually the H1 title
const stepContents = rawSteps.slice(1); // Everything after H1 is a step

// 2. Extract all catalog IDs globally for metadata lookup
const catalogIdPattern = /\[catalog ID: ([^\]]+)\]|`([a-zA-Z0-9_-]+)`/g;
const foundIds = new Set<string>();
let match;

// Reset regex state
catalogIdPattern.lastIndex = 0;
while ((match = catalogIdPattern.exec(content)) !== null) {
  const catalogId = (match[1] || match[2]).trim();
  if (catalogId) {
    foundIds.add(catalogId);
  }
}

// 3. Build Paper Map
const paperMap = new Map();
Array.from(foundIds).forEach(catalogId => {
  const paper = catalog.papers.find((p: any) => p.id === catalogId);
  if (paper) {
    paperMap.set(catalogId, {
      id: paper.id,
      title: paper.title,
      year: paper.year,
      domain: paper.domain || 'Unknown',
      authors: paper.authors || []
    });
  }
});

const papersInPath = Array.from(paperMap.values());
const paperCount = papersInPath.length;
const totalSteps = stepContents.length;

// Helper to process markdown content within a step
function processStepContent(md: string) {
  // Replace [catalog ID: xxx] with custom HTML tag
  const processed = md.replace(
    /\[catalog ID: ([^\]]+)\]/g,
    (_, catalogId) => `<paper-card id="${catalogId.trim()}"></paper-card>`
  );
  return marked(processed);
}

// Helper to inject actual card HTML into the rendered string
function injectCards(html: string) {
  return html.replace(/<paper-card id="([^"]+)"><\/paper-card>/g, (_, paperId) => {
    const paper = paperMap.get(paperId);
    if (!paper) return `<span class="text-red-400 font-mono text-sm">[Missing Paper: ${paperId}]</span>`;
    
    return `
      <div class="my-6 group relative overflow-hidden rounded-xl border border-slate-700 bg-slate-900/50 p-5 transition-all hover:border-amber-500/50 hover:bg-slate-900 hover:shadow-lg hover:shadow-amber-900/10">
        <div class="absolute top-0 right-0 p-3 opacity-0 transition-opacity group-hover:opacity-100">
           <span class="flex h-8 w-8 items-center justify-center rounded-full bg-amber-500 text-slate-950 shadow-lg">
             <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
               <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
             </svg>
           </span>
        </div>
        <div class="flex flex-col gap-2">
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs font-bold text-amber-500 bg-amber-500/10 px-2 py-0.5 rounded border border-amber-500/20">
              ${paper.id}
            </span>
            <span class="text-xs text-slate-500 font-medium">${paper.year}</span>
          </div>
          <h4 class="text-lg font-semibold text-slate-200 leading-snug group-hover:text-amber-400 transition-colors">
            <a href="/paper/${paper.id}" class="focus:outline-none">
              ${paper.title}
            </a>
          </h4>
          <div class="flex items-center gap-2 mt-1">
             <span class="text-xs text-slate-400 border border-slate-700 px-2 py-0.5 rounded-full bg-slate-800/50">
               ${paper.domain}
             </span>
          </div>
        </div>
      </div>
    `;
  });
}
---

<Layout title={title}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8 flex items-center gap-2">
      <a href="/" class="hover:text-amber-400 transition-colors">Home</a>
      <span class="text-slate-700">/</span>
      <a href="/paths" class="hover:text-amber-400 transition-colors">Reading Paths</a>
      <span class="text-slate-700">/</span>
      <span class="text-slate-300 font-medium truncate">{title}</span>
    </nav>

    <!-- Header Area -->
    <header class="mb-12 border-b border-slate-800 pb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-slate-100 mb-4">{title}</h1>
      <div class="flex flex-wrap gap-6 text-sm">
        <div class="flex items-center gap-2 text-slate-400">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
          <span><strong class="text-slate-200">{totalSteps}</strong> Steps</span>
        </div>
        <div class="flex items-center gap-2 text-slate-400">
          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          <span><strong class="text-slate-200">{paperCount}</strong> Papers</span>
        </div>
      </div>
    </header>

    <!-- Progress Indicator (Sticky on Desktop) -->
    <div class="sticky top-4 z-40 mb-12 bg-slate-950/90 backdrop-blur-md border border-slate-800 rounded-full p-2 shadow-2xl overflow-x-auto scrollbar-hide">
      <div class="flex items-center gap-2 min-w-max px-2">
        {stepContents.map((_, i) => (
          <div class="flex items-center gap-2">
            <div class={`
              flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold border transition-all duration-300
              ${i === 0 ? 'bg-amber-500 text-slate-950 border-amber-500 shadow-[0_0_15px_rgba(245,158,11,0.4)]' : 'bg-slate-900 text-slate-500 border-slate-700'}
            `}>
              {i + 1}
            </div>
            {i < stepContents.length - 1 && (
              <div class="w-8 h-0.5 bg-slate-800 rounded-full"></div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Course Content Steps -->
    <div class="space-y-16 relative">
      <!-- Vertical Line connecting steps -->
      <div class="absolute left-4 top-8 bottom-8 w-0.5 bg-slate-800 -z-10 hidden md:block"></div>

      {stepContents.map((stepContent, index) => {
        // Extract the first line as the step title, rest as body
        const lines = stepContent.trim().split('\n');
        const stepTitle = lines[0].trim();
        const stepBody = lines.slice(1).join('\n');
        
        const isLast = index === stepContents.length - 1;
        const isFirst = index === 0;

        // Process Markdown
        const rawHtml = processStepContent(stepBody);
        const finalHtml = injectCards(rawHtml);

        return (
          <section class="relative pl-0 md:pl-12 group/step scroll-mt-24" id={`step-${index + 1}`}>
            
            {/* Step Number Badge (Desktop) */}
            <div class="hidden md:flex absolute left-0 top-0 w-8 h-8 rounded-full bg-slate-900 border-2 border-slate-700 text-slate-400 font-bold items-center justify-center z-10 group-hover/step:border-amber-500 group-hover/step:text-amber-400 transition-colors shadow-lg shadow-slate-950">
              {index + 1}
            </div>

            {/* Mobile Step Number (Inline) */}
            <div class="md:hidden flex items-center gap-3 mb-4">
               <span class="flex items-center justify-center w-8 h-8 rounded-full bg-slate-800 border border-slate-700 text-amber-400 font-bold text-sm">
                 {index + 1}
               </span>
               <h2 class="text-2xl font-bold text-slate-200">{stepTitle}</h2>
            </div>

            {/* Desktop Step Title */}
            <h2 class="hidden md:block text-2xl font-bold text-slate-200 mb-6 pl-2 border-l-4 border-amber-500/50">
              {stepTitle}
            </h2>

            {/* Step Content */}
            <article class="prose prose-invert prose-amber max-w-none prose-headings:text-slate-300 prose-a:text-amber-400 hover:prose-a:text-amber-300 prose-strong:text-slate-200">
              <div set:html={finalHtml} />
            </article>

            {/* Navigation Footer for Step */}
            <div class="mt-12 pt-8 border-t border-slate-800/50 flex justify-between items-center">
              {isFirst ? (
                <div></div> // Spacer
              ) : (
                <a 
                  href={`#step-${index}`} 
                  class="flex items-center gap-2 text-slate-500 hover:text-amber-400 transition-colors text-sm font-medium group/nav"
                >
                  <svg class="w-4 h-4 transform group-hover/nav:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                  Previous Step
                </a>
              )}

              {isLast ? (
                <div class="text-slate-600 text-sm font-medium italic flex items-center gap-2">
                  <span>Journey Complete</span>
                  <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </div>
              ) : (
                <a 
                  href={`#step-${index + 2}`} 
                  class="flex items-center gap-2 text-amber-400 hover:text-amber-300 transition-colors text-sm font-bold group/nav"
                >
                  Next Step
                  <svg class="w-4 h-4 transform group-hover/nav:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </a>
              )}
            </div>
          </section>
        );
      })}
    </div>

    <!-- Final Completion Card -->
    <div class="mt-20 p-8 rounded-2xl bg-gradient-to-br from-slate-900 to-slate-900 border border-amber-500/30 text-center relative overflow-hidden">
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-amber-500 to-transparent opacity-50"></div>
      <h3 class="text-2xl font-bold text-slate-100 mb-2">Path Completed</h3>
      <p class="text-slate-400 mb-6 max-w-lg mx-auto">
        You've reviewed all {paperCount} papers in this path. Consider revisiting specific papers or exploring a new reading path.
      </p>
      <a href="/paths" class="inline-flex items-center justify-center px-6 py-3 bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold rounded-lg transition-colors shadow-lg shadow-amber-900/20">
        Browse All Paths
      </a>
    </div>

  </div>
</Layout>