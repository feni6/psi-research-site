---
import Layout from '../../layouts/Layout.astro';
import { readdirSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

// Read all era markdown files
const timelineDir = join(process.cwd(), 'src/data/timeline');
const eraFiles = readdirSync(timelineDir).filter(f => f.endsWith('.md') && f.startsWith('era_'));

// Color configuration for eras (bg, border, text, glow)
const eraConfig: Record<string, { bg: string, border: string, text: string, glow: string }> = {
  'era_1_pre_modern': { bg: 'bg-purple-500', border: 'border-purple-400', text: 'text-purple-400', glow: 'shadow-purple-500/20' },
  'era_2_rhine': { bg: 'bg-blue-500', border: 'border-blue-400', text: 'text-blue-400', glow: 'shadow-blue-500/20' },
  'era_3_ganzfeld': { bg: 'bg-cyan-500', border: 'border-cyan-400', text: 'text-cyan-400', glow: 'shadow-cyan-500/20' },
  'era_4_stargate': { bg: 'bg-green-500', border: 'border-green-400', text: 'text-green-400', glow: 'shadow-green-500/20' },
  'era_5_modern': { bg: 'bg-amber-500', border: 'border-amber-400', text: 'text-amber-400', glow: 'shadow-amber-500/20' },
  'era_6_current': { bg: 'bg-red-500', border: 'border-red-400', text: 'text-red-400', glow: 'shadow-red-500/20' },
};

const eras = eraFiles.map((file) => {
  const filePath = join(timelineDir, file);
  const content = readFileSync(filePath, 'utf-8');
  
  // Extract first non-heading paragraph for "Key Developments"
  const lines = content.split('\n');
  let description = '';
  let inFrontmatter = false;
  
  for (const line of lines) {
    const trimmed = line.trim();
    
    // Track frontmatter
    if (trimmed === '---') {
      inFrontmatter = !inFrontmatter;
      continue;
    }
    
    // Skip if in frontmatter
    if (inFrontmatter) continue;
    
    // Skip empty lines and headings
    if (!trimmed || trimmed.startsWith('#')) continue;
    
    // Found first paragraph
    description = trimmed;
    break;
  }
  
  // Count paper references: [catalog ID: xxx] or backtick-wrapped IDs
  const catalogMatches = content.match(/\[catalog ID: [a-z0-9_]+\]/gi) || [];
  const backtickMatches = content.match(/`[a-z0-9_]+`/gi) || [];
  const paperCount = catalogMatches.length + backtickMatches.length;
  
  // Extract ID from filename
  const id = file.replace('.md', '');
  
  // Try to extract title from first heading
  const titleMatch = content.match(/^#\s+(.+)$/m);
  let title = titleMatch ? titleMatch[1] : id.replace(/_/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
  
  // Try to extract years from content
  const yearsMatch = content.match(/(\d{4}[–-]\d{4}|\d{4}[–-]present)/i);
  const years = yearsMatch ? yearsMatch[1] : '';
  
  // Get config or fallback
  const config = eraConfig[id] || { bg: 'bg-slate-500', border: 'border-slate-400', text: 'text-slate-400', glow: 'shadow-slate-500/20' };
  
  return {
    id,
    title,
    years,
    desc: description,
    paperCount,
    ...config,
  };
});

// Sort eras by ID to maintain chronological order
eras.sort((a, b) => a.id.localeCompare(b.id));
---

<Layout title="Timeline">
  <!-- Breadcrumb -->
  <nav class="mb-6">
    <ol class="flex items-center gap-2 text-sm text-slate-500">
      <li><a href="/" class="hover:text-amber-400 transition">Home</a></li>
      <li>/</li>
      <li class="text-slate-300">Timeline</li>
    </ol>
  </nav>
  
  <div class="mb-10">
    <h1 class="text-3xl font-bold mb-2 text-slate-100">Historical Timeline</h1>
    <p class="text-slate-400 max-w-2xl">
      Trace the evolution of psi research from Victorian séance investigations to modern pre-registered experiments.
    </p>
  </div>
  
  <div class="relative max-w-4xl">
    <!-- Prominent Gradient Timeline Line -->
    <div class="absolute left-[19px] top-4 bottom-0 w-1.5 bg-gradient-to-b from-purple-600 via-cyan-600 to-amber-600 rounded-full opacity-80"></div>
    
    <div class="space-y-12">
      {eras.map((era, index) => (
        <a href={`/timeline/${era.id}`} class="timeline-item block relative pl-16 group opacity-0 translate-y-8 transition-all duration-700 ease-out">
          
          <!-- Era Dot -->
          <div class={`absolute left-0 top-1.5 w-10 h-10 rounded-full bg-slate-950 border-4 ${era.border} flex items-center justify-center z-10 shadow-lg ${era.glow} group-hover:scale-110 transition-transform duration-300`}>
            <div class={`w-3 h-3 rounded-full ${era.bg}`}></div>
          </div>
          
          <!-- Card Content -->
          <div class="bg-slate-900/50 backdrop-blur-sm border border-slate-800 rounded-xl p-6 group-hover:border-slate-700 group-hover:bg-slate-900 transition-all duration-300 shadow-sm hover:shadow-md">
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-4 mb-3">
              <span class={`font-mono text-xs font-bold tracking-wider uppercase ${era.text} bg-slate-950 px-2 py-0.5 rounded border border-slate-800`}>
                {era.years}
              </span>
              <h3 class="text-xl font-bold text-slate-200 group-hover:text-white transition-colors">
                {era.title}
              </h3>
              
              {era.paperCount > 0 && (
                <span class="sm:ml-auto inline-flex items-center gap-1.5 text-xs font-medium text-slate-400 bg-slate-950 px-2.5 py-1 rounded-full border border-slate-800 group-hover:border-slate-700 transition-colors">
                  <svg class="w-3.5 h-3.5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                  {era.paperCount} referenced paper{era.paperCount !== 1 ? 's' : ''}
                </span>
              )}
            </div>
            
            <div class="space-y-2">
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Key Developments</p>
              <p class="text-slate-400 leading-relaxed group-hover:text-slate-300 transition-colors">
                {era.desc}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- Scroll Animation Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, observer) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            // Add a slight delay based on index for staggered effect if desired, 
            // but immediate fade is cleaner for scrolling
            setTimeout(() => {
              entry.target.classList.remove('opacity-0', 'translate-y-8');
              entry.target.classList.add('opacity-100', 'translate-y-0');
            }, index * 50); 
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      const items = document.querySelectorAll('.timeline-item');
      items.forEach(item => observer.observe(item));
    });
  </script>
</Layout>