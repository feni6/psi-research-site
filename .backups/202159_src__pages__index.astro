---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

const papers = catalog.papers;
const totalPapers = papers.length;
const domains = [...new Set(papers.map((p: any) => p.psi_domain).filter(Boolean))];
const journals = [...new Set(papers.map((p: any) => p.journal).filter(Boolean))];
const skepticalCount = papers.filter((p: any) => p.folder === '10_Skeptical_and_Critical').length;
const yearRange = {
  min: Math.min(...papers.map((p: any) => p.year).filter(Boolean)),
  max: Math.max(...papers.map((p: any) => p.year).filter(Boolean)),
};

// Paper of the Day — changes daily based on date
const today = new Date();
const start = new Date(today.getFullYear(), 0, 0);
const diff = today.getTime() - start.getTime();
const oneDay = 1000 * 60 * 60 * 24;
const dayOfYear = Math.floor(diff / oneDay);
const podIndex = dayOfYear % papers.length;
const paperOfDay = papers[podIndex];

// Notable Papers lookup
const notableIds = ['bem_2011_feeling', 'cardena_2018_experimental', 'bem_1994_does'];
const notablePapers = notableIds
  .map(id => papers.find((p: any) => p.id === id))
  .filter(Boolean);

// Recently Added (Top 5 by Year)
const recentPapers = [...papers]
  .sort((a: any, b: any) => (b.year || 0) - (a.year || 0))
  .slice(0, 5);

// Domain Configuration
const domainConfig: Record<string, { icon: string, color: string, label: string }> = {
  methodology: { icon: '🔬', color: 'border-blue-500/30 hover:border-blue-400', label: 'Methods & Protocols' },
  telepathy: { icon: '🧠', color: 'border-purple-500/30 hover:border-purple-400', label: 'Telepathy' },
  psychokinesis: { icon: '🎲', color: 'border-red-500/30 hover:border-red-400', label: 'Psychokinesis' },
  nde: { icon: '✨', color: 'border-cyan-500/30 hover:border-cyan-400', label: 'Near-Death Exp.' },
  skeptical: { icon: '🔍', color: 'border-orange-500/30 hover:border-orange-400', label: 'Skeptical Analysis' },
  precognition: { icon: '🔮', color: 'border-violet-500/30 hover:border-violet-400', label: 'Precognition' },
  healing: { icon: '💚', color: 'border-green-500/30 hover:border-green-400', label: 'Healing' },
  overview: { icon: '📖', color: 'border-amber-500/30 hover:border-amber-400', label: 'Overviews' },
  remote_viewing: { icon: '👁️', color: 'border-teal-500/30 hover:border-teal-400', label: 'Remote Viewing' },
  mediumship: { icon: '🕯️', color: 'border-indigo-500/30 hover:border-indigo-400', label: 'Mediumship' },
  nonverbal: { icon: '🤝', color: 'border-pink-500/30 hover:border-pink-400', label: 'Nonverbal Comm.' },
  meta_analysis: { icon: '📊', color: 'border-yellow-500/30 hover:border-yellow-400', label: 'Meta-Analyses' },
};

// Deterministic random paper selection for the "Feeling Adventurous?" feature
const randomPaperIds = papers.filter((_: any, i: number) => i % 17 === 0).slice(0, 20).map((p: any) => p.id);

// All paper IDs for the "Surprise Me" button
const allPaperIds = papers.map((p: any) => p.id);
---

<Layout title="Home">
  <!-- First Visit Welcome Banner -->
  <div id="welcome-banner" class="w-full bg-gradient-to-r from-amber-500/10 to-slate-950 border-b border-amber-500/30 text-slate-200 overflow-hidden transition-all duration-500 ease-out transform translate-y-[-100%] opacity-0 z-50 relative">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex-1 text-center md:text-left">
        <h3 class="font-bold text-amber-400 mb-1 text-lg">👋 Welcome to the Psi Research Library</h3>
        <p class="text-sm text-slate-400">
          New here? Check out our <a href="/guide" class="underline hover:text-amber-300 transition-colors">Guide</a> to understand how this library works, or jump into a <a href="/paths" class="underline hover:text-amber-300 transition-colors">Reading Path</a> for a curated tour.
        </p>
      </div>
      <div class="flex items-center gap-4 shrink-0">
        <div class="flex gap-3">
          <a href="/guide" class="text-xs font-semibold text-slate-300 hover:text-amber-400 transition-colors flex items-center">
            Read the Guide <span class="ml-1">→</span>
          </a>
          <a href="/paths" class="px-4 py-2 bg-amber-500 hover:bg-amber-400 text-slate-950 text-xs font-bold rounded-lg transition-colors shadow-lg shadow-amber-500/20">
            Browse Paths →
          </a>
        </div>
        <button id="dismiss-banner" class="text-slate-500 hover:text-slate-300 transition-colors p-1 hover:bg-slate-800 rounded" aria-label="Dismiss banner">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Hero Section with Animated Background -->
  <section class="relative text-center py-24 bg-slate-950 border-b border-slate-800 overflow-hidden">
    <!-- Ambient Glow Effect -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-amber-500/5 rounded-full blur-3xl animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-0 right-0 w-[600px] h-[400px] bg-blue-500/5 rounded-full blur-3xl animate-pulse delay-700 pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-4">
      <div class="inline-block mb-4 px-3 py-1 rounded-full bg-amber-500/10 border border-amber-500/20 text-amber-400 text-xs font-semibold tracking-wide uppercase">
        Epistemically Responsible Archive
      </div>
      <h1 class="text-5xl md:text-6xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-200 via-amber-400 to-amber-200 mb-6 drop-shadow-sm">
        Psi Research Library
      </h1>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto mb-10 leading-relaxed">
        A curated collection of {totalPapers} peer-reviewed papers on psi phenomena. 
        <span class="text-slate-400">Both sides of every debate. Transparent methodology. Machine-readable.</span>
      </p>
      
      <div class="flex flex-col sm:flex-row justify-center gap-4 mb-12">
        <a href="/catalog" class="group relative px-8 py-4 bg-amber-500 text-slate-950 rounded-xl font-bold text-lg hover:bg-amber-400 transition-all hover:scale-105 shadow-[0_0_20px_rgba(245,158,11,0.3)]">
          Browse Catalog
          <span class="absolute right-4 top-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
        </a>
        <a href="/paths" class="px-8 py-4 bg-slate-900 border border-slate-700 text-slate-200 rounded-xl font-semibold text-lg hover:border-amber-500/50 hover:text-amber-400 transition-all">
          Guided Paths
        </a>
        <a href="/method" class="px-8 py-4 bg-transparent border border-slate-800 text-slate-400 rounded-xl font-semibold text-lg hover:bg-slate-900 hover:text-slate-200 transition-all">
          Methodology
        </a>
      </div>

      <form action="/search" method="get" class="max-w-xl mx-auto relative group">
        <div class="absolute inset-0 bg-amber-500/20 blur-xl rounded-full opacity-0 group-focus-within:opacity-100 transition-opacity duration-500"></div>
        <div class="relative flex items-center">
          <svg class="absolute left-4 h-5 w-5 text-slate-500 group-focus-within:text-amber-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input type="text" name="q" placeholder="Search 354+ papers, authors, or topics..."
            class="w-full bg-slate-900/80 backdrop-blur border border-slate-700 rounded-xl px-12 py-4 text-slate-200 placeholder-slate-500 focus:border-amber-500 focus:ring-1 focus:ring-amber-500 focus:outline-none transition-all shadow-lg" />
        </div>
      </form>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 border-b border-slate-800 bg-slate-950/50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="stat-card group bg-slate-900 rounded-2xl p-6 text-center border border-slate-800 hover:border-amber-500/30 hover:bg-slate-800/50 transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-500/10 text-amber-400 mb-3 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
          </div>
          <div class="text-4xl font-bold text-slate-100">{totalPapers}</div>
          <div class="text-slate-500 text-sm font-medium mt-1 uppercase tracking-wider">Papers Indexed</div>
        </div>
        <div class="stat-card group bg-slate-900 rounded-2xl p-6 text-center border border-slate-800 hover:border-amber-500/30 hover:bg-slate-800/50 transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-blue-500/10 text-blue-400 mb-3 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"></path></svg>
          </div>
          <div class="text-4xl font-bold text-slate-100">{journals.length}</div>
          <div class="text-slate-500 text-sm font-medium mt-1 uppercase tracking-wider">Journals</div>
        </div>
        <div class="stat-card group bg-slate-900 rounded-2xl p-6 text-center border border-slate-800 hover:border-amber-500/30 hover:bg-slate-800/50 transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-orange-500/10 text-orange-400 mb-3 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
          </div>
          <div class="text-4xl font-bold text-slate-100">{skepticalCount}</div>
          <div class="text-slate-500 text-sm font-medium mt-1 uppercase tracking-wider">Critical Views</div>
        </div>
        <div class="stat-card group bg-slate-900 rounded-2xl p-6 text-center border border-slate-800 hover:border-amber-500/30 hover:bg-slate-800/50 transition-all duration-300">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-purple-500/10 text-purple-400 mb-3 group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="text-4xl font-bold text-slate-100">{yearRange.min}–{yearRange.max}</div>
          <div class="text-slate-500 text-sm font-medium mt-1 uppercase tracking-wider">Year Span</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Paper of the Day -->
  <section class="py-16 border-b border-slate-800 bg-gradient-to-b from-slate-950 to-slate-900">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-4">
        <div>
          <h2 class="text-2xl font-bold text-slate-200 flex items-center gap-2">
            <span class="text-amber-400">📄</span> Paper of the Day
          </h2>
          <p class="text-slate-500 text-sm mt-1">A daily selection from the archive</p>
        </div>
        <button id="surprise-btn" class="group flex items-center gap-2 bg-slate-800 hover:bg-amber-500 text-slate-300 hover:text-slate-950 px-5 py-2.5 rounded-lg font-semibold transition-all border border-slate-700 hover:border-amber-400 shadow-lg hover:shadow-amber-500/20">
          <span class="text-lg group-hover:rotate-180 transition-transform duration-500">🎲</span>
          <span>Surprise Me</span>
        </button>
      </div>
      
      <div class="relative bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-2xl overflow-hidden group">
        <!-- Subtle highlight animation on border -->
        <div class="absolute inset-0 border-2 border-amber-500/20 rounded-2xl animate-pulse pointer-events-none"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row gap-6">
          <div class="flex-shrink-0 hidden md:flex flex-col items-center justify-center w-24 h-24 bg-slate-800 rounded-xl border border-slate-700">
            <span class="text-3xl font-bold text-amber-400">{paperOfDay.year}</span>
          </div>
          
          <div class="flex-grow">
            <div class="flex flex-wrap items-center gap-2 mb-3">
              {paperOfDay.psi_domain && (
                <span class="px-2.5 py-0.5 rounded-full bg-amber-500/10 text-amber-400 text-xs font-semibold border border-amber-500/20 uppercase tracking-wide">
                  {paperOfDay.psi_domain.replace(/_/g, ' ')}
                </span>
              )}
              <span class="text-slate-500 text-xs">• {paperOfDay.journal}</span>
            </div>
            
            <a href={`/paper/${paperOfDay.id}`} class="block group/title">
              <h3 class="text-2xl font-bold text-slate-100 group-hover/title:text-amber-400 transition-colors mb-3 leading-tight">
                {paperOfDay.title}
              </h3>
            </a>
            
            <div class="text-slate-400 text-sm mb-4 font-medium">
              {paperOfDay.authors?.slice(0, 3).join(', ')}{paperOfDay.authors?.length > 3 ? ' et al.' : ''}
            </div>
            
            <p class="text-slate-300 leading-relaxed mb-6 line-clamp-3">
              {paperOfDay.abstract?.substring(0, 250)}...
            </p>
            
            <a href={`/paper/${paperOfDay.id}`} class="inline-flex items-center text-amber-400 hover:text-amber-300 text-sm font-bold uppercase tracking-wide transition-colors">
              Read Full Summary <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Where Do You Start? -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold mb-2 text-center text-slate-200">Where Do You Start?</h2>
      <p class="text-slate-500 text-center mb-10 max-w-2xl mx-auto">Choose a path based on your current perspective or research goals.</p>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/paths/path_2_weak_spots" class="group bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-orange-500/50 hover:bg-slate-800/50 transition-all duration-300 hover:-translate-y-1 shadow-lg">
          <div class="w-12 h-12 bg-orange-500/10 rounded-lg flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">🔍</div>
          <div class="font-bold text-lg text-slate-200 mb-1 group-hover:text-orange-400 transition-colors">I'm Skeptical</div>
          <div class="text-xs text-orange-400/80 font-medium mb-3 uppercase tracking-wider">~15 min read</div>
          <p class="text-slate-400 text-sm leading-relaxed">Start with the weakest links. See where the evidence falls short and where the debates are fiercest.</p>
        </a>
        
        <a href="/paths/path_3_newcomer_survey" class="group bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-blue-500/50 hover:bg-slate-800/50 transition-all duration-300 hover:-translate-y-1 shadow-lg">
          <div class="w-12 h-12 bg-blue-500/10 rounded-lg flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">🗺️</div>
          <div class="font-bold text-lg text-slate-200 mb-1 group-hover:text-blue-400 transition-colors">I'm New Here</div>
          <div class="text-xs text-blue-400/80 font-medium mb-3 uppercase tracking-wider">~20 min read</div>
          <p class="text-slate-400 text-sm leading-relaxed">A balanced overview. Understand the landscape, key terms, and major findings without bias.</p>
        </a>
        
        <a href="/paths/path_1_steelman_psi" class="group bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-amber-500/50 hover:bg-slate-800/50 transition-all duration-300 hover:-translate-y-1 shadow-lg">
          <div class="w-12 h-12 bg-amber-500/10 rounded-lg flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">💪</div>
          <div class="font-bold text-lg text-slate-200 mb-1 group-hover:text-amber-400 transition-colors">Show Me Evidence</div>
          <div class="text-xs text-amber-400/80 font-medium mb-3 uppercase tracking-wider">~25 min read</div>
          <p class="text-slate-400 text-sm leading-relaxed">The strongest case for psi. Dive into high-quality studies published in top-tier journals.</p>
        </a>
        
        <a href="/catalog" class="group bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-purple-500/50 hover:bg-slate-800/50 transition-all duration-300 hover:-translate-y-1 shadow-lg">
          <div class="w-12 h-12 bg-purple-500/10 rounded-lg flex items-center justify-center text-2xl mb-4 group-hover:scale-110 transition-transform">📊</div>
          <div class="font-bold text-lg text-slate-200 mb-1 group-hover:text-purple-400 transition-colors">I'm a Researcher</div>
          <div class="text-xs text-purple-400/80 font-medium mb-3 uppercase tracking-wider">Full Access</div>
          <p class="text-slate-400 text-sm leading-relaxed">Full catalog with methodology data, effect sizes, cross-references, and raw metadata.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Recently Added -->
  <section class="py-16 border-b border-slate-800 bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-slate-200">Recently Added</h2>
        <a href="/catalog?sort=year_desc" class="text-sm text-amber-400 hover:text-amber-300 font-medium">View All →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentPapers.map((paper: any) => (
          <a href={`/paper/${paper.id}`} class="flex items-start gap-4 p-4 rounded-xl bg-slate-900 border border-slate-800 hover:border-amber-500/30 hover:bg-slate-800 transition-all group">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center text-slate-500 group-hover:text-amber-400 group-hover:bg-amber-500/10 transition-colors">
              <span class="font-bold text-sm">{paper.year}</span>
            </div>
            <div class="min-w-0 flex-grow">
              <h3 class="font-semibold text-slate-200 truncate group-hover:text-amber-400 transition-colors">{paper.title}</h3>
              <p class="text-xs text-slate-500 mt-1 truncate">{paper.authors?.[0]}{paper.authors?.length > 1 ? ' et al.' : ''} • {paper.journal}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Domain Explorer -->
  <section class="py-16 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2 text-slate-200">Research Domains</h2>
      <p class="text-slate-500 mb-8">Explore specific areas of psi research.</p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {domains.sort().map((domain: string) => {
          const count = papers.filter((p: any) => p.psi_domain === domain).length;
          const config = domainConfig[domain] || { icon: '📄', color: 'border-slate-500/30 hover:border-slate-400', label: domain };
          const topPaper = papers.find((p: any) => p.psi_domain === domain);
          
          return (
            <a href={`/domain/${domain}`} class={`group relative bg-slate-900 border border-slate-800 ${config.color} rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg overflow-hidden`}>
              <div class="relative z-10">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-2xl filter grayscale group-hover:grayscale-0 transition-all">{config.icon}</span>
                  <span class="text-xs font-bold bg-slate-800 text-slate-300 px-2 py-1 rounded-md group-hover:bg-amber-500 group-hover:text-slate-900 transition-colors">{count}</span>
                </div>
                <div class="font-bold text-slate-200 text-sm mb-1 group-hover:text-amber-400 transition-colors">{config.label}</div>
                <div class="text-xs text-slate-500 group-hover:text-slate-400">Explore domain</div>
              </div>
              
              <!-- Hover Preview Overlay -->
              <div class="absolute inset-0 bg-slate-900/95 backdrop-blur-sm p-5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-center">
                {topPaper ? (
                  <>
                    <div class="text-xs text-amber-400 font-semibold mb-1 uppercase">Featured Paper</div>
                    <div class="text-sm text-slate-300 line-clamp-3 font-medium">{topPaper.title}</div>
                    <div class="text-xs text-slate-500 mt-2">{topPaper.year}</div>
                  </>
                ) : (
                  <div class="text-sm text-slate-400 italic">No papers found</div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Notable Papers -->
  <section class="py-16 border-b border-slate-800 bg-slate-900/30">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2 text-slate-200">Notable Papers</h2>
      <p class="text-slate-500 mb-8">Landmark studies that shaped the field — and the debates that followed.</p>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {notablePapers.map((paper: any) => (
          <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex flex-col h-full hover:border-amber-500/30 transition-colors">
            <div class="mb-4">
              <span class="text-xs bg-amber-500/10 text-amber-400 px-2.5 py-1 rounded-full border border-amber-500/20 capitalize font-medium">
                {paper.psi_domain?.replace(/_/g, ' ')}
              </span>
            </div>
            <a href={`/paper/${paper.id}`} class="font-bold text-lg text-slate-200 hover:text-amber-400 mb-3 block line-clamp-2 transition-colors">
              {paper.title}
