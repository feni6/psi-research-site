---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<Layout title="Compare Papers">
  <div class="min-h-screen bg-slate-950 text-slate-200 font-sans selection:bg-amber-500/30 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      
      <!-- Breadcrumbs -->
      <div class="mb-6">
        <Breadcrumb 
          items={[
            { label: 'Home', href: '/' },
            { label: 'Compare Papers', href: '/compare' }
          ]} 
        />
      </div>

      <!-- Hero Section -->
      <div class="mb-10 text-center md:text-left">
        <h1 class="text-4xl font-bold text-amber-400 mb-3 tracking-tight">Compare Papers Side-by-Side</h1>
        <p class="text-lg text-slate-400 max-w-3xl">
          Select 2-3 papers to compare their methodology, findings, and evidence strength. 
          Analyze sample sizes, blinding protocols, and effect sizes at a glance.
        </p>
      </div>

      <!-- Quick Compare Section -->
      <div class="mb-8 bg-slate-900/50 border border-slate-800 rounded-lg p-6">
        <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-4">Quick Compare: Famous Debates</h3>
        <div class="flex flex-wrap gap-3">
          <button onclick="quickCompare(['bem_2011_feeling', 'wagenmakers_2011_why_psychologists'])" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-md text-sm font-medium border border-slate-700 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Bem vs. Wagenmakers (2011)
          </button>
          <button onclick="quickCompare(['storm_2010_metaanalysis', 'hyman_2010_meta_analysis_conceals'])" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-md text-sm font-medium border border-slate-700 transition-colors flex items-center gap-2">
            <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            Storm vs. Hyman (Ganzfeld)
          </button>
        </div>
      </div>

      <!-- Main Interface -->
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        
        <!-- Left Column: Search & Controls -->
        <div class="lg:col-span-1 space-y-6">
          
          <!-- Search Box -->
          <div class="relative z-50">
            <label for="paperSearch" class="block text-sm font-medium text-slate-400 mb-2">Add Paper</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
              </div>
              <input 
                type="text" 
                id="paperSearch" 
                class="block w-full pl-10 pr-3 py-3 border border-slate-700 rounded-md leading-5 bg-slate-900 text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-amber-500 sm:text-sm transition-shadow shadow-lg" 
                placeholder="Search title, author..."
                autocomplete="off"
              >
            </div>
            <!-- Search Results Dropdown -->
            <div id="searchResults" class="absolute w-full mt-1 bg-slate-900 border border-slate-700 rounded-md shadow-2xl max-h-80 overflow-y-auto hidden">
              <!-- Results injected via JS -->
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col gap-3 pt-4 border-t border-slate-800">
            <button id="shareBtn" class="w-full px-4 py-3 text-sm font-bold text-slate-950 bg-amber-400 hover:bg-amber-300 rounded-md transition-colors shadow-lg shadow-amber-900/20 flex justify-center items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path></svg>
              Share Comparison
            </button>
            <button id="clearBtn" class="w-full px-4 py-2 text-sm font-medium text-slate-400 hover:text-slate-200 bg-transparent hover:bg-slate-800 rounded-md transition-colors">
              Clear Selection
            </button>
          </div>

          <!-- Selected Count -->
          <div class="text-xs text-slate-500 text-center mt-2">
            <span id="countDisplay">0</span> / 3 papers selected
          </div>
        </div>

        <!-- Right Column: Comparison Table -->
        <div class="lg:col-span-3">
          <div class="bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden shadow-2xl relative min-h-[400px]">
            
            <!-- Empty State -->
            <div id="emptyState" class="absolute inset-0 flex flex-col items-center justify-center text-slate-500 z-0 bg-slate-900/80 backdrop-blur-sm">
              <svg class="w-16 h-16 mb-4 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
              <p class="text-lg font-medium">No papers selected</p>
              <p class="text-sm">Search for papers on the left or use a Quick Compare preset.</p>
            </div>

            <div class="overflow-x-auto" id="tableWrapper">
              <table class="min-w-full divide-y divide-slate-800" id="compareTable">
                <thead class="bg-slate-900">
                  <tr id="tableHeaderRow">
                    <th scope="col" class="px-6 py-4 text-left text-xs font-medium text-slate-400 uppercase tracking-wider w-48 sticky left-0 bg-slate-900 z-20 border-r border-slate-800 shadow-[4px_0_12px_-4px_rgba(0,0,0,0.5)]">
                      Metric
                    </th>
                    <!-- Paper Columns injected via JS -->
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-800 bg-slate-900/30" id="compareBody">
                  <!-- Rows injected via JS -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // --- State ---
    let catalog = [];
    let selectedIds = [];
    const MAX_SELECTION = 3;

    // --- DOM Elements ---
    const searchInput = document.getElementById('paperSearch');
    const searchResults = document.getElementById('searchResults');
    const tableHeaderRow = document.getElementById('tableHeaderRow');
    const compareBody = document.getElementById('compareBody');
    const emptyState = document.getElementById('emptyState');
    const tableWrapper = document.getElementById('tableWrapper');
    const clearBtn = document.getElementById('clearBtn');
    const shareBtn = document.getElementById('shareBtn');
    const countDisplay = document.getElementById('countDisplay');

    // --- Initialization ---
    async function init() {
      // 1. Load Catalog
      try {
        const res = await fetch('/api/catalog.json');
        catalog = await res.json();
      } catch (e) {
        console.error("Failed to load catalog", e);
        searchInput.placeholder = "Error loading catalog...";
        return;
      }

      // 2. Check URL Params for shared link
      const urlParams = new URLSearchParams(window.location.search);
      const sharedIds = urlParams.get('ids');
      
      if (sharedIds) {
        // Validate IDs exist in current catalog
        selectedIds = sharedIds.split(',').filter(id => catalog.papers.find(p => p.id == id));
        saveToStorage();
      } else {
        // 3. Check LocalStorage
        const stored = localStorage.getItem('psi_compare_ids');
        if (stored) {
          selectedIds = JSON.parse(stored);
          // Validate IDs exist in current catalog
          selectedIds = selectedIds.filter(id => catalog.papers.find(p => p.id == id));
        }
      }

      updateCount();
      renderTable();
    }

    // --- Rendering ---
    function renderTable() {
      // Toggle Empty State
      if (selectedIds.length === 0) {
        emptyState.style.display = 'flex';
        tableWrapper.style.opacity = '0.3';
        tableWrapper.style.pointerEvents = 'none';
      } else {
        emptyState.style.display = 'none';
        tableWrapper.style.opacity = '1';
        tableWrapper.style.pointerEvents = 'auto';
      }

      // Clear existing dynamic columns (keep the first "Metric" column)
      const headers = Array.from(tableHeaderRow.children);
      for (let i = headers.length - 1; i >= 1; i--) {
        headers[i].remove();
      }
      compareBody.innerHTML = '';

      if (selectedIds.length === 0) return;

      const selectedPapers = selectedIds.map(id => catalog.papers.find(p => p.id == id)).filter(Boolean);

      // Render Headers
      selectedPapers.forEach((paper, index) => {
        const th = document.createElement('th');
        th.scope = "col";
        th.className = "px-6 py-4 text-left text-xs font-medium text-amber-400 uppercase tracking-wider min-w-[280px] border-l border-slate-800 relative group bg-slate-900 align-top";
        
        th.innerHTML = `
          <div class="flex justify-between items-start gap-2">
            <div class="flex-1 min-w-0">
              <span class="block line-clamp-2 font-bold text-base normal-case text-slate-100 mb-1 leading-snug">${paper.title}</span>
              <div class="text-xs text-slate-500 mt-1 truncate">${paper.authors?.split(';')[0] || 'Unknown'}, ${paper.year}</div>
            </div>
            <button onclick="removePaper('${paper.id}')" class="shrink-0 text-slate-600 hover:text-red-400 transition-colors p-1" title="Remove">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
          </div>
        `;
        tableHeaderRow.appendChild(th);
      });

      // Define Rows Configuration
      const rows = [
        { key: 'journal', label: 'Journal', type: 'text' },
        { key: 'domain', label: 'Domain', type: 'badge' },
        { key: 'study_type', label: 'Study Type', type: 'text' },
        { key: 'sample_size', label: 'Sample Size (N)', type: 'number', metric: 'sample' },
        { key: 'blinding', label: 'Blinding', type: 'categorical', metric: 'blinding' },
        { key: 'pre_registered', label: 'Pre-registered', type: 'boolean', metric: 'binary' },
        { key: 'effect_size', label: 'Effect Size', type: 'number', metric: 'effect' },
        { key: 'abstract', label: 'Key Finding', type: 'text', metric: 'abstract' },
      ];

      // Render Rows
      rows.forEach(rowConfig => {
        const tr = document.createElement('tr');
        tr.className = "hover:bg-slate-800/50 transition-colors group";

        // Label Cell
        const tdLabel = document.createElement('td');
        tdLabel.className = "px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-400 bg-slate-900/90 sticky left-0 z-10 border-r border-slate-800 group-hover:bg-slate-800/90 transition-colors";
        tdLabel.textContent = rowConfig.label;
        tr.appendChild(tdLabel);

        // Data Cells
        selectedPapers.forEach(paper => {
          const td = document.createElement('td');
          td.className = "px-6 py-4 text-sm text-slate-300 border-l border-slate-800 align-top";
          
          let value = paper[rowConfig.key];
          let displayValue = value;
          let colorClass = "";
          let badgeClass = "";

          // Formatting & Color Coding Logic
          if (rowConfig.metric === 'sample') {
            const n = parseInt(value) || 0;
            if (n >= 200) colorClass = "text-emerald-400 font-semibold";
            else if (n >= 50) colorClass = "text-amber-400 font-semibold";
            else colorClass = "text-rose-400 font-semibold";
            displayValue = n.toLocaleString();
          } 
          else if (rowConfig.metric === 'blinding') {
            const v = (value || "").toLowerCase();
            if (v.includes('double')) {
              badgeClass = "bg-emerald-900/30 text-emerald-300 px-2 py-1 rounded border border-emerald-800/50 inline-block text-xs font-medium";
              displayValue = "Double-Blind";
            } else if (v.includes('single')) {
              badgeClass = "bg-amber-900/30 text-amber-300 px-2 py-1 rounded border border-amber-800/50 inline-block text-xs font-medium";
              displayValue = "Single-Blind";
            } else {
              badgeClass = "bg-rose-900/30 text-rose-300 px-2 py-1 rounded border border-rose-800/50 inline-block text-xs font-medium";
              displayValue = "None / Open";
            }
          }
          else if (rowConfig.metric === 'binary') {
            if (value === true || value === "true" || value === "yes") {
              badgeClass = "bg-emerald-900/30 text-emerald-300 px-2 py-1 rounded border border-emerald-800/50 inline-block text-xs font-medium";
              displayValue = "Yes";
            } else if (value === false || value === "false" || value === "no") {
              badgeClass = "bg-rose-900/30 text-rose-300 px-2 py-1 rounded border border-rose-800/50 inline-block text-xs font-medium";
              displayValue = "No";
            } else {
              badgeClass = "bg-slate-800 text-slate-400 px-2 py-1 rounded border border-slate-700 inline-block text-xs font-medium";
              displayValue = "Unknown";
            }
          }
          else if (rowConfig.metric === 'effect') {
             if (value) {
               const num = parseFloat(value);
               if (!isNaN(num)) {
                 // Heuristic coloring for effect sizes
                 if (Math.abs(num) > 0.8) {
                   colorClass = "text-emerald-400 font-mono font-bold";
                 } else if (Math.abs(num) > 0.5) {
                   colorClass = "text-amber-400 font-mono";
                 } else {
                   colorClass = "text-slate-400 font-mono";
                 }
                 displayValue = num.toFixed(2);
               }
             } else {
               displayValue = "<span class='text-slate-600 italic'>-</span>";
             }
          }
          else if (rowConfig.metric === 'abstract') {
            // Key Finding: First 100 chars
            const abs = paper.abstract || "No abstract available.";
            displayValue = abs.length > 100 ? abs.substring(0, 100) + "..." : abs;
            colorClass = "text-slate-400 leading-relaxed";
          }
          else if (rowConfig.type === 'badge') {
             // Domain Badge
             badgeClass = "bg-slate-800 text-slate-300 px-2 py-1 rounded border border-slate-700 inline-block text-xs font-medium";
          }

          if (!displayValue && displayValue !== 0 && rowConfig.metric !== 'abstract') {
            displayValue = "<span class='text-slate-600 italic'>Not reported</span>";
          }

          td.innerHTML = `<span class="${colorClass} ${badgeClass}">${displayValue}</span>`;
          tr.appendChild(td);
        });

        compareBody.appendChild(tr);
      });
    }

    function updateCount() {
      countDisplay.textContent = selectedIds.length;
    }

    // --- Actions ---
    function addPaper(id) {
      if (selectedIds.includes(id)) return;
      if (selectedIds.length >= MAX_SELECTION) {
        alert(`Maximum ${MAX_SELECTION} papers allowed. Remove one to add another.`);
        return;
      }
      selectedIds.push(id);
      saveToStorage();
      renderTable();
      searchInput.value = '';
      searchResults.classList.add('hidden');
      updateCount();
    }

    window.removePaper = function(id) {
      selectedIds = selectedIds.filter(sid => sid != id);
      saveToStorage();
      renderTable();
      updateCount();
    }

    window.quickCompare = function(ids) {
      // Clear current and add new
      selectedIds = [];
      ids.forEach(id => {
        if(catalog.papers.find(p => p.id == id)) {
          selectedIds.push(id);
        }
      });
      saveToStorage();
      renderTable();
      updateCount();
      // Scroll to table on mobile
      if(window.innerWidth < 1024) {
        document.querySelector('.lg\\:col-span-3').scrollIntoView({ behavior: 'smooth' });
      }
    }

    function saveToStorage() {
      localStorage.setItem('psi_compare_ids', JSON.stringify(selectedIds));
      
      // Update URL without reload if sharing
      const url = new URL(window.location);
      if (selectedIds.length > 0) {
        url.searchParams.set('ids', selectedIds.join(','));
      } else {
        url.searchParams.delete('ids');
      }
      window.history.replaceState({}, '', url);
    }

    clearBtn.addEventListener('click', () => {
      selectedIds = [];
      saveToStorage();
      renderTable();
      updateCount();
    });

    shareBtn.addEventListener('click', () => {
      if (selectedIds.length < 2) {
        alert("Select at least 2 papers to share a comparison.");
        return;
      }
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        const originalHTML = shareBtn.innerHTML;
        shareBtn.innerHTML = `
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
          Copied!
        `;
        shareBtn.classList.add('bg-emerald-500', 'text-slate-950');
        setTimeout(() => {
          shareBtn.innerHTML = originalHTML;
          shareBtn.classList.remove('bg-emerald-500', 'text-slate-950');
        }, 2000);
      });
    });

    // --- Search Logic ---
    searchInput.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      searchResults.innerHTML = '';
      
      if (query.length < 2) {
        searchResults.classList.add('hidden');
        return;
      }

      const matches = catalog.papers.filter(p => 
        (p.title && p.title.toLowerCase().includes(query)) || 
        (p.authors && p.authors.toLowerCase().includes(query)) ||
        (p.domain && p.domain.toLowerCase().includes(query))
      ).slice(0, 10); // Limit results

      if (matches.length > 0) {
        searchResults.classList.remove('hidden');
        matches.forEach(p => {
          const isAdded = selectedIds.includes(p.id);
          const div = document.createElement('div');
          div.className = `px-4 py-3 cursor-pointer border-b border-slate-800 hover:bg-slate-800 transition-colors ${isAdded ? 'opacity-50 bg-slate-900' : ''}`;
          div.innerHTML = `
            <div class="text-sm font-medium text-slate-200 line-clamp-1">${p.title}</div>
            <div class="text-xs text-slate-500 mt-1 flex justify-between">
              <span>${p.authors?.split(';')[0]} • ${p.year}</span>
              <span class="text-amber-500/80">${p.domain}</span>
            </div>
            ${isAdded ? '<div class="text-xs text-amber-500 mt-1 font-bold flex items-center gap-1"><svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg> Added</div>' : ''}
          `;
          
          if (!isAdded) {
            div.addEventListener('click', () => addPaper(p.id));
          }
          
          searchResults.appendChild(div);
        });
      } else {
        searchResults.classList.add('hidden');
      }
    });

    // Close search on click outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !searchResults.contains(e.target)) {
        searchResults.classList.add('hidden');
      }
    });

    // Run
    init();
  </script>
</Layout>