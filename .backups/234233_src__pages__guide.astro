---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Guide', href: '/guide' }
];
---

<Layout title="How to Read This Library" description="A quick guide to understanding the epistemic status, methodology scores, and structure of the Psi Research Library.">
  <div class="max-w-5xl mx-auto px-4 py-12 space-y-20">
    
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbs} />

    <!-- Hero Section -->
    <header class="text-center space-y-6">
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight">
        How to Read This Library
      </h1>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Navigating psi research requires a critical eye. This guide explains our classification system, methodology metrics, and how to find the signal in the noise.
      </p>
    </header>

    <!-- VISUAL EXAMPLE: Anatomy of a Paper Card -->
    <section class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8 md:p-12">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-bold text-white mb-2">Anatomy of a Paper Card</h2>
        <p class="text-slate-400">Every entry in our catalog follows this structure to help you assess quality quickly.</p>
      </div>

      <!-- The Mock Card -->
      <div class="relative bg-slate-950 border border-slate-800 rounded-xl p-6 max-w-3xl mx-auto shadow-2xl">
        
        <!-- Header Row -->
        <div class="flex flex-col md:flex-row md:items-start justify-between gap-4 mb-4 relative group">
          <div class="space-y-2 flex-1">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="px-2 py-0.5 rounded text-xs font-bold bg-amber-500/10 text-amber-400 border border-amber-500/20">Mixed Evidence</span>
              <span class="text-xs text-slate-500 font-mono">2023 • Journal of Parapsychology</span>
            </div>
            <h3 class="text-xl font-bold text-white group-hover:text-amber-400 transition-colors cursor-pointer">
              Anomalous Cognition in Random Number Generator Experiments: A Meta-Analysis
            </h3>
            <p class="text-sm text-slate-400">Smith, J., & Doe, A.</p>
          </div>
          <!-- Annotation: Badge -->
          <div class="absolute -right-4 md:-right-12 top-0 w-32 text-right hidden md:block">
            <div class="text-xs text-slate-500 mb-1">Epistemic Status</div>
            <div class="h-px w-full bg-slate-700"></div>
          </div>
        </div>

        <!-- Metrics Row -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4 py-4 border-y border-slate-800/50 relative">
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Sample Size</div>
            <div class="text-white font-mono">n = 1,240</div>
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Effect Size</div>
            <div class="text-white font-mono">d = 0.18</div>
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Bayes Factor</div>
            <div class="text-amber-400 font-mono">BF₁₀ = 4.5</div>
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-1">Pre-Reg</div>
            <div class="text-green-400 font-mono">Yes</div>
          </div>
           <!-- Annotation: Metrics -->
           <div class="absolute -left-4 md:-left-16 top-1/2 -translate-y-1/2 w-32 text-right hidden md:block">
            <div class="text-xs text-slate-500 mb-1">Key Metrics</div>
            <div class="h-px w-full bg-slate-700"></div>
          </div>
        </div>

        <!-- Abstract Snippet -->
        <div class="relative">
          <p class="text-sm text-slate-400 italic line-clamp-2">
            "We analyzed 40 years of RNG data to determine if conscious intention can influence electronic noise. Results indicate a small but statistically significant deviation from chance..."
          </p>
           <!-- Annotation: Abstract -->
           <div class="absolute -bottom-8 left-0 w-32 text-left hidden md:block">
            <div class="text-xs text-slate-500 mb-1">Abstract Preview</div>
            <div class="h-px w-full bg-slate-700"></div>
          </div>
        </div>

      </div>
    </section>

    <!-- Epistemic Status Badges -->
    <section class="space-y-8">
      <div class="flex items-center gap-3 border-b border-slate-800 pb-4">
        <span class="text-3xl">🏷️</span>
        <h2 class="text-2xl font-semibold text-white">Epistemic Status Badges</h2>
      </div>
      <p class="text-slate-400 text-lg">
        We tag every paper with a status badge indicating the current scientific consensus regarding its findings.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Strong Evidence -->
        <div class="bg-slate-900 border border-green-500/30 rounded-xl p-6 space-y-4 hover:border-green-500/50 transition-colors shadow-lg shadow-green-900/5">
          <div class="flex items-center justify-between">
            <h3 class="font-bold text-green-400">Strong Evidence</h3>
            <div class="w-2 h-2 rounded-full bg-green-500 shadow-[0_0_8px_rgba(34,197,94,0.8)]"></div>
          </div>
          <div class="inline-block px-2 py-1 rounded bg-green-500/10 border border-green-500/20 text-xs font-bold text-green-400">
            STRONG EVIDENCE
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            Multiple successful replications, significant meta-analyses, and robust methodology. The effect is considered reliable within the field.
          </p>
        </div>

        <!-- Mixed Evidence -->
        <div class="bg-slate-900 border border-amber-500/30 rounded-xl p-6 space-y-4 hover:border-amber-500/50 transition-colors shadow-lg shadow-amber-900/5">
          <div class="flex items-center justify-between">
            <h3 class="font-bold text-amber-400">Mixed Evidence</h3>
            <div class="w-2 h-2 rounded-full bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.8)]"></div>
          </div>
          <div class="inline-block px-2 py-1 rounded bg-amber-500/10 border border-amber-500/20 text-xs font-bold text-amber-400">
            MIXED EVIDENCE
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            Some positive results exist, but there are notable critiques, failed replications, or methodological inconsistencies that prevent consensus.
          </p>
        </div>

        <!-- Weak/Contested -->
        <div class="bg-slate-900 border border-red-500/30 rounded-xl p-6 space-y-4 hover:border-red-500/50 transition-colors shadow-lg shadow-red-900/5">
          <div class="flex items-center justify-between">
            <h3 class="font-bold text-red-400">Weak / Contested</h3>
            <div class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.8)]"></div>
          </div>
          <div class="inline-block px-2 py-1 rounded bg-red-500/10 border border-red-500/20 text-xs font-bold text-red-400">
            WEAK / CONTESTED
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            Failed replications, serious methodological concerns, fraud allegations, or strong counter-evidence dominates the literature.
          </p>
        </div>

        <!-- Insufficient Data -->
        <div class="bg-slate-900 border border-slate-600/30 rounded-xl p-6 space-y-4 hover:border-slate-500/50 transition-colors">
          <div class="flex items-center justify-between">
            <h3 class="font-bold text-slate-400">Insufficient Data</h3>
            <div class="w-2 h-2 rounded-full bg-slate-500"></div>
          </div>
          <div class="inline-block px-2 py-1 rounded bg-slate-800 border border-slate-700 text-xs font-bold text-slate-400">
            INSUFFICIENT DATA
          </div>
          <p class="text-sm text-slate-400 leading-relaxed">
            Too few studies to draw conclusions. Often applies to niche phenomena, historical cases, or very recent research.
          </p>
        </div>
      </div>
    </section>

    <!-- Methodology Scores -->
    <section class="space-y-8">
      <div class="flex items-center gap-3 border-b border-slate-800 pb-4">
        <span class="text-3xl">📊</span>
        <h2 class="text-2xl font-semibold text-white">Methodology Scores</h2>
      </div>
      <p class="text-slate-400 text-lg">
        We extract key methodological metrics from each paper to help you assess quality at a glance.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:bg-slate-900 transition-colors">
          <h3 class="text-amber-400 font-mono text-sm mb-3 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> SAMPLE SIZE (n)
          </h3>
          <p class="text-slate-300 text-sm leading-relaxed">
            The total number of participants or trials. In psi research, small samples (n &lt; 50) are often viewed with skepticism due to the "file drawer problem" and statistical noise.
          </p>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:bg-slate-900 transition-colors">
          <h3 class="text-amber-400 font-mono text-sm mb-3 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> PRE-REGISTRATION
          </h3>
          <p class="text-slate-300 text-sm leading-relaxed">
            Indicates if the study hypothesis and analysis plan were registered publicly <em>before</em> data collection began. This is the gold standard for preventing p-hacking.
          </p>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:bg-slate-900 transition-colors">
          <h3 class="text-amber-400 font-mono text-sm mb-3 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> BLINDING
          </h3>
          <div class="text-slate-300 text-sm space-y-2">
            <p><strong class="text-white">Double-blind:</strong> Neither participant nor experimenter knows the condition.</p>
            <p><strong class="text-white">Single-blind:</strong> Only the participant is unaware.</p>
            <p><strong class="text-white">Open:</strong> No blinding (high risk of experimenter bias).</p>
          </div>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 hover:bg-slate-900 transition-colors">
          <h3 class="text-amber-400 font-mono text-sm mb-3 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> EFFECT SIZE (Cohen's d)
          </h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-2">
            Measures the magnitude of the phenomenon independent of sample size.
          </p>
          <div class="flex gap-4 text-xs font-mono text-slate-400 border-t border-slate-800 pt-2">
            <span>0.2 = Small</span>
            <span>0.5 = Medium</span>
            <span>0.8 = Large</span>
          </div>
        </div>

        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 md:col-span-2 hover:bg-slate-900 transition-colors">
          <h3 class="text-amber-400 font-mono text-sm mb-3 flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span> BAYES FACTOR (BF₁₀)
          </h3>
          <p class="text-slate-300 text-sm mb-4">
            A ratio indicating how much more likely the data is under the alternative hypothesis (psi exists) vs the null hypothesis (chance).
          </p>
          <div class="flex flex-wrap gap-2 text-xs font-mono">
            <span class="px-3 py-1.5 bg-slate-800 rounded border border-slate-700 text-slate-400">BF &lt; 1: Evidence for Null</span>
            <span class="px-3 py-1.5 bg-slate-800 rounded border border-slate-700 text-slate-400">1 - 3: Anecdotal</span>
            <span class="px-3 py-1.5 bg-slate-800 rounded border border-amber-500/30 text-amber-400/80">3 - 10: Moderate</span>
            <span class="px-3 py-1.5 bg-slate-800 rounded border border-amber-500/30 text-amber-400">10 - 30: Strong</span>
            <span class="px-3 py-1.5 bg-slate-800 rounded border border-green-500/30 text-green-400">100+: Very Strong</span>
          </div>
        </div>
      </div>
    </section>

    <!-- TRY IT YOURSELF SECTION -->
    <section class="space-y-8">
      <div class="text-center space-y-4">
        <h2 class="text-3xl font-bold text-white">Try It Yourself</h2>
        <p class="text-slate-400">Ready to explore? Here are three ways to start your research journey.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Card 1: Browse Catalog -->
        <a href="/catalog" class="group block bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-amber-500/50 transition-all hover:-translate-y-1">
          <div class="h-32 bg-slate-950 border-b border-slate-800 p-4 flex flex-col justify-center items-center gap-2 group-hover:bg-slate-900 transition-colors">
            <div class="text-3xl">📂</div>
            <div class="text-xs font-mono text-slate-500">354 Papers Indexed</div>
          </div>
          <div class="p-6 space-y-3">
            <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors">Browse the Catalog</h3>
            <p class="text-sm text-slate-400">
              Search and filter the entire database by phenomenon, year, or methodology score.
            </p>
            <div class="pt-2 text-xs font-bold text-amber-400 flex items-center gap-1">
              Start Browsing <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>

        <!-- Card 2: Read Controversy -->
        <a href="/controversies" class="group block bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-amber-500/50 transition-all hover:-translate-y-1">
          <div class="h-32 bg-slate-950 border-b border-slate-800 p-4 flex flex-col justify-center items-center gap-2 group-hover:bg-slate-900 transition-colors">
            <div class="text-3xl">⚔️</div>
            <div class="text-xs font-mono text-slate-500">12 Major Debates</div>
          </div>
          <div class="p-6 space-y-3">
            <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors">Read a Controversy</h3>
            <p class="text-sm text-slate-400">
              Dive into specific debates like "Ganzfeld ESP" or "Remote Viewing" with balanced perspectives.
            </p>
            <div class="pt-2 text-xs font-bold text-amber-400 flex items-center gap-1">
              View Debates <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>

        <!-- Card 3: Follow Path -->
        <a href="/paths" class="group block bg-slate-900 border border-slate-800 rounded-xl overflow-hidden hover:border-amber-500/50 transition-all hover:-translate-y-1">
          <div class="h-32 bg-slate-950 border-b border-slate-800 p-4 flex flex-col justify-center items-center gap-2 group-hover:bg-slate-900 transition-colors">
            <div class="text-3xl">🗺️</div>
            <div class="text-xs font-mono text-slate-500">Curated Journeys</div>
          </div>
          <div class="p-6 space-y-3">
            <h3 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors">Follow a Reading Path</h3>
            <p class="text-sm text-slate-400">
              Don't know where to start? Follow a curated sequence from beginner to expert.
            </p>
            <div class="pt-2 text-xs font-bold text-amber-400 flex items-center gap-1">
              Find a Path <span class="group-hover:translate-x-1 transition-transform">→</span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Controversy Maps & Reading Paths (Detailed) -->
    <section class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Controversy Maps -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">🗺️</span>
          <h2 class="text-xl font-semibold text-white">Controversy Maps</h2>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-4">
          <p class="text-slate-300">
            Our controversy pages are designed to be neutral ground. Each map visualizes the research landscape for a specific debate.
          </p>
          <ul class="space-y-3 text-sm text-slate-400">
            <li class="flex items-start gap-3">
              <span class="text-amber-400 mt-1">✓</span>
              <span>Shows papers from <strong class="text-slate-200">both</strong> proponents and skeptics.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-400 mt-1">✓</span>
              <span>Highlights methodological flaws and strengths side-by-side.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-amber-400 mt-1">✓</span>
              <span>Links directly to relevant <strong class="text-slate-200">Reading Paths</strong> for guided exploration.</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Reading Paths -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl">📚</span>
          <h2 class="text-xl font-semibold text-white">Reading Paths</h2>
        </div>
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 space-y-4">
          <p class="text-slate-300">
            Don't know where to start? Reading Paths are curated sequences of papers designed to take you from foundational concepts to advanced debates.
          </p>
          <div class="space-y-4 pt-2">
            <div class="flex items-start gap-4 p-3 rounded-lg bg-slate-950/50 border border-slate-800/50">
              <span class="text-amber-400 font-bold font-mono text-lg">01</span>
              <div>
                <h4 class="text-white text-sm font-medium">Beginner</h4>
                <p class="text-xs text-slate-500">High-level overviews and famous historical cases.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-3 rounded-lg bg-slate-950/50 border border-slate-800/50">
              <span class="text-amber-400 font-bold font-mono text-lg">02</span>
              <div>
                <h4 class="text-white text-sm font-medium">Methodology Deep Dive</h4>
                <p class="text-xs text-slate-500">Focus on experimental design, statistics, and controls.</p>
              </div>
            </div>
            <div class="flex items-start gap-4 p-3 rounded-lg bg-slate-950/50 border border-slate-800/50">
              <span class="text-amber-400 font-bold font-mono text-lg">03</span>
              <div>
                <h4 class="text-white text-sm font-medium">The Skeptic's Case</h4>
                <p class="text-xs text-slate-500">Key papers arguing against psi phenomena.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="border-t border-slate-800 pt-12 space-y-8">
      <h2 class="text-2xl font-bold text-white text-center">Frequently Asked Questions</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Q1 -->
        <div class="bg-slate-900/30 border border-slate-800 rounded-lg p-6">
          <h3 class="text-white font-semibold mb-2">Is this library pro-psi?</h3>
          <p class="text-slate-400 text-sm">
            No. This library is agnostic. We catalog papers based on their methodology and findings, regardless of the outcome. We explicitly include skeptical critiques and failed replications to provide a balanced view of the literature.
          </p>
        </div>

        <!-- Q2 -->
        <div class="bg-slate-900/30 border border-slate-800 rounded-lg p-6">
          <h3 class="text-white font-semibold mb-2">Who built this?</h3>
          <p class="text-slate-400 text-sm">
            This project was built by a team of researchers and developers interested in open science and data transparency. We believe that psi research suffers from information silos, and we aim to fix that.
          </p>
        </div>

        <!-- Q3 -->
        <div class="bg-slate-900/30 border border-slate-800 rounded-lg p-6">
          <h3 class="text-white font-semibold mb-2">How are papers selected?</h3>
          <p class="text-slate-400 text-sm">
            We prioritize peer-reviewed journals in parapsychology and related fields (physics, psychology). We also include significant pre-prints and historical papers that shaped the field. Papers are excluded if they lack basic methodological transparency.
          </p>
        </div>

        <!-- Q4 -->
        <div class="bg-slate-900/30 border border-slate-800 rounded-lg p-6">
          <h3 class="text-white font-semibold mb-2">Can I contribute?</h3>
          <p class="text-slate-400 text-sm">
            Yes! The library is open source. If you find a missing paper, a data error, or want to suggest a new reading path, please visit our GitHub repository to submit a pull request or open an issue.
          </p>
        </div>
      </div>
    </section>

    <!-- For AI Agents -->
    <section class="border-t border-slate-800 pt-10">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 bg-slate-900/30 p-6 rounded-xl border border-slate-800">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold text-white flex items-center gap-2">
            <span class="text-2xl">🤖</span> For AI Agents
          </h2>
          <p class="text-slate-400 text-sm max-w-xl">
            This library is optimized for LLM consumption. You can access the full structured dataset via our API or context file.
          </p>
        </div>
        
        <div class="flex flex-col gap-3 min-w-[300px]">
          <div class="bg-slate-950 border border-slate-800 rounded p-3 font-mono text-xs text-slate-300 flex items-center justify-between group cursor-default">
            <span class="truncate">/llms.txt</span>
            <span class="text-slate-600 group-hover:text-amber-400 transition-colors">Context File</span>
          </div>
          <div class="bg-slate-950 border border-slate-800 rounded p-3 font-mono text-xs text-slate-300 flex items-center justify-between group cursor-default">
            <span class="truncate">/api/catalog.json</span>
            <span class="text-slate-600 group-hover:text-amber-400 transition-colors">Full Dataset</span>
          </div>
        </div>
      </div>
    </section>

  </div>
</Layout>