<!-- src/pages/paths/[id].astro -->
---
import Layout from '../../layouts/Layout.astro';
import { marked } from 'marked';
import fs from 'node:fs';
import path from 'node:path';
import catalog from '../../data/catalog.json';

export function getStaticPaths() {
  const dir = path.join(process.cwd(), 'src/data/reading_paths');
  const files = fs.readdirSync(dir).filter(f => f.startsWith('path_') && f.endsWith('.md'));
  return files.map(f => {
    const id = f.replace('.md', '');
    const content = fs.readFileSync(path.join(dir, f), 'utf-8');
    return { params: { id }, props: { content } };
  });
}

const { id } = Astro.params;
const { content } = Astro.props;

// 1. Extract Steps (## Headings) for Progress Bar
const stepPattern = /^## (.+)$/gm;
const steps = [];
let stepMatch;
// We clone content to avoid modifying the original while matching
const contentForSteps = content; 
while ((stepMatch = stepPattern.exec(contentForSteps)) !== null) {
  steps.push(stepMatch[1].trim());
}

// 2. Extract all catalog IDs for metadata lookup
const catalogIdPattern = /\[catalog ID: ([^\]]+)\]|`([a-zA-Z0-9_-]+)`/g;
const foundIds = new Set<string>();
let match;

// Reset regex state
catalogIdPattern.lastIndex = 0;
while ((match = catalogIdPattern.exec(content)) !== null) {
  const catalogId = (match[1] || match[2]).trim();
  if (catalogId) {
    foundIds.add(catalogId);
  }
}

// 3. Build Paper Map for quick lookup during rendering
const paperMap = new Map();
Array.from(foundIds).forEach(catalogId => {
  const paper = catalog.papers.find((p: any) => p.id === catalogId);
  if (paper) {
    paperMap.set(catalogId, {
      id: paper.id,
      title: paper.title,
      year: paper.year,
      domain: paper.domain || 'Unknown'
    });
  }
});

const papersInPath = Array.from(paperMap.values());
const paperCount = papersInPath.length;

// 4. Pre-process content: Convert [catalog ID: xxx] to a custom HTML tag 
// that we can style heavily later, instead of a standard markdown link.
// We use a custom tag <paper-card id="xxx" /> which marked will pass through as HTML.
const processedContent = content.replace(
  /\[catalog ID: ([^\]]+)\]/g,
  (_, catalogId) => `<paper-card id="${catalogId.trim()}"></paper-card>`
);

// Also handle backtick references `xxx` if they look like IDs, but keep them simpler for now
// or convert them similarly if needed. For this update, we focus on the explicit [catalog ID] syntax.

const html = marked(processedContent);

// 5. Post-process HTML: Replace <paper-card> tags with actual styled cards
const finalHtml = html.replace(/<paper-card id="([^"]+)"><\/paper-card>/g, (_, paperId) => {
  const paper = paperMap.get(paperId);
  if (!paper) return `<span class="text-red-400">Paper ${paperId} not found</span>`;
  
  return `
    <div class="my-4 p-4 bg-slate-900 border border-slate-700 rounded-lg hover:border-amber-500/50 transition-colors group">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-mono text-amber-500 bg-amber-500/10 px-2 py-0.5 rounded">PAPER ${paper.id}</span>
            <span class="text-xs text-slate-500">{paper.year}</span>
          </div>
          <h4 class="text-slate-200 font-medium group-hover:text-amber-400 transition-colors">
            <a href="/paper/${paper.id}" class="hover:underline">${paper.title}</a>
          </h4>
          <p class="text-xs text-slate-400 mt-1">${paper.domain}</p>
        </div>
        <a href="/paper/${paper.id}" class="shrink-0 text-slate-500 hover:text-amber-400 transition-colors" title="Read Paper">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  `;
});

const title = content.split('\n')[0].replace(/^#\s*/, '').trim();
---

<Layout title={title}>
  <nav class="text-sm text-slate-500 mb-6">
    <a href="/" class="hover:text-amber-400">Home</a>
    <span class="mx-1 text-slate-600">/</span>
    <a href="/paths" class="hover:text-amber-400">Reading Paths</a>
    <span class="mx-1 text-slate-600">/</span>
    <span class="text-slate-300">{title}</span>
  </nav>

  <!-- Header Stats -->
  <div class="mb-8 flex flex-wrap items-center gap-4">
    <div class="flex items-center gap-3 bg-slate-900 border border-slate-700 rounded-lg px-4 py-3">
      <span class="text-amber-400 text-xl">📚</span>
      <div>
        <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Journey Length</p>
        <p class="text-lg font-bold text-slate-200">{paperCount} Papers</p>
      </div>
    </div>
    
    {steps.length > 0 && (
      <div class="flex items-center gap-3 bg-slate-900 border border-slate-700 rounded-lg px-4 py-3">
        <span class="text-amber-400 text-xl">👣</span>
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold">Steps</p>
          <p class="text-lg font-bold text-slate-200">{steps.length} Sections</p>
        </div>
      </div>
    )}
  </div>

  <!-- Visual Progress Indicator -->
  {steps.length > 0 && (
    <div class="mb-10 overflow-x-auto pb-4 scrollbar-hide">
      <div class="flex items-center gap-0 min-w-max">
        {steps.map((step, i) => (
          <div class="flex items-center">
            <div class="flex flex-col items-center gap-2 z-10">
              <div class="w-8 h-8 rounded-full bg-slate-800 border border-amber-500/30 text-amber-400 flex items-center justify-center text-xs font-bold shrink-0 shadow-lg shadow-amber-900/10">
                {i + 1}
              </div>
              <span class="text-[10px] text-slate-400 uppercase tracking-wider font-semibold max-w-[100px] truncate text-center">{step}</span>
            </div>
            {i < steps.length - 1 && (
              <div class="w-12 h-0.5 bg-slate-800 mx-2 relative">
                <div class="absolute inset-0 bg-gradient-to-r from-amber-500/20 to-transparent"></div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Collapsible Papers Table -->
  {paperCount > 0 && (
    <details class="mb-10 bg-slate-900/50 border border-slate-800 rounded-xl overflow-hidden backdrop-blur-sm">
      <summary class="cursor-pointer p-4 font-semibold text-slate-300 hover:text-amber-400 hover:bg-slate-800/50 transition-colors flex items-center justify-between group">
        <div class="flex items-center gap-2">
          <span>📋 Manifest</span>
          <span class="text-xs bg-slate-800 text-slate-400 px-2 py-0.5 rounded-full group-hover:bg-amber-500/20 group-hover:text-amber-400 transition-colors">{paperCount} items</span>
        </div>
        <span class="text-slate-600 text-sm group-hover:text-amber-400">Expand List</span>
      </summary>
      <div class="p-0 border-t border-slate-800">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-slate-950/50">
              <tr class="border-b border-slate-800">
                <th class="text-left py-3 px-4 text-slate-500 font-medium w-20">Year</th>
                <th class="text-left py-3 px-4 text-slate-500 font-medium">Title</th>
                <th class="text-left py-3 px-4 text-slate-500 font-medium w-40">Domain</th>
              </tr>
            </thead>
            <tbody>
              {papersInPath.map((paper: any, index: number) => (
                <tr class="border-b border-slate-800/50 hover:bg-slate-800/30 transition-colors last:border-0">
                  <td class="py-3 px-4 text-slate-500 font-mono text-xs">{paper.year}</td>
                  <td class="py-3 px-4">
                    <a 
                      href={`/paper/${paper.id}`} 
                      class="text-slate-300 hover:text-amber-400 hover:underline transition-colors line-clamp-2"
                    >
                      {paper.title}
                    </a>
                  </td>
                  <td class="py-3 px-4 text-slate-500 text-xs">
                    <span class="inline-block px-2 py-1 rounded bg-slate-800 border border-slate-700">{paper.domain}</span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </details>
  )}

  <!-- Main Content -->
  <article class="prose prose-invert prose-amber max-w-4xl prose-headings:text-slate-200 prose-headings:font-bold prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline">
    <!-- Custom CSS to ensure our injected cards don't get messed up by prose styles -->
    <style>
      .prose :where(.my-4) {
        margin-top: 1rem;
        margin-bottom: 1rem;
      }
      /* Override prose link styles for the cards specifically if needed, 
         but the card structure handles its own internal links */
    </style>
    <div set:html={finalHtml} />
  </article>
</Layout>