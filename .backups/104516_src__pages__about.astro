---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';
---

<Layout title="About" description="Learn about the mission, methodology, and epistemic principles of the Psi Research Library.">
  <main class="max-w-5xl mx-auto px-4 py-12 space-y-20">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500">
      <ol class="flex items-center space-x-2">
        <li><a href="/" class="hover:text-amber-400 transition-colors">Home</a></li>
        <li>/</li>
        <li class="text-white font-medium">About</li>
      </ol>
    </nav>

    <!-- Hero Section -->
    <section class="relative text-center space-y-6 py-8">
      <!-- Subtle background glow effect -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-amber-500/10 blur-[100px] rounded-full -z-10"></div>
      
      <h1 class="text-4xl md:text-6xl font-bold text-white tracking-tight">
        About the <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-300 to-amber-500">Psi Research Library</span>
      </h1>
      <p class="text-xl md:text-2xl text-slate-400 max-w-3xl mx-auto leading-relaxed font-light">
        A curated, machine-readable archive of peer-reviewed research on psi phenomena, built for epistemic transparency and rigorous inquiry.
      </p>
    </section>

    <!-- Mission Statement -->
    <section class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8 md:p-10 shadow-lg shadow-black/20">
      <div class="flex items-start gap-6">
        <div class="text-5xl">🎯</div>
        <div>
          <h2 class="text-2xl font-semibold text-white mb-4">Our Mission</h2>
          <p class="text-slate-300 leading-relaxed text-lg">
            The Psi Research Library is a curated collection of peer-reviewed research on psi phenomena, built with <strong class="text-amber-400">epistemic transparency</strong>. Our goal is not to advocate for or against psi claims, but to present the evidence — both supportive and critical — in a structured, searchable format. We serve researchers, students, curious skeptics, and AI agents alike by providing a neutral ground for examining the data.
          </p>
        </div>
      </div>
    </section>

    <!-- What's Included Grid -->
    <section>
      <h2 class="text-2xl font-semibold text-white mb-8 flex items-center gap-2">
        <span>📚</span> What's Included
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card 1 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">📄</div>
          <h3 class="text-xl font-medium text-white mb-2">354 Papers</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Spanning 1882–2025, covering over a century of parapsychological research.</p>
        </div>
        <!-- Card 2 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">🏷️</div>
          <h3 class="text-xl font-medium text-white mb-2">13 Categories</h3>
          <p class="text-slate-400 text-sm leading-relaxed">From meta-analyses and Ganzfeld studies to skeptical critiques and replication attempts.</p>
        </div>
        <!-- Card 3 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">⚖️</div>
          <h3 class="text-xl font-medium text-white mb-2">14 Controversy Maps</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Detailed breakdowns showing arguments for and against major debates in the field.</p>
        </div>
        <!-- Card 4 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">🛤️</div>
          <h3 class="text-xl font-medium text-white mb-2">6 Reading Paths</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Curated journeys for beginners, skeptics, researchers, and AI training.</p>
        </div>
        <!-- Card 5 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">🔄</div>
          <h3 class="text-xl font-medium text-white mb-2">Replication Tracking</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Complete tracking of replication attempts across major experimental paradigms.</p>
        </div>
        <!-- Card 6 -->
        <div class="group bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-400/50 hover:bg-slate-800/50 transition-all duration-300">
          <div class="text-amber-400 text-3xl mb-4 group-hover:scale-110 transition-transform">🤖</div>
          <h3 class="text-xl font-medium text-white mb-2">Machine Readable</h3>
          <p class="text-slate-400 text-sm leading-relaxed">Full JSON API and llms.txt support for seamless AI integration.</p>
        </div>
      </div>
    </section>

    <!-- Epistemic Principles -->
    <section class="bg-slate-900/50 border border-slate-800 rounded-2xl p-8 md:p-10">
      <h2 class="text-2xl font-semibold text-white mb-8 flex items-center gap-2">
        <span>🛡️</span> Epistemic Principles
      </h2>
      <div class="space-y-8">
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-400 font-bold border border-amber-400/20">1</div>
          <div>
            <h3 class="text-white font-medium text-lg">Both Sides Represented</h3>
            <p class="text-slate-400 mt-2 leading-relaxed">Every major controversy includes papers arguing <em>for</em> and <em>against</em> the phenomenon. We do not hide negative results.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-400 font-bold border border-amber-400/20">2</div>
          <div>
            <h3 class="text-white font-medium text-lg">Transparent Methodology</h3>
            <p class="text-slate-400 mt-2 leading-relaxed">Full documentation of how papers were selected, processed, and categorized, including known biases in the source material.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-400 font-bold border border-amber-400/20">3</div>
          <div>
            <h3 class="text-white font-medium text-lg">No Hidden Agenda</h3>
            <p class="text-slate-400 mt-2 leading-relaxed">This is an open resource, not an advocacy platform. We present the data so you can draw your own conclusions.</p>
          </div>
        </div>
        <div class="flex gap-5">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-amber-400/10 flex items-center justify-center text-amber-400 font-bold border border-amber-400/20">4</div>
          <div>
            <h3 class="text-white font-medium text-lg">AI-Friendly Design</h3>
            <p class="text-slate-400 mt-2 leading-relaxed">Structured specifically for both human browsing and machine consumption, enabling advanced analysis by LLMs.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Was Built -->
    <section class="grid md:grid-cols-2 gap-10 items-center">
      <div class="space-y-6">
        <h2 class="text-2xl font-semibold text-white flex items-center gap-2">
          <span>🏗️</span> How It Was Built
        </h2>
        <p class="text-slate-300 leading-relaxed">
          The library was curated using a combination of systematic literature review and AI-assisted processing. Paper metadata was extracted and structured using large language models, then rigorously validated against original sources.
        </p>
        <p class="text-slate-300 leading-relaxed">
          This hybrid approach allowed us to process a vast volume of literature while maintaining high accuracy in categorization and summarization.
        </p>
        <a href="/method" class="inline-flex items-center text-amber-400 hover:text-amber-300 font-medium transition-colors group">
          Read the full methodology 
          <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
        </a>
      </div>
      <div class="bg-slate-950 border border-slate-800 rounded-xl p-6 font-mono text-xs text-slate-400 overflow-hidden shadow-inner">
        <div class="flex gap-1.5 mb-4 border-b border-slate-800 pb-4">
          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        </div>
        <p class="mb-2"><span class="text-purple-400">// Curated with epistemic transparency</span></p>
        <p class="mb-1"><span class="text-blue-400">sources</span>: <span class="text-green-400">PubMed, PsycINFO, JPAR</span></p>
        <p class="mb-1"><span class="text-blue-400">years</span>: <span class="text-green-400">1882 — 2025</span></p>
        <p class="mb-1"><span class="text-blue-400">validation</span>: <span class="text-green-400">human-in-the-loop</span></p>
        <p><span class="text-blue-400">bias_check</span>: <span class="text-green-400">enabled</span></p>
      </div>
    </section>

    <!-- Contributors Acknowledgment -->
    <section class="bg-gradient-to-br from-slate-900 to-slate-900/50 border border-slate-800 rounded-2xl p-8 text-center">
      <h2 class="text-xl font-semibold text-white mb-4">Curated By</h2>
      <div class="flex flex-col md:flex-row items-center justify-center gap-6">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-amber-400/20 flex items-center justify-center text-amber-400 text-xl font-bold border border-amber-400/30">J</div>
          <div class="text-left">
            <div class="text-white font-medium">Jay</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider">Lead Curator</div>
          </div>
        </div>
        <div class="hidden md:block text-slate-600">+</div>
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-blue-500/20 flex items-center justify-center text-blue-400 text-xl">🤖</div>
          <div class="text-left">
            <div class="text-white font-medium">AI Assistants</div>
            <div class="text-xs text-slate-500 uppercase tracking-wider">Data Processing & Validation</div>
          </div>
        </div>
      </div>
      <p class="mt-6 text-slate-400 text-sm max-w-lg mx-auto">
        This project represents a collaboration between human critical thinking and machine efficiency to organize complex scientific data.
      </p>
    </section>

    <!-- Built With Section (Visual Cards) -->
    <section>
      <h2 class="text-2xl font-semibold text-white mb-8 flex items-center gap-2">
        <span>🛠️</span> Built With
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
        <!-- Tool Card 1 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-amber-400/40 hover:shadow-[0_0_15px_-3px_rgba(251,191,36,0.15)] transition-all duration-300 group">
          <div class="text-amber-400 font-bold text-xl mb-1 group-hover:scale-105 transition-transform inline-block">Astro</div>
          <div class="text-xs text-slate-500 font-medium uppercase tracking-wide">Static Site</div>
        </div>
        <!-- Tool Card 2 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-cyan-400/40 hover:shadow-[0_0_15px_-3px_rgba(34,211,238,0.15)] transition-all duration-300 group">
          <div class="text-cyan-400 font-bold text-xl mb-1 group-hover:scale-105 transition-transform inline-block">Tailwind</div>
          <div class="text-xs text-slate-500 font-medium uppercase tracking-wide">Styling</div>
        </div>
        <!-- Tool Card 3 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-orange-400/40 hover:shadow-[0_0_15px_-3px_rgba(251,146,60,0.15)] transition-all duration-300 group">
          <div class="text-orange-400 font-bold text-xl mb-1 group-hover:scale-105 transition-transform inline-block">Claude</div>
          <div class="text-xs text-slate-500 font-medium uppercase tracking-wide">Curation</div>
        </div>
        <!-- Tool Card 4 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-purple-400/40 hover:shadow-[0_0_15px_-3px_rgba(192,132,252,0.15)] transition-all duration-300 group">
          <div class="text-purple-400 font-bold text-xl mb-1 group-hover:scale-105 transition-transform inline-block">Qwen 3.5</div>
          <div class="text-xs text-slate-500 font-medium uppercase tracking-wide">Code Gen</div>
        </div>
        <!-- Tool Card 5 -->
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5 text-center hover:border-emerald-400/40 hover:shadow-[0_0_15px_-3px_rgba(52,211,153,0.15)] transition-all duration-300 group">
          <div class="text-emerald-400 font-bold text-xl mb-1 group-hover:scale-105 transition-transform inline-block">llama.cpp</div>
          <div class="text-xs text-slate-500 font-medium uppercase tracking-wide">Local AI</div>
        </div>
      </div>
    </section>

    <!-- Site Statistics Section -->
    <section>
      <h2 class="text-2xl font-semibold text-white mb-8 flex items-center gap-2">
        <span>📊</span> Site Statistics
      </h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl font-bold text-white mb-1">{catalog.papers.length}</div>
          <div class="text-sm text-slate-400 font-medium uppercase tracking-wide">Total Papers</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl font-bold text-white mb-1">400+</div>
          <div class="text-sm text-slate-400 font-medium uppercase tracking-wide">Total Pages</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl font-bold text-white mb-1">14</div>
          <div class="text-sm text-slate-400 font-medium uppercase tracking-wide">Controversy Maps</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:bg-slate-800/50 transition-colors">
          <div class="text-3xl font-bold text-white mb-1">6</div>
          <div class="text-sm text-slate-400 font-medium uppercase tracking-wide">Reading Paths</div>
        </div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-xl p-6 text-center hover:bg-slate-800/50 transition-colors col-span-2 md:col-span-4 lg:col-span-1 lg:col-start-2">
          <div class="text-3xl font-bold text-white mb-1">&lt;1s</div>
          <div class="text-sm text-slate-400 font-medium uppercase tracking-wide">Build Time</div>
        </div>
      </div>
    </section>

    <!-- Related Pages / Footer Links -->
    <section class="pt-8 border-t border-slate-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="text-center md:text-left">
          <h3 class="text-white font-semibold mb-1">Continue Exploring</h3>
          <p class="text-slate-500 text-sm">Dive deeper into the data and methodology.</p>
        </div>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/method" class="px-5 py-2.5 bg-slate-800 text-slate-300 text-sm font-medium rounded-lg hover:bg-slate-700 hover:text-white transition-all border border-slate-700">
            Methodology
          </a>
          <a href="/stats" class="px-5 py-2.5 bg-slate-800 text-slate-300 text-sm font-medium rounded-lg hover:bg-slate-700 hover:text-white transition-all border border-slate-700">
            Statistics
          </a>
          <a href="/catalog" class="px-5 py-2.5 bg-amber-400 text-slate-950 text-sm font-semibold rounded-lg hover:bg-amber-300 transition-all shadow-lg shadow-amber-400/10">
            Browse Catalog
          </a>
        </div>
      </div>
    </section>

  </main>
</Layout>