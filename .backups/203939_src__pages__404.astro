---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// Helper to get deterministic random papers based on an hour seed
function getPapersForHour(hour: number, allPapers: any[], count: number = 3) {
  const seed = hour;
  const papers = [...allPapers];
  const selected = [];
  
  // Simple seeded shuffle logic
  for (let i = papers.length - 1; i > 0; i--) {
    const j = (seed * (i + 1)) % (i + 1);
    [papers[i], papers[j]] = [papers[j], papers[i]];
  }
  
  return papers.slice(0, count);
}

// We'll pass the catalog to the client script to allow dynamic hour-based selection
const catalogJson = JSON.stringify(catalog);
---

<Layout title="Page Not Found">
  <div class="min-h-[80vh] flex flex-col items-center justify-center px-4 py-12">
    
    <!-- Hero Section -->
    <div class="text-center mb-12 animate-fade-in">
      <div class="text-6xl mb-4">👻</div>
      <h1 class="text-5xl md:text-6xl font-bold text-amber-400 mb-4 tracking-tight">
        404
      </h1>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-200 mb-2">
        Page Not Found
      </h2>
      <p class="text-slate-400 text-lg max-w-md mx-auto italic">
        "Even our best remote viewers couldn't locate this page in the spatial-temporal continuum."
      </p>
    </div>

    <!-- Search Box -->
    <div class="w-full max-w-lg mb-12">
      <form action="/search" method="GET" class="relative group">
        <input 
          type="text" 
          name="q" 
          placeholder="Search the archives..." 
          class="w-full bg-slate-900 border border-slate-700 text-slate-200 rounded-lg py-4 pl-6 pr-14 focus:outline-none focus:border-amber-400 focus:ring-1 focus:ring-amber-400 transition-all placeholder:text-slate-600"
          required
        />
        <button 
          type="submit" 
          class="absolute right-2 top-2 bottom-2 bg-amber-400 hover:bg-amber-500 text-slate-950 font-bold px-4 rounded-md transition-colors"
        >
          Search
        </button>
      </form>
    </div>

    <!-- Dynamic Suggestions -->
    <div class="w-full max-w-4xl mb-12">
      <h3 class="text-slate-400 text-sm font-bold uppercase tracking-widest mb-6 text-center">
        Maybe you were looking for...
      </h3>
      <div id="suggestions-grid" class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Fallback content while JS loads -->
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
        <div class="bg-slate-900/50 border border-slate-800 rounded-lg p-6 h-32 animate-pulse"></div>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a href="/" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg font-medium transition-colors border border-slate-700">
        Home
      </a>
      <a href="/catalog" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg font-medium transition-colors border border-slate-700">
        Full Catalog
      </a>
      <a href="/reading-paths" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg font-medium transition-colors border border-slate-700">
        Reading Paths
      </a>
      <a href="/timeline" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-slate-200 rounded-lg font-medium transition-colors border border-slate-700">
        Timeline
      </a>
    </div>

    <!-- Random Button -->
    <button 
      id="random-btn"
      class="group flex items-center gap-2 px-8 py-4 bg-amber-400/10 hover:bg-amber-400/20 border border-amber-400/50 text-amber-400 rounded-full font-bold transition-all hover:scale-105 active:scale-95"
    >
      <span>🎲</span>
      <span>Take me somewhere random</span>
    </button>

  </div>

  <!-- Client-side logic for dynamic content -->
  <script>
    const catalog = JSON.parse(`${catalogJson}`);

    // 1. Dynamic Suggestions based on current hour
    function renderSuggestions() {
      const hour = new Date().getHours();
      const seed = hour;
      
      // Deterministic shuffle based on hour
      const shuffled = [...catalog].sort(() => 0.5 - Math.sin(seed + Math.random()));
      const suggestions = shuffled.slice(0, 3);
      
      const grid = document.getElementById('suggestions-grid');
      if (!grid) return;

      grid.innerHTML = suggestions.map(paper => `
        <a href="/papers/${paper.slug}" class="block bg-slate-900 border border-slate-800 hover:border-amber-400/50 rounded-lg p-5 transition-all hover:-translate-y-1 group">
          <div class="text-xs text-amber-400/80 font-mono mb-2">${paper.year}</div>
          <h4 class="text-slate-200 font-semibold leading-snug group-hover:text-amber-400 transition-colors line-clamp-2">
            ${paper.title}
          </h4>
          <div class="mt-3 text-xs text-slate-500 truncate">
            ${paper.author}
          </div>
        </a>
      `).join('');
    }

    // 2. Random Paper Navigation
    document.getElementById('random-btn')?.addEventListener('click', () => {
      const randomPaper = catalog[Math.floor(Math.random() * catalog.length)];
      window.location.href = `/papers/${randomPaper.slug}`;
    });

    // Initialize
    renderSuggestions();
  </script>
</Layout>