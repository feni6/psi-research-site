---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import wishlistData from '../data/wishlist.json';

const pageTitle = "Wishlist: Wanted Papers";

// Categorization Logic
function categorizePaper(whyNeeded: string | undefined): string {
  const text = (whyNeeded || "").toLowerCase();
  if (text.includes("skeptic") || text.includes("critical")) return "Skeptical/Critical";
  if (text.includes("replicat")) return "Replications";
  if (text.includes("meta")) return "Meta-Analyses";
  if (text.includes("method")) return "Methodology";
  return "General";
}

// Priority Color Helper
function getPriorityClasses(priority: string): string {
  const p = (priority || "low").toLowerCase();
  if (p === "high") return "bg-red-500/10 text-red-400 border-red-500/20";
  if (p === "medium") return "bg-amber-500/10 text-amber-400 border-amber-500/20";
  return "bg-emerald-500/10 text-emerald-400 border-emerald-500/20";
}

// Process papers
const allPapers = (wishlistData.papers_wanted || []);

// Calculate Progress
const acquiredPapers = allPapers.filter(p => p.status === "acquired");
const wantedPapers = allPapers.filter(p => p.status !== "acquired");
const totalPapers = allPapers.length;
const progressPercent = totalPapers > 0 ? Math.round((acquiredPapers.length / totalPapers) * 100) : 0;

// Process Wanted Papers for the main list
const processedPapers = wantedPapers.map(paper => ({
  ...paper,
  category: categorizePaper(paper.why_needed),
  priorityClass: getPriorityClasses(paper.priority)
}));

// Calculate category counts for filters
const categoryCounts: Record<string, number> = {};
processedPapers.forEach(p => {
  categoryCounts[p.category] = (categoryCounts[p.category] || 0) + 1;
});
const categories = Object.keys(categoryCounts).sort();

// Get "Most Wanted" (Top 10 High Priority)
const mostWanted = processedPapers
  .filter(p => (p.priority || "low").toLowerCase() === "high")
  .sort((a, b) => (b.year || 0) - (a.year || 0)) // Sort by newest first
  .slice(0, 10);
---

<Layout title={pageTitle}>
  <div class="max-w-6xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
    
    <!-- Breadcrumbs & Header -->
    <div class="mb-8">
      <Breadcrumb items={[
        { label: "Home", href: "/" },
        { label: "Wishlist", href: "/wishlist" }
      ]} />
      
      <div class="mt-4 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-slate-800 pb-6">
        <div>
          <h1 class="text-3xl font-bold text-amber-400 mb-2">Research Wishlist</h1>
          <p class="text-slate-400 max-w-2xl">
            A curated list of <span class="text-white font-semibold">{wantedPapers.length}</span> papers currently missing from our library but critical for comprehensive research.
          </p>
        </div>
        
        <!-- Progress Indicator -->
        <div class="w-full md:w-64 bg-slate-900 p-4 rounded-lg border border-slate-800">
          <div class="flex justify-between text-xs mb-2">
            <span class="text-slate-400">Acquisition Progress</span>
            <span class="text-amber-400 font-mono">{acquiredPapers.length} / {totalPapers}</span>
          </div>
          <div class="w-full bg-slate-800 rounded-full h-2">
            <div class="bg-amber-400 h-2 rounded-full transition-all duration-1000" style={`width: ${progressPercent}%`}></div>
          </div>
          <p class="text-xs text-slate-500 mt-2 text-right">{progressPercent}% Complete</p>
        </div>
      </div>
    </div>

    <!-- MOST WANTED SECTION -->
    {mostWanted.length > 0 && (
      <div class="mb-12">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          <h2 class="text-xl font-bold text-slate-200">Most Wanted (High Priority)</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {mostWanted.map(paper => (
            <div class="bg-slate-900/50 border border-red-500/20 rounded-lg p-4 hover:border-red-500/40 transition-all group">
              <div class="flex justify-between items-start mb-2">
                <span class="text-xs font-mono text-slate-500">{paper.year || "N/A"}</span>
                <span class="px-2 py-0.5 rounded text-xs font-bold bg-red-500/20 text-red-400 border border-red-500/20">HIGH PRIORITY</span>
              </div>
              <h3 class="text-slate-200 font-medium mb-1 group-hover:text-amber-400 transition-colors line-clamp-2">{paper.title}</h3>
              <p class="text-xs text-slate-500 mb-3">{(paper.authors || []).join(', ')}</p>
              <p class="text-sm text-slate-400 bg-slate-950 p-2 rounded border-l-2 border-red-500/50">
                {paper.why_needed}
              </p>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- CONTROLS: Search & Filter -->
    <div class="mb-8 space-y-4 sticky top-4 z-10 bg-slate-950/95 backdrop-blur py-4 -mx-4 px-4 md:mx-0 md:px-0 md:bg-transparent md:static md:backdrop-blur-none border-b md:border-none border-slate-800">
      
      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2" id="categoryFilters">
        <button 
          class="filter-badge px-3 py-1.5 rounded-full text-xs font-medium border transition-all bg-amber-400/10 border-amber-400/50 text-amber-400"
          data-category="all"
        >
          All ({processedPapers.length})
        </button>
        {categories.map(cat => (
          <button 
            class="filter-badge px-3 py-1.5 rounded-full text-xs font-medium border transition-all bg-slate-900 border-slate-700 text-slate-400 hover:border-slate-500 hover:text-slate-200"
            data-category={cat}
          >
            {cat} ({categoryCounts[cat]})
          </button>
        ))}
      </div>

      <!-- Search Input -->
      <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        <input 
          type="text" 
          id="searchInput"
          placeholder="Filter by title, author, or reason needed..." 
          class="w-full pl-10 pr-4 py-2.5 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-amber-400/50 focus:border-amber-400 transition-all text-sm"
        />
        <div id="resultCount" class="absolute right-3 top-2.5 text-xs text-slate-500 hidden">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>

    <!-- Contribution Callout -->
    <div class="mb-8 bg-slate-900/50 border border-amber-400/20 rounded-lg p-4 flex gap-4 items-start">
      <div class="flex-shrink-0 mt-1">
        <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      </div>
      <div>
        <h3 class="text-amber-400 font-semibold mb-1">Help us find these papers</h3>
        <p class="text-slate-400 text-sm leading-relaxed">
          Do you have access to academic databases (JSTOR, PubMed, university libraries) or physical archives? 
          If you can locate and digitize any of the papers listed below, please contact us. 
          Your contribution helps preserve the history of psi research for future study.
        </p>
      </div>
    </div>

    <!-- Papers List Header (Desktop) -->
    <div class="hidden md:grid grid-cols-12 gap-4 px-4 py-3 bg-slate-900/50 border-y border-slate-800 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">
      <div class="col-span-1">Year</div>
      <div class="col-span-1">Pri</div>
      <div class="col-span-4">Title</div>
      <div class="col-span-3">Authors</div>
      <div class="col-span-3">Why Needed</div>
    </div>

    <!-- Papers List -->
    <div class="space-y-3" id="papersList">
      {processedPapers.map((paper) => (
        <article 
          class="paper-row group relative bg-slate-900 border border-slate-800 rounded-lg p-4 hover:border-amber-400/30 hover:bg-slate-800/50 transition-all"
          data-category={paper.category}
          data-priority={(paper.priority || "low").toLowerCase()}
          data-title={(paper.title || "").toLowerCase()}
          data-authors={((paper.authors || []) as string[]).join(' ').toLowerCase()}
          data-reason={(paper.why_needed || "").toLowerCase()}
        >
          <!-- Mobile Layout (Stacked) -->
          <div class="md:hidden space-y-3">
            <div class="flex justify-between items-start">
              <div class="flex gap-2">
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-mono bg-slate-800 text-amber-400/80 border border-slate-700">
                  {paper.year || "N/A"}
                </span>
                <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-bold border uppercase ${paper.priorityClass}`}>
                  {paper.priority || "Low"}
                </span>
              </div>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-slate-800 text-slate-400 border border-slate-700">
                {paper.category}
              </span>
            </div>
            
            <h3 class="text-base font-medium text-slate-200 group-hover:text-amber-400 transition-colors">
              {paper.title || "Untitled"}
            </h3>
            
            <div class="text-sm text-slate-500">
              {(paper.authors || []).join(', ')}
            </div>
            
            <div class="text-sm text-slate-400 bg-slate-950/50 p-3 rounded border-l-2 border-amber-400/30">
              <span class="font-semibold text-slate-500 block text-xs uppercase mb-1">Why needed:</span>
              {paper.why_needed || "No reason provided"}
            </div>
          </div>

          <!-- Desktop Layout (Table-like Grid) -->
          <div class="hidden md:grid grid-cols-12 gap-4 items-center">
            <div class="col-span-1 text-sm font-mono text-amber-400/80">
              {paper.year || "N/A"}
            </div>
            <div class="col-span-1">
              <span class={`inline-block px-2 py-0.5 rounded text-[10px] font-bold border uppercase w-full text-center ${paper.priorityClass}`}>
                {paper.priority || "Low"}
              </span>
            </div>
            <div class="col-span-4">
              <h3 class="text-sm font-medium text-slate-200 group-hover:text-amber-400 transition-colors line-clamp-2">
                {paper.title || "Untitled"}
              </h3>
            </div>
            <div class="col-span-3 text-sm text-slate-400 truncate" title={(paper.authors || []).join(', ')}>
              {(paper.authors || []).join(', ')}
            </div>
            <div class="col-span-3 text-sm text-slate-400 line-clamp-2" title={paper.why_needed}>
              {paper.why_needed || "No reason provided"}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty State (Hidden by default) -->
    <div id="emptyState" class="hidden text-center py-12">
      <svg class="mx-auto h-12 w-12 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
      <h3 class="mt-2 text-sm font-medium text-slate-300">No papers found</h3>
      <p class="mt-1 text-sm text-slate-500">Try adjusting your search terms or category filter.</p>
      <button 
        id="resetFilters"
        class="mt-4 text-amber-400 hover:text-amber-300 text-sm font-medium underline underline-offset-4"
      >
        Clear all filters
      </button>
    </div>

  </div>

  <script>
    // Client-side filtering functionality
    const searchInput = document.getElementById('searchInput') as HTMLInputElement;
    const papersList = document.getElementById('papersList');
    const paperRows = papersList?.querySelectorAll('.paper-row') || [];
    const emptyState = document.getElementById('emptyState');
    const resultCount = document.getElementById('resultCount');
    const categoryButtons = document.querySelectorAll('.filter-badge');
    const resetButton = document.getElementById('resetFilters');

    let activeCategory = 'all';
    let searchTerm = '';

    function filterPapers() {
      let visibleCount = 0;

      paperRows.forEach(row => {
        const rowCategory = row.getAttribute('data-category');
        const title = row.getAttribute('data-title') || '';
        const authors = row.getAttribute('data-authors') || '';
        const reason = row.getAttribute('data-reason') || '';

        const matchesCategory = activeCategory === 'all' || rowCategory === activeCategory;
        const matchesSearch = title.includes(searchTerm) || authors.includes(searchTerm) || reason.includes(searchTerm);

        if (matchesCategory && matchesSearch) {
          row.classList.remove('hidden');
          visibleCount++;
        } else {
          row.classList.add('hidden');
        }
      });

      // Toggle empty state
      if (visibleCount === 0) {
        papersList?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        resultCount?.classList.add('hidden');
      } else {
        papersList?.classList.remove('hidden');
        emptyState?.classList.add('hidden');
        if (resultCount) {
          resultCount.textContent = `${visibleCount} results`;
          resultCount.classList.remove('hidden');
        }
      }
    }

    // Category Filter Click Handlers
    categoryButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        // Update UI state
        categoryButtons.forEach(b => {
          b.classList.remove('bg-amber-400/10', 'border-amber-400/50', 'text-amber-400');
          b.classList.add('bg-slate-900', 'border-slate-700', 'text-slate-400');
        });
        
        btn.classList.remove('bg-slate-900', 'border-slate-700', 'text-slate-400');
        btn.classList.add('bg-amber-400/10', 'border-amber-400/50', 'text-amber-400');

        // Update logic state
        activeCategory = btn.getAttribute('data-category') || 'all';
        filterPapers();
      });
    });

    // Search Input Handler
    searchInput?.addEventListener('input', (e) => {
      searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
      filterPapers();
    });

    // Reset Handler
    resetButton?.addEventListener('click', () => {
      activeCategory = 'all';
      searchTerm = '';
      if (searchInput) searchInput.value = '';
      
      // Reset UI buttons
      categoryButtons.forEach(b => {
        if (b.getAttribute('data-category') === 'all') {
          b.classList.remove('bg-slate-900', 'border-slate-700', 'text-slate-400');
          b.classList.add('bg-amber-400/10', 'border-amber-400/50', 'text-amber-400');
        } else {
          b.classList.remove('bg-amber-400/10', 'border-amber-400/50', 'text-amber-400');
          b.classList.add('bg-slate-900', 'border-slate-700', 'text-slate-400');
        }
      });
      
      filterPapers();
    });
  </script>
</Layout>