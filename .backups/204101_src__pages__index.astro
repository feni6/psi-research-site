---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

const papers = catalog.papers;
const totalPapers = papers.length;
const domains = [...new Set(papers.map((p: any) => p.psi_domain).filter(Boolean))];
const journals = [...new Set(papers.map((p: any) => p.journal).filter(Boolean))];
const skepticalCount = papers.filter((p: any) => p.folder === '10_Skeptical_and_Critical').length;
const yearRange = {
  min: Math.min(...papers.map((p: any) => p.year).filter(Boolean)),
  max: Math.max(...papers.map((p: any) => p.year).filter(Boolean)),
};

// Notable Papers lookup
const notableIds = ['bem_2011_feeling', 'cardena_2018_experimental', 'bem_1994_does'];
const notablePapers = notableIds
  .map(id => papers.find((p: any) => p.id === id))
  .filter(Boolean);

// Domain Configuration
const domainConfig: Record<string, { icon: string, color: string }> = {
  methodology: { icon: '🔬', color: 'border-blue-500/30' },
  telepathy: { icon: '🧠', color: 'border-purple-500/30' },
  psychokinesis: { icon: '🎲', color: 'border-red-500/30' },
  nde: { icon: '✨', color: 'border-cyan-500/30' },
  skeptical: { icon: '🔍', color: 'border-orange-500/30' },
  precognition: { icon: '🔮', color: 'border-violet-500/30' },
  healing: { icon: '💚', color: 'border-green-500/30' },
  overview: { icon: '📖', color: 'border-amber-500/30' },
  remote_viewing: { icon: '👁️', color: 'border-teal-500/30' },
  mediumship: { icon: '🕯️', color: 'border-indigo-500/30' },
  nonverbal: { icon: '🤝', color: 'border-pink-500/30' },
  meta_analysis: { icon: '📊', color: 'border-yellow-500/30' },
};

// Deterministic random paper selection for the "Feeling Adventurous?" feature
const randomPaperIds = papers.filter((_: any, i: number) => i % 17 === 0).slice(0, 20).map((p: any) => p.id);
---

<Layout title="Home">
  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold text-amber-400 mb-4">Psi Research Library</h1>
    <p class="text-xl text-slate-300 max-w-3xl mx-auto mb-8">
      A curated, epistemically responsible collection of {totalPapers} peer-reviewed papers on psi phenomena. 
      Both sides of every debate. Transparent methodology. Machine-readable.
    </p>
    <div class="flex justify-center gap-4 flex-wrap">
      <a href="/catalog" class="bg-amber-500 text-slate-950 px-6 py-3 rounded-lg font-semibold hover:bg-amber-400 transition">
        Browse Catalog →
      </a>
      <a href="/paths" class="border border-amber-500 text-amber-400 px-6 py-3 rounded-lg font-semibold hover:bg-amber-500/10 transition">
        Guided Reading Paths
      </a>
      <a href="/method" class="border border-slate-600 text-slate-300 px-6 py-3 rounded-lg font-semibold hover:bg-slate-800 transition">
        How This Was Built
      </a>
    </div>

    <form action="/search" method="get" class="mt-6 max-w-md mx-auto">
      <div class="relative">
        <input type="text" name="q" placeholder="Search papers, topics, authors..."
          class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 pl-10 text-sm text-slate-200 placeholder-slate-500 focus:border-amber-500/50 focus:outline-none" />
        <svg class="absolute left-3 top-3.5 h-4 w-4 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
    </form>
  </section>

  <!-- Stats -->
  <section class="grid grid-cols-2 md:grid-cols-4 gap-4 py-8">
    <div class="bg-slate-900 rounded-lg p-6 text-center border border-slate-800">
      <div class="text-3xl font-bold text-amber-400">{totalPapers}</div>
      <div class="text-slate-400 text-sm mt-1">Papers</div>
    </div>
    <div class="bg-slate-900 rounded-lg p-6 text-center border border-slate-800">
      <div class="text-3xl font-bold text-amber-400">{journals.length}</div>
      <div class="text-slate-400 text-sm mt-1">Journals</div>
    </div>
    <div class="bg-slate-900 rounded-lg p-6 text-center border border-slate-800">
      <div class="text-3xl font-bold text-amber-400">{skepticalCount}</div>
      <div class="text-slate-400 text-sm mt-1">Skeptical Papers</div>
    </div>
    <div class="bg-slate-900 rounded-lg p-6 text-center border border-slate-800">
      <div class="text-3xl font-bold text-amber-400">{yearRange.min}–{yearRange.max}</div>
      <div class="text-slate-400 text-sm mt-1">Year Range</div>
    </div>
  </section>

  <!-- Where Do You Start? -->
  <section class="py-12">
    <h2 class="text-2xl font-bold mb-6 text-center">Where Do You Start?</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <a href="/paths/path_2_weak_spots" class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition block">
        <div class="text-3xl mb-3">🔍</div>
        <div class="font-semibold text-amber-400 mb-2">I'm Skeptical</div>
        <p class="text-slate-400 text-sm">Start with the weakest links. See where the evidence falls short.</p>
      </a>
      <a href="/paths/path_3_newcomer_survey" class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition block">
        <div class="text-3xl mb-3">🗺️</div>
        <div class="font-semibold text-amber-400 mb-2">I'm New Here</div>
        <p class="text-slate-400 text-sm">A balanced overview. Both sides, no agenda.</p>
      </a>
      <a href="/paths/path_1_steelman_psi" class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition block">
        <div class="text-3xl mb-3">💪</div>
        <div class="font-semibold text-amber-400 mb-2">Show Me the Evidence</div>
        <p class="text-slate-400 text-sm">The strongest case for psi. Published in top journals.</p>
      </a>
      <a href="/catalog" class="bg-slate-900 border border-slate-800 rounded-lg p-6 hover:border-amber-500/30 transition block">
        <div class="text-3xl mb-3">📊</div>
        <div class="font-semibold text-amber-400 mb-2">I'm a Researcher</div>
        <p class="text-slate-400 text-sm">Full catalog with methodology data, effect sizes, and cross-references.</p>
      </a>
    </div>
  </section>

  <!-- Domain overview -->
  <section class="py-8">
    <h2 class="text-2xl font-bold mb-6">Research Domains</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {domains.sort().map((domain: string) => {
        const count = papers.filter((p: any) => p.psi_domain === domain).length;
        const config = domainConfig[domain] || { icon: '📄', color: 'border-slate-500/30' };
        return (
          <a href={`/domain/${domain}`} class={`bg-slate-900 border border-slate-800 rounded-lg p-4 hover:${config.color} transition`}>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-lg">{config.icon}</span>
              <div class="font-semibold text-slate-200 capitalize">{domain.replace(/_/g, ' ')}</div>
            </div>
            <div class="text-amber-400 text-sm ml-7">{count} papers</div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Notable Papers -->
  <section class="py-12">
    <h2 class="text-2xl font-bold mb-2">Notable Papers</h2>
    <p class="text-slate-400 mb-6">Landmark studies that shaped the field — and the debates that followed.</p>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      {notablePapers.map((paper: any) => (
        <div class="bg-slate-900 border border-slate-800 rounded-lg p-6 flex flex-col h-full">
          <div class="mb-4">
            <span class="text-xs bg-amber-500/20 text-amber-400 px-2 py-1 rounded capitalize">
              {paper.psi_domain?.replace(/_/g, ' ')}
            </span>
          </div>
          <a href={`/paper/${paper.id}`} class="font-semibold text-slate-200 hover:text-amber-400 mb-2 block line-clamp-2">
            {paper.title}
          </a>
          <div class="text-slate-500 text-sm mb-4">
            {paper.authors?.slice(0, 3).join(', ')}{paper.authors?.length > 3 ? ' et al.' : ''}, {paper.year} • {paper.journal}
          </div>
          <p class="text-slate-400 text-sm flex-grow line-clamp-4">
            {paper.abstract?.substring(0, 150)}...
          </p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Debates -->
  <section class="py-12">
    <h2 class="text-2xl font-bold mb-6">Featured Debates</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <a href="/controversies/01_ganzfeld_telepathy" class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/30 transition block">
        <h3 class="text-lg font-bold text-slate-200 mb-2">Ganzfeld Telepathy</h3>
        <p class="text-slate-400 text-sm mb-4">Can telepathy be demonstrated under controlled conditions?</p>
        <span class="text-amber-400 text-sm font-medium">Explore this debate →</span>
      </a>
      <a href="/controversies/02_bem_feeling_the_future" class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/30 transition block">
        <h3 class="text-lg font-bold text-slate-200 mb-2">Bem's Feeling the Future</h3>
        <p class="text-slate-400 text-sm mb-4">Did a respected psychologist really prove precognition?</p>
        <span class="text-amber-400 text-sm font-medium">Explore this debate →</span>
      </a>
      <a href="/controversies/07_ndes_consciousness_survival" class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/30 transition block">
        <h3 class="text-lg font-bold text-slate-200 mb-2">NDEs & Consciousness</h3>
        <p class="text-slate-400 text-sm mb-4">Do near-death experiences provide evidence for consciousness beyond the brain?</p>
        <span class="text-amber-400 text-sm font-medium">Explore this debate →</span>
      </a>
      <a href="/controversies/10_meta_debate" class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-amber-500/30 transition block">
        <h3 class="text-lg font-bold text-slate-200 mb-2">The Meta-Analysis Debate</h3>
        <p class="text-slate-400 text-sm mb-4">Do the numbers actually support psi when you aggregate all the studies?</p>
        <span class="text-amber-400 text-sm font-medium">Explore this debate →</span>
      </a>
    </div>
  </section>

  <!-- What makes this different -->
  <section class="py-8">
    <h2 class="text-2xl font-bold mb-6">What Makes This Different</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <h3 class="font-bold text-amber-400 mb-2">⚖️ Both Sides</h3>
        <p class="text-slate-400 text-sm">14 controversy maps present papers on both sides of every major debate. This is not advocacy — it's structured evidence.</p>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <h3 class="font-bold text-amber-400 mb-2">🔍 Transparent Method</h3>
        <p class="text-slate-400 text-sm">Complete documentation of how papers were selected, sourced, and processed — including known biases and limitations.</p>
      </div>
      <div class="bg-slate-900 border border-slate-800 rounded-lg p-6">
        <h3 class="font-bold text-amber-400 mb-2">🤖 AI-Readable</h3>
        <p class="text-slate-400 text-sm">Full JSON catalog with structured metadata, effect sizes, and cross-references. Designed for both human and machine navigation.</p>
      </div>
    </div>
  </section>

  <!-- Wishlist Callout -->
  <section class="py-8 text-center">
    <div class="bg-slate-900 border border-slate-800 rounded-xl p-8 max-w-2xl mx-auto">
      <h2 class="text-xl font-bold text-amber-400 mb-2">514 Papers Still Wanted</h2>
      <p class="text-slate-400 text-sm mb-4">Our wishlist tracks papers that would strengthen the collection. Know where to find one?</p>
      <a href="/wishlist" class="text-amber-400 hover:underline text-sm font-medium">Browse the Wishlist →</a>
    </div>
  </section>

  <!-- Feeling Adventurous? -->
  <section class="py-16 text-center">
    <h2 class="text-3xl font-bold text-slate-200 mb-2">Feeling Adventurous?</h2>
    <p class="text-slate-400 mb-8">Discover something unexpected in the collection.</p>
    <button 
      id="random-paper-btn"
      class="bg-amber-500 text-slate-950 px-8 py-4 rounded-xl text-lg font-bold hover:bg-amber-400 transition transform hover:scale-105 active:scale-95"
    >
      🎲 Random Paper
    </button>
  </section>
</Layout>

<script define:vars={{ randomPaperIds }}>
  const btn = document.getElementById('random-paper-btn');
  if (btn) {
    btn.addEventListener('click', () => {
      const randomId = randomPaperIds[Math.floor(Math.random() * randomPaperIds.length)];
      window.location.href = `/paper/${randomId}`;
    });
  }
</script>