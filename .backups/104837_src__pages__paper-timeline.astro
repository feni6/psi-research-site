---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';

// 1. Data Processing: Group by Decade -> Year
const papersByDecade: Record<number, Record<number, any[]>> = {};
let minYear = 9999;
let maxYear = 0;

catalog.papers.forEach((p: any) => {
  if (p.year) {
    if (p.year < minYear) minYear = p.year;
    if (p.year > maxYear) maxYear = p.year;

    const decade = Math.floor(p.year / 10) * 10;
    if (!papersByDecade[decade]) papersByDecade[decade] = {};
    if (!papersByDecade[decade][p.year]) papersByDecade[decade][p.year] = [];
    papersByDecade[decade][p.year].push(p);
  }
});

// Sort decades descending
const decades = Object.keys(papersByDecade).map(Number).sort((a, b) => b - a);

// 2. Domain Color Mapping (Specific Requirements)
const domainColors: Record<string, string> = {
  'methodology': 'bg-blue-400 hover:bg-blue-300 border-blue-500',
  'telepathy': 'bg-purple-400 hover:bg-purple-300 border-purple-500',
  'psychokinesis': 'bg-red-400 hover:bg-red-300 border-red-500',
  'nde': 'bg-cyan-400 hover:bg-cyan-300 border-cyan-500',
  'skeptical': 'bg-orange-400 hover:bg-orange-300 border-orange-500',
  'precognition': 'bg-violet-400 hover:bg-violet-300 border-violet-500',
  'healing': 'bg-green-400 hover:bg-green-300 border-green-500',
  'overview': 'bg-amber-400 hover:bg-amber-300 border-amber-500',
  'remote_viewing': 'bg-teal-400 hover:bg-teal-300 border-teal-500',
  'mediumship': 'bg-indigo-400 hover:bg-indigo-300 border-indigo-500',
  'nonverbal': 'bg-pink-400 hover:bg-pink-300 border-pink-500',
  'meta_analysis': 'bg-yellow-400 hover:bg-yellow-300 border-yellow-500',
};

const getDomainStyle = (domain: string) => {
  // Normalize domain key (lowercase, replace spaces with underscores if needed)
  const key = domain ? domain.toLowerCase().replace(/\s+/g, '_') : 'methodology';
  return domainColors[key] || 'bg-slate-500 hover:bg-slate-400 border-slate-600';
};

// Extract unique domains for legend (sorted alphabetically)
const uniqueDomains = Array.from(new Set(catalog.papers.map((p: any) => p.domain).filter(Boolean))).sort();
---

<Layout title="Paper Timeline" description="Visual chronology of psi research papers">
  <div class="max-w-6xl mx-auto px-4 py-12">
    
    <!-- Header & Summary -->
    <div class="mb-12">
      <nav class="flex items-center text-sm text-slate-400 mb-4 space-x-2">
        <a href="/" class="hover:text-amber-400 transition-colors">Home</a>
        <span>/</span>
        <span class="text-amber-400 font-medium">Paper Timeline</span>
      </nav>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-4">
        Research <span class="text-amber-400">Chronology</span>
      </h1>
      <p class="text-slate-400 max-w-2xl text-lg mb-2">
        {catalog.papers.length} papers spanning {minYear}-{maxYear}.
      </p>
      <p class="text-slate-500 text-sm">
        Hover over dots to see titles, click to read the full paper entry.
      </p>
    </div>

    <!-- Legend -->
    <div class="mb-12 flex flex-wrap gap-x-6 gap-y-2 p-5 bg-slate-900/50 rounded-lg border border-slate-800">
      <span class="text-slate-400 text-xs font-bold uppercase tracking-wider mr-2 self-center w-full mb-1">Research Domains:</span>
      {uniqueDomains.map(domain => {
        const styleClass = getDomainStyle(domain).split(' ')[0]; // Get just the bg-color class
        return (
          <div class="flex items-center space-x-2">
            <div class={`w-2.5 h-2.5 rounded-full ${styleClass} shadow-sm`}></div>
            <span class="text-slate-300 text-xs capitalize">{domain.replace(/_/g, ' ')}</span>
          </div>
        );
      })}
    </div>

    <!-- Timeline Container -->
    <div class="relative border-l-2 border-slate-800 ml-3 md:ml-5 space-y-8 pb-12">
      
      {decades.map((decade) => {
        const yearsInDecade = Object.keys(papersByDecade[decade]).map(Number).sort((a, b) => b - a);
        const decadeTotal = yearsInDecade.reduce((sum, year) => sum + papersByDecade[decade][year].length, 0);
        const decadeLabel = `${decade}s`;

        return (
          <div class="relative pl-6 md:pl-8">
            
            {/* Decade Header */}
            <div class="sticky top-4 z-30 mb-6 flex items-baseline gap-4 bg-slate-950/90 backdrop-blur-sm py-2 -ml-4 pl-4 pr-4 rounded-r-lg border-l-4 border-amber-500 shadow-lg">
              <h2 class="text-3xl font-bold text-slate-200 font-mono tracking-tight">
                {decadeLabel}
              </h2>
              <span class="text-slate-500 text-sm font-medium bg-slate-900 px-2 py-0.5 rounded border border-slate-800">
                {decadeTotal} papers
              </span>
            </div>

            {/* Years within Decade */}
            <div class="space-y-6">
              {yearsInDecade.map((year) => {
                const papers = papersByDecade[decade][year];
                
                return (
                  <div class="relative group/year">
                    
                    {/* Year Label & Dot on Main Line */}
                    <div class="absolute -left-[41px] md:-left-[49px] top-1.5 flex items-center justify-end w-8 md:w-10 pr-2">
                       <span class="text-xs font-mono text-slate-500 font-bold">{year}</span>
                    </div>
                    
                    {/* The Node on the vertical line */}
                    <div class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full bg-slate-950 border-2 border-slate-700 group-hover/year:border-amber-500 transition-colors z-10"></div>

                    {/* Paper Dots Row */}
                    <div class="ml-6 flex flex-wrap gap-2 items-center min-h-[2rem]">
                      {papers.map((paper: any) => {
                        const domainStyle = getDomainStyle(paper.domain);
                        const paperId = paper.id || paper.id; // Fallback to slug if id missing, but prefer id
                        
                        return (
                          <a 
                            href={`/paper/${paperId}`}
                            title={`${paper.title} (${paper.year}) - ${paper.author}`}
                            class="group/dot relative flex items-center justify-center transition-all duration-200 hover:scale-150 hover:z-50 focus:outline-none focus:ring-2 focus:ring-amber-400 rounded-full"
                          >
                            <div class={`w-3 h-3 rounded-full border border-slate-950 shadow-sm ${domainStyle}`}></div>
                            
                            {/* Tooltip */}
                            <div class="absolute bottom-full mb-3 left-1/2 -translate-x-1/2 w-max max-w-[300px] px-3 py-2 bg-slate-800 text-slate-200 text-xs rounded shadow-2xl border border-slate-700 opacity-0 group-hover/dot:opacity-100 transition-opacity pointer-events-none z-50 transform translate-y-2 group-hover/dot:translate-y-0">
                              <p class="font-bold text-amber-400 mb-1 line-clamp-2">{paper.title}</p>
                              <div class="flex justify-between items-center text-slate-400 text-[10px]">
                                <span>{paper.author}</span>
                                {paper.domain && (
                                  <span class="ml-2 px-1.5 py-0.5 bg-slate-900 rounded text-[9px] uppercase tracking-wider text-slate-500 border border-slate-800">
                                    {paper.domain}
                                  </span>
                                )}
                              </div>
                              {/* Arrow */}
                              <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-800"></div>
                            </div>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>